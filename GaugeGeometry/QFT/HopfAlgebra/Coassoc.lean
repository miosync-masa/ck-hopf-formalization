/-- Internal-edge field transport for canonical mapPerm-preimage contractions
over a well-formed source ambient graph. -/
private theorem admissibleForestContractCanonicalPreimage_internalEdges_eq_of_starPermutation
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ ŌĄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (hG‚āĀwf : G‚āĀ.WellFormed)
    (A : AdmissibleSubgraph G‚āā)
    (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs)
    (hŌĄV : ‚ąÄ v ‚ąą G‚āĀ.vertices, ŌĄ v = ŌÄ v)
    (hŌĄStar :
      ‚ąÄ ő≥ ‚ąą A.elements,
        ŌĄ (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA)
            (mapPermSubgraph_preimage hŌÄ ő≥)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA ő≥) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).internalEdges =
    ((FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
      (mapPermAdmissibleSubgraphPreimage hŌÄ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
        (mapPermAdmissibleSubgraphPreimage hŌÄ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hŌÄ hA))).mapPerm ŌĄ).internalEdges := by
  classical
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges,
    FeynmanGraph.mapPerm_internalEdges]
  let Apre := mapPermAdmissibleSubgraphPreimage hŌÄ A
  let starPre := FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre
    (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA)
  let starTarget := FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA
  calc
    A.complementEdges.map (A.retargetEdge starTarget)
        =
      (Apre.complementEdges.map (FeynmanEdge.map ŌÄ)).map
        (A.retargetEdge starTarget) := by
          rw [mapPermAdmissibleSubgraphPreimage_complementEdges_map hŌÄ A]
    _ = Apre.complementEdges.map
        ((A.retargetEdge starTarget) ‚ąė (FeynmanEdge.map ŌÄ)) := by
          rw [Multiset.map_map]
    _ = Apre.complementEdges.map
        ((FeynmanEdge.map ŌĄ) ‚ąė (Apre.retargetEdge starPre)) := by
          refine Multiset.map_congr rfl ?_
          intro e he
          exact (admissibleForestContractCanonicalPreimage_retargetEdge_map
            hŌÄ hG‚āĀwf A hA hŌĄV hŌĄStar he).symm
    _ = (Apre.complementEdges.map (Apre.retargetEdge starPre)).map
        (FeynmanEdge.map ŌĄ) := by
          rw [Multiset.map_map]

/-- External-leg field transport for canonical mapPerm-preimage contractions
