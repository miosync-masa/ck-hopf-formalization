private theorem forestComponentSplitPhi_inr_of_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentSplitPhi g (Sum.inr q) =
      forestComponentMixedBoundaryToQuotientForestSigma g q hq := by
  unfold forestComponentSplitPhi
  change (if hq' : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g then
      forestComponentMixedBoundaryToQuotientForestSigma g q hq'
    else forestComponentSplitPhiDefault g (Sum.inr q)) =
      forestComponentMixedBoundaryToQuotientForestSigma g q hq
  rw [dif_pos hq]

/-- The mixed-boundary half of `ŌÜ` has the required RHS membership. -/
private theorem forestComponentSplitPhi_map_mem_mixedBoundary
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : Sum.inr q ‚ąą forestComponentSplitChoiceSigmaIndex g) :
    forestComponentSplitPhi g (Sum.inr q) ‚ąą
      forestQuotientForestSigmaIndex g := by
  classical
  have hqMixed : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
    simpa [forestComponentSplitChoiceSigmaIndex] using hq
  rw [forestComponentSplitPhi_inr_of_mem g q hqMixed]
  exact forestComponentMixedBoundaryToQuotientForestSigma_mem g q hqMixed

/-- Membership for the total `ŌÜ` is reduced to the genuine-forest branch,
since the mixed-boundary branch is already canonical. -/
private theorem forestComponentSplitPhi_map_mem_of_forestBranch
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForest :
      ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq ‚ąą
          forestQuotientForestSigmaIndex g) :
    ‚ąÄ q, q ‚ąą forestComponentSplitChoiceSigmaIndex g ‚Üí
      forestComponentSplitPhi g q ‚ąą forestQuotientForestSigmaIndex g := by
  classical
  intro q hq
  cases q with
  | inl q =>
      have hqForest : q ‚ąą forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitPhi_inl_of_mem g q hqForest]
      exact hForest q hqForest
  | inr q =>
      exact forestComponentSplitPhi_map_mem_mixedBoundary g q hq

/-- Concrete `ŌÜ` membership from canonical mixed-boundary membership plus the
remaining genuine-forest remnant-positivity certificates. -/
private theorem forestComponentSplitPhi_map_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq) :
    ‚ąÄ q, q ‚ąą forestComponentSplitChoiceSigmaIndex g ‚Üí
      forestComponentSplitPhi g q ‚ąą forestQuotientForestSigmaIndex g :=
  forestComponentSplitPhi_map_mem_of_forestBranch g
    (fun q hq => forestComponentForestChoiceToQuotientForestSigma_mem_of_remnantPositive
      g q hq (C q hq))

/-- Concrete `ŌÜ` injectivity reduces to the two same-branch injectivity
statements plus the cross-branch separation statement. -/
private theorem forestComponentSplitPhi_inj_on_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForest :
      ‚ąÄ q‚āĀ, ‚ąÄ hq‚āĀ : q‚āĀ ‚ąą forestComponentForestChoiceSigmaIndex g,
        ‚ąÄ q‚āā, ‚ąÄ hq‚āā : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q‚āĀ hq‚āĀ =
            forestComponentForestChoiceToQuotientForestSigma g q‚āā hq‚āā ‚Üí
            q‚āĀ = q‚āā)
    (hMixed :
      ‚ąÄ q‚āĀ, ‚ąÄ hq‚āĀ : q‚āĀ ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
        ‚ąÄ q‚āā, ‚ąÄ hq‚āā : q‚āā ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q‚āĀ hq‚āĀ =
            forestComponentMixedBoundaryToQuotientForestSigma g q‚āā hq‚āā ‚Üí
            q‚āĀ = q‚āā)
    (hCross :
      ‚ąÄ qF, ‚ąÄ hF : qF ‚ąą forestComponentForestChoiceSigmaIndex g,
        ‚ąÄ qM, ‚ąÄ hM : qM ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g qF hF ‚Č†
            forestComponentMixedBoundaryToQuotientForestSigma g qM hM) :
    ‚ąÄ q‚āĀ, q‚āĀ ‚ąą forestComponentSplitChoiceSigmaIndex g ‚Üí
      ‚ąÄ q‚āā, q‚āā ‚ąą forestComponentSplitChoiceSigmaIndex g ‚Üí
        forestComponentSplitPhi g q‚āĀ = forestComponentSplitPhi g q‚āā ‚Üí
          q‚āĀ = q‚āā := by
  classical
  intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
  cases q‚āĀ with
  | inl q‚āĀ =>
      have hq‚āĀForest : q‚āĀ ‚ąą forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āĀ
      rw [forestComponentSplitPhi_inl_of_mem g q‚āĀ hq‚āĀForest] at hŌÜ
      cases q‚āā with
      | inl q‚āā =>
          have hq‚āāForest : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
          rw [forestComponentSplitPhi_inl_of_mem g q‚āā hq‚āāForest] at hŌÜ
          exact congrArg Sum.inl
            (hForest q‚āĀ hq‚āĀForest q‚āā hq‚āāForest hŌÜ)
      | inr q‚āā =>
          have hq‚āāMixed :
              q‚āā ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
          rw [forestComponentSplitPhi_inr_of_mem g q‚āā hq‚āāMixed] at hŌÜ
          exact False.elim
            ((hCross q‚āĀ hq‚āĀForest q‚āā hq‚āāMixed) hŌÜ)
  | inr q‚āĀ =>
      have hq‚āĀMixed :
          q‚āĀ ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āĀ
      rw [forestComponentSplitPhi_inr_of_mem g q‚āĀ hq‚āĀMixed] at hŌÜ
      cases q‚āā with
      | inl q‚āā =>
          have hq‚āāForest : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
          rw [forestComponentSplitPhi_inl_of_mem g q‚āā hq‚āāForest] at hŌÜ
          exact False.elim
            ((hCross q‚āā hq‚āāForest q‚āĀ hq‚āĀMixed) hŌÜ.symm)
      | inr q‚āā =>
          have hq‚āāMixed :
              q‚āā ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
          rw [forestComponentSplitPhi_inr_of_mem g q‚āā hq‚āāMixed] at hŌÜ
          exact congrArg Sum.inr
            (hMixed q‚āĀ hq‚āĀMixed q‚āā hq‚āāMixed hŌÜ)

/-- Concrete `ŌÜ` surjectivity reduces to a branch-covering statement for the
RHS quotient-forest carrier. -/
private theorem forestComponentSplitPhi_surj_on_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hCover :
      ‚ąÄ r, r ‚ąą forestQuotientForestSigmaIndex g ‚Üí
        (‚ąÉ q, ‚ąÉ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q hq = r) ‚ą®
        (‚ąÉ q, ‚ąÉ hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r)) :
    ‚ąÄ r, r ‚ąą forestQuotientForestSigmaIndex g ‚Üí
      ‚ąÉ q, ‚ąÉ hq : q ‚ąą forestComponentSplitChoiceSigmaIndex g,
        forestComponentSplitPhi g q = r := by
  classical
  intro r hr
  rcases hCover r hr with hForest | hMixed
  ¬∑ rcases hForest with ‚ü®q, hq, hŌÜ‚ü©
    refine ‚ü®Sum.inl q, ?_, ?_‚ü©
    ¬∑ simpa [forestComponentSplitChoiceSigmaIndex] using hq
    ¬∑ rw [forestComponentSplitPhi_inl_of_mem g q hq]
      exact hŌÜ
  ¬∑ rcases hMixed with ‚ü®q, hq, hŌÜ‚ü©
    refine ‚ü®Sum.inr q, ?_, ?_‚ü©
    ¬∑ simpa [forestComponentSplitChoiceSigmaIndex] using hq
    ¬∑ rw [forestComponentSplitPhi_inr_of_mem g q hq]
      exact hŌÜ

/-- Concrete `ŌÜ` term equality reduces to the genuine-forest and mixed-boundary
branch term-identification statements. -/
private theorem forestComponentSplitPhi_term_eq_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForestTerm :
      ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q =
          forestQuotientForestSigmaTerm g
            (forestComponentForestChoiceToQuotientForestSigma g q hq))
    (hMixedTerm :
      ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q =
          forestQuotientForestSigmaTerm g
            (forestComponentMixedBoundaryToQuotientForestSigma g q hq)) :
    ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentSplitChoiceSigmaIndex g,
      forestComponentSplitChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g (forestComponentSplitPhi g q) := by
  classical
  intro q hq
  cases q with
  | inl q =>
      have hqForest : q ‚ąą forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitChoiceSigmaTerm,
        forestComponentSplitPhi_inl_of_mem g q hqForest]
      exact hForestTerm q hqForest
  | inr q =>
      have hqMixed : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitChoiceSigmaTerm,
        forestComponentSplitPhi_inr_of_mem g q hqMixed]
      exact hMixedTerm q hqMixed

