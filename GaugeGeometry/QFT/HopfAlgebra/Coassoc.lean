/-- Sprint F2-Track-B-1b-2: retarget-subgraph injectivity on A.elements.
For γ₁, γ₂ ∈ A.elements, equality of `admissibleSubgraphRetargetSubgraph`
implies γ₁ = γ₂.  Proof: extract vertex-set equality → for any v ∈ γ₁.vertices,
its retarget = starOf γ₁ is also in γ₂.vertices.image retargetVertex, giving
some v₂ ∈ γ₂.vertices with retargetVertex v₂ = starOf γ₁ = starOf γ₂; then
star injectivity (B-1b-1) closes. -/
private theorem admissibleSubgraphRetargetSubgraph_inj_on_elements
    {G : FeynmanGraph}
    {A : AdmissibleSubgraph G}
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    {γ₁ γ₂ : FeynmanSubgraph G}
    (hγ₁ : γ₁ ∈ A.elements)
    (hγ₂ : γ₂ ∈ A.elements)
    (hEdges₁ : γ₁.internalEdges ≤ A.complementEdges)
    (hEdges₂ : γ₂.internalEdges ≤ A.complementEdges)
    (hRetarget :
      admissibleSubgraphRetargetSubgraph A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) γ₁ hEdges₁ =
      admissibleSubgraphRetargetSubgraph A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) γ₂ hEdges₂) :
    γ₁ = γ₂ := by
  classical
  have hDisj : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hNE : A.HasNonemptyComponents :=
    G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hA
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf G A hA with hstarOfDef
  have hVerts : γ₁.vertices.image (A.retargetVertex starOf) =
      γ₂.vertices.image (A.retargetVertex starOf) := by
    have := congrArg FeynmanSubgraph.vertices hRetarget
    simpa using this
  -- γ₁ is nonempty: pick v₁ ∈ γ₁.vertices
  have hγ₁card : 0 < γ₁.vertices.card := by
    have hne := hNE γ₁ hγ₁
    unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hne
    exact hne
  obtain ⟨v₁, hv₁⟩ := Finset.card_pos.mp hγ₁card
  -- retargetVertex v₁ = starOf γ₁
  have hRetV₁ : A.retargetVertex starOf v₁ = starOf γ₁ :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj starOf hγ₁ hv₁
  -- starOf γ₁ ∈ γ₂.vertices.image retargetVertex
  have hStarMem : starOf γ₁ ∈ γ₂.vertices.image (A.retargetVertex starOf) := by
    rw [← hVerts, ← hRetV₁]
    exact Finset.mem_image_of_mem _ hv₁
  -- Extract v₂ ∈ γ₂.vertices with retargetVertex v₂ = starOf γ₁
  obtain ⟨v₂, hv₂, hRetV₂⟩ := Finset.mem_image.mp hStarMem
  -- retargetVertex v₂ = starOf γ₂
  have hRetV₂' : A.retargetVertex starOf v₂ = starOf γ₂ :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj starOf hγ₂ hv₂
  -- Combine
  have hStarEq : starOf γ₁ = starOf γ₂ := hRetV₂.symm.trans hRetV₂'
  exact admissibleForestCanonicalStarOf_injOn_elements A hA hγ₁ hγ₂ hStarEq

/-- Sprint F2-Track-B-1b-3-scout: HEq on `Sigma.snd` from Sigma equality.
Generic helper — when two Σ-typed pairs are equal, their second components
are HEq.  Pure `cases hEq` trick. -/
private theorem Sigma_snd_heq_of_eq
    {α : Type*} {β : α → Type*}
    {a₁ a₂ : α} {b₁ : β a₁} {b₂ : β a₂}
    (h : (⟨a₁, b₁⟩ : Σ x, β x) = ⟨a₂, b₂⟩) :
    HEq b₁ b₂ := by
  cases h
  rfl

/-- Sprint F2-Track-B-HEq-0: generic `eqRec` form of the `Sigma.snd` equality.
For `h : x = y` between Σ-pairs with *free-variable* first components, `cases h`
closes — so this generic lemma sidesteps the "computed fst blocks `cases`"
wall.  Specialize it to the concrete (computed-fst) `toQuotient` equality by
applying it to `hEq`; the conclusion is the casted `Eq` form
`(congrArg Sigma.fst h) ▸ x.2 = y.2`. -/
private theorem Sigma_snd_eqRec_of_eq
    {α : Type*} {β : α → Type*} {x y : Σ a, β a}
    (h : x = y) :
    (congrArg Sigma.fst h) ▸ x.2 = y.2 := by
  cases h
  rfl

