/-- The indexed classifier supplies branch injectivity and cross-branch
separation, using component-complement positivity only to certify genuine
branch images as RHS carrier elements. -/
private def
    forestComponentSplitPhiBranchInjectivitySeparationOfIndexedClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceComponentComplementPositiveCertificate g q hq)
    (X : forestComponentSplitPhiIndexedBranchClassifier g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    let r‚āĀ : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g q‚āĀ hq‚āĀ,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g q‚āĀ hq‚āĀ (C q‚āĀ hq‚āĀ)‚ü©
    let r‚āā : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g q‚āā hq‚āā,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g q‚āā hq‚āā (C q‚āā hq‚āā)‚ü©
    have hr : r‚āĀ = r‚āā := Subtype.ext hŌÜ
    have h‚āĀ : X.preimage r‚āĀ = Sum.inl q‚āĀ :=
      X.forest_inv q‚āĀ hq‚āĀ r‚āĀ.2
    have h‚āā : X.preimage r‚āā = Sum.inl q‚āā :=
      X.forest_inv q‚āā hq‚āā r‚āā.2
    rw [hr] at h‚āĀ
    exact Sum.inl.inj (h‚āĀ.symm.trans h‚āā)
  mixed_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    let r‚āĀ : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q‚āĀ hq‚āĀ,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q‚āĀ hq‚āĀ‚ü©
    let r‚āā : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q‚āā hq‚āā,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q‚āā hq‚āā‚ü©
    have hr : r‚āĀ = r‚āā := Subtype.ext hŌÜ
    have h‚āĀ : X.preimage r‚āĀ = Sum.inr q‚āĀ :=
      X.mixed_inv q‚āĀ hq‚āĀ r‚āĀ.2
    have h‚āā : X.preimage r‚āā = Sum.inr q‚āā :=
      X.mixed_inv q‚āā hq‚āā r‚āā.2
    rw [hr] at h‚āĀ
    exact Sum.inr.inj (h‚āĀ.symm.trans h‚āā)
  cross := by
    intro qF hF qM hM hŌÜ
    let rF : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g qF hF,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g qF hF (C qF hF)‚ü©
    let rM : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g qM hM,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g qM hM‚ü©
    have hr : rF = rM := Subtype.ext hŌÜ
    have hFpre : X.preimage rF = Sum.inl qF :=
      X.forest_inv qF hF rF.2
    have hMpre : X.preimage rM = Sum.inr qM :=
      X.mixed_inv qM hM rM.2
    rw [hr] at hFpre
    have hsum : Sum.inl qF = Sum.inr qM := hFpre.symm.trans hMpre
    cases hsum

/-- The indexed classifier supplies branch injectivity and cross-branch
separation with only the source-edge witnesses needed to certify genuine branch
images as RHS carrier elements. -/
private def
    forestComponentSplitPhiBranchInjectivitySeparationOfIndexedClassifierSourceEdge
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq)
    (X : forestComponentSplitPhiIndexedBranchClassifier g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    let r‚āĀ : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g q‚āĀ hq‚āĀ,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_sourceEdgeWitness
          g q‚āĀ hq‚āĀ (C q‚āĀ hq‚āĀ)‚ü©
    let r‚āā : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g q‚āā hq‚āā,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_sourceEdgeWitness
          g q‚āā hq‚āā (C q‚āā hq‚āā)‚ü©
    have hr : r‚āĀ = r‚āā := Subtype.ext hŌÜ
    have h‚āĀ : X.preimage r‚āĀ = Sum.inl q‚āĀ :=
      X.forest_inv q‚āĀ hq‚āĀ r‚āĀ.2
    have h‚āā : X.preimage r‚āā = Sum.inl q‚āā :=
      X.forest_inv q‚āā hq‚āā r‚āā.2
    rw [hr] at h‚āĀ
    exact Sum.inl.inj (h‚āĀ.symm.trans h‚āā)
  mixed_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    let r‚āĀ : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q‚āĀ hq‚āĀ,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q‚āĀ hq‚āĀ‚ü©
    let r‚āā : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q‚āā hq‚āā,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q‚āā hq‚āā‚ü©
    have hr : r‚āĀ = r‚āā := Subtype.ext hŌÜ
    have h‚āĀ : X.preimage r‚āĀ = Sum.inr q‚āĀ :=
      X.mixed_inv q‚āĀ hq‚āĀ r‚āĀ.2
    have h‚āā : X.preimage r‚āā = Sum.inr q‚āā :=
      X.mixed_inv q‚āā hq‚āā r‚āā.2
    rw [hr] at h‚āĀ
    exact Sum.inr.inj (h‚āĀ.symm.trans h‚āā)
  cross := by
    intro qF hF qM hM hŌÜ
    let rF : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentForestChoiceToQuotientForestSigma g qF hF,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_sourceEdgeWitness
          g qF hF (C qF hF)‚ü©
    let rM : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g} :=
      ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g qM hM,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g qM hM‚ü©
    have hr : rF = rM := Subtype.ext hŌÜ
    have hFpre : X.preimage rF = Sum.inl qF :=
      X.forest_inv qF hF rF.2
    have hMpre : X.preimage rM = Sum.inr qM :=
      X.mixed_inv qM hM rM.2
    rw [hr] at hFpre
    have hsum : Sum.inl qF = Sum.inr qM := hFpre.symm.trans hMpre
    cases hsum

/-- The indexed classifier supplies RHS branch cover by inspecting the selected
preimage branch. -/
private def forestComponentSplitPhiBranchCoverCertificateOfIndexedClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiIndexedBranchClassifier g) :
    forestComponentSplitPhiBranchCoverCertificate g where
