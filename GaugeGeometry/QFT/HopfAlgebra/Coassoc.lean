/-- Sprint F2i-3q-4l-2d: v3 source preimage's `choiceFn`.  Three-way dispatch
on `A_source_v3.elements = Left ⊔ LiftedRight ⊔ LiftedForest`:
- `.left` if γ ∈ LeftComponents (forest-untouched outer original),
- `.right` if γ ∈ LiftedRightComponents (no-star quotient lift),
- `.forest B_γ` otherwise (γ ∈ LiftedForestComponents by exhaustion). -/
private noncomputable def forestQuotientForestSigmaForestCoverChoiceFn_v3
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices)
    (hB : forestQuotientForestSigmaForestCoverForestBWitness g r hForestCD) :
    forestComponentChoiceFn
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint) :=
  fun γ _ =>
    if _hL : γ.1 ∈ forestQuotientForestSigmaForestCoverLeftComponents g r then
      forestCoproductChoice.left
    else if _hR :
        γ.1 ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r then
      forestCoproductChoice.right
    else
      forestCoproductChoice.forest
        (forestQuotientForestSigmaForestCoverForestB
          g r hForestCD hB γ.1
          (by
            have hγUnion :
                γ.1 ∈ forestQuotientForestSigmaForestCoverSourceElements_v3 g r := by
              simpa [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_elements]
                using γ.2
            rcases (forestQuotientForestSigmaForestCoverSourceElements_v3_mem g r).mp hγUnion
              with hL' | hRF
            · exact (_hL hL').elim
            · rcases hRF with hR' | hF
              · exact (_hR hR').elim
              · exact hF))

/-- Sprint F2i-3q-4l-2e-1: `ChoiceFn_v3` evaluates to `.left` on
`LeftComponents` elements.  First `if` branch fires directly. -/
private theorem forestQuotientForestSigmaForestCoverChoiceFn_v3_eq_left_of_mem_left
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices)
    (hB : forestQuotientForestSigmaForestCoverForestBWitness g r hForestCD)
    {γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint).elements}}
    (hγAttach :
      γ ∈ (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint).elements.attach)
    (hL : γ.1 ∈ forestQuotientForestSigmaForestCoverLeftComponents g r) :
    forestQuotientForestSigmaForestCoverChoiceFn_v3
        g r hForestCD hForestDisjoint hB γ hγAttach =
      forestCoproductChoice.left := by
  unfold forestQuotientForestSigmaForestCoverChoiceFn_v3
  split_ifs with h
  · rfl
  · exact (h hL).elim

/-- Sprint F2i-3q-4l-2e-2: Finset-disjointness of `LeftComponents` and
`LiftedRightComponents`.  Per-pair `Disjoint γ.vertices γ.vertices` (F2i-3q-4l-1d
with γ=γ) collides with `A_final.HasNonemptyComponents`. -/
private theorem forestQuotientForestSigmaForestCover_leftComponents_disjoint_liftedRightComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Disjoint
      (forestQuotientForestSigmaForestCoverLeftComponents g r)
      (forestQuotientForestSigmaForestCoverLiftedRightComponents g r) := by
  classical
  rw [Finset.disjoint_left]
  intro γ hL hR
  have hηA :=
    ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hL).1
  have hVDisj :=
    forestQuotientForestSigmaForestCover_left_disjoint_liftedRight_vertices
      g r hL hR
  have hAhasNonempty : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  rcases Finset.card_pos.mp (hAhasNonempty γ hηA) with ⟨v, hv⟩
  exact (Finset.disjoint_left.mp hVDisj hv) hv

