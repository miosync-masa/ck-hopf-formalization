        G₀.internalEdges - A.internalEdges := by
    refine Multiset.ext.mpr ?_
    intro e
    simp only [Multiset.count_sub]
    have hAoutA := Multiset.count_le_of_le e hAout_le_A
    have hAG := Multiset.count_le_of_le e hA_le_G
