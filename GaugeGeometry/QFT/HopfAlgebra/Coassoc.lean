    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiBranchDecisionReconstruction g) :
    forestComponentSplitPhiIndexedBranchClassifier g where
  preimage := forestComponentSplitPhiBranchDecisionPreimageOfClassify g X.classify
  preimage_mem := by
    intro r
    cases h : X.classify r with
    | inl data =>
        have hq : data.1 ∈ forestComponentForestChoiceSigmaIndex g :=
          data.2.1
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitChoiceSigmaIndex] using hq
    | inr data =>
        have hq : data.1 ∈ forestComponentMixedBoundaryChoiceSigmaIndex g :=
          data.2.1
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitChoiceSigmaIndex] using hq
  right_inv := by
    intro r
    cases h : X.classify r with
    | inl data =>
        have hq : data.1 ∈ forestComponentForestChoiceSigmaIndex g :=
          data.2.1
        have htarget :
            forestComponentForestChoiceToQuotientForestSigma g data.1 hq =
              r.1 := data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitPhi_inl_of_mem g data.1 hq] using htarget
    | inr data =>
        have hq : data.1 ∈ forestComponentMixedBoundaryChoiceSigmaIndex g :=
          data.2.1
        have htarget :
            forestComponentMixedBoundaryToQuotientForestSigma g data.1 hq =
              r.1 := data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitPhi_inr_of_mem g data.1 hq] using htarget
  forest_inv := by
    intro q hq hr
    exact X.forest_preimage q hq hr
  mixed_inv := by
    intro q hq hr
    exact X.mixed_preimage q hq hr

