    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (hForestCD :
      ‚ąÄ r : {r : forestQuotientForestSigma g //
          r ‚ąą forestQuotientForestSigmaIndex g},
