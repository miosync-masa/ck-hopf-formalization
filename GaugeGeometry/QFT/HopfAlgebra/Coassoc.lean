/-- Remnant carriers contributed by distinct original components are disjoint
finite carriers. -/
private theorem forestComponentForestChoiceRemnantComponentsForChoice_pairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    Set.PairwiseDisjoint (↑q.1.1.elements.attach)
      (fun γ =>
        forestComponentForestChoiceRemnantComponentsForChoice g q hq γ
          (Finset.mem_attach q.1.1.elements γ)) := by
  classical
  intro γ _hγ η _hη hγη
  change Disjoint
    (forestComponentForestChoiceRemnantComponentsForChoice g q hq γ
      (Finset.mem_attach q.1.1.elements γ))
    (forestComponentForestChoiceRemnantComponentsForChoice g q hq η
      (Finset.mem_attach q.1.1.elements η))
  rw [Finset.disjoint_left]
  intro δ hδγ hδη
  cases hγChoice : q.2 γ (Finset.mem_attach q.1.1.elements γ) with
  | left =>
      simp [forestComponentForestChoiceRemnantComponentsForChoice, hγChoice] at hδγ
  | right =>
      simp [forestComponentForestChoiceRemnantComponentsForChoice, hγChoice] at hδγ
  | forest Bγ =>
      cases hηChoice : q.2 η (Finset.mem_attach q.1.1.elements η) with
      | left =>
          simp [forestComponentForestChoiceRemnantComponentsForChoice, hηChoice] at hδη
      | right =>
          simp [forestComponentForestChoiceRemnantComponentsForChoice, hηChoice] at hδη
      | forest Bη =>
          let remγ :
              FeynmanSubgraph
                (forestOuterActualQuotientGraph g
                  (forestComponentForestChoiceOuterIndex g q hq)) :=
            admissibleSubgraphQuotientRemainderSubgraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (FeynmanGraph.admissibleForestCanonicalStarOf
                (repG g).toFeynmanGraph
                (forestComponentForestChoiceOuterIndex g q hq).1
                (forestComponentForestChoiceOuterIndex g q hq).2)
              γ.1
          let remη :
              FeynmanSubgraph
                (forestOuterActualQuotientGraph g
                  (forestComponentForestChoiceOuterIndex g q hq)) :=
            admissibleSubgraphQuotientRemainderSubgraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (FeynmanGraph.admissibleForestCanonicalStarOf
                (repG g).toFeynmanGraph
                (forestComponentForestChoiceOuterIndex g q hq).1
                (forestComponentForestChoiceOuterIndex g q hq).2)
              η.1
          have hδγeq : δ = remγ := by
            have hCarrier :
                forestComponentForestChoiceRemnantComponentsForChoice
                  g q hq γ (Finset.mem_attach q.1.1.elements γ) =
                ({remγ} :
                  Finset (FeynmanSubgraph
                    (forestOuterActualQuotientGraph g
                      (forestComponentForestChoiceOuterIndex g q hq)))) := by
              simp [forestComponentForestChoiceRemnantComponentsForChoice,
                hγChoice, remγ]
              rfl
            have hmem :
                δ ∈ ({remγ} :
                  Finset (FeynmanSubgraph
                    (forestOuterActualQuotientGraph g
                      (forestComponentForestChoiceOuterIndex g q hq)))) := by
              rw [← hCarrier]
              exact hδγ
            exact Finset.mem_singleton.mp hmem
          have hδηeq : δ = remη := by
            have hCarrier :
                forestComponentForestChoiceRemnantComponentsForChoice
                  g q hq η (Finset.mem_attach q.1.1.elements η) =
                ({remη} :
                  Finset (FeynmanSubgraph
                    (forestOuterActualQuotientGraph g
                      (forestComponentForestChoiceOuterIndex g q hq)))) := by
              simp [forestComponentForestChoiceRemnantComponentsForChoice,
                hηChoice, remη]
              rfl
            have hmem :
                δ ∈ ({remη} :
                  Finset (FeynmanSubgraph
                    (forestOuterActualQuotientGraph g
                      (forestComponentForestChoiceOuterIndex g q hq)))) := by
              rw [← hCarrier]
              exact hδη
            exact Finset.mem_singleton.mp hmem
          have hγVal : γ.1 ≠ η.1 := by
            intro h
            exact hγη (Subtype.ext h)
          have hRemDisj : remγ.Disjoint remη := by
            simpa [remγ, remη] using
              forestComponentForestChoiceRemnantComponents_disjoint_of_source_ne
                g q hq γ η hγChoice hηChoice hγVal
          have hδSelf : δ.Disjoint δ := by
            simpa [← hδγeq, ← hδηeq] using hRemDisj
          have hδGlobal :
              δ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
            rw [forestComponentForestChoiceRemnantComponents_eq_biUnion_forChoice]
            exact Finset.mem_biUnion.mpr
              ⟨γ, Finset.mem_attach q.1.1.elements γ, hδγ⟩
          have hδQ :
              δ ∈ forestComponentForestChoiceActualQuotientComponents g q hq := by
            unfold forestComponentForestChoiceActualQuotientComponents
            exact Finset.mem_union_right _ hδGlobal
          have hδNonempty :
              δ.IsNonempty :=
            forestComponentForestChoiceActualQuotientSubgraphCanonical_hasNonemptyComponents
              g q hq δ hδQ
          unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hδNonempty
          rcases Finset.card_pos.mp hδNonempty with ⟨v, hv⟩
          exact (Finset.disjoint_left.mp hδSelf hv) hv

