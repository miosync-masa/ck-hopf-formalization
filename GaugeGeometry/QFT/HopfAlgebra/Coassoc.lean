  intro γ hL hF
  have hηA :=
    ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hL).1
  have hVDisj :=
    forestQuotientForestSigmaForestCover_leftComponents_disjoint_liftedForestComponents_vertices
      g r hL hF
  have hAhasNonempty : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  rcases Finset.card_pos.mp (hAhasNonempty γ hηA) with ⟨v, hv⟩
  exact (Finset.disjoint_left.mp hVDisj hv) hv

/-- Sprint F2i-3q-4h-2: forest preimage's `choiceFn`.  Dispatches each
γ ∈ A_source.elements (= LiftedRight ⊔ LiftedForest) to:
- `.right` if γ ∈ LiftedRight,
- `.forest B_γ` if γ ∈ LiftedForest, using `_ForestB` witness.
The else-branch's `LiftedForest` membership is recovered from the
A_source partition `_v2_elements`. -/
private noncomputable def forestQuotientForestSigmaForestCoverChoiceFn
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices)
    (hB : forestQuotientForestSigmaForestCoverForestBWitness g r hForestCD) :
    forestComponentChoiceFn
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v2
        g r hForestCD hForestDisjoint) :=
  fun γ _ =>
    if hR : γ.1 ∈
        forestQuotientForestSigmaForestCoverLiftedRightComponents g r then
      forestCoproductChoice.right
    else
      forestCoproductChoice.forest
        (forestQuotientForestSigmaForestCoverForestB
          g r hForestCD hB γ.1
          (by
            have hγUnion :
                γ.1 ∈
                  forestQuotientForestSigmaForestCoverLiftedRightComponents g r ∪
                    forestQuotientForestSigmaForestCoverLiftedForestComponents g r := by
              simpa [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v2_elements]
                using γ.2
            rcases Finset.mem_union.mp hγUnion with hR' | hF
            · exact (hR hR').elim
            · exact hF))

/-- Sprint F2i-3q-4h-3a: Finset-disjointness of lifted right and lifted forest
components.  Derives from F2i-3q-4f-1 vertex disjointness + nonemptiness of
each lifted component (chained through `D`'s `HasNonemptyComponents` via
proper-disjoint membership). -/
private theorem forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForestComponents
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Disjoint
      (forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
      (forestQuotientForestSigmaForestCoverLiftedForestComponents g r) := by
  classical
  rw [Finset.disjoint_left]
  intro γ hR hF
  have hVdisj :=
    forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForest_vertices
      g r hR hF
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hR with ⟨δR, hδRRight, _hNoStar, hEqR⟩
  have hδRD :
      δR ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδRRight).1
  have hR2Proper :
      r.1.2 ∈ (forestOuterQuotientGraph g r.1.1
        ).properDisjointAdmissibleDivergentSubgraphs := by
    have hSigma := Finset.mem_sigma.mp r.2
    exact ((mem_forestCoproductProperForestIndex _ _).mp hSigma.2).1
  have hDProper :
      forestQuotientForestSigmaActualQuotientSubgraph g r.1 ∈
