/-- Sprint F2i-3i: general Multiset submultiset-preimage existence.
If `t ≤ s.map f`, then some sub-multiset of `s` maps onto `t`.  Pure
Multiset combinatorics — no `FeynmanEdge` / `retargetEdge` / source
vertices.  Used as the multiplicity-aware substitute for per-element
`Classical.choose` in the forest-cover edge construction. -/
private theorem Multiset.exists_le_of_le_map
    {α β : Type*} [DecidableEq α] [DecidableEq β]
    (f : α → β) (t : Multiset β) :
    ∀ s : Multiset α, t ≤ s.map f →
      ∃ u : Multiset α, u ≤ s ∧ u.map f = t := by
  induction t using Multiset.induction_on with
  | empty =>
    intro s _
    exact ⟨0, Multiset.zero_le _, by simp⟩
  | cons b t' ih =>
    intro s h
    have hb : b ∈ s.map f :=
      Multiset.mem_of_le h (Multiset.mem_cons_self b t')
    rcases Multiset.mem_map.mp hb with ⟨a, ha, hfa⟩
    have h_map_erase : (s.erase a).map f = (s.map f).erase b := by
      have := Multiset.map_erase_of_mem f s ha
      rw [hfa] at this; exact this
    have ht' : t' ≤ (s.erase a).map f := by
      rw [Multiset.le_iff_count]
      intro x
      rw [h_map_erase]
      have h1 : Multiset.count x (b ::ₘ t') ≤ Multiset.count x (s.map f) :=
        Multiset.count_le_of_le x h
      rw [Multiset.count_cons] at h1
      by_cases hxb : x = b
      · subst hxb
        rw [Multiset.count_erase_self]
        simp at h1
        omega
      · rw [Multiset.count_erase_of_ne hxb]
        simp [hxb] at h1
        exact h1
    rcases ih (s.erase a) ht' with ⟨u', hu'le, hu'map⟩
    refine ⟨a ::ₘ u', ?_, ?_⟩
    · calc a ::ₘ u'
          ≤ a ::ₘ (s.erase a) := Multiset.cons_le_cons a hu'le
        _ = s := Multiset.cons_erase ha
    · rw [Multiset.map_cons, hu'map, hfa]

/-- Sprint F2i-3j: existence of a multiplicity-preserving edge multiset
that retargets onto `δ.internalEdges` with endpoints in source vertices.
Pure existence, no `Classical.choose` wrapper — F2i-3k will package this. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    ∃ E : Multiset FeynmanEdge,
      E ≤ r.1.1.1.complementEdges ∧
      E ≤ (repG g).toFeynmanGraph.internalEdges ∧
      E.map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
        δ.internalEdges ∧
      ∀ e ∈ E,
        e.source ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
        e.target ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  classical
  have hδLe : δ.internalEdges ≤
      (forestOuterActualQuotientGraph g r.1.1).internalEdges :=
    δ.internalEdges_le
  have hActualEq :
      (forestOuterActualQuotientGraph g r.1.1).internalEdges =
        r.1.1.1.complementEdges.map
          (r.1.1.1.retargetEdge
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    unfold forestOuterActualQuotientGraph
    rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges]
  rw [hActualEq] at hδLe
  rcases Multiset.exists_le_of_le_map _ _ _ hδLe with ⟨E, hELe, hEmap⟩
  have hCompLe :
      r.1.1.1.complementEdges ≤ (repG g).toFeynmanGraph.internalEdges := by
    unfold AdmissibleSubgraph.complementEdges
    exact Multiset.sub_le_self _ _
  have hEGLe : E ≤ (repG g).toFeynmanGraph.internalEdges := hELe.trans hCompLe
  refine ⟨E, hELe, hEGLe, hEmap, ?_⟩
  intro e he
  have hfe :
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e ∈ δ.internalEdges := by
    rw [← hEmap]
    exact Multiset.mem_map_of_mem _ he
  have hfeSupp := δ.edges_supported _ hfe
  have heG : e ∈ (repG g).toFeynmanGraph.internalEdges :=
    Multiset.mem_of_le hEGLe he
  have heGsupp := FeynmanGraph.wellFormed_internal (repG_wellFormed g) heG
  refine ⟨?_, ?_⟩
  · exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r δ heGsupp.1 rfl hfeSupp.1
  · exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r δ heGsupp.2 rfl hfeSupp.2

/-- Sprint F2i-3k: canonical exact internal edge carrier for the
forest-cover source subgraph, obtained from `_exists` via
`Classical.choose`.  This replaces the per-edge `_EdgePreimageOf`
approach of F2i-3h (which was deprecated due to multiplicity issues). -/
private noncomputable def forestQuotientForestSigmaForestCoverExactInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset FeynmanEdge :=
  Classical.choose
    (forestQuotientForestSigmaForestCoverExactInternalEdges_exists g r δ)

/-- Sprint F2i-3o-2e-pre-1: exact internal edges are a sub-multiset of the
outer forest's complement edges.  This is the strengthened bound recovered
from F2i-3j's existence proof (previously discarded); needed for the
upcoming `E + P ≤ G.internalEdges` calculation. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_le_complementEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverExactInternalEdges g r δ ≤
      r.1.1.1.complementEdges :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactInternalEdges_exists g r δ)).1

/-- Sprint F2i-3k spec 1: exact internal edges are a sub-multiset of
ambient internal edges. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_le
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverExactInternalEdges g r δ ≤
      (repG g).toFeynmanGraph.internalEdges :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactInternalEdges_exists g r δ)).2.1

/-- Sprint F2i-3k spec 2: retargeting the exact internal edges produces
exactly `δ.internalEdges` (count-preserving). -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_map
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
      δ.internalEdges :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactInternalEdges_exists g r δ)).2.2.1

/-- Sprint F2i-3k spec 3: every exact internal edge has both endpoints in
the recovered source vertices. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (he : e ∈ forestQuotientForestSigmaForestCoverExactInternalEdges g r δ) :
    e.source ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
    e.target ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactInternalEdges_exists g r δ)).2.2.2
    e he

/-- Sprint F2i-3k optional: the exact internal edges satisfy the
`EdgePreimage` compatibility predicate from F2i-3c. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_edgePreimage
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverEdgePreimage g r δ
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ) :=
  ⟨forestQuotientForestSigmaForestCoverExactInternalEdges_map g r δ,
    forestQuotientForestSigmaForestCoverExactInternalEdges_le g r δ,
    fun _ he =>
      forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints g r δ he⟩

/-- Sprint F2i-3l: existence of a multiplicity-preserving external-leg
multiset that retargets onto `δ.externalLegs` with attachment in source
vertices.  Mirror of F2i-3j on the leg side; reuses the F2i-3i general
Multiset lemma. -/
private theorem forestQuotientForestSigmaForestCoverExactExternalLegs_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    ∃ L : Multiset ExternalLeg,
      L ≤ (repG g).toFeynmanGraph.externalLegs ∧
      L.map
        (r.1.1.1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
        δ.externalLegs ∧
      ∀ ℓ ∈ L,
        ℓ.attachedTo ∈
          forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  classical
  have hδLe : δ.externalLegs ≤
      (forestOuterActualQuotientGraph g r.1.1).externalLegs :=
    δ.externalLegs_le
  have hActualEq :
      (forestOuterActualQuotientGraph g r.1.1).externalLegs =
        (repG g).toFeynmanGraph.externalLegs.map
          (r.1.1.1.retargetExternalLeg
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    unfold forestOuterActualQuotientGraph
    rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_externalLegs]
  rw [hActualEq] at hδLe
  rcases Multiset.exists_le_of_le_map _ _ _ hδLe with ⟨L, hLLe, hLmap⟩
  refine ⟨L, hLLe, hLmap, ?_⟩
  intro ℓ hℓ
  have hfℓ :
      r.1.1.1.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) ℓ ∈ δ.externalLegs := by
    rw [← hLmap]
    exact Multiset.mem_map_of_mem _ hℓ
  have hfℓSupp := δ.legs_supported _ hfℓ
  have hℓG : ℓ ∈ (repG g).toFeynmanGraph.externalLegs :=
    Multiset.mem_of_le hLLe hℓ
  have hℓGsupp := FeynmanGraph.wellFormed_external (repG_wellFormed g) hℓG
  exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
    g r δ hℓGsupp rfl hfℓSupp

/-- Sprint F2i-3m: canonical exact external-leg carrier for the
forest-cover source subgraph, obtained from `_exists` via
`Classical.choose`.  Mirror of F2i-3k on the leg side. -/
private noncomputable def forestQuotientForestSigmaForestCoverExactExternalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset ExternalLeg :=
  Classical.choose
    (forestQuotientForestSigmaForestCoverExactExternalLegs_exists g r δ)

/-- Sprint F2i-3m spec 1: exact external legs are a sub-multiset of ambient. -/
private theorem forestQuotientForestSigmaForestCoverExactExternalLegs_le
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverExactExternalLegs g r δ ≤
      (repG g).toFeynmanGraph.externalLegs :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactExternalLegs_exists g r δ)).1

/-- Sprint F2i-3m spec 2: retargeting the exact external legs produces
exactly `δ.externalLegs`. -/
private theorem forestQuotientForestSigmaForestCoverExactExternalLegs_map
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverExactExternalLegs g r δ).map
        (r.1.1.1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
      δ.externalLegs :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactExternalLegs_exists g r δ)).2.1

/-- Sprint F2i-3m spec 3: every exact external leg attaches in source vertices. -/
private theorem forestQuotientForestSigmaForestCoverExactExternalLegs_attached
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ℓ : ExternalLeg}
    (hℓ : ℓ ∈ forestQuotientForestSigmaForestCoverExactExternalLegs g r δ) :
    ℓ.attachedTo ∈
      forestQuotientForestSigmaForestCoverSourceVertices g r δ :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverExactExternalLegs_exists g r δ)).2.2
    ℓ hℓ

/-- Sprint F2i-3m optional: the exact external legs satisfy the
`ExternalLegPreimage` compatibility predicate from F2i-3c. -/
private theorem forestQuotientForestSigmaForestCoverExactExternalLegs_externalLegPreimage
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverExternalLegPreimage g r δ
      (forestQuotientForestSigmaForestCoverExactExternalLegs g r δ) :=
  ⟨forestQuotientForestSigmaForestCoverExactExternalLegs_map g r δ,
    forestQuotientForestSigmaForestCoverExactExternalLegs_le g r δ,
    fun _ hℓ =>
      forestQuotientForestSigmaForestCoverExactExternalLegs_attached g r δ hℓ⟩

/-- Sprint F2i-3n: exact source subgraph candidate.  Bundles the normalized
F2i-3a / F2i-3k / F2i-3m carriers (V, ExactInternalEdges, ExactExternalLegs)
into a `FeynmanSubgraph (repG g).toFG`.  Unlike F2i-3e (which used the
broad hull edges/legs deprecated by F2i-3f), this `Exact` version uses
multiplicity-preserving carriers and is the canonical source candidate
for the upcoming retarget / remainder equality. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceSubgraphExact
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices := forestQuotientForestSigmaForestCoverSourceVertices g r δ
  internalEdges :=
    forestQuotientForestSigmaForestCoverExactInternalEdges g r δ
  externalLegs :=
    forestQuotientForestSigmaForestCoverExactExternalLegs g r δ
  vertices_subset :=
    forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ
  internalEdges_le :=
    forestQuotientForestSigmaForestCoverExactInternalEdges_le g r δ
  externalLegs_le :=
    forestQuotientForestSigmaForestCoverExactExternalLegs_le g r δ
  edges_supported := fun e he =>
    forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints g r δ he
  legs_supported := fun ℓ hℓ =>
    forestQuotientForestSigmaForestCoverExactExternalLegs_attached g r δ hℓ

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExact_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExact g r δ).vertices =
      forestQuotientForestSigmaForestCoverSourceVertices g r δ := rfl

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExact_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExact g r δ).internalEdges =
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ := rfl

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExact_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExact g r δ).externalLegs =
      forestQuotientForestSigmaForestCoverExactExternalLegs g r δ := rfl

/-- Sprint F2i-3o-1: the externalLegs of the quotient remainder of the exact
source subgraph coincide with `δ.externalLegs`.  This is the lightest of the
three remainder-equality pieces: the F2i-3m `_map` spec on the exact external
legs is essentially a direct hit once the remainder's externalLegs `simp`
lemma rewrites the goal to `γ.externalLegs.map (retargetExternalLeg …)`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExact_remainder_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExact g r δ)).externalLegs
      = δ.externalLegs := by
  rw [admissibleSubgraphQuotientRemainderSubgraph_externalLegs,
      forestQuotientForestSigmaForestCoverSourceSubgraphExact_externalLegs]
  exact forestQuotientForestSigmaForestCoverExactExternalLegs_map g r δ

/-- Sprint F2i-3o-2b: components of the outer forest `r.1.1.1` whose
canonical star vertex lies inside `δ.vertices`.  These are the "promoted"
components: the ones whose internal edges must be retained inside the
forest-cover source subgraph, so that the quotient-remainder subtraction
`(γ.internalEdges - A.internalEdges)` cancels them exactly. -/
private noncomputable def forestQuotientForestSigmaForestCoverPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  r.1.1.1.elements.filter fun η =>
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices

/-- Sprint F2i-3o-2b: membership characterization for promoted components. -/
private theorem forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph} :
    η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ ↔
      η ∈ r.1.1.1.elements ∧
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices := by
  unfold forestQuotientForestSigmaForestCoverPromotedComponents
  exact Finset.mem_filter

/-- Sprint F2i-3o-2b: total internal-edge multiset contributed by the
promoted components.  This is the additive term required by the corrected
source subgraph design `γ.internalEdges = E + promoted_A.internalEdges`,
so that the quotient remainder cancels `A.internalEdges` exactly. -/
private noncomputable def forestQuotientForestSigmaForestCoverPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset FeynmanEdge :=
  (forestQuotientForestSigmaForestCoverPromotedComponents g r δ).sum
    (fun η => η.internalEdges)

/-- Sprint F2i-3o-2b: every promoted internal edge has both endpoints inside
the recovered source vertices.  The proof unpacks the `Finset.sum` membership
into `η ∈ PromotedComponents`, then uses F2i-3a `_eta_subset` to send
each endpoint into SourceVertices via `η.vertices`. -/
private theorem forestQuotientForestSigmaForestCoverPromotedInternalEdges_endpoints
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (he : e ∈ forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ) :
    e.source ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
      e.target ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  classical
  unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges at he
  rcases Multiset.mem_sum.mp he with ⟨η, hηPromoted, heI⟩
  rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff]
    at hηPromoted
  obtain ⟨hηA, hStarInδ⟩ := hηPromoted
  have hSupp : e.source ∈ η.vertices ∧ e.target ∈ η.vertices :=
    η.edges_supported e heI
  refine ⟨?_, ?_⟩
  · exact forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hηA hStarInδ hSupp.1
  · exact forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hηA hStarInδ hSupp.2

/-- Sprint F2i-3o-2e-pre-2: standalone packaging of the F2i-3o-2c inner step.
The promoted internal-edge multiset is bounded by the outer forest's own
internal edges, before the ambient passage.  Needed for the Plus source
subgraph's `internalEdges_le` calculation `E + P ≤ complementEdges + A.I = G.I`. -/
private theorem forestQuotientForestSigmaForestCoverPromotedInternalEdges_le_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤
      r.1.1.1.internalEdges := by
  classical
  unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges
    forestQuotientForestSigmaForestCoverPromotedComponents
    AdmissibleSubgraph.internalEdges
  exact Finset.sum_le_sum_of_subset (Finset.filter_subset _ _)

/-- Sprint F2i-3o-2c: the promoted internal-edge multiset is bounded by the
ambient internal edges.  Refactored on F2i-3o-2e-pre-2 day to delegate the
first half to `_le_outer`. -/
private theorem forestQuotientForestSigmaForestCoverPromotedInternalEdges_le
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤
      (repG g).toFeynmanGraph.internalEdges := by
  have hDisj : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  exact (forestQuotientForestSigmaForestCoverPromotedInternalEdges_le_outer
    g r δ).trans
    (admissibleSubgraph_internalEdges_le_of_pairwise r.1.1.1 hDisj)

/-- Sprint F2i-3o-2d: components of the outer forest whose canonical star does
NOT lie in `δ.vertices`.  Complementary to PromotedComponents (F2i-3o-2b);
later passes will show `A.elements = PromotedComponents ⊔ NonPromotedComponents`
as a partition. -/
private noncomputable def forestQuotientForestSigmaForestCoverNonPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  r.1.1.1.elements.filter fun η =>
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∉ δ.vertices

/-- Sprint F2i-3o-2d: membership characterization for non-promoted components. -/
private theorem forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph} :
    η ∈ forestQuotientForestSigmaForestCoverNonPromotedComponents g r δ ↔
      η ∈ r.1.1.1.elements ∧
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∉ δ.vertices := by
  unfold forestQuotientForestSigmaForestCoverNonPromotedComponents
  exact Finset.mem_filter

/-- Sprint F2i-3o-2d: total internal-edge multiset contributed by the
non-promoted components.  This is the "obstruction" half of `A.internalEdges`
that the source subgraph must avoid: if the exact preimage multiset ever
contained one of these edges, its retarget image would land at a star vertex
absent from `δ.vertices`, contradicting `δ.edges_supported`. -/
private noncomputable def forestQuotientForestSigmaForestCoverNonPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset FeynmanEdge :=
  (forestQuotientForestSigmaForestCoverNonPromotedComponents g r δ).sum
    (fun η => η.internalEdges)

/-- Sprint F2i-3o-2d main: an exact preimage edge can never lie inside the
non-promoted internal edges.  Proof: if `e ∈ NonPromotedInternalEdges`, then
some non-promoted `η ∋ e` exists with `starOf η ∉ δ.vertices`.  But by
`ExactInternalEdges_map`, the retarget of `e` lies in `δ.internalEdges`, so
its source `= retargetVertex e.source = starOf η` (pairwise-disjoint retarget)
must lie in `δ.vertices` (by `δ.edges_supported`).  Contradiction. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_not_mem_nonPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (heE : e ∈ forestQuotientForestSigmaForestCoverExactInternalEdges g r δ) :
    e ∉ forestQuotientForestSigmaForestCoverNonPromotedInternalEdges g r δ := by
  classical
  intro heNP
  unfold forestQuotientForestSigmaForestCoverNonPromotedInternalEdges at heNP
  rcases Multiset.mem_sum.mp heNP with ⟨η, hηNon, heη⟩
  rw [forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff]
    at hηNon
  obtain ⟨hηA, hStarNotIn⟩ := hηNon
  have hSupp : e.source ∈ η.vertices ∧ e.target ∈ η.vertices :=
    η.edges_supported e heη
  have hDisj : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hRet :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.source =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj _ hηA hSupp.1
  have hMap :=
    forestQuotientForestSigmaForestCoverExactInternalEdges_map g r δ
  have hfe :
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e ∈ δ.internalEdges := by
    rw [← hMap]
    exact Multiset.mem_map_of_mem _ heE
  have hSrcInδ :
      (r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e).source ∈ δ.vertices :=
    (δ.edges_supported _ hfe).1
  rw [AdmissibleSubgraph.retargetEdge_source, hRet] at hSrcInδ
  exact hStarNotIn hSrcInδ

/-- Sprint F2i-3o-2d': promoted ∪ non-promoted components recover the full
outer forest `A.elements`.  Each η ∈ A.elements lies in exactly one side
depending on whether `starOf η ∈ δ.vertices`. -/
private theorem forestQuotientForestSigmaForestCover_promoted_union_nonPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverPromotedComponents g r δ ∪
      forestQuotientForestSigmaForestCoverNonPromotedComponents g r δ =
      r.1.1.1.elements := by
  classical
  ext η
  constructor
  · intro h
    rcases Finset.mem_union.mp h with hP | hNP
    · exact (forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r δ).mp hP |>.1
    · exact (forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
        g r δ).mp hNP |>.1
  · intro hη
    by_cases hStar :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices
    · exact Finset.mem_union_left _
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
          g r δ).mpr ⟨hη, hStar⟩)
    · exact Finset.mem_union_right _
        ((forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
          g r δ).mpr ⟨hη, hStar⟩)

/-- Sprint F2i-3o-2d': promoted and non-promoted components are disjoint as
finsets of forest elements.  The predicates `starOf η ∈ δ.vertices` and
`starOf η ∉ δ.vertices` are mutually exclusive. -/
private theorem forestQuotientForestSigmaForestCover_promoted_disjoint_nonPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Disjoint
      (forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
      (forestQuotientForestSigmaForestCoverNonPromotedComponents g r δ) := by
  classical
  rw [Finset.disjoint_left]
  intro η hP hNP
  rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff] at hP
  rw [forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff] at hNP
  exact hNP.2 hP.2

/-- Sprint F2i-3o-2d' optional: convenience symmetric form of the union
identity, expressing `A.elements` as the partition. -/
private theorem forestQuotientForestSigmaForestCover_elements_eq_promoted_union_nonPromoted
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    r.1.1.1.elements =
      forestQuotientForestSigmaForestCoverPromotedComponents g r δ ∪
        forestQuotientForestSigmaForestCoverNonPromotedComponents g r δ :=
  (forestQuotientForestSigmaForestCover_promoted_union_nonPromotedComponents
    g r δ).symm

/-- Sprint F2i-3o-2d'': `r.1.1.1.internalEdges` splits as a disjoint multiset
sum of the promoted and non-promoted internal-edge multisets.  This is the
multiset lift of the F2i-3o-2d' Finset partition, ready to drive the
subtraction calculation `(E + P.I) - A.I = E - NP.I = E` in the upcoming
remainder equality. -/
private theorem forestQuotientForestSigmaForestCover_internalEdges_eq_promoted_add_nonPromoted
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    r.1.1.1.internalEdges =
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ +
        forestQuotientForestSigmaForestCoverNonPromotedInternalEdges g r δ := by
  classical
  unfold AdmissibleSubgraph.internalEdges
    forestQuotientForestSigmaForestCoverPromotedInternalEdges
    forestQuotientForestSigmaForestCoverNonPromotedInternalEdges
  rw [forestQuotientForestSigmaForestCover_elements_eq_promoted_union_nonPromoted
        g r δ,
      Finset.sum_union
        (forestQuotientForestSigmaForestCover_promoted_disjoint_nonPromotedComponents
          g r δ)]

/-- Sprint F2i-3o-2d''': package the per-element `not_mem` lemma (F2i-3o-2d)
into a `Multiset.Disjoint` statement, suitable for direct use in the
subtraction calculation `(E + P.I) - (P.I + NP.I) = E - NP.I = E`. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_disjoint_nonPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Disjoint
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ)
      (forestQuotientForestSigmaForestCoverNonPromotedInternalEdges g r δ) := by
  rw [Multiset.disjoint_left]
  intro e heE
  exact
    forestQuotientForestSigmaForestCoverExactInternalEdges_not_mem_nonPromotedInternalEdges
      g r δ heE

/-- Sprint F2i-3o-2e: the **Plus** version of the forest-cover source
subgraph.  Its `internalEdges` is the additive form
`ExactInternalEdges + PromotedInternalEdges`, which is the geometrically
correct preimage for the `(γ.internalEdges - A.internalEdges).map retarget`
remainder formula.  Existing `SourceSubgraphExact` (whose `internalEdges`
is just `ExactInternalEdges`) is preserved unchanged. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices :=
    forestQuotientForestSigmaForestCoverSourceVertices g r δ
  internalEdges :=
    forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ
  externalLegs :=
    forestQuotientForestSigmaForestCoverExactExternalLegs g r δ
  vertices_subset :=
    forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ
  internalEdges_le := by
    have hAIPair : r.1.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        r.1.1.2
    have hAIle :
        r.1.1.1.internalEdges ≤ (repG g).toFeynmanGraph.internalEdges :=
      admissibleSubgraph_internalEdges_le_of_pairwise r.1.1.1 hAIPair
    calc
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
          forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ
          ≤ r.1.1.1.complementEdges +
              forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ :=
        add_le_add
          (forestQuotientForestSigmaForestCoverExactInternalEdges_le_complementEdges
            g r δ)
          (le_refl _)
      _ ≤ r.1.1.1.complementEdges + r.1.1.1.internalEdges :=
        add_le_add (le_refl _)
          (forestQuotientForestSigmaForestCoverPromotedInternalEdges_le_outer g r δ)
      _ = (repG g).toFeynmanGraph.internalEdges := by
        unfold AdmissibleSubgraph.complementEdges
        exact Multiset.sub_add_cancel hAIle
  externalLegs_le :=
    forestQuotientForestSigmaForestCoverExactExternalLegs_le g r δ
  edges_supported := by
    intro e he
    rcases Multiset.mem_add.mp he with heE | heP
    · exact forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints
        g r δ heE
    · exact forestQuotientForestSigmaForestCoverPromotedInternalEdges_endpoints
        g r δ heP
  legs_supported := by
    intro ℓ hℓ
    exact forestQuotientForestSigmaForestCoverExactExternalLegs_attached g r δ hℓ

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).vertices =
      forestQuotientForestSigmaForestCoverSourceVertices g r δ := rfl

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges =
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
        forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ := rfl

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).externalLegs =
      forestQuotientForestSigmaForestCoverExactExternalLegs g r δ := rfl

/-- Sprint F2i-3o-2f: Plus version of F2i-3o-1 externalLegs remainder
equality.  Same mechanism: rewrite the remainder `externalLegs` to
`γ.externalLegs.map retargetExternalLeg`, simp through the Plus carrier
identification, then close with the F2i-3m `_map` spec.  This works because
the Plus version's `externalLegs` field is identical to that of
`SourceSubgraphExact` (only `internalEdges` was strengthened by adding
`PromotedInternalEdges`). -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)).externalLegs
      = δ.externalLegs := by
  rw [admissibleSubgraphQuotientRemainderSubgraph_externalLegs,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_externalLegs]
  exact forestQuotientForestSigmaForestCoverExactExternalLegs_map g r δ

/-- Sprint F2i-3o-2g helper: if two multisets are `Multiset.Disjoint`, then
subtraction by one leaves the other unchanged.  Pure count calculation. -/
private theorem Multiset.sub_eq_self_of_disjoint
    {α : Type*} [DecidableEq α] {s t : Multiset α}
    (h : Disjoint s t) :
    s - t = s := by
  ext x
  by_cases hx : x ∈ s
  · have hxt : x ∉ t := (Multiset.disjoint_left.mp h) hx
    have ht0 : Multiset.count x t = 0 := Multiset.count_eq_zero_of_notMem hxt
    rw [Multiset.count_sub, ht0, Nat.sub_zero]
  · have hs0 : Multiset.count x s = 0 := Multiset.count_eq_zero_of_notMem hx
    rw [Multiset.count_sub, hs0, Nat.zero_sub]

/-- Sprint F2i-3o-2g cancellation: subtraction of the outer forest's internal
edges from `E + P.I` returns exactly `E`.  Uses the F2i-3o-2d'' partition
`A.I = P.I + NP.I` and the F2i-3o-2d''' Disjoint between E and NP.I. -/
private theorem forestQuotientForestSigmaForestCover_exact_add_promoted_sub_outerInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
        forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ) -
        r.1.1.1.internalEdges =
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ := by
  rw [forestQuotientForestSigmaForestCover_internalEdges_eq_promoted_add_nonPromoted
        g r δ,
      Multiset.sub_add_eq_sub_sub,
      Multiset.add_sub_cancel_right]
  exact Multiset.sub_eq_self_of_disjoint
    (forestQuotientForestSigmaForestCoverExactInternalEdges_disjoint_nonPromotedInternalEdges
      g r δ)

/-- Sprint F2i-3o-2g main: the Plus version's quotient-remainder internal
edges coincide with `δ.internalEdges`.  Proof: rewrite the remainder
internalEdges as `(γ.I - A.I).map retarget`, identify `γ.I` with
`E + P.I`, simplify the subtraction to `E` via the cancellation helper,
then close with the F2i-3k `_map` spec. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)).internalEdges
      = δ.internalEdges := by
  rw [admissibleSubgraphQuotientRemainderSubgraph_internalEdges,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges,
      forestQuotientForestSigmaForestCover_exact_add_promoted_sub_outerInternalEdges]
  exact forestQuotientForestSigmaForestCoverExactInternalEdges_map g r δ

/-- Sprint F2i-3o-2h-1: forward inclusion for vertices remainder equality.
The image of `SourceVertices` under `retargetVertex` is contained in
`δ.vertices`.  Two cases per the SourceVertices definition:
- non-star δ-vertex (in `δ.vertices \ A.starVertices`): comes from the
  actual quotient graph's complement side, hence outside `A.vertices`,
  so `retargetVertex` is the identity (F2g-0 pattern).
- promoted η.vertex (some η ∈ A.elements with starOf η ∈ δ.vertices):
  `retargetVertex` sends it to `starOf η ∈ δ.vertices`. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceVertices g r δ).image
      (r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) ⊆
      δ.vertices := by
  classical
  intro v hv
  rcases Finset.mem_image.mp hv with ⟨x, hxSrc, rfl⟩
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hxSrc
  rcases Finset.mem_union.mp hxSrc with hLeft | hRight
  · -- non-star δ-vertex
    rcases Finset.mem_sdiff.mp hLeft with ⟨hxδ, hxNotStar⟩
    have hxQ : x ∈ (forestOuterActualQuotientGraph g r.1.1).vertices :=
      δ.vertices_subset hxδ
    unfold forestOuterActualQuotientGraph at hxQ
    simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices] at hxQ
    rcases Finset.mem_union.mp hxQ with hRest | hStar
    · have hxNotA : x ∉ r.1.1.1.vertices :=
        (Finset.mem_sdiff.mp hRest).2
      rw [AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1 _ hxNotA]
      exact hxδ
    · exact absurd hStar hxNotStar
  · -- promoted η.vertices
    rcases Finset.mem_biUnion.mp hRight with ⟨η, hηA, hxBranch⟩
    by_cases hStarη :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices
    · simp only [hStarη, if_true] at hxBranch
      have hDisj : r.1.1.1.IsPairwiseDisjoint :=
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          r.1.1.2
      rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisj _ hηA hxBranch]
      exact hStarη
    · simp only [hStarη, if_false] at hxBranch
      exact (Finset.notMem_empty x hxBranch).elim

/-- Sprint F2i-3o-2h-2a: star-vertex preimage helper.  If a forest element
`η ∈ A.elements` has `starOf η ∈ δ.vertices`, then `starOf η` lies in the
image of SourceVertices under retargetVertex.  Uses `A.HasNonemptyComponents`
(from `properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents`) to
extract a witness vertex `x ∈ η.vertices`, then F2i-3a `_eta_subset` to
place it in SourceVertices, and `retargetVertex_of_mem_component` to send it
to `starOf η`. -/
private theorem forestQuotientForestSigmaForestCover_starVertex_mem_image_retarget
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hηA : η ∈ r.1.1.1.elements)
    (hStar :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices) :
    FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈
      (forestQuotientForestSigmaForestCoverSourceVertices g r δ).image
        (r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  classical
  have hCompNE : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  have hηNE : η.IsNonempty := hCompNE η hηA
  rcases Finset.card_pos.mp hηNE with ⟨x, hxη⟩
  have hxSrc :
      x ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ :=
    forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hηA hStar hxη
  have hPair : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hRet :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hPair _ hηA hxη
  exact Finset.mem_image.mpr ⟨x, hxSrc, hRet⟩

/-- Sprint F2i-3o-2h-2b: reverse inclusion for vertices remainder equality.
`δ.vertices ⊆ (SourceVertices).image retargetVertex`.  Two cases:
- non-star case: `v ∈ G.V \ A.V`, then `v ∉ starVertices` via fresh-star
  disjointness, so `v ∈ SourceVertices` (non-star branch) and
  `retargetVertex v = v` (F2i-3o-2h-1 mechanics).
- star case: `v = starOf η` for some `η ∈ A.elements`; the F2i-3o-2h-2a
  helper closes this. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_supset
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    δ.vertices ⊆
      (forestQuotientForestSigmaForestCoverSourceVertices g r δ).image
        (r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  classical
  intro v hvδ
  have hvQ : v ∈ (forestOuterActualQuotientGraph g r.1.1).vertices :=
    δ.vertices_subset hvδ
  unfold forestOuterActualQuotientGraph at hvQ
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices] at hvQ
  rcases Finset.mem_union.mp hvQ with hOutside | hStar
  · -- non-star: v ∈ G.V \ A.V
    rcases Finset.mem_sdiff.mp hOutside with ⟨_, hvNotA⟩
    have hFresh :
        r.1.1.1.IsFreshStarAssignment
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
      FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
    have hvNotStar :
        v ∉ r.1.1.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
      Finset.disjoint_left.mp hFresh.disjoint_sdiff_starVertices hOutside
    have hvSrc :
        v ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ :=
      forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem
        g r hvδ hvNotStar
    have hRet :
        r.1.1.1.retargetVertex
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v = v :=
      AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1 _ hvNotA
    exact Finset.mem_image.mpr ⟨v, hvSrc, hRet⟩
  · -- star case: v = starOf η for some η ∈ A.elements
    rcases AdmissibleSubgraph.mem_starVertices.mp hStar with ⟨η, hηA, rfl⟩
    exact forestQuotientForestSigmaForestCover_starVertex_mem_image_retarget
      g r δ hηA hvδ

/-- Sprint F2i-3o-2h-3: Plus version's quotient-remainder vertices coincide
with `δ.vertices`.  Combines the F2i-3o-2h-1 forward inclusion with the
F2i-3o-2h-2b reverse inclusion via `Finset.Subset.antisymm`.  Completes the
3-carrier remainder equality (vertices ✓, internalEdges ✓, externalLegs ✓). -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)).vertices
      = δ.vertices := by
  rw [admissibleSubgraphQuotientRemainderSubgraph_vertices,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices]
  exact Finset.Subset.antisymm
    (forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_subset g r δ)
    (forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_supset g r δ)

/-- Sprint F2i-3o-2i: the Plus version's quotient remainder is *exactly* `δ`
as a `FeynmanSubgraph` of the actual quotient graph.  Bundles the F2i-3o-2f
externalLegs, F2i-3o-2g internalEdges, and F2i-3o-2h-3 vertices equalities
into a full structural equality; the five proof fields collapse by
definitional proof irrelevance once the three carriers are pinned down.
This is the **local inverse** for forest cover source recovery: starting
from any `δ` in the actual quotient graph, the Plus source subgraph in the
ambient graph quotient-remainders back to `δ`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)
      = δ := by
  have hV :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_vertices
      g r δ
  have hI :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_internalEdges
      g r δ
  have hE :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_externalLegs
      g r δ
  generalize hlhs :
      admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ) = lhs
    at hV hI hE ⊢
  cases lhs
  cases δ
  cases hV
  cases hI
  cases hE
  rfl

/-- Sprint F2i-3q-4l-actual-promoted-7a: `SourceSubgraphExactPlus` is injective
on δ.  Immediate corollary of `_remainder_eq`: `δ` is recovered from `Plus δ`
by the quotient-remainder, so `Plus δ₁ = Plus δ₂ → δ₁ = δ₂`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_injective
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ₁ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (hPlus :
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₁ =
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₂) :
    δ₁ = δ₂ := by
  have h₁ :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r δ₁
  have h₂ :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r δ₂
  rw [hPlus] at h₁
  exact h₁.symm.trans h₂

/-- Sprint F2i-3q-4l-actual-promoted-7a: `PromotedComponents g r δ` is
determined by `Plus δ`.  Direct consequence of `Plus` injectivity. -/
private theorem forestQuotientForestSigmaForestCoverPromotedComponents_eq_of_plus_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ₁ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (hPlus :
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₁ =
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₂) :
    forestQuotientForestSigmaForestCoverPromotedComponents g r δ₁ =
      forestQuotientForestSigmaForestCoverPromotedComponents g r δ₂ := by
  have hδ :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_injective g r hPlus
  subst hδ
  rfl

/-- Sprint F2i-3p-1: lifted source components of the actualized RHS quotient
forest.  Each component `δ ∈ D.elements` is lifted via `SourceSubgraphExactPlus`
to a `FeynmanSubgraph (repG g).toFeynmanGraph`.  Forest-cover analogue of
mixed cover's `MixedLiftedRightComponents`; lays the groundwork for the
upcoming forest-cover source admissible subgraph. -/
private noncomputable def forestQuotientForestSigmaForestCoverLiftedSourceComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.attach.image
    (fun δ =>
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ.1)

/-- Sprint F2i-3p-1 spec 1: every lifted source component is of the form
`SourceSubgraphExactPlus g r δ.1` for some component `δ` of the actualized
RHS quotient forest. -/
private theorem forestQuotientForestSigmaForestCoverLiftedSourceComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedSourceComponents g r) :
    ∃ δ : {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1) //
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements},
      γ =
        forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ.1 := by
  unfold forestQuotientForestSigmaForestCoverLiftedSourceComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨δ, _, hEq⟩
  exact ⟨δ, hEq.symm⟩

/-- Sprint F2i-3p-1 spec 2: each lifted source component remainders to its
originating `δ` in the actual quotient graph.  Direct wrapper around the
F2i-3o-2i `_remainder_eq`. -/
private theorem forestQuotientForestSigmaForestCoverLiftedSourceComponents_remainder_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1) //
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements}) :
    admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ.1)
      = δ.1 :=
  forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
    g r δ.1

/-- Sprint F2i-3p-2a: reduce the CD obligation on lifted source components
to an explicit per-`δ` hypothesis.  Pure plumbing — no new typeclass, no new
axiom, no `sorry`.  The actual CD proof for `SourceSubgraphExactPlus` is
deliberately postponed; this wrapper fixes the bottleneck shape so the
next forest-cover-source admissible-subgraph construction has only **one**
explicit CD obligation. -/
private theorem forestQuotientForestSigmaForestCoverLiftedSourceComponents_cd_of_source_cd
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ forestQuotientForestSigmaForestCoverLiftedSourceComponents g r) :
    γ.IsConnectedDivergent := by
  rcases forestQuotientForestSigmaForestCoverLiftedSourceComponents_mem_exists
    g r hγ with ⟨δ, hEq⟩
  rw [hEq]
  exact hSourceCD δ.1 δ.2

/-- Sprint F2i-3p-2b: reduce the NOD obligation on lifted source components
to an explicit pairwise hypothesis on per-`δ` Plus lifts.  Same shape as
F2i-3p-2a for CD: no new typeclass, no new axiom, no `sorry`.  After this
the forest-cover-source admissible-subgraph construction's CD and NOD
obligations are both pinned to single explicit hypotheses. -/
private theorem forestQuotientForestSigmaForestCoverLiftedSourceComponents_nestedOrDisjoint_of_source_nod
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂))
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ :
      γ₁ ∈ forestQuotientForestSigmaForestCoverLiftedSourceComponents g r)
    (hγ₂ :
      γ₂ ∈ forestQuotientForestSigmaForestCoverLiftedSourceComponents g r)
    (hne : γ₁ ≠ γ₂) :
    γ₁.NestedOrDisjoint γ₂ := by
  rcases forestQuotientForestSigmaForestCoverLiftedSourceComponents_mem_exists
    g r hγ₁ with ⟨δ₁, hEq₁⟩
  rcases forestQuotientForestSigmaForestCoverLiftedSourceComponents_mem_exists
    g r hγ₂ with ⟨δ₂, hEq₂⟩
  subst hEq₁
  subst hEq₂
  have hδne : δ₁.1 ≠ δ₂.1 := fun h => hne (by rw [h])
  exact hSourceNOD δ₁.1 δ₁.2 δ₂.1 δ₂.2 hδne

/-- Sprint F2i-3p-3: the forest-cover source admissible subgraph.  Built
from `LiftedSourceComponents` via `AdmissibleSubgraph.ofElements`, with the
CD/NOD obligations dispatched to the F2i-3p-2a/2b wrappers (which in turn
depend on `hSourceCD` and `hSourceNOD` per-`δ` hypotheses). -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂)) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (forestQuotientForestSigmaForestCoverLiftedSourceComponents g r)
    ⟨fun _ hγ =>
        forestQuotientForestSigmaForestCoverLiftedSourceComponents_cd_of_source_cd
          g r hSourceCD hγ,
      fun _ hγ₁ _ hγ₂ hne =>
        forestQuotientForestSigmaForestCoverLiftedSourceComponents_nestedOrDisjoint_of_source_nod
          g r hSourceNOD hγ₁ hγ₂ hne⟩

@[simp] private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂)) :
    (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph
        g r hSourceCD hSourceNOD).elements =
      forestQuotientForestSigmaForestCoverLiftedSourceComponents g r := by
  unfold forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph
  rfl

/-- Sprint F2i-3p-4: the quotient-remainder image of the forest-cover source
admissible subgraph's elements coincides with the actualized RHS quotient
forest's elements.  Collection-level lift of F2i-3o-2i's local inverse:
applying `admissibleSubgraphQuotientRemainderSubgraph` componentwise sends
`LiftedSourceComponents` bijectively onto `D.elements`. -/
private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_remainder_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂)) :
    (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph
        g r hSourceCD hSourceNOD).elements.image
      (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
  classical
  ext γ
  constructor
  · intro hγ
    rcases Finset.mem_image.mp hγ with ⟨γs, hγs, hRem⟩
    rw [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_elements]
      at hγs
    rcases forestQuotientForestSigmaForestCoverLiftedSourceComponents_mem_exists
      g r hγs with ⟨δ, hEq⟩
    subst hEq
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq]
      at hRem
    exact hRem ▸ δ.2
  · intro hγ
    refine Finset.mem_image.mpr
      ⟨forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r γ,
        ?_,
        forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
          g r γ⟩
    rw [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_elements]
    unfold forestQuotientForestSigmaForestCoverLiftedSourceComponents
    exact Finset.mem_image.mpr ⟨⟨γ, hγ⟩, Finset.mem_attach _ _, rfl⟩

/-- Sprint F2i-3p-5 def: bundle the image of `SourceAdmissibleSubgraph.elements`
under `admissibleSubgraphQuotientRemainderSubgraph` into an `AdmissibleSubgraph
(actual)`.  CD/NOD obligations are derived from the actualized RHS forest
`D`'s own properties via the F2i-3p-4 elements equality. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraphActualRemainder
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂)) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g r.1.1) := by
  refine AdmissibleSubgraph.ofElements
    ((forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph
        g r hSourceCD hSourceNOD).elements.image
      (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2))) ⟨?_, ?_⟩
  · intro γ hγ
    have hD :
        γ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
      rw [← forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_remainder_elements
            g r hSourceCD hSourceNOD]
      exact hγ
    exact (forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem
      hD
  · intro γ₁ hγ₁ γ₂ hγ₂ hne
    have h₁ :
        γ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
      rw [← forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_remainder_elements
            g r hSourceCD hSourceNOD]
      exact hγ₁
    have h₂ :
        γ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
      rw [← forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_remainder_elements
            g r hSourceCD hSourceNOD]
      exact hγ₂
    exact (forestQuotientForestSigmaActualQuotientSubgraph g r.1).forest.nestedOrDisjoint
      h₁ h₂ hne

/-- Sprint F2i-3p-5: the bundled actual-quotient-remainder admissible subgraph
coincides with the actualized RHS quotient forest `D`.  Combines F2i-3p-4
elements equality with `AdmissibleSubgraph.ext` / `Forest.ext` to lift from
Finset equality to full structural equality. -/
private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraphActualRemainder_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hSourceCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hSourceNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂)) :
    forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraphActualRemainder
        g r hSourceCD hSourceNOD =
      forestQuotientForestSigmaActualQuotientSubgraph g r.1 := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  show (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraphActualRemainder
        g r hSourceCD hSourceNOD).elements =
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements
  unfold forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraphActualRemainder
  rw [AdmissibleSubgraph.ofElements_elements]
  exact forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_remainder_elements
    g r hSourceCD hSourceNOD

/-- Sprint F2i-3q-2a: predicate on a quotient component `δ` matching the
"forest-remnant" pattern of an outer-forest element `γ`.  By the F2i-3q-1'
calculation, `δ = remainder(γ)` for `γ ∈ A.elements` with `A.IsPairwiseDisjoint`
has:
- `δ.vertices = {starOf γ}` (singleton),
- `δ.internalEdges = 0` (empty),
- `δ.externalLegs = γ.externalLegs.map (retargetExternalLeg starOf)`.

This predicate captures that shape and will be used to classify
`D.elements` toward the eventual `A_source` reconstruction in F2i-3q. -/
private def forestQuotientForestSigma_isForestRemnantPattern
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) : Prop :=
  ∃ γ ∈ r.1.1.1.elements,
    δ.vertices =
      {FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ} ∧
    δ.internalEdges = 0 ∧
    δ.externalLegs =
      γ.externalLegs.map
        (r.1.1.1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2))

/-- Sprint F2i-3q-2b: a quotient component `δ` can match the
remnant-pattern singleton-vertex equation for at most one outer-forest
element `γ`.  Proof uses the singleton vertex equality + the freshness
property `IsFreshStarAssignment.eq_of_star_eq` (distinct components
receive distinct canonical stars).  Foundation for a future
`Classical.choose`-based `δ → γ` map. -/
private theorem forestQuotientForestSigma_isForestRemnantPattern_source_unique
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ : γ₁ ∈ r.1.1.1.elements)
    (hγ₂ : γ₂ ∈ r.1.1.1.elements)
    (hδ₁ :
      δ.vertices =
        {FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ₁})
    (hδ₂ :
      δ.vertices =
        {FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ₂}) :
    γ₁ = γ₂ := by
  classical
  have hStarEq :
      FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ₁ =
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ₂ := by
    have hmem :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ₁ ∈ δ.vertices := by
      rw [hδ₁]; exact Finset.mem_singleton.mpr rfl
    rw [hδ₂] at hmem
    exact Finset.mem_singleton.mp hmem
  have hFresh :
      r.1.1.1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  exact hFresh.eq_of_star_eq hγ₁ hγ₂ hStarEq

/-- Sprint F2i-3q-2c: `Classical.choose` extraction of the unique outer-forest
element matching the remnant pattern for `δ`.  Only invokable when `δ`
satisfies the pattern via the `hδ` hypothesis. -/
private noncomputable def forestQuotientForestSigma_forestRemnantSourceOf
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ) :
    FeynmanSubgraph (repG g).toFeynmanGraph :=
  Classical.choose hδ

/-- Spec 1: the chosen source belongs to the outer forest. -/
private theorem forestQuotientForestSigma_forestRemnantSourceOf_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ) :
    forestQuotientForestSigma_forestRemnantSourceOf g r δ hδ ∈
      r.1.1.1.elements :=
  (Classical.choose_spec hδ).1

/-- Spec 2: `δ.vertices` is the singleton of the chosen source's canonical star. -/
private theorem forestQuotientForestSigma_forestRemnantSourceOf_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ) :
    δ.vertices =
      {FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
        (forestQuotientForestSigma_forestRemnantSourceOf g r δ hδ)} :=
  (Classical.choose_spec hδ).2.1

/-- Spec 3: `δ.internalEdges` is empty. -/
private theorem forestQuotientForestSigma_forestRemnantSourceOf_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ) :
    δ.internalEdges = 0 :=
  (Classical.choose_spec hδ).2.2.1

/-- Spec 4: `δ.externalLegs` is the retarget image of the chosen source's
external legs. -/
private theorem forestQuotientForestSigma_forestRemnantSourceOf_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ) :
    δ.externalLegs =
      (forestQuotientForestSigma_forestRemnantSourceOf g r δ hδ).externalLegs.map
        (r.1.1.1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) :=
  (Classical.choose_spec hδ).2.2.2

/-- Sprint F2i-3q-2c': any witness `γ` matching the singleton-vertex
equation for `δ` agrees with the `Classical.choose`-extracted source.
Vertex equality alone is sufficient (F2i-3q-2b uniqueness); `δ.internalEdges`
and `δ.externalLegs` aren't needed to pin `γ`. -/
private theorem forestQuotientForestSigma_forestRemnantSourceOf_eq_of_pattern
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ r.1.1.1.elements)
    (hV :
      δ.vertices =
        {FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 γ}) :
    forestQuotientForestSigma_forestRemnantSourceOf g r δ hδ = γ :=
  forestQuotientForestSigma_isForestRemnantPattern_source_unique
    g r
    (forestQuotientForestSigma_forestRemnantSourceOf_mem g r δ hδ)
    hγ
    (forestQuotientForestSigma_forestRemnantSourceOf_vertices g r δ hδ)
    hV

/-- Sprint F2i-3q-2d: the `Finset` of quotient components matching the
forest-remnant pattern.  Filter of `D.elements` by `isForestRemnantPattern`.
The `letI` supplies a classical `DecidablePred` instance for the
existential pattern predicate. -/
private noncomputable def forestQuotientForestSigmaForestRemnantComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :=
  letI : DecidablePred
      (fun δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1) =>
        forestQuotientForestSigma_isForestRemnantPattern g r δ) :=
    Classical.decPred _
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.filter
    (fun δ => forestQuotientForestSigma_isForestRemnantPattern g r δ)

/-- Sprint F2i-3q-2d: membership iff for the remnant-component filter. -/
private theorem forestQuotientForestSigmaForestRemnantComponents_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)} :
    δ ∈ forestQuotientForestSigmaForestRemnantComponents g r ↔
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ∧
        forestQuotientForestSigma_isForestRemnantPattern g r δ := by
  classical
  unfold forestQuotientForestSigmaForestRemnantComponents
  exact Finset.mem_filter

/-- Sprint F2i-3q-2d: `Finset` of forest-remnant *sources* — the outer-forest
elements identified by `Classical.choose` from each remnant-pattern
component.  These are the candidates for "forest choice" sources in the
upcoming `A_source` reconstruction. -/
private noncomputable def forestQuotientForestSigmaForestRemnantSources
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaForestRemnantComponents g r).attach.image
    (fun δ =>
      forestQuotientForestSigma_forestRemnantSourceOf g r δ.1
        ((forestQuotientForestSigmaForestRemnantComponents_mem g r).mp δ.2).2)

/-- Sprint F2i-3q-2d': every element of `ForestRemnantSources` arises as the
chosen source of some remnant-pattern component.  The pattern proof is
existentially quantified inside, keeping the theorem statement clean. -/
private theorem forestQuotientForestSigmaForestRemnantSources_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestRemnantSources g r) :
    ∃ δ,
      δ ∈ forestQuotientForestSigmaForestRemnantComponents g r ∧
        ∃ hδ : forestQuotientForestSigma_isForestRemnantPattern g r δ,
          forestQuotientForestSigma_forestRemnantSourceOf g r δ hδ = γ := by
  unfold forestQuotientForestSigmaForestRemnantSources at hγ
  rcases Finset.mem_image.mp hγ with ⟨δ, _hδAttach, hEq⟩
  refine ⟨δ.1, δ.2, ?_⟩
  have hPattern :
      forestQuotientForestSigma_isForestRemnantPattern g r δ.1 :=
    ((forestQuotientForestSigmaForestRemnantComponents_mem g r).mp δ.2).2
  exact ⟨hPattern, hEq⟩

/-- Sprint F2i-3q-2e: complementary filter — quotient components NOT
matching the remnant pattern.  Partition piece for the upcoming
`A_source` reconstruction (right-side components candidate). -/
private noncomputable def forestQuotientForestSigmaForestNonRemnantComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :=
  letI : DecidablePred
      (fun δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1) =>
        forestQuotientForestSigma_isForestRemnantPattern g r δ) :=
    Classical.decPred _
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.filter
    (fun δ => ¬ forestQuotientForestSigma_isForestRemnantPattern g r δ)

/-- Sprint F2i-3q-2e: membership iff for non-remnant components. -/
private theorem forestQuotientForestSigmaForestNonRemnantComponents_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)} :
    δ ∈ forestQuotientForestSigmaForestNonRemnantComponents g r ↔
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ∧
        ¬ forestQuotientForestSigma_isForestRemnantPattern g r δ := by
  classical
  unfold forestQuotientForestSigmaForestNonRemnantComponents
  exact Finset.mem_filter

/-- Sprint F2i-3q-2e: union recovers `D.elements`. -/
private theorem forestQuotientForestSigmaForest_remnant_union_nonRemnantComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    forestQuotientForestSigmaForestRemnantComponents g r ∪
      forestQuotientForestSigmaForestNonRemnantComponents g r =
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
  classical
  ext δ
  constructor
  · intro h
    rcases Finset.mem_union.mp h with hR | hN
    · exact ((forestQuotientForestSigmaForestRemnantComponents_mem
        g r).mp hR).1
    · exact ((forestQuotientForestSigmaForestNonRemnantComponents_mem
        g r).mp hN).1
  · intro hδ
    by_cases hPat : forestQuotientForestSigma_isForestRemnantPattern g r δ
    · exact Finset.mem_union_left _
        ((forestQuotientForestSigmaForestRemnantComponents_mem
          g r).mpr ⟨hδ, hPat⟩)
    · exact Finset.mem_union_right _
        ((forestQuotientForestSigmaForestNonRemnantComponents_mem
          g r).mpr ⟨hδ, hPat⟩)

/-- Sprint F2i-3q-2e: remnant and non-remnant components are Finset-disjoint. -/
private theorem forestQuotientForestSigmaForest_remnant_disjoint_nonRemnantComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Disjoint
      (forestQuotientForestSigmaForestRemnantComponents g r)
      (forestQuotientForestSigmaForestNonRemnantComponents g r) := by
  classical
  rw [Finset.disjoint_left]
  intro δ hR hN
  have hPat :=
    ((forestQuotientForestSigmaForestRemnantComponents_mem g r).mp hR).2
  have hNot :=
    ((forestQuotientForestSigmaForestNonRemnantComponents_mem g r).mp hN).2
  exact hNot hPat

/-- Sprint F2i-3q-2e: convenience symmetric form of the union identity. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_elements_eq_remnant_union_nonRemnant
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements =
      forestQuotientForestSigmaForestRemnantComponents g r ∪
        forestQuotientForestSigmaForestNonRemnantComponents g r :=
  (forestQuotientForestSigmaForest_remnant_union_nonRemnantComponents g r).symm

/-- Sprint F2i-3q-3a: hull-based source-component candidates over all of
`D.elements`.  Reuses the v1 `forestQuotientForestSigmaForestCoverSourceSubgraph`
(broad vertex-induced hull) — not the Plus version — because forest-cover
preimage existence does not require remainder equality.  The hull form is
the natural γ_source candidate via Route Y of F2i-3q-2h scout. -/
private noncomputable def forestQuotientForestSigmaForestCoverHullSourceComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.attach.image
    (fun δ =>
      forestQuotientForestSigmaForestCoverSourceSubgraph g r δ.1)

/-- Sprint F2i-3q-3a: every hull-based source candidate arises from some
component `δ ∈ D.elements`. -/
private theorem forestQuotientForestSigmaForestCoverHullSourceComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverHullSourceComponents g r) :
    ∃ δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements,
      forestQuotientForestSigmaForestCoverSourceSubgraph g r δ = γ := by
  unfold forestQuotientForestSigmaForestCoverHullSourceComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨δ, _hδAttach, hEq⟩
  exact ⟨δ.1, δ.2, hEq⟩

/-- Sprint F2i-3q-3b: reduce the CD obligation on the hull-based source
components to an explicit per-`δ` hypothesis.  Same plumbing pattern as
F2i-3p-2a (Plus version) — no new typeclass, no axiom, no `sorry`. -/
private theorem forestQuotientForestSigmaForestCoverHullSourceComponents_cd_of_source_cd
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hHullCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ forestQuotientForestSigmaForestCoverHullSourceComponents g r) :
    γ.IsConnectedDivergent := by
  rcases forestQuotientForestSigmaForestCoverHullSourceComponents_mem_exists
    g r hγ with ⟨δ, hδ, hEq⟩
  rw [← hEq]
  exact hHullCD δ hδ

/-- Sprint F2i-3q-3c: NOD bottleneck reduction for the hull-based source
components.  Same plumbing pattern as F2i-3p-2b (Plus version). -/
private theorem forestQuotientForestSigmaForestCoverHullSourceComponents_nestedOrDisjoint_of_source_nod
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hHullNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraph g r δ₂))
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ :
      γ₁ ∈ forestQuotientForestSigmaForestCoverHullSourceComponents g r)
    (hγ₂ :
      γ₂ ∈ forestQuotientForestSigmaForestCoverHullSourceComponents g r)
    (hne : γ₁ ≠ γ₂) :
    γ₁.NestedOrDisjoint γ₂ := by
  rcases forestQuotientForestSigmaForestCoverHullSourceComponents_mem_exists
    g r hγ₁ with ⟨δ₁, hδ₁, hEq₁⟩
  rcases forestQuotientForestSigmaForestCoverHullSourceComponents_mem_exists
    g r hγ₂ with ⟨δ₂, hδ₂, hEq₂⟩
  have hδne : δ₁ ≠ δ₂ := by
    intro hδ
    apply hne
    rw [← hEq₁, ← hEq₂, hδ]
  rw [← hEq₁, ← hEq₂]
  exact hHullNOD δ₁ hδ₁ δ₂ hδ₂ hδne

/-- Sprint F2i-3q-3d: hull-based forest-cover source admissible subgraph.
Mirrors F2i-3p-3 (Plus version) but uses the v1 hull source components.
CD/NOD dispatched to F2i-3q-3b/3c wrappers via `hHullCD`/`hHullNOD`. -/
private noncomputable def forestQuotientForestSigmaForestCoverHullSourceAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hHullCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ).IsConnectedDivergent)
    (hHullNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraph g r δ₂)) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (forestQuotientForestSigmaForestCoverHullSourceComponents g r)
    ⟨fun _ hγ =>
        forestQuotientForestSigmaForestCoverHullSourceComponents_cd_of_source_cd
          g r hHullCD hγ,
      fun _ hγ₁ _ hγ₂ hne =>
        forestQuotientForestSigmaForestCoverHullSourceComponents_nestedOrDisjoint_of_source_nod
          g r hHullNOD hγ₁ hγ₂ hne⟩

@[simp] private theorem forestQuotientForestSigmaForestCoverHullSourceAdmissibleSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hHullCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ).IsConnectedDivergent)
    (hHullNOD :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
        δ₁ ≠ δ₂ →
          (forestQuotientForestSigmaForestCoverSourceSubgraph
            g r δ₁).NestedOrDisjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraph g r δ₂)) :
    (forestQuotientForestSigmaForestCoverHullSourceAdmissibleSubgraph
        g r hHullCD hHullNOD).elements =
      forestQuotientForestSigmaForestCoverHullSourceComponents g r := by
  unfold forestQuotientForestSigmaForestCoverHullSourceAdmissibleSubgraph
  rfl

/-- Sprint F2i-3q-4a: right-type components of `D.elements` — those disjoint
from `A_final.starVertices`.  Candidate δ_R's for the right-choice path in
