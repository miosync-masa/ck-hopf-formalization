import GaugeGeometry.QFT.HopfAlgebra.Counit

/-!
# Coassociativity of `coproduct_strict_forest`  [Sprint D — H5.8F]

This file proves H5.8F: `coproduct_strict_forest` is coassociative, in the
Mathlib `Coalgebra.coassoc` form.

```
TensorProduct.assoc ℚ HopfH HopfH HopfH ∘ₗ
    coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap
  = coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap
```

## Strategy P1F — admissible-forest `φ` reindexing

* **AlgHom pivot**: prove the equality at the AlgHom level, where
  `MvPolynomial.algHom_ext` reduces it to a generator-by-generator check.
* **Forest expansion**: expand `coproduct_strict_forest (X g)` over the
  proper-disjoint admissible forest carrier, using canonical fresh stars for
  the right forest quotient.
* **Component-choice split**: distribute the LHS component coproduct choices
  and split the RHS quotient-forest choices into the concrete graph-level map
  `φ`.
* **Graph/product transports**: discharge the mixed and genuine branches by
  literal graph-field equalities, product transports, right-factor class
  transports, and finite star-alignment permutations.
* **Final summit gate**: the active proof is reduced to
  `coassocStrictForestH58FinalPayloads`, whose two fields are genuine
  component-complement positivity and the finite RHS indexed branch
  classifier.
* **LinearMap form (Stage 6)**: `congrArg AlgHom.toLinearMap` on the
  AlgHom equality completes the conversion.
-/

open scoped TensorProduct

set_option linter.unusedSectionVars false
set_option linter.unusedVariables false
set_option linter.unnecessarySimpa false
set_option linter.unusedSimpArgs false

namespace GaugeGeometry.QFT.Combinatorial

section PathW

variable [∀ G : FeynmanGraph, DivergenceMeasure G]
         [∀ G : FeynmanGraph, IsPermInvariantDivergence G]
         [∀ G : FeynmanGraph, IsIsoInvariantDivergence G]
         [∀ G : FeynmanGraph, Fintype (FeynmanSubgraph G)]
         [IsAmbientInvariantDivergence] [IsDivergencePreservedByContract]

open MvPolynomial

/-! ### Stage 2 — generator-level expand of `coproduct_strict (X g)`

The internal `genG = gen ⟨G.toFG.toClass, _⟩` matches `MvPolynomial.X g`
(via `genG_eq_X`), so the body of `coproduct_strict (X g)` can be
rewritten in terms of `X g` without exposing the `Quotient.out`-rebuilt
representative. -/

-- `repG`, `repG_wellFormed`, `repG_toClass`, `repG_isConnectedDivergent`,
-- and `repG_isOnePI` moved to `Coproduct.lean` as public Sprint E shared
-- API (canonical representative extraction for `HopfGen`). They are
-- reused by both the strict forest coproduct machinery and the Sprint E
-- antipode construction.

/-- Local body unfold for the canonical-star forest generator formula.  Keeping
this in `Coassoc` avoids depending on a freshly rebuilt imported olean while
H5.8 is still being refactored. -/
private theorem coproductGen_strict_forestWithCanonicalStars_body
    (G : ConnectedFeynmanGraph)
    (hGCD : G.toFeynmanGraph.IsConnectedDivergent)
    (hCD : ∀ A : AdmissibleSubgraph G.toFeynmanGraph,
      ∀ hA : A ∈ G.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs,
        (FeynmanGraph.admissibleForestContractGraphWithStars
          G.toFeynmanGraph A
          (FeynmanGraph.admissibleForestCanonicalStarOf
            G.toFeynmanGraph A hA)).IsConnectedDivergent) :
    coproductGen_strict_forestWithCanonicalStars G hGCD hCD =
      (have genG : HopfH := gen ⟨G.toFeynmanGraph.toClass,
        (FeynmanGraphClass.isConnectedDivergent_toClass G.toFeynmanGraph).mpr hGCD⟩
      (genG ⊗ₜ[ℚ] (1 : HopfH))
      + ((1 : HopfH) ⊗ₜ[ℚ] genG)
      + ∑ A ∈ G.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
          FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            G.toFeynmanGraph hCD A) := by
  rfl

/-- **Stage 2 expand** — `coproduct_strict (X g)` as a clean sum of
`X g ⊗ 1`, `1 ⊗ X g`, and a sum over proper connected divergent
subgraphs of the chosen representative `repG g`. -/
theorem coproduct_strict_X_eq (g : HopfGen) :
    coproduct_strict (MvPolynomial.X g) =
      ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      + ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
      + ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
          if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
            let hγNe : γ.IsNonempty :=
              FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
            (gen (γ.toHopfGen hγ.1)) ⊗ₜ[ℚ]
              (gen (γ.contractToHopfGen (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe))
          else 0 := by
  rw [coproduct_strict_X]
  unfold coproductGenClass_strict coproductGen_strict
  simp only []
  rw [genG_eq_X g _]
  rfl

/-! ### Stage 2F — forest-generator expand of the redesigned coproduct

This is the first H5.8 restart point after the admissible-forest redesign:
the coproduct summand is displayed over the genuine proper-disjoint
admissible carrier, with the canonical forest quotient as the right tensor
factor. -/

/-- **Stage 2F expand** — the forest strict coproduct on a generator, using
the final canonical proper-disjoint admissible forest summand. -/
theorem coproduct_strict_forest_X_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    coproduct_strict_forest (MvPolynomial.X g) =
      ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      + ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
      + ∑ A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
          FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            (repG g).toFeynmanGraph
            (FeynmanGraph.admissibleForestCanonicalContractGraph_hCD_of_ambient_preservation
              (repG g).toFeynmanGraph
              (repG_wellFormed g)
              (repG_isOnePI g)
              (repG_isConnectedDivergent g))
            A := by
  rw [coproduct_strict_forest_X]
  rw [coproductGenClass_strict_forest_eq]
  rw [coproductGen_strict_forestWithCanonicalStarsFromAmbientPreservation_eq]
  rw [coproductGen_strict_forestWithCanonicalStars_body]
  simp [repG, gen, genG_eq_X g _]
  apply Finset.sum_congr rfl
  intro A hA
  rfl

/-- **H5.8F AlgHom reduction** — forest coassociativity is reduced to the
generator-level identity. The remaining work is the `X g` calculation over
the proper-disjoint admissible forest carrier. -/
theorem coassoc_strict_forest_algHom_of_generators
    [IsDivergencePreservedByAdmissibleForestContract]
    (hX : ∀ g : HopfGen,
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH))
          (coproduct_strict_forest (MvPolynomial.X g))) =
      (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest)
        (coproduct_strict_forest (MvPolynomial.X g))) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom.comp
        ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH)).comp
          coproduct_strict_forest)
      =
    (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest).comp
      coproduct_strict_forest := by
  apply MvPolynomial.algHom_ext
  intro g
  simpa [AlgHom.comp_apply] using hX g

/-- `(map Δ_forest id).toLinearMap` is the right tensoring of the forest
strict coproduct linear map. -/
private theorem map_coproduct_strict_forest_id_toLinearMap_eq_rTensor
    [IsDivergencePreservedByAdmissibleForestContract] :
    (Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH)).toLinearMap =
      coproduct_strict_forest.toLinearMap.rTensor HopfH := by
  ext a b
  simp [LinearMap.rTensor_tmul]

/-- `(map id Δ_forest).toLinearMap` is the left tensoring of the forest
strict coproduct linear map. -/
private theorem map_id_coproduct_strict_forest_toLinearMap_eq_lTensor
    [IsDivergencePreservedByAdmissibleForestContract] :
    (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest).toLinearMap =
      coproduct_strict_forest.toLinearMap.lTensor HopfH := by
  ext a b
  simp [LinearMap.lTensor_tmul]

/-- **H5.8F LinearMap reduction** — the AlgHom forest coassociativity
identity implies the Mathlib `Coalgebra.coassoc`-shaped LinearMap identity. -/
theorem coassoc_strict_forest_linear_of_algHom
    [IsDivergencePreservedByAdmissibleForestContract]
    (hAlg :
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom.comp
          ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH)).comp
            coproduct_strict_forest)
        =
      (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest).comp
        coproduct_strict_forest) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap := by
  have h := congrArg AlgHom.toLinearMap hAlg
  simpa [AlgHom.comp_toLinearMap,
    map_coproduct_strict_forest_id_toLinearMap_eq_rTensor,
    map_id_coproduct_strict_forest_toLinearMap_eq_lTensor] using h

/-- **H5.8F generator-to-LinearMap reduction** — after this point the whole
forest coassociativity proof is the generator calculation. -/
theorem coassoc_strict_forest_linear_of_generators
    [IsDivergencePreservedByAdmissibleForestContract]
    (hX : ∀ g : HopfGen,
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH))
          (coproduct_strict_forest (MvPolynomial.X g))) =
      (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest)
        (coproduct_strict_forest (MvPolynomial.X g))) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_algHom
    (coassoc_strict_forest_algHom_of_generators hX)

/-! ### Stage 3F-a — named forest coassoc summands

These names keep the genuine forest expansion readable.  Unlike the old
connected-only Stage 3, the left tensor factor in the summand is
`A.toHopfH`, the product of the admissible forest components. -/

/-- Canonical connected-divergent preservation package for the forest
quotient of the representative of `g`. -/
private def forestCanonicalHCD
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    ∀ A : AdmissibleSubgraph (repG g).toFeynmanGraph,
      ∀ hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs,
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG g).toFeynmanGraph A
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A hA)).IsConnectedDivergent :=
  FeynmanGraph.admissibleForestCanonicalContractGraph_hCD_of_ambient_preservation
    (repG g).toFeynmanGraph
    (repG_wellFormed g)
    (repG_isOnePI g)
    (repG_isConnectedDivergent g)

/-- The right Hopf factor for an admissible forest summand in `repG g`. -/
private noncomputable def forestRightHopfH
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs) :
    HopfH :=
  gen (FeynmanGraph.admissibleForestRightWithCanonicalStars
    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)

/-- To identify right Hopf factors it is enough to identify the underlying
canonical forest-contraction generator classes. -/
private theorem forestRightHopfH_eq_of_right_val_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g₁ g₂ : HopfGen}
    {A₁ : AdmissibleSubgraph (repG g₁).toFeynmanGraph}
    {A₂ : AdmissibleSubgraph (repG g₂).toFeynmanGraph}
    {hA₁ : A₁ ∈ (repG g₁).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs}
    {hA₂ : A₂ ∈ (repG g₂).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs}
    (hVal :
      (FeynmanGraph.admissibleForestRightWithCanonicalStars
        (repG g₁).toFeynmanGraph (forestCanonicalHCD g₁) A₁ hA₁).val =
      (FeynmanGraph.admissibleForestRightWithCanonicalStars
        (repG g₂).toFeynmanGraph (forestCanonicalHCD g₂) A₂ hA₂).val) :
    forestRightHopfH g₁ A₁ hA₁ = forestRightHopfH g₂ A₂ hA₂ := by
  unfold forestRightHopfH gen
  exact congrArg MvPolynomial.X (Subtype.ext hVal)

/-- Contracted-graph class equality is the graph-level certificate needed for
the final quotient right-factor identification. -/
private theorem forestRightHopfH_eq_of_contract_toClass_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g₁ g₂ : HopfGen}
    {A₁ : AdmissibleSubgraph (repG g₁).toFeynmanGraph}
    {A₂ : AdmissibleSubgraph (repG g₂).toFeynmanGraph}
    {hA₁ : A₁ ∈ (repG g₁).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs}
    {hA₂ : A₂ ∈ (repG g₂).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs}
    (hClass :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g₁).toFeynmanGraph A₁
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g₁).toFeynmanGraph A₁ hA₁)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g₂).toFeynmanGraph A₂
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g₂).toFeynmanGraph A₂ hA₂)).toClass) :
    forestRightHopfH g₁ A₁ hA₁ = forestRightHopfH g₂ A₂ hA₂ :=
  forestRightHopfH_eq_of_right_val_eq (by simpa using hClass)

/-- Three summand shapes in the forest coproduct of a single strict
generator: left boundary, right boundary, and a genuine forest summand. -/
private inductive forestCoproductChoice (g : HopfGen) where
  | left
  | right
  | forest (A : AdmissibleSubgraph (repG g).toFeynmanGraph)

private noncomputable instance forestCoproductChoiceDecidableEq (g : HopfGen) :
    DecidableEq (forestCoproductChoice g) := by
  classical
  intro c₁ c₂
  cases c₁ <;> cases c₂
  · exact isTrue rfl
  · exact isFalse (by intro h; cases h)
  · exact isFalse (by intro h; cases h)
  · exact isFalse (by intro h; cases h)
  · exact isTrue rfl
  · exact isFalse (by intro h; cases h)
  · exact isFalse (by intro h; cases h)
  · exact isFalse (by intro h; cases h)
  · rename_i A B
    by_cases hAB : A = B
    · subst B
      exact isTrue rfl
    · exact isFalse (by
        intro h
        injection h with hAB'
        exact hAB hAB')

-- `forestCoproductProperForestIndex` and `mem_forestCoproductProperForestIndex`
-- moved to `Coproduct.lean` as the public Sprint E shared carrier between
-- the strict forest coproduct and the antipode recursion.

/-- Finite three-way summand carrier for `coproductGenClass_strict_forest`. -/
private noncomputable def forestCoproductChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestCoproductChoice g) :=
  insert forestCoproductChoice.left
    (insert forestCoproductChoice.right
      ((forestCoproductProperForestIndex g).image
        forestCoproductChoice.forest))

/-- The genuine forest-summand part of a generator-level forest coproduct
choice carrier. -/
private noncomputable def forestCoproductForestChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestCoproductChoice g) :=
  (forestCoproductProperForestIndex g).image
    forestCoproductChoice.forest

/-- The left boundary choice is not a genuine forest choice. -/
private theorem forestCoproductChoice_left_not_mem_forestIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestCoproductChoice.left ∉ forestCoproductForestChoiceIndex g := by
  intro hmem
  unfold forestCoproductForestChoiceIndex at hmem
  rw [Finset.mem_image] at hmem
  rcases hmem with ⟨A, _hA, hEq⟩
  cases hEq

/-- The right boundary choice is not a genuine forest choice. -/
private theorem forestCoproductChoice_right_not_mem_forestIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestCoproductChoice.right ∉ forestCoproductForestChoiceIndex g := by
  intro hmem
  unfold forestCoproductForestChoiceIndex at hmem
  rw [Finset.mem_image] at hmem
  rcases hmem with ⟨A, _hA, hEq⟩
  cases hEq

/-- The genuine-forest constructor for generator-level choices is injective. -/
private theorem forestCoproductChoice_forest_injective (g : HopfGen) :
    Function.Injective (forestCoproductChoice.forest :
      AdmissibleSubgraph (repG g).toFeynmanGraph → forestCoproductChoice g) := by
  intro A B h
  injection h with hAB

/-- Summing over the image carrier of genuine forest choices is the same as
the underlying admissible-forest sum. -/
private theorem forestCoproductForestChoiceIndex_sum
    [IsDivergencePreservedByAdmissibleForestContract]
    {M : Type} [AddCommMonoid M] (g : HopfGen)
    (f : forestCoproductChoice g → M) :
    (∑ c ∈ forestCoproductForestChoiceIndex g, f c) =
      ∑ A ∈ forestCoproductProperForestIndex g,
        f (forestCoproductChoice.forest A) := by
  unfold forestCoproductForestChoiceIndex
  exact Finset.sum_image (forestCoproductChoice_forest_injective g).injOn

/-- A generator-level choice sum splits into its two boundary choices and the
genuine forest-choice core. -/
private theorem forestCoproductChoice_inner_sum_eq_boundaries_add_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {M : Type} [AddCommMonoid M] (g : HopfGen)
    (f : forestCoproductChoice g → M) :
    (∑ c ∈ forestCoproductChoiceIndex g, f c) =
      f forestCoproductChoice.left + f forestCoproductChoice.right +
        ∑ c ∈ forestCoproductForestChoiceIndex g, f c := by
  have hLeftNot :
      forestCoproductChoice.left ∉
        insert forestCoproductChoice.right
          (forestCoproductForestChoiceIndex g) := by
    intro hmem
    rw [Finset.mem_insert] at hmem
    rcases hmem with hEq | hForest
    · cases hEq
    · exact forestCoproductChoice_left_not_mem_forestIndex g hForest
  have hRightNot :
      forestCoproductChoice.right ∉ forestCoproductForestChoiceIndex g :=
    forestCoproductChoice_right_not_mem_forestIndex g
  change
    (∑ c ∈ insert forestCoproductChoice.left
        (insert forestCoproductChoice.right
          (forestCoproductForestChoiceIndex g)), f c) =
      f forestCoproductChoice.left + f forestCoproductChoice.right +
        ∑ c ∈ forestCoproductForestChoiceIndex g, f c
  rw [Finset.sum_insert hLeftNot]
  rw [Finset.sum_insert hRightNot]
  abel

/-- The tensor term selected by one generator-level forest coproduct choice. -/
private noncomputable def forestCoproductChoiceTerm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestCoproductChoice g → HopfH ⊗[ℚ] HopfH
  | forestCoproductChoice.left =>
      (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH)
  | forestCoproductChoice.right =>
      (1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH)
  | forestCoproductChoice.forest A =>
      FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
        (repG g).toFeynmanGraph (forestCanonicalHCD g) A

/-- A non-forest generator choice is the tensor of its left/right indicator
factors.  This is the pointwise component calculation behind the mixed-boundary
product factorization. -/
private theorem forestCoproductChoiceTerm_eq_leftRightIndicators_of_not_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (c : forestCoproductChoice g)
    (hNoForest :
      ∀ A : AdmissibleSubgraph (repG g).toFeynmanGraph,
        c ≠ forestCoproductChoice.forest A) :
    forestCoproductChoiceTerm g c =
      (if c = forestCoproductChoice.left then
        (MvPolynomial.X g : HopfH) else 1) ⊗ₜ[ℚ]
      (if c = forestCoproductChoice.right then
        (MvPolynomial.X g : HopfH) else 1) := by
  cases c with
  | left =>
      simp [forestCoproductChoiceTerm]
  | right =>
      simp [forestCoproductChoiceTerm]
  | forest A =>
      exact False.elim ((hNoForest A) rfl)

/-- The forest coproduct of one generator is a finite sum over the explicit
three-way choice carrier. -/
private theorem coproductGenClass_strict_forest_eq_choiceSum
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    coproductGenClass_strict_forest g =
      ∑ c ∈ forestCoproductChoiceIndex g, forestCoproductChoiceTerm g c := by
  rw [forestCoproductChoice_inner_sum_eq_boundaries_add_forest]
  rw [forestCoproductForestChoiceIndex_sum]
  rw [coproductGenClass_strict_forest_eq]
  rw [coproductGen_strict_forestWithCanonicalStarsFromAmbientPreservation_eq]
  rw [coproductGen_strict_forestWithCanonicalStars_body]
  simp [forestCoproductChoiceTerm, forestCoproductProperForestIndex, repG, gen]
  apply Finset.sum_congr rfl
  intro A hA
  rfl

/-- Forest pure `X g ⊗ (1 ⊗ 1)`. -/
private noncomputable def forestTermA (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH))

/-- Forest pure `1 ⊗ (X g ⊗ 1)`. -/
private noncomputable def forestTermB (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (1 : HopfH) ⊗ₜ[ℚ] ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))

/-- Forest pure `1 ⊗ (1 ⊗ X g)`. -/
private noncomputable def forestTermD (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (1 : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))

/-- Forest mixed `Σ_A A.toHopfH ⊗ ([Γ/A] ⊗ 1)`. -/
private noncomputable def forestTermC
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      A.toHopfH ⊗ₜ[ℚ] ((forestRightHopfH g A hA) ⊗ₜ[ℚ] (1 : HopfH))
    else 0

/-- Forest LHS aggregate `Σ_A assoc (Δ(A.toHopfH) ⊗ [Γ/A])`. -/
private noncomputable def forestTermE
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((coproduct_strict_forest A.toHopfH) ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- Forest RHS boundary aggregate `Σ_A 1 ⊗ (A.toHopfH ⊗ [Γ/A])`. -/
private noncomputable def forestTermE2
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      (1 : HopfH) ⊗ₜ[ℚ] (A.toHopfH ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- Forest RHS aggregate `Σ_A A.toHopfH ⊗ Δ([Γ/A])`. -/
private noncomputable def forestTermF
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      A.toHopfH ⊗ₜ[ℚ] coproduct_strict_forest (forestRightHopfH g A hA)
    else 0

/-- `Δ_forest` expands across the admissible forest component product. -/
private theorem coproduct_strict_forest_admissible_toHopfH
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    coproduct_strict_forest A.toHopfH =
      ∏ γ ∈ A.elements, coproduct_strict_forest (A.componentToHopfH γ) := by
  rw [AdmissibleSubgraph.toHopfH]
  simp [map_prod]

/-- On a component of an admissible forest, the expanded factor is the
forest coproduct of that connected-divergent generator. -/
private theorem coproduct_strict_forest_componentToHopfH_of_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    {γ : FeynmanSubgraph G} (hγ : γ ∈ A.elements) :
    coproduct_strict_forest (A.componentToHopfH γ) =
      coproductGenClass_strict_forest
        (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ)) := by
  unfold AdmissibleSubgraph.componentToHopfH
  rw [dif_pos hγ]
  unfold gen
  rw [coproduct_strict_forest_X]

/-- Component-level factor for expanding `Δ_forest(A.toHopfH)`.  The
non-member branch makes it usable under ordinary Finset products without
dependent indexing. -/
private noncomputable def forestComponentCoproductFactor
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) (γ : FeynmanSubgraph G) :
    HopfH ⊗[ℚ] HopfH :=
  if hγ : γ ∈ A.elements then
    coproductGenClass_strict_forest
      (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ))
  else 1

/-- A component factor in the expanded left core is exactly the three-way
choice sum for that component generator. -/
private theorem forestComponentCoproductFactor_eq_choiceSum_of_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    {γ : FeynmanSubgraph G} (hγ : γ ∈ A.elements) :
    forestComponentCoproductFactor A γ =
      ∑ c ∈ forestCoproductChoiceIndex
          (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ)),
        forestCoproductChoiceTerm
          (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ)) c := by
  unfold forestComponentCoproductFactor
  rw [dif_pos hγ]
  rw [coproductGenClass_strict_forest_eq_choiceSum]

/-- Component-level choice carrier, indexed by the attached forest component
so the connected-divergent proof is available without another lookup. -/
private noncomputable def forestComponentChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}) :
    Finset (forestCoproductChoice
      (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :=
  forestCoproductChoiceIndex
    (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))

/-- Product-of-component-factors expanded by `Finset.prod_sum`.  This is the
left-core indexing skeleton: a choice function assigns left/right/forest to
each connected component of `A`. -/
private theorem forestComponentCoproductFactor_prod_eq_choicePi
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    (∏ γ ∈ A.elements, forestComponentCoproductFactor A γ) =
      ∑ p ∈ A.elements.attach.pi (forestComponentChoiceIndex A),
        ∏ γ ∈ A.elements.attach.attach,
          forestCoproductChoiceTerm
            (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
            (p γ.1 γ.2) := by
  rw [← Finset.prod_attach A.elements
    (fun γ : FeynmanSubgraph G => forestComponentCoproductFactor A γ)]
  have hProd :
      (∏ γ ∈ A.elements.attach, forestComponentCoproductFactor A γ.1) =
        ∏ γ ∈ A.elements.attach,
          ∑ c ∈ forestComponentChoiceIndex A γ,
            forestCoproductChoiceTerm
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) c := by
    apply Finset.prod_congr rfl
    intro γ _hγ
    rw [forestComponentCoproductFactor_eq_choiceSum_of_mem A γ.2]
    rfl
  rw [hProd]
  rw [Finset.prod_sum]

/-- The tensor factor obtained by multiplying the chosen coproduct summand
for each component of an admissible forest. -/
private noncomputable def forestComponentChoiceProductTerm
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :
    HopfH ⊗[ℚ] HopfH :=
  ∏ γ ∈ A.elements.attach.attach,
    forestCoproductChoiceTerm
      (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
      (p γ.1 γ.2)

/-- The constant all-left component choice. -/
private noncomputable def forestComponentAllLeftChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) :=
  fun _ _ => forestCoproductChoice.left

/-- The constant all-right component choice. -/
private noncomputable def forestComponentAllRightChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) :=
  fun _ _ => forestCoproductChoice.right

/-- The all-left component choice belongs to the component-choice `pi`
carrier. -/
private theorem forestComponentAllLeftChoice_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    forestComponentAllLeftChoice A ∈
      A.elements.attach.pi (forestComponentChoiceIndex A) := by
  rw [Finset.mem_pi]
  intro γ _hγ
  unfold forestComponentAllLeftChoice forestComponentChoiceIndex
    forestCoproductChoiceIndex
  simp

/-- The all-right component choice belongs to the component-choice `pi`
carrier. -/
private theorem forestComponentAllRightChoice_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    forestComponentAllRightChoice A ∈
      A.elements.attach.pi (forestComponentChoiceIndex A) := by
  rw [Finset.mem_pi]
  intro γ _hγ
  unfold forestComponentAllRightChoice forestComponentChoiceIndex
    forestCoproductChoiceIndex
  simp

/-- Under the all-left component choice, the component product is
`A.toHopfH ⊗ 1`. -/
private theorem forestComponentChoiceProductTerm_allLeft
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    forestComponentChoiceProductTerm A (forestComponentAllLeftChoice A) =
      A.toHopfH ⊗ₜ[ℚ] (1 : HopfH) := by
  unfold forestComponentChoiceProductTerm forestComponentAllLeftChoice
    forestCoproductChoiceTerm
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      (MvPolynomial.X (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) :
          HopfH) ⊗ₜ[ℚ] (1 : HopfH))]
  unfold AdmissibleSubgraph.toHopfH AdmissibleSubgraph.componentToHopfH gen
  let incl : HopfH →ₐ[ℚ] HopfH ⊗[ℚ] HopfH :=
    Algebra.TensorProduct.includeLeft
  change (∏ x ∈ A.elements.attach,
      incl (MvPolynomial.X (x.1.toHopfGen
        (A.isConnectedDivergent_of_mem x.2)) : HopfH)) =
    incl (∏ x ∈ A.elements,
      if hγ : x ∈ A.elements then
        (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hγ)) :
          HopfH)
      else 1)
  calc
    (∏ x ∈ A.elements.attach,
        incl (MvPolynomial.X (x.1.toHopfGen
          (A.isConnectedDivergent_of_mem x.2)) : HopfH))
        = incl (∏ x ∈ A.elements.attach,
            (MvPolynomial.X (x.1.toHopfGen
              (A.isConnectedDivergent_of_mem x.2)) : HopfH)) := by
          rw [map_prod]
    _ = incl (∏ x ∈ A.elements,
          if hγ : x ∈ A.elements then
            (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hγ)) :
              HopfH)
          else 1) := by
          congr 1
          rw [← Finset.prod_attach A.elements
            (fun x : FeynmanSubgraph G =>
              if hγ : x ∈ A.elements then
                (MvPolynomial.X (x.toHopfGen
                  (A.isConnectedDivergent_of_mem hγ)) : HopfH)
              else 1)]
          apply Finset.prod_congr rfl
          intro x hx
          simp

/-- Under the all-right component choice, the component product is
`1 ⊗ A.toHopfH`. -/
private theorem forestComponentChoiceProductTerm_allRight
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    forestComponentChoiceProductTerm A (forestComponentAllRightChoice A) =
      (1 : HopfH) ⊗ₜ[ℚ] A.toHopfH := by
  unfold forestComponentChoiceProductTerm forestComponentAllRightChoice
    forestCoproductChoiceTerm
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      (1 : HopfH) ⊗ₜ[ℚ]
        (MvPolynomial.X (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) :
          HopfH))]
  unfold AdmissibleSubgraph.toHopfH AdmissibleSubgraph.componentToHopfH gen
  let incl : HopfH →ₐ[ℚ] HopfH ⊗[ℚ] HopfH :=
    Algebra.TensorProduct.includeRight
  change (∏ x ∈ A.elements.attach,
      incl (MvPolynomial.X (x.1.toHopfGen
        (A.isConnectedDivergent_of_mem x.2)) : HopfH)) =
    incl (∏ x ∈ A.elements,
      if hγ : x ∈ A.elements then
        (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hγ)) :
          HopfH)
      else 1)
  calc
    (∏ x ∈ A.elements.attach,
        incl (MvPolynomial.X (x.1.toHopfGen
          (A.isConnectedDivergent_of_mem x.2)) : HopfH))
        = incl (∏ x ∈ A.elements.attach,
            (MvPolynomial.X (x.1.toHopfGen
              (A.isConnectedDivergent_of_mem x.2)) : HopfH)) := by
          rw [map_prod]
    _ = incl (∏ x ∈ A.elements,
          if hγ : x ∈ A.elements then
            (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hγ)) :
              HopfH)
          else 1) := by
          congr 1
          rw [← Finset.prod_attach A.elements
            (fun x : FeynmanSubgraph G =>
              if hγ : x ∈ A.elements then
                (MvPolynomial.X (x.toHopfGen
                  (A.isConnectedDivergent_of_mem hγ)) : HopfH)
              else 1)]
          apply Finset.prod_congr rfl
          intro x hx
          simp

/-- Component-choice functions other than the two boundary choices. -/
private noncomputable def forestComponentCoreChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    Finset (∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :=
  (A.elements.attach.pi (forestComponentChoiceIndex A)).filter
    (fun p => p ≠ forestComponentAllLeftChoice A ∧
      p ≠ forestComponentAllRightChoice A)

/-- Membership in the component-choice core is exactly membership in the
component-choice `pi` carrier plus exclusion of the two constant boundary
choices. -/
private theorem mem_forestComponentCoreChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :
    p ∈ forestComponentCoreChoiceIndex A ↔
      p ∈ A.elements.attach.pi (forestComponentChoiceIndex A) ∧
        p ≠ forestComponentAllLeftChoice A ∧
        p ≠ forestComponentAllRightChoice A := by
  unfold forestComponentCoreChoiceIndex
  rw [Finset.mem_filter]

/-- If a core component choice selects a genuine forest summand, that forest
comes from the strict forest-choice carrier for the component. -/
private theorem forestComponentChoice_forest_mem_coproductProperForestIndex_of_core_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    B ∈ forestCoproductProperForestIndex
      (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) := by
  classical
  have hpPi :
      p ∈ A.elements.attach.pi (forestComponentChoiceIndex A) :=
    ((mem_forestComponentCoreChoiceIndex A p).mp hp).1
  rw [Finset.mem_pi] at hpPi
  have hChoice :
      p γ (Finset.mem_attach A.elements γ) ∈
        forestComponentChoiceIndex A γ :=
    hpPi γ (Finset.mem_attach A.elements γ)
  unfold forestComponentChoiceIndex forestCoproductChoiceIndex at hChoice
  rw [hB] at hChoice
  rw [Finset.mem_insert] at hChoice
  rcases hChoice with hLeft | hChoice
  · cases hLeft
  rw [Finset.mem_insert] at hChoice
  rcases hChoice with hRight | hForest
  · cases hRight
  rw [Finset.mem_image] at hForest
  rcases hForest with ⟨B', hB', hEq⟩
  have hB'eq : B' = B :=
    forestCoproductChoice_forest_injective
      (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) hEq
  subst B'
  exact hB'

/-- If a core component choice selects a genuine forest summand, that forest
comes from the proper-disjoint representative carrier for the component. -/
private theorem forestComponentChoice_forest_mem_properDisjoint_of_core_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    B ∈ ((repG (γ.1.toHopfGen
      (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs := by
  have hStrict :=
    forestComponentChoice_forest_mem_coproductProperForestIndex_of_core_mem
      hp γ hB
  exact ((mem_forestCoproductProperForestIndex
    (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B).mp hStrict).1

/-- A genuine component forest choice from the strict carrier leaves a
nonempty complement in the representative component graph. -/
private theorem forestComponentChoice_forest_complementEdges_positive_of_core_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    0 < B.complementEdges.card := by
  have hStrict :=
    forestComponentChoice_forest_mem_coproductProperForestIndex_of_core_mem
      hp γ hB
  exact ((mem_forestCoproductProperForestIndex
    (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B).mp hStrict).2

/-- A component-choice function selects a left boundary on some component. -/
private def forestComponentChoiceHasLeft
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) : Prop :=
  ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left

/-- A component-choice function selects a right boundary on some component. -/
private def forestComponentChoiceHasRight
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) : Prop :=
  ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right

/-- A component-choice function selects a genuine forest summand on some
component. -/
private def forestComponentChoiceHasForest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) : Prop :=
  ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
    ∃ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B

/-- Any single generator-level choice is left, right, or a genuine forest
choice. -/
private theorem forestCoproductChoice_eq_left_or_right_or_forest
    (g : HopfGen) (c : forestCoproductChoice g) :
    c = forestCoproductChoice.left ∨
      c = forestCoproductChoice.right ∨
      ∃ A : AdmissibleSubgraph (repG g).toFeynmanGraph,
        c = forestCoproductChoice.forest A := by
  cases c with
  | left =>
      exact Or.inl rfl
  | right =>
      exact Or.inr (Or.inl rfl)
  | forest A =>
      exact Or.inr (Or.inr ⟨A, rfl⟩)

/-- Being different from the all-left component choice is the same as having
some component whose choice is not left. -/
private theorem forestComponentChoice_ne_allLeft_iff_exists_not_left
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :
    p ≠ forestComponentAllLeftChoice A ↔
      ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.left := by
  constructor
  · intro hp
    by_contra hnone
    apply hp
    funext γ hγ
    unfold forestComponentAllLeftChoice
    have hcanon : p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.left := by
      by_contra hneq
      exact hnone ⟨γ, hneq⟩
    have hproof : hγ = Finset.mem_attach A.elements γ := Subsingleton.elim _ _
    rw [hproof]
    exact hcanon
  · rintro ⟨γ, hγ⟩ hpEq
    have hval := congrFun (congrFun hpEq γ) (Finset.mem_attach A.elements γ)
    unfold forestComponentAllLeftChoice at hval
    exact hγ hval

/-- Being different from the all-right component choice is the same as having
some component whose choice is not right. -/
private theorem forestComponentChoice_ne_allRight_iff_exists_not_right
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) :
    p ≠ forestComponentAllRightChoice A ↔
      ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.right := by
  constructor
  · intro hp
    by_contra hnone
    apply hp
    funext γ hγ
    unfold forestComponentAllRightChoice
    have hcanon : p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.right := by
      by_contra hneq
      exact hnone ⟨γ, hneq⟩
    have hproof : hγ = Finset.mem_attach A.elements γ := Subsingleton.elim _ _
    rw [hproof]
    exact hcanon
  · rintro ⟨γ, hγ⟩ hpEq
    have hval := congrFun (congrFun hpEq γ) (Finset.mem_attach A.elements γ)
    unfold forestComponentAllRightChoice at hval
    exact hγ hval

/-- A component-choice core element has a non-left component and a non-right
component. -/
private theorem forestComponentCoreChoice_has_nonLeft_and_nonRight
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))}
    (hp : p ∈ forestComponentCoreChoiceIndex A) :
    (∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.left) ∧
      ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.right := by
  have hpCore := (mem_forestComponentCoreChoiceIndex A p).mp hp
  exact ⟨(forestComponentChoice_ne_allLeft_iff_exists_not_left A p).mp hpCore.2.1,
    (forestComponentChoice_ne_allRight_iff_exists_not_right A p).mp hpCore.2.2⟩

/-- Core component choices split into two regimes: either some component uses a
genuine forest summand, or the core is purely a mixed left/right boundary
choice.  The next reindexing proof treats these two regimes separately. -/
private theorem forestComponentCoreChoice_has_forest_or_mixed_boundary
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))}
    (hp : p ∈ forestComponentCoreChoiceIndex A) :
    forestComponentChoiceHasForest A p ∨
      (forestComponentChoiceHasLeft A p ∧ forestComponentChoiceHasRight A p) := by
  rcases forestComponentCoreChoice_has_nonLeft_and_nonRight (A := A) hp with
    ⟨⟨γNotLeft, hNotLeft⟩, ⟨γNotRight, hNotRight⟩⟩
  rcases forestCoproductChoice_eq_left_or_right_or_forest
      (γNotLeft.1.toHopfGen (A.isConnectedDivergent_of_mem γNotLeft.2))
      (p γNotLeft (Finset.mem_attach A.elements γNotLeft)) with
    hLeft | hRightOrForest
  · exact False.elim (hNotLeft hLeft)
  · rcases hRightOrForest with hRight | hForest
    · have hasRight : forestComponentChoiceHasRight A p := ⟨γNotLeft, hRight⟩
      rcases forestCoproductChoice_eq_left_or_right_or_forest
          (γNotRight.1.toHopfGen (A.isConnectedDivergent_of_mem γNotRight.2))
          (p γNotRight (Finset.mem_attach A.elements γNotRight)) with
        hLeft2 | hRightOrForest2
      · have hasLeft : forestComponentChoiceHasLeft A p := ⟨γNotRight, hLeft2⟩
        exact Or.inr ⟨hasLeft, hasRight⟩
      · rcases hRightOrForest2 with hRight2 | hForest2
        · exact False.elim (hNotRight hRight2)
        · rcases hForest2 with ⟨B, hB⟩
          exact Or.inl ⟨γNotRight, B, hB⟩
    · rcases hForest with ⟨B, hB⟩
      exact Or.inl ⟨γNotLeft, B, hB⟩

/-- The all-left and all-right component choices are distinct when the
admissible forest has at least one component. -/
private theorem forestComponentAllLeftChoice_ne_allRightChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (hAne : A.IsNonempty) :
    forestComponentAllLeftChoice A ≠ forestComponentAllRightChoice A := by
  intro h
  rcases hAne with ⟨γ, hγ⟩
  have hmem : (⟨γ, hγ⟩ : {γ : FeynmanSubgraph G // γ ∈ A.elements}) ∈
      A.elements.attach := by
    exact Finset.mem_attach A.elements _
  have hval := congrFun (congrFun h ⟨γ, hγ⟩) hmem
  unfold forestComponentAllLeftChoice forestComponentAllRightChoice at hval
  cases hval

/-- The component-choice carrier is the two boundary choices plus the
non-boundary core carrier. -/
private theorem forestComponentChoiceIndex_eq_insert_boundaries
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    A.elements.attach.pi (forestComponentChoiceIndex A) =
      insert (forestComponentAllLeftChoice A)
        (insert (forestComponentAllRightChoice A)
          (forestComponentCoreChoiceIndex A)) := by
  classical
  ext p
  unfold forestComponentCoreChoiceIndex
  simp only [Finset.mem_insert, Finset.mem_filter]
  constructor
  · intro hp
    by_cases hLeft : p = forestComponentAllLeftChoice A
    · exact Or.inl hLeft
    · by_cases hRight : p = forestComponentAllRightChoice A
      · exact Or.inr (Or.inl hRight)
      · exact Or.inr (Or.inr ⟨hp, ⟨hLeft, hRight⟩⟩)
  · intro hp
    rcases hp with hLeft | hRest
    · rw [hLeft]
      exact forestComponentAllLeftChoice_mem A
    · rcases hRest with hRight | hCore
      · rw [hRight]
        exact forestComponentAllRightChoice_mem A
      · exact hCore.1

/-- Inner component-choice sums split into the all-left boundary, the
all-right boundary, and the non-boundary component-choice core. -/
private theorem forestComponentChoice_inner_sum_eq_boundaries_add_core
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) (hAne : A.IsNonempty)
    (right : HopfH) :
    (∑ p ∈ A.elements.attach.pi (forestComponentChoiceIndex A),
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ] right)) =
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((forestComponentChoiceProductTerm A
          (forestComponentAllLeftChoice A)) ⊗ₜ[ℚ] right)
      +
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((forestComponentChoiceProductTerm A
          (forestComponentAllRightChoice A)) ⊗ₜ[ℚ] right)
      +
      ∑ p ∈ forestComponentCoreChoiceIndex A,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ] right) := by
  classical
  rw [forestComponentChoiceIndex_eq_insert_boundaries A]
  have hne := forestComponentAllLeftChoice_ne_allRightChoice (A := A) hAne
  have hLeftNot :
      forestComponentAllLeftChoice A ∉
        insert (forestComponentAllRightChoice A)
          (forestComponentCoreChoiceIndex A) := by
    intro hmem
    rw [Finset.mem_insert] at hmem
    rcases hmem with hEq | hCore
    · exact hne hEq
    · unfold forestComponentCoreChoiceIndex at hCore
      exact (Finset.mem_filter.mp hCore).2.1 rfl
  have hRightNot :
      forestComponentAllRightChoice A ∉ forestComponentCoreChoiceIndex A := by
    intro hCore
    unfold forestComponentCoreChoiceIndex at hCore
    exact (Finset.mem_filter.mp hCore).2.2 rfl
  rw [Finset.sum_insert hLeftNot]
  rw [Finset.sum_insert hRightNot]
  abel

/-- Membership in the proper disjoint admissible forest carrier includes
nonemptiness of the component carrier. -/
private theorem properDisjointAdmissibleDivergentSubgraphs_isNonempty
    {G : FeynmanGraph} [DivergenceMeasure G] [Fintype (FeynmanSubgraph G)]
    {A : AdmissibleSubgraph G}
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs) :
    A.IsNonempty := by
  have hNonempty :
      A ∈ G.nonemptyDisjointAdmissibleDivergentSubgraphs :=
    ((G.mem_properDisjointAdmissibleDivergentSubgraphs A).mp hA).1
  exact ((G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs A).mp hNonempty).2

/-- Uniform component-factor rewrite, including the non-member case. -/
private theorem coproduct_strict_forest_componentToHopfH
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) (γ : FeynmanSubgraph G) :
    coproduct_strict_forest (A.componentToHopfH γ) =
      forestComponentCoproductFactor A γ := by
  unfold forestComponentCoproductFactor AdmissibleSubgraph.componentToHopfH
  by_cases hγ : γ ∈ A.elements
  · rw [dif_pos hγ, dif_pos hγ]
    unfold gen
    rw [coproduct_strict_forest_X]
  · rw [dif_neg hγ, dif_neg hγ, map_one]

/-- Product expansion of `Δ_forest(A.toHopfH)` with each factor already
rewritten to the component generator formula. -/
private theorem coproduct_strict_forest_admissible_toHopfH_components
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :
    coproduct_strict_forest A.toHopfH =
      ∏ γ ∈ A.elements, forestComponentCoproductFactor A γ := by
  rw [coproduct_strict_forest_admissible_toHopfH A]
  apply Finset.prod_congr rfl
  intro γ _hγ
  rw [coproduct_strict_forest_componentToHopfH A γ]

/-- `forestTermE` after only the multiplicativity expansion of
`Δ_forest(A.toHopfH)`. -/
private noncomputable def forestTermEComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        (((∏ γ ∈ A.elements,
            coproduct_strict_forest (A.componentToHopfH γ)) :
            HopfH ⊗[ℚ] HopfH) ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- First expansion of the main left aggregate: push `Δ_forest` through the
component product defining `A.toHopfH`. -/
private theorem forestTermE_eq_components
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermE g = forestTermEComponents g := by
  unfold forestTermE forestTermEComponents
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [coproduct_strict_forest_admissible_toHopfH A]
  · rw [dif_neg hA, dif_neg hA]

/-- `forestTermE` after rewriting each component product factor to the
forest coproduct of the corresponding connected-divergent generator. -/
private noncomputable def forestTermEComponentGenerators
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        (((∏ γ ∈ A.elements, forestComponentCoproductFactor A γ) :
            HopfH ⊗[ℚ] HopfH) ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- Second expansion of the main left aggregate: each product factor is now
the forest generator coproduct for one component. -/
private theorem forestTermE_eq_componentGenerators
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermE g = forestTermEComponentGenerators g := by
  rw [forestTermE_eq_components]
  unfold forestTermEComponents forestTermEComponentGenerators
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    have hProd : (∏ γ ∈ A.elements,
        coproduct_strict_forest (A.componentToHopfH γ)) =
        ∏ γ ∈ A.elements, forestComponentCoproductFactor A γ := by
      apply Finset.prod_congr rfl
      intro γ _hγ
      rw [coproduct_strict_forest_componentToHopfH A γ]
    rw [hProd]
  · rw [dif_neg hA, dif_neg hA]

/-- `forestTermEComponentGenerators` after expanding each component product
into a `Finset.pi` over generator-level left/right/forest choices. -/
private noncomputable def forestTermEComponentChoices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        (((∑ p ∈ A.elements.attach.pi (forestComponentChoiceIndex A),
            ∏ γ ∈ A.elements.attach.attach,
              forestCoproductChoiceTerm
                (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
                (p γ.1 γ.2)) : HopfH ⊗[ℚ] HopfH)
          ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- Distributed form of `forestTermEComponentChoices`, with the component
choice function `p` exposed as the inner summation index. -/
private noncomputable def forestTermEComponentChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ p ∈ A.elements.attach.pi (forestComponentChoiceIndex A),
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
            forestRightHopfH g A hA)
    else 0

/-- Distribute the outer tensor and associator across the component-choice
sum on the left core. -/
private theorem forestTermEComponentChoices_eq_distributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentChoices g =
      forestTermEComponentChoicesDistributed g := by
  unfold forestTermEComponentChoices forestTermEComponentChoicesDistributed
    forestComponentChoiceProductTerm
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    simp only [TensorProduct.sum_tmul, map_sum]
  · rw [dif_neg hA, dif_neg hA]

/-- Push the product-of-sums expansion through the left aggregate without
yet distributing the outer tensor/associator. -/
private theorem forestTermEComponentGenerators_eq_choices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentGenerators g = forestTermEComponentChoices g := by
  unfold forestTermEComponentGenerators forestTermEComponentChoices
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [forestComponentCoproductFactor_prod_eq_choicePi A]
  · rw [dif_neg hA, dif_neg hA]

/-- `forestTermF` with the quotient Hopf generator's coproduct exposed at
the generator-formula level. -/
private noncomputable def forestTermFQuotientGenerators
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      A.toHopfH ⊗ₜ[ℚ]
        coproductGenClass_strict_forest
          (FeynmanGraph.admissibleForestRightWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
    else 0

/-- The forest quotient right factor is a generator, so applying
`Δ_forest` to it reduces to `coproductGenClass_strict_forest`. -/
private theorem coproduct_strict_forest_forestRightHopfH
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs) :
    coproduct_strict_forest (forestRightHopfH g A hA) =
      coproductGenClass_strict_forest
        (FeynmanGraph.admissibleForestRightWithCanonicalStars
          (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) := by
  unfold forestRightHopfH gen
  rw [coproduct_strict_forest_X]

/-- Rewrite `forestTermF` with the quotient coproduct exposed as a generator
formula. -/
private theorem forestTermF_eq_quotientGenerators
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermF g = forestTermFQuotientGenerators g := by
  unfold forestTermF forestTermFQuotientGenerators
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [coproduct_strict_forest_forestRightHopfH g A hA]
  · rw [dif_neg hA, dif_neg hA]

/-- `forestTermFQuotientGenerators` with the quotient generator coproduct
expanded over the same explicit three-way choice carrier. -/
private noncomputable def forestTermFQuotientChoices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      A.toHopfH ⊗ₜ[ℚ]
        (∑ c ∈ forestCoproductChoiceIndex
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA),
          forestCoproductChoiceTerm
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) c)
    else 0

/-- Distributed form of `forestTermFQuotientChoices`, with the quotient
generator choice `c` exposed as the inner summation index. -/
private noncomputable def forestTermFQuotientChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ c ∈ forestCoproductChoiceIndex
          (FeynmanGraph.admissibleForestRightWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA),
        A.toHopfH ⊗ₜ[ℚ]
          forestCoproductChoiceTerm
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) c
    else 0

/-- Distribute the left tensor factor across the quotient-choice sum on the
right core. -/
private theorem forestTermFQuotientChoices_eq_distributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermFQuotientChoices g =
      forestTermFQuotientChoicesDistributed g := by
  unfold forestTermFQuotientChoices forestTermFQuotientChoicesDistributed
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    simp only [TensorProduct.tmul_sum]
  · rw [dif_neg hA, dif_neg hA]

/-- The `left` choice in the quotient generator coproduct is exactly the
`forestTermC` boundary. -/
private theorem forestTermFQuotient_leftChoice_eq_C
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (∑ A ∈ forestCoproductProperForestIndex g,
      if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
        A.toHopfH ⊗ₜ[ℚ]
          forestCoproductChoiceTerm
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
            forestCoproductChoice.left
      else 0) =
      forestTermC g := by
  unfold forestTermC forestCoproductChoiceTerm forestRightHopfH gen
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · simp [hA]
  · simp [hA]

/-- Push the generator-level choice expansion through the right quotient
aggregate, without yet distributing the left tensor factor. -/
private theorem forestTermFQuotientGenerators_eq_choices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermFQuotientGenerators g = forestTermFQuotientChoices g := by
  unfold forestTermFQuotientGenerators forestTermFQuotientChoices
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [coproductGenClass_strict_forest_eq_choiceSum]
  · rw [dif_neg hA, dif_neg hA]

/-- Forest analogue of the old `termE1`: the all-left boundary choice in
`Δ_forest(A.toHopfH)`, tensored with `[Γ/A]`. -/
private noncomputable def forestTermE1
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      A.toHopfH ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] forestRightHopfH g A hA)
    else 0

/-- The `right` choice in the quotient generator coproduct is exactly the
`forestTermE1` boundary. -/
private theorem forestTermFQuotient_rightChoice_eq_E1
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (∑ A ∈ forestCoproductProperForestIndex g,
      if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
        A.toHopfH ⊗ₜ[ℚ]
          forestCoproductChoiceTerm
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
            forestCoproductChoice.right
      else 0) =
      forestTermE1 g := by
  unfold forestTermE1 forestCoproductChoiceTerm forestRightHopfH gen
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · simp [hA]
  · simp [hA]

/-- The distributed RHS core after removing the quotient generator's left and
right boundary choices. -/
private noncomputable def forestTermFQuotientForestChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ c ∈ forestCoproductForestChoiceIndex
          (FeynmanGraph.admissibleForestRightWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA),
        A.toHopfH ⊗ₜ[ℚ]
          forestCoproductChoiceTerm
            (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) c
    else 0

/-- RHS genuine forest-choice core with the image over
`forestCoproductChoice.forest` removed.  This exposes the quotient-side
admissible forest `B` as an ordinary inner summation index. -/
private noncomputable def forestTermFQuotientForestChoicesExpanded
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ B ∈ forestCoproductProperForestIndex
          (FeynmanGraph.admissibleForestRightWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA),
        A.toHopfH ⊗ₜ[ℚ]
          FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            (repG (FeynmanGraph.admissibleForestRightWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)).toFeynmanGraph
            (forestCanonicalHCD
              (FeynmanGraph.admissibleForestRightWithCanonicalStars
                (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA))
            B
    else 0

/-- Remove the `forestCoproductChoice.forest` image wrapper from the RHS
genuine forest-choice core. -/
private theorem forestTermFQuotientForestChoicesDistributed_eq_expanded
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermFQuotientForestChoicesDistributed g =
      forestTermFQuotientForestChoicesExpanded g := by
  unfold forestTermFQuotientForestChoicesDistributed
    forestTermFQuotientForestChoicesExpanded
  apply Finset.sum_congr rfl
  intro A _hAouter
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [forestCoproductForestChoiceIndex_sum]
    apply Finset.sum_congr rfl
    intro B _hB
    unfold forestCoproductChoiceTerm
    rfl
  · rw [dif_neg hA, dif_neg hA]

/-- The fully distributed RHS quotient-choice sum is its two boundary slices
plus the genuine forest-choice core. -/
private theorem forestTermFQuotientChoicesDistributed_eq_boundaries_add_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermFQuotientChoicesDistributed g =
      forestTermC g + forestTermE1 g +
        forestTermFQuotientForestChoicesDistributed g := by
  calc
    forestTermFQuotientChoicesDistributed g
        = ∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              A.toHopfH ⊗ₜ[ℚ]
                forestCoproductChoiceTerm
                  (FeynmanGraph.admissibleForestRightWithCanonicalStars
                    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
                  forestCoproductChoice.left
              +
              A.toHopfH ⊗ₜ[ℚ]
                forestCoproductChoiceTerm
                  (FeynmanGraph.admissibleForestRightWithCanonicalStars
                    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
                  forestCoproductChoice.right
              +
              ∑ c ∈ forestCoproductForestChoiceIndex
                  (FeynmanGraph.admissibleForestRightWithCanonicalStars
                    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA),
                A.toHopfH ⊗ₜ[ℚ]
                  forestCoproductChoiceTerm
                    (FeynmanGraph.admissibleForestRightWithCanonicalStars
                      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) c
            else 0 := by
          unfold forestTermFQuotientChoicesDistributed
          apply Finset.sum_congr rfl
          intro A _hAouter
          by_cases hA :
              A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
          · simpa [hA] using
              forestCoproductChoice_inner_sum_eq_boundaries_add_forest
                (FeynmanGraph.admissibleForestRightWithCanonicalStars
                  (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
                (fun c => A.toHopfH ⊗ₜ[ℚ]
                  forestCoproductChoiceTerm
                    (FeynmanGraph.admissibleForestRightWithCanonicalStars
                      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA) c)
          · simp [hA]
    _ = (∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              A.toHopfH ⊗ₜ[ℚ]
                forestCoproductChoiceTerm
                  (FeynmanGraph.admissibleForestRightWithCanonicalStars
                    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
                  forestCoproductChoice.left
            else 0)
          +
          (∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              A.toHopfH ⊗ₜ[ℚ]
                forestCoproductChoiceTerm
                  (FeynmanGraph.admissibleForestRightWithCanonicalStars
                    (repG g).toFeynmanGraph (forestCanonicalHCD g) A hA)
                  forestCoproductChoice.right
            else 0)
          +
          forestTermFQuotientForestChoicesDistributed g := by
          unfold forestTermFQuotientForestChoicesDistributed
          rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
          apply Finset.sum_congr rfl
          intro A _hAouter
          by_cases hA :
              A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
          · rw [dif_pos hA, dif_pos hA, dif_pos hA, dif_pos hA]
          · rw [dif_neg hA, dif_neg hA, dif_neg hA, dif_neg hA]
            simp
    _ = forestTermC g + forestTermE1 g +
          forestTermFQuotientForestChoicesDistributed g := by
          rw [forestTermFQuotient_leftChoice_eq_C g,
            forestTermFQuotient_rightChoice_eq_E1 g]

/-- The all-left component-choice slice on the LHS is exactly
`forestTermE1`. -/
private theorem forestTermEComponent_allLeftChoice_eq_E1
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (∑ A ∈ forestCoproductProperForestIndex g,
      if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A
            (forestComponentAllLeftChoice A)) ⊗ₜ[ℚ]
              forestRightHopfH g A hA)
      else 0) =
      forestTermE1 g := by
  unfold forestTermE1
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [forestComponentChoiceProductTerm_allLeft A]
    exact Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
      (A := HopfH) (C := HopfH) (D := HopfH) _ _ _
  · rw [dif_neg hA, dif_neg hA]

/-- The all-right component-choice slice on the LHS is exactly
`forestTermE2`. -/
private theorem forestTermEComponent_allRightChoice_eq_E2
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (∑ A ∈ forestCoproductProperForestIndex g,
      if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A
            (forestComponentAllRightChoice A)) ⊗ₜ[ℚ]
              forestRightHopfH g A hA)
      else 0) =
      forestTermE2 g := by
  unfold forestTermE2
  apply Finset.sum_congr rfl
  intro A _
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA]
    rw [forestComponentChoiceProductTerm_allRight A]
    exact Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
      (A := HopfH) (C := HopfH) (D := HopfH) _ _ _
  · rw [dif_neg hA, dif_neg hA]

/-- The distributed LHS core after removing the all-left and all-right
component-choice boundary slices. -/
private noncomputable def forestTermEComponentCoreChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ p ∈ forestComponentCoreChoiceIndex A,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
            forestRightHopfH g A hA)
    else 0

/-- The part of the component-choice core where some component uses a genuine
forest summand. -/
private noncomputable def forestComponentForestChoiceCoreIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :=
  by
  classical
  exact
  (forestComponentCoreChoiceIndex A).filter
    (fun p => forestComponentChoiceHasForest A p)

/-- The part of the component-choice core with no genuine forest summand.  By
`forestComponentCoreChoice_has_forest_or_mixed_boundary`, this is the mixed
left/right boundary regime. -/
private noncomputable def forestComponentMixedBoundaryChoiceCoreIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) :=
  by
  classical
  exact
  (forestComponentCoreChoiceIndex A).filter
    (fun p => ¬ forestComponentChoiceHasForest A p)

/-- LHS core terms whose component-choice function contains a genuine forest
choice. -/
private noncomputable def forestTermEComponentForestChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ p ∈ forestComponentForestChoiceCoreIndex A,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
            forestRightHopfH g A hA)
    else 0

/-- LHS core terms whose component-choice function contains no genuine forest
choice, hence is a mixed left/right boundary choice. -/
private noncomputable def forestTermEComponentMixedBoundaryChoicesDistributed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ A ∈ forestCoproductProperForestIndex g,
    if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
      ∑ p ∈ forestComponentMixedBoundaryChoiceCoreIndex A,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
            forestRightHopfH g A hA)
    else 0

/-- Split the exposed LHS core into the genuine-forest-choice regime and the
mixed left/right boundary regime. -/
private theorem forestTermEComponentCoreChoicesDistributed_eq_forest_add_mixed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentCoreChoicesDistributed g =
      forestTermEComponentForestChoicesDistributed g +
        forestTermEComponentMixedBoundaryChoicesDistributed g := by
  classical
  unfold forestTermEComponentCoreChoicesDistributed
    forestTermEComponentForestChoicesDistributed
    forestTermEComponentMixedBoundaryChoicesDistributed
    forestComponentForestChoiceCoreIndex
    forestComponentMixedBoundaryChoiceCoreIndex
  rw [← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro A _hAouter
  by_cases hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
  · rw [dif_pos hA, dif_pos hA, dif_pos hA]
    exact (Finset.sum_filter_add_sum_filter_not
      (forestComponentCoreChoiceIndex A)
      (fun p => forestComponentChoiceHasForest A p)
      (fun p =>
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
            forestRightHopfH g A hA))).symm
  · simp [hA]

/-- The fully distributed LHS choice sum is its two boundary slices plus the
component-choice core. -/
private theorem forestTermEComponentChoicesDistributed_eq_boundaries_add_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentChoicesDistributed g =
      forestTermE1 g + forestTermE2 g +
        forestTermEComponentCoreChoicesDistributed g := by
  calc
    forestTermEComponentChoicesDistributed g
        = ∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                  ((forestComponentChoiceProductTerm A
                    (forestComponentAllLeftChoice A)) ⊗ₜ[ℚ]
                      forestRightHopfH g A hA)
              +
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                  ((forestComponentChoiceProductTerm A
                    (forestComponentAllRightChoice A)) ⊗ₜ[ℚ]
                      forestRightHopfH g A hA)
              +
              ∑ p ∈ forestComponentCoreChoiceIndex A,
                (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                  ((forestComponentChoiceProductTerm A p) ⊗ₜ[ℚ]
                    forestRightHopfH g A hA)
            else 0 := by
          unfold forestTermEComponentChoicesDistributed
          apply Finset.sum_congr rfl
          intro A _hAouter
          by_cases hA :
              A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
          · simpa [hA] using
              forestComponentChoice_inner_sum_eq_boundaries_add_core A
              (properDisjointAdmissibleDivergentSubgraphs_isNonempty hA)
              (forestRightHopfH g A hA)
          · simp [hA]
    _ = (∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                ((forestComponentChoiceProductTerm A
                  (forestComponentAllLeftChoice A)) ⊗ₜ[ℚ]
                    forestRightHopfH g A hA)
            else 0)
          +
          (∑ A ∈ forestCoproductProperForestIndex g,
            if hA : A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs then
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                ((forestComponentChoiceProductTerm A
                  (forestComponentAllRightChoice A)) ⊗ₜ[ℚ]
                    forestRightHopfH g A hA)
            else 0)
          +
          forestTermEComponentCoreChoicesDistributed g := by
          unfold forestTermEComponentCoreChoicesDistributed
          rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
          apply Finset.sum_congr rfl
          intro A _hAouter
          by_cases hA :
              A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs
          · rw [dif_pos hA, dif_pos hA, dif_pos hA, dif_pos hA]
          · rw [dif_neg hA, dif_neg hA, dif_neg hA, dif_neg hA]
            simp
    _ = forestTermE1 g + forestTermE2 g +
          forestTermEComponentCoreChoicesDistributed g := by
          rw [forestTermEComponent_allLeftChoice_eq_E1 g,
            forestTermEComponent_allRightChoice_eq_E2 g]

/-- The non-boundary part of `forestTermE`. It will be compared with the
non-boundary part of `forestTermF`. -/
private noncomputable def forestTermE3
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  forestTermE g - forestTermE1 g - forestTermE2 g

/-- The non-boundary part of `forestTermF`. Its boundary terms are
`forestTermC` and `forestTermE1`. -/
private noncomputable def forestTermF3
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  forestTermF g - forestTermC g - forestTermE1 g

/-- Algebraic split of `forestTermE` into two boundary pieces and the core. -/
private theorem forestTermE_eq_boundaries_add_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermE g = forestTermE1 g + forestTermE2 g + forestTermE3 g := by
  unfold forestTermE3
  abel

/-- Algebraic split of `forestTermF` into two boundary pieces and the core. -/
private theorem forestTermF_eq_boundaries_add_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermF g = forestTermC g + forestTermE1 g + forestTermF3 g := by
  unfold forestTermF3
  abel

/-- After boundary cancellation, the main forest identity is reduced to the
core equality `forestTermE3 = forestTermF3`. -/
private theorem coassoc_forest_main_terms_of_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hCore : forestTermE3 g = forestTermF3 g) :
    forestTermC g + forestTermE g = forestTermE2 g + forestTermF g := by
  rw [forestTermE_eq_boundaries_add_core g,
    forestTermF_eq_boundaries_add_core g, hCore]
  abel

/-- The left core with `Δ_forest(A.toHopfH)` expanded through the component
product. -/
private theorem forestTermE3_eq_componentGenerators_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermE3 g =
      forestTermEComponentGenerators g - forestTermE1 g - forestTermE2 g := by
  unfold forestTermE3
  rw [forestTermE_eq_componentGenerators]

/-- The right core with the quotient generator coproduct exposed. -/
private theorem forestTermF3_eq_quotientGenerators_core
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermF3 g =
      forestTermFQuotientGenerators g - forestTermC g - forestTermE1 g := by
  unfold forestTermF3
  rw [forestTermF_eq_quotientGenerators]

/-- Forest LHS one-step expansion.  The still-unexpanded aggregate is
`forestTermE`, where `Δ_forest` is applied to the product `A.toHopfH`. -/
private theorem coassoc_forest_LHS_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH))
          (coproduct_strict_forest (MvPolynomial.X g))) =
      forestTermA g + forestTermB g + forestTermC g + forestTermD g + forestTermE g := by
  rw [coproduct_strict_forest_X_eq g]
  simp only [map_add, Algebra.TensorProduct.map_tmul, AlgHom.coe_id, id_eq,
    map_one, map_sum]
  rw [coproduct_strict_forest_X_eq g]
  simp only [TensorProduct.add_tmul, TensorProduct.sum_tmul, map_add, map_sum]
  rw [show ((1 : HopfH ⊗[ℚ] HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
        = ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH) from by
      rw [Algebra.TensorProduct.one_def]]
  rw [show (∑ A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A) ⊗ₜ[ℚ] (1 : HopfH))) =
        forestTermC g from ?cEq]
  case cEq =>
    unfold forestTermC forestRightHopfH forestCoproductProperForestIndex
    apply Finset.sum_congr rfl
    intro A hA
    have hAProper :
        A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
      (Finset.mem_filter.mp hA).1
    rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hAProper]
    rw [dif_pos hAProper]
    exact Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
      (A := HopfH) (C := HopfH) (D := HopfH) _ _ _
  rw [show (∑ A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH))
            (FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
              (repG g).toFeynmanGraph (forestCanonicalHCD g) A))) =
        forestTermE g from ?eEq]
  case eEq =>
    unfold forestTermE forestRightHopfH forestCoproductProperForestIndex
    apply Finset.sum_congr rfl
    intro A hA
    have hAProper :
        A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
      (Finset.mem_filter.mp hA).1
    rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hAProper]
    rw [dif_pos hAProper]
    simp [Algebra.TensorProduct.map_tmul]
  unfold forestTermA forestTermB forestTermD
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) =
      (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) =
      (1 : HopfH) ⊗ₜ[ℚ] ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH)) =
      (1 : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]

/-- Forest RHS one-step expansion.  The still-unexpanded aggregate is
`forestTermF`, where `Δ_forest` is applied to the canonical quotient
generator `[Γ/A]`. -/
private theorem coassoc_forest_RHS_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest)
        (coproduct_strict_forest (MvPolynomial.X g)) =
      forestTermA g + forestTermB g + forestTermD g + forestTermE2 g + forestTermF g := by
  rw [coproduct_strict_forest_X_eq g]
  simp only [map_add, Algebra.TensorProduct.map_tmul, AlgHom.coe_id, id_eq,
    map_one, map_sum]
  rw [coproduct_strict_forest_X_eq g]
  simp only [TensorProduct.tmul_add, TensorProduct.tmul_sum]
  rw [show ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH ⊗[ℚ] HopfH))
        = (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) from by
      rw [Algebra.TensorProduct.one_def]]
  rw [show (∑ A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
        ((1 : HopfH) ⊗ₜ[ℚ]
          FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A)) =
        forestTermE2 g from ?e2Eq]
  case e2Eq =>
    unfold forestTermE2 forestRightHopfH forestCoproductProperForestIndex
    apply Finset.sum_congr rfl
    intro A hA
    have hAProper :
        A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
      (Finset.mem_filter.mp hA).1
    rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hAProper]
    rw [dif_pos hAProper]
  rw [show (∑ A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs.filter
          (fun A => 0 < A.complementEdges.card),
        (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest)
          (FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
            (repG g).toFeynmanGraph (forestCanonicalHCD g) A)) =
        forestTermF g from ?fEq]
  case fEq =>
    unfold forestTermF forestRightHopfH forestCoproductProperForestIndex
    apply Finset.sum_congr rfl
    intro A hA
    have hAProper :
        A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
      (Finset.mem_filter.mp hA).1
    rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
      (repG g).toFeynmanGraph (forestCanonicalHCD g) A hAProper]
    rw [dif_pos hAProper]
    simp [Algebra.TensorProduct.map_tmul]
  unfold forestTermA forestTermB forestTermD
  abel

/-- Forest generator coassociativity after the pure boundary terms have been
cancelled.  This is the main H5.8 combinatorial target. -/
private theorem coassoc_forest_X_of_main_terms
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hMain : forestTermC g + forestTermE g = forestTermE2 g + forestTermF g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((Algebra.TensorProduct.map coproduct_strict_forest (AlgHom.id ℚ HopfH))
          (coproduct_strict_forest (MvPolynomial.X g))) =
      (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict_forest)
        (coproduct_strict_forest (MvPolynomial.X g)) := by
  rw [coassoc_forest_LHS_eq g, coassoc_forest_RHS_eq g]
  calc
    forestTermA g + forestTermB g + forestTermC g + forestTermD g + forestTermE g
        = (forestTermC g + forestTermE g)
            + (forestTermA g + forestTermB g + forestTermD g) := by
          abel
    _ = (forestTermE2 g + forestTermF g)
            + (forestTermA g + forestTermB g + forestTermD g) := by
          rw [hMain]
    _ = forestTermA g + forestTermB g + forestTermD g + forestTermE2 g + forestTermF g := by
          abel

/-- Forest LinearMap coassociativity reduced to the main forest identity on
each generator. -/
private theorem coassoc_strict_forest_linear_of_main_terms
    [IsDivergencePreservedByAdmissibleForestContract]
    (hMain : ∀ g : HopfGen,
      forestTermC g + forestTermE g = forestTermE2 g + forestTermF g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_generators
    (fun g => coassoc_forest_X_of_main_terms g (hMain g))

/-- H5.8F now reduces to the core forest identity on each generator. -/
private theorem coassoc_strict_forest_linear_of_core_terms
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen, forestTermE3 g = forestTermF3 g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_main_terms
    (fun g => coassoc_forest_main_terms_of_core g (hCore g))

/-- Final algebraic cut before the real forest combinatorics: it is enough
to compare the component-expanded left core with the quotient-expanded right
core. -/
private theorem coassoc_strict_forest_linear_of_expanded_core
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentGenerators g - forestTermE1 g - forestTermE2 g =
        forestTermFQuotientGenerators g - forestTermC g - forestTermE1 g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_core_terms
    (fun g => by
      rw [forestTermE3_eq_componentGenerators_core g,
        forestTermF3_eq_quotientGenerators_core g]
      exact hCore g)

/-- Additive form of the expanded core target.  This is the cleaner shape
for the remaining forest combinatorics: component-expanded left terms plus
the quotient-left boundary equal quotient-expanded right terms plus the
component-right boundary. -/
private theorem coassoc_strict_forest_linear_of_expanded_core_add
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentGenerators g + forestTermC g =
        forestTermFQuotientGenerators g + forestTermE2 g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_expanded_core
    (fun g => by
      have h := hCore g
      calc
        forestTermEComponentGenerators g - forestTermE1 g - forestTermE2 g
            = (forestTermEComponentGenerators g + forestTermC g)
                - forestTermC g - forestTermE1 g - forestTermE2 g := by
              abel
        _ = (forestTermFQuotientGenerators g + forestTermE2 g)
                - forestTermC g - forestTermE1 g - forestTermE2 g := by
              rw [h]
        _ = forestTermFQuotientGenerators g - forestTermC g - forestTermE1 g := by
              abel)

/-- Choice-expanded additive core target.  Both sides now expose their
generator-level coproduct choices; the remaining H5.8F work is the
combinatorial alignment between component-wise choices and quotient choices,
with the two boundary slices already isolated. -/
private theorem coassoc_strict_forest_linear_of_choice_core_add
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentChoices g + forestTermC g =
        forestTermFQuotientChoices g + forestTermE2 g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_expanded_core_add
    (fun g => by
      rw [forestTermEComponentGenerators_eq_choices g,
        forestTermFQuotientGenerators_eq_choices g]
      exact hCore g)

/-- Fully distributed choice-core target.  The remaining work can now reason
term-by-term over an admissible forest `A`, a component-choice function `p`,
and a quotient choice `c`. -/
private theorem coassoc_strict_forest_linear_of_distributed_choice_core_add
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentChoicesDistributed g + forestTermC g =
        forestTermFQuotientChoicesDistributed g + forestTermE2 g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_choice_core_add
    (fun g => by
      rw [forestTermEComponentChoices_eq_distributed g,
        forestTermFQuotientChoices_eq_distributed g]
      exact hCore g)

/-- Final exposed forest-core cut: after the left and right boundary choices
are removed from the fully distributed target, H5.8F only needs the genuine
component-choice core to match the genuine quotient forest-choice core. -/
private theorem coassoc_strict_forest_linear_of_distributed_forest_core
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentCoreChoicesDistributed g =
        forestTermFQuotientForestChoicesDistributed g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_distributed_choice_core_add
    (fun g => by
      rw [forestTermEComponentChoicesDistributed_eq_boundaries_add_core g,
        forestTermFQuotientChoicesDistributed_eq_boundaries_add_core g,
        hCore g]
      abel)

/-- Same final core cut, with the RHS image over
`forestCoproductChoice.forest` already removed into an explicit quotient
forest index. -/
private theorem coassoc_strict_forest_linear_of_expanded_quotient_forest_core
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentCoreChoicesDistributed g =
        forestTermFQuotientForestChoicesExpanded g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_distributed_forest_core
    (fun g => by
      rw [forestTermFQuotientForestChoicesDistributed_eq_expanded g]
      exact hCore g)

/-- Split-regime final core cut: it is enough to match the RHS explicit
quotient forest double-sum with the sum of the LHS genuine-forest-choice
regime and the LHS mixed left/right boundary regime. -/
private theorem coassoc_strict_forest_linear_of_split_component_core
    [IsDivergencePreservedByAdmissibleForestContract]
    (hCore : ∀ g : HopfGen,
      forestTermEComponentForestChoicesDistributed g +
          forestTermEComponentMixedBoundaryChoicesDistributed g =
        forestTermFQuotientForestChoicesExpanded g) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_expanded_quotient_forest_core
    (fun g => by
      rw [forestTermEComponentCoreChoicesDistributed_eq_forest_add_mixed g]
      exact hCore g)

/-! ### Stage 3F-h — flat forest-core reindexing interface

The remaining H5.8F identity is now a finite reindexing problem.  This
section flattens the LHS component-choice regimes and the RHS quotient-forest
double sum into explicit `Finset` carriers, then packages the final proof as a
single `Finset.sum_bij` cut. -/

/-- Products of pure tensor factors split componentwise. -/
private theorem tensorProduct_prod_tmul {ι : Type*} (s : Finset ι)
    (a b : ι → HopfH) :
    (∏ x ∈ s, (a x ⊗ₜ[ℚ] b x)) =
      (∏ x ∈ s, a x) ⊗ₜ[ℚ] (∏ x ∈ s, b x) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      simp [Algebra.TensorProduct.one_def]
  | insert x s hx ih =>
      simp [Finset.prod_insert hx, ih, Algebra.TensorProduct.tmul_mul_tmul]

/-- The first tensor factor contributed by one component-level coproduct
choice.  Genuine forest choices contribute the selected component forest
product. -/
private noncomputable def forestComponentChoiceOuterTensorFactor
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)))
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) : HopfH :=
  match p γ hγ with
  | forestCoproductChoice.left =>
      MvPolynomial.X (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))
  | forestCoproductChoice.right => 1
  | forestCoproductChoice.forest B => B.toHopfH

/-- The second tensor factor contributed by one component-level coproduct
choice.  Genuine forest choices contribute the contracted right generator of
the selected component forest. -/
private noncomputable def forestComponentChoiceInnerTensorFactorOfCore
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)))
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) : HopfH :=
  if p γ hγ = forestCoproductChoice.left then
    1
  else if p γ hγ = forestCoproductChoice.right then
    MvPolynomial.X (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))
  else
    match p γ hγ with
    | forestCoproductChoice.left => 1
    | forestCoproductChoice.right =>
      MvPolynomial.X (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))
    | forestCoproductChoice.forest B =>
      if hB :
          B ∈ ((repG (γ.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          ).properDisjointAdmissibleDivergentSubgraphs then
        forestRightHopfH
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B hB
      else
        1

/-- Pointwise two-factor form of a core component choice term, including the
genuine forest case. -/
private theorem forestCoproductChoiceTerm_eq_outer_inner_of_core
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)))
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) :
    forestCoproductChoiceTerm
        (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))
        (p γ hγ) =
      forestComponentChoiceOuterTensorFactor A p γ hγ ⊗ₜ[ℚ]
        forestComponentChoiceInnerTensorFactorOfCore A p hp γ hγ := by
  classical
  cases hChoice : p γ hγ with
  | left =>
      rw [forestCoproductChoiceTerm]
      have hOuter :
          forestComponentChoiceOuterTensorFactor A p γ hγ =
            MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) := by
        unfold forestComponentChoiceOuterTensorFactor
        rw [hChoice]
      have hInner :
          forestComponentChoiceInnerTensorFactorOfCore A p hp γ hγ = 1 := by
        simpa [forestComponentChoiceInnerTensorFactorOfCore, hChoice]
      rw [hOuter, hInner]
  | right =>
      rw [forestCoproductChoiceTerm]
      have hOuter :
          forestComponentChoiceOuterTensorFactor A p γ hγ = 1 := by
        unfold forestComponentChoiceOuterTensorFactor
        rw [hChoice]
      have hInner :
          forestComponentChoiceInnerTensorFactorOfCore A p hp γ hγ =
            MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) := by
        simpa [forestComponentChoiceInnerTensorFactorOfCore, hChoice]
      rw [hOuter, hInner]
  | forest B =>
      have hBmem :
          B ∈ ((repG (γ.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          ).properDisjointAdmissibleDivergentSubgraphs :=
        forestComponentChoice_forest_mem_properDisjoint_of_core_mem
          hp γ (by simpa using hChoice)
      rw [forestCoproductChoiceTerm]
      rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
        (repG (γ.1.toHopfGen
          (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
        (forestCanonicalHCD
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)))
        B hBmem]
      have hOuter :
          forestComponentChoiceOuterTensorFactor A p γ hγ = B.toHopfH := by
        unfold forestComponentChoiceOuterTensorFactor
        rw [hChoice]
      have hInner :
          forestComponentChoiceInnerTensorFactorOfCore A p hp γ hγ =
            forestRightHopfH
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B hBmem := by
        let hBmem' :
            B ∈ ((repG (γ.1.toHopfGen
              (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            ).properDisjointAdmissibleDivergentSubgraphs :=
          forestComponentChoice_forest_mem_properDisjoint_of_core_mem
            hp γ (by simpa using hChoice)
        have hInner' :
            forestComponentChoiceInnerTensorFactorOfCore A p hp γ hγ =
              forestRightHopfH
                (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B hBmem' := by
          simp [forestComponentChoiceInnerTensorFactorOfCore, hChoice, hBmem']
        have hProof : hBmem' = hBmem := Subsingleton.elim _ _
        simpa [hProof] using hInner'
      rw [hOuter, hInner]
      unfold forestRightHopfH
      rfl

/-- Product form of a core component choice: multiplying the pointwise
two-factor forms splits the total tensor product into the product of all
outer factors and the product of all inner factors. -/
private theorem forestComponentChoiceProductTerm_eq_outer_inner_products_of_core
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      γ ∈ A.elements.attach →
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)))
    (hp : p ∈ forestComponentCoreChoiceIndex A) :
    forestComponentChoiceProductTerm A p =
      (∏ γ ∈ A.elements.attach,
        forestComponentChoiceOuterTensorFactor A p γ
          (Finset.mem_attach A.elements γ)) ⊗ₜ[ℚ]
      (∏ γ ∈ A.elements.attach,
        forestComponentChoiceInnerTensorFactorOfCore A p hp γ
          (Finset.mem_attach A.elements γ)) := by
  classical
  unfold forestComponentChoiceProductTerm
  have hFactor :
      (∏ γ ∈ A.elements.attach.attach,
          forestCoproductChoiceTerm
            (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
            (p γ.1 γ.2)) =
        ∏ γ ∈ A.elements.attach.attach,
          (forestComponentChoiceOuterTensorFactor A p γ.1 γ.2 ⊗ₜ[ℚ]
            forestComponentChoiceInnerTensorFactorOfCore A p hp γ.1 γ.2) := by
    apply Finset.prod_congr rfl
    intro γ _hγ
    exact forestCoproductChoiceTerm_eq_outer_inner_of_core A p hp γ.1 γ.2
  rw [hFactor]
  rw [tensorProduct_prod_tmul A.elements.attach.attach
    (fun γ => forestComponentChoiceOuterTensorFactor A p γ.1 γ.2)
    (fun γ => forestComponentChoiceInnerTensorFactorOfCore A p hp γ.1 γ.2)]
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      forestComponentChoiceOuterTensorFactor A p γ
        (Finset.mem_attach A.elements γ))]
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      forestComponentChoiceInnerTensorFactorOfCore A p hp γ
        (Finset.mem_attach A.elements γ))]

/-- Proof-dependent `attach` sums match the original `dite`-guarded sums. -/
private theorem sum_attach_dite {α M : Type*} [AddCommMonoid M]
    (s : Finset α) [DecidablePred (fun a => a ∈ s)]
    (f : ∀ a : α, a ∈ s → M) :
    (∑ a ∈ s, if ha : a ∈ s then f a ha else 0) =
      ∑ a ∈ s.attach, f a.1 a.2 := by
  apply Finset.sum_bij (fun a ha => ⟨a, ha⟩)
  · intro a ha
    exact Finset.mem_attach s ⟨a, ha⟩
  · intro a₁ _ a₂ _ h
    exact congrArg Subtype.val h
  · intro a ha
    exact ⟨a.1, a.2, Subtype.ext rfl⟩
  · intro a ha
    exact dif_pos ha

/-- Dependent two-level sums over a guarded outer carrier flatten to a sigma
sum over the attached outer carrier. -/
private theorem sum_dite_sigma_attach {α M : Type*} [AddCommMonoid M]
    (s : Finset α) [DecidablePred (fun a => a ∈ s)]
    {β : α → Type*} (t : ∀ a : α, Finset (β a))
    (f : ∀ a : α, a ∈ s → β a → M) :
    (∑ a ∈ s, if ha : a ∈ s then ∑ b ∈ t a, f a ha b else 0) =
      ∑ q ∈ s.attach.sigma (fun a : {a // a ∈ s} => t a.1),
        f q.1.1 q.1.2 q.2 := by
  rw [sum_attach_dite s (fun a ha => ∑ b ∈ t a, f a ha b)]
  rw [Finset.sum_sigma']

/-- A filtered outer carrier flattens to a sigma over the filtered attached
outer carrier while the payload still receives membership in the unfiltered
carrier. -/
private theorem sum_dite_filter_sigma_attach {α M : Type*} [AddCommMonoid M]
    (s : Finset α) [DecidablePred (fun a => a ∈ s)]
    (p : α → Prop) [DecidablePred p]
    {β : α → Type*} (t : ∀ a : α, Finset (β a))
    (f : ∀ a : α, a ∈ s → β a → M) :
    (∑ a ∈ s.filter p, if ha : a ∈ s then ∑ b ∈ t a, f a ha b else 0) =
      ∑ q ∈ (s.attach.filter (fun a : {a // a ∈ s} => p a.1)).sigma
          (fun a : {a // a ∈ s} => t a.1),
        f q.1.1 q.1.2 q.2 := by
  classical
  calc
    (∑ a ∈ s.filter p, if ha : a ∈ s then ∑ b ∈ t a, f a ha b else 0)
        = ∑ a ∈ s.filter p,
            if hap : a ∈ s.filter p then
              ∑ b ∈ t a, f a (Finset.mem_filter.mp hap).1 b
            else 0 := by
          apply Finset.sum_congr rfl
          intro a ha
          rw [dif_pos (Finset.mem_filter.mp ha).1, dif_pos ha]
    _ = ∑ a ∈ (s.filter p).attach, ∑ b ∈ t a.1,
          f a.1 (Finset.mem_filter.mp a.2).1 b := by
          rw [sum_attach_dite (s.filter p)
            (fun a ha => ∑ b ∈ t a, f a (Finset.mem_filter.mp ha).1 b)]
    _ = ∑ a ∈ s.attach.filter (fun a : {a // a ∈ s} => p a.1),
          ∑ b ∈ t a.1, f a.1 a.2 b := by
          let e : {a // a ∈ s.filter p} ↪ {a // a ∈ s} :=
            (Function.Embedding.refl α).subtypeMap (by
              intro a ha
              exact (Finset.mem_filter.mp ha).1)
          rw [Finset.filter_attach]
          change
              (∑ a ∈ (s.filter p).attach, ∑ b ∈ t a.1,
                  f a.1 (Finset.mem_filter.mp a.2).1 b) =
                ∑ a ∈ (s.filter p).attach.map e, ∑ b ∈ t a.1,
                  f a.1 a.2 b
          rw [Finset.sum_map]
          apply Finset.sum_congr rfl
          intro a ha
          rfl
    _ = ∑ q ∈ (s.attach.filter (fun a : {a // a ∈ s} => p a.1)).sigma
          (fun a : {a // a ∈ s} => t a.1),
        f q.1.1 q.1.2 q.2 := by
          rw [Finset.sum_sigma']

/-- Dependent two-level sums where the inner carrier depends on the proof that
the outer index lies in the carrier also flatten to an attached sigma sum. -/
private theorem sum_dite_sigma_attach_subtype {α M : Type*} [AddCommMonoid M]
    (s : Finset α) [DecidablePred (fun a => a ∈ s)]
    {β : ∀ a : α, a ∈ s → Type*}
    (t : ∀ a : α, ∀ ha : a ∈ s, Finset (β a ha))
    (f : ∀ a : α, ∀ ha : a ∈ s, β a ha → M) :
    (∑ a ∈ s, if ha : a ∈ s then ∑ b ∈ t a ha, f a ha b else 0) =
      ∑ q ∈ s.attach.sigma (fun a : {a // a ∈ s} => t a.1 a.2),
        f q.1.1 q.1.2 q.2 := by
  rw [sum_attach_dite s (fun a ha => ∑ b ∈ t a ha, f a ha b)]
  rw [Finset.sum_sigma']

/-- Filtered variant of `sum_dite_sigma_attach_subtype`.  The outer sigma
carrier is filtered, but the payload keeps the original unfiltered membership
proof. -/
private theorem sum_dite_filter_sigma_attach_subtype
    {α M : Type*} [AddCommMonoid M]
    (s : Finset α) [DecidablePred (fun a => a ∈ s)]
    (p : α → Prop) [DecidablePred p]
    {β : ∀ a : α, a ∈ s → Type*}
    (t : ∀ a : α, ∀ ha : a ∈ s, Finset (β a ha))
    (f : ∀ a : α, ∀ ha : a ∈ s, β a ha → M) :
    (∑ a ∈ s.filter p,
      if ha : a ∈ s then ∑ b ∈ t a ha, f a ha b else 0) =
      ∑ q ∈ (s.attach.filter (fun a : {a // a ∈ s} => p a.1)).sigma
          (fun a : {a // a ∈ s} => t a.1 a.2),
        f q.1.1 q.1.2 q.2 := by
  classical
  calc
    (∑ a ∈ s.filter p,
      if ha : a ∈ s then ∑ b ∈ t a ha, f a ha b else 0)
        = ∑ a ∈ s.filter p,
            if hap : a ∈ s.filter p then
              ∑ b ∈ t a (Finset.mem_filter.mp hap).1,
                f a (Finset.mem_filter.mp hap).1 b
            else 0 := by
          apply Finset.sum_congr rfl
          intro a ha
          rw [dif_pos (Finset.mem_filter.mp ha).1, dif_pos ha]
    _ = ∑ a ∈ (s.filter p).attach,
          ∑ b ∈ t a.1 (Finset.mem_filter.mp a.2).1,
            f a.1 (Finset.mem_filter.mp a.2).1 b := by
          rw [sum_attach_dite (s.filter p)
            (fun a ha => ∑ b ∈ t a (Finset.mem_filter.mp ha).1,
              f a (Finset.mem_filter.mp ha).1 b)]
    _ = ∑ a ∈ s.attach.filter (fun a : {a // a ∈ s} => p a.1),
          ∑ b ∈ t a.1 a.2, f a.1 a.2 b := by
          let e : {a // a ∈ s.filter p} ↪ {a // a ∈ s} :=
            (Function.Embedding.refl α).subtypeMap (by
              intro a ha
              exact (Finset.mem_filter.mp ha).1)
          rw [Finset.filter_attach]
          change
              (∑ a ∈ (s.filter p).attach,
                  ∑ b ∈ t a.1 (Finset.mem_filter.mp a.2).1,
                    f a.1 (Finset.mem_filter.mp a.2).1 b) =
                ∑ a ∈ (s.filter p).attach.map e,
                  ∑ b ∈ t a.1 a.2, f a.1 a.2 b
          rw [Finset.sum_map]
          apply Finset.sum_congr rfl
          intro a ha
          rfl
    _ = ∑ q ∈ (s.attach.filter (fun a : {a // a ∈ s} => p a.1)).sigma
          (fun a : {a // a ∈ s} => t a.1 a.2),
        f q.1.1 q.1.2 q.2 := by
          rw [Finset.sum_sigma']

/-- The dependent component-choice function type for one admissible forest. -/
private abbrev forestComponentChoiceFn
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G) : Type :=
  ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
    γ ∈ A.elements.attach →
      forestCoproductChoice
        (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))

/-- Attached outer forest carrier for the representative of `g`. -/
private abbrev forestOuterProperIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) : Type :=
  {A : AdmissibleSubgraph (repG g).toFeynmanGraph //
    A ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs}

/-- The finite attached outer forest carrier for the representative of `g`. -/
private noncomputable def forestOuterProperFinset
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestOuterProperIndex g) :=
  ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs).attach

/-- Flat LHS carrier shape: an outer forest plus a component-choice function. -/
private abbrev forestComponentChoiceSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) : Type :=
  Σ A : forestOuterProperIndex g, forestComponentChoiceFn A.1

/-- Flat LHS carrier for the genuine-forest component-choice regime. -/
private noncomputable def forestComponentForestChoiceSigmaIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestComponentChoiceSigma g) :=
  ((forestOuterProperFinset g).filter
    (fun A => 0 < A.1.complementEdges.card)).sigma
    (fun A => forestComponentForestChoiceCoreIndex A.1)

/-- Flat LHS carrier for the mixed left/right boundary component-choice regime. -/
private noncomputable def forestComponentMixedBoundaryChoiceSigmaIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestComponentChoiceSigma g) :=
  ((forestOuterProperFinset g).filter
    (fun A => 0 < A.1.complementEdges.card)).sigma
    (fun A => forestComponentMixedBoundaryChoiceCoreIndex A.1)

/-- The tensor term attached to one flat LHS component-choice index. -/
private noncomputable def forestComponentChoiceSigmaTerm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
    ((forestComponentChoiceProductTerm q.1.1 q.2) ⊗ₜ[ℚ]
      forestRightHopfH g q.1.1 q.1.2)

/-- A raw subset of the components of an admissible subgraph is again an
admissible subgraph.  This is the graph-level constructor used by the final
component-choice reindexing map. -/
private def admissibleSubgraphOfSubelements
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (s : Finset (FeynmanSubgraph G))
    (hs : s ⊆ A.elements) : AdmissibleSubgraph G :=
  AdmissibleSubgraph.ofElements s
    (by
      constructor
      · intro γ hγ
        exact A.isConnectedDivergent_of_mem (hs hγ)
      · intro γ₁ hγ₁ γ₂ hγ₂ hne
        exact A.forest.nestedOrDisjoint (hs hγ₁) (hs hγ₂) hne)

@[simp] private theorem admissibleSubgraphOfSubelements_elements
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (s : Finset (FeynmanSubgraph G))
    (hs : s ⊆ A.elements) :
    (admissibleSubgraphOfSubelements A s hs).elements = s := rfl

/-- Predicate selecting the components whose generator-level choice contributes
to the left tensor factor. -/
private def forestComponentChoiceIsLeft
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (γ : FeynmanSubgraph G) : Prop :=
  if hγ : γ ∈ A.elements then
    p ⟨γ, hγ⟩ (Finset.mem_attach A.elements ⟨γ, hγ⟩) =
      forestCoproductChoice.left
  else False

/-- Predicate selecting the components whose generator-level choice contributes
to the middle tensor factor. -/
private def forestComponentChoiceIsRight
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (γ : FeynmanSubgraph G) : Prop :=
  if hγ : γ ∈ A.elements then
    p ⟨γ, hγ⟩ (Finset.mem_attach A.elements ⟨γ, hγ⟩) =
      forestCoproductChoice.right
  else False

private noncomputable instance forestComponentChoiceIsLeftDecidablePred
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    DecidablePred (forestComponentChoiceIsLeft A p) := by
  classical
  intro γ
  unfold forestComponentChoiceIsLeft
  infer_instance

private noncomputable instance forestComponentChoiceIsRightDecidablePred
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    DecidablePred (forestComponentChoiceIsRight A p) := by
  classical
  intro γ
  unfold forestComponentChoiceIsRight
  infer_instance

/-- Sprint F2i-3q-4l-actual-4m-bridge-1: predicate selecting the components
whose generator-level choice is a genuine forest summand (.forest B for some
B).  Mirrors `IsLeft`/`IsRight` ([Coassoc.lean:2557-2575]), with an existential
on the `B` payload. -/
private def forestComponentChoiceIsForest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (γ : FeynmanSubgraph G) : Prop :=
  if hγ : γ ∈ A.elements then
    ∃ B, p ⟨γ, hγ⟩ (Finset.mem_attach A.elements ⟨γ, hγ⟩) =
      forestCoproductChoice.forest B
  else False

/-- Sprint F2i-3q-4l-actual-4m-bridge-1: `IsForest` introduction from
direct `.forest B` evaluation. -/
private theorem forestComponentChoiceIsForest_of_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    {γ : FeynmanSubgraph G}
    (hγ : γ ∈ A.elements)
    {B : AdmissibleSubgraph
      (repG (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ))).toFeynmanGraph}
    (h :
      p ⟨γ, hγ⟩ (Finset.mem_attach A.elements ⟨γ, hγ⟩) =
        forestCoproductChoice.forest B) :
    forestComponentChoiceIsForest A p γ := by
  unfold forestComponentChoiceIsForest
  rw [dif_pos hγ]
  exact ⟨B, h⟩

/-- Sprint F2i-3q-4l-actual-4m-bridge-1: `IsForest` elimination — recover the
`γ ∈ A.elements` witness and a `.forest B` evaluation. -/
private theorem forestComponentChoiceIsForest_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    {γ : FeynmanSubgraph G}
    (h : forestComponentChoiceIsForest A p γ) :
    ∃ hγ : γ ∈ A.elements,
      ∃ B : AdmissibleSubgraph
        (repG (γ.toHopfGen (A.isConnectedDivergent_of_mem hγ))).toFeynmanGraph,
        p ⟨γ, hγ⟩ (Finset.mem_attach A.elements ⟨γ, hγ⟩) =
          forestCoproductChoice.forest B := by
  unfold forestComponentChoiceIsForest at h
  by_cases hγ : γ ∈ A.elements
  · rw [dif_pos hγ] at h
    rcases h with ⟨B, hB⟩
    exact ⟨hγ, B, hB⟩
  · rw [dif_neg hγ] at h
    cases h

/-- The admissible subgraph made from all components selected on the left by a
component-choice function. -/
private noncomputable def forestComponentChoiceLeftSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) : AdmissibleSubgraph G :=
  admissibleSubgraphOfSubelements A
    (A.elements.filter (forestComponentChoiceIsLeft A p))
    (Finset.filter_subset _ _)

@[simp] private theorem forestComponentChoiceLeftSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceLeftSubgraph A p).elements =
      A.elements.filter (forestComponentChoiceIsLeft A p) := rfl

/-- The admissible subgraph made from all components selected on the right by a
component-choice function. -/
private noncomputable def forestComponentChoiceRightSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) : AdmissibleSubgraph G :=
  admissibleSubgraphOfSubelements A
    (A.elements.filter (forestComponentChoiceIsRight A p))
    (Finset.filter_subset _ _)

@[simp] private theorem forestComponentChoiceRightSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceRightSubgraph A p).elements =
      A.elements.filter (forestComponentChoiceIsRight A p) := rfl

/-- The left-selected component subgraph is nonempty exactly when the
component-choice function has a left boundary choice. -/
private theorem forestComponentChoiceLeftSubgraph_isNonempty_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceLeftSubgraph A p).IsNonempty ↔
      forestComponentChoiceHasLeft A p := by
  classical
  unfold AdmissibleSubgraph.IsNonempty forestComponentChoiceHasLeft
  constructor
  · rintro ⟨γ, hγ⟩
    rw [forestComponentChoiceLeftSubgraph_elements] at hγ
    rcases Finset.mem_filter.mp hγ with ⟨hγA, hγLeft⟩
    refine ⟨⟨γ, hγA⟩, ?_⟩
    unfold forestComponentChoiceIsLeft at hγLeft
    rw [dif_pos hγA] at hγLeft
    exact hγLeft
  · rintro ⟨γ, hγLeft⟩
    refine ⟨γ.1, ?_⟩
    rw [forestComponentChoiceLeftSubgraph_elements]
    refine Finset.mem_filter.mpr ⟨γ.2, ?_⟩
    unfold forestComponentChoiceIsLeft
    rw [dif_pos γ.2]
    exact hγLeft

/-- The right-selected component subgraph is nonempty exactly when the
component-choice function has a right boundary choice. -/
private theorem forestComponentChoiceRightSubgraph_isNonempty_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceRightSubgraph A p).IsNonempty ↔
      forestComponentChoiceHasRight A p := by
  classical
  unfold AdmissibleSubgraph.IsNonempty forestComponentChoiceHasRight
  constructor
  · rintro ⟨γ, hγ⟩
    rw [forestComponentChoiceRightSubgraph_elements] at hγ
    rcases Finset.mem_filter.mp hγ with ⟨hγA, hγRight⟩
    refine ⟨⟨γ, hγA⟩, ?_⟩
    unfold forestComponentChoiceIsRight at hγRight
    rw [dif_pos hγA] at hγRight
    exact hγRight
  · rintro ⟨γ, hγRight⟩
    refine ⟨γ.1, ?_⟩
    rw [forestComponentChoiceRightSubgraph_elements]
    refine Finset.mem_filter.mpr ⟨γ.2, ?_⟩
    unfold forestComponentChoiceIsRight
    rw [dif_pos γ.2]
    exact hγRight

/-- The left-selected component subgraph only uses components of the ambient
admissible subgraph. -/
private theorem forestComponentChoiceLeftSubgraph_elements_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceLeftSubgraph A p).elements ⊆ A.elements := by
  intro γ hγ
  rw [forestComponentChoiceLeftSubgraph_elements] at hγ
  exact (Finset.mem_filter.mp hγ).1

/-- The right-selected component subgraph only uses components of the ambient
admissible subgraph. -/
private theorem forestComponentChoiceRightSubgraph_elements_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceRightSubgraph A p).elements ⊆ A.elements := by
  intro γ hγ
  rw [forestComponentChoiceRightSubgraph_elements] at hγ
  exact (Finset.mem_filter.mp hγ).1

private theorem forestComponentChoiceLeftSubgraph_isPairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    (forestComponentChoiceLeftSubgraph A p).IsPairwiseDisjoint := by
  intro γ₁ hγ₁ γ₂ hγ₂ hne
  exact hA
    (forestComponentChoiceLeftSubgraph_elements_subset A p hγ₁)
    (forestComponentChoiceLeftSubgraph_elements_subset A p hγ₂)
    hne

private theorem forestComponentChoiceRightSubgraph_isPairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    (forestComponentChoiceRightSubgraph A p).IsPairwiseDisjoint := by
  intro γ₁ hγ₁ γ₂ hγ₂ hne
  exact hA
    (forestComponentChoiceRightSubgraph_elements_subset A p hγ₁)
    (forestComponentChoiceRightSubgraph_elements_subset A p hγ₂)
    hne

private theorem forestComponentChoiceLeftSubgraph_hasNonemptyComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.HasNonemptyComponents) :
    (forestComponentChoiceLeftSubgraph A p).HasNonemptyComponents := by
  intro γ hγ
  exact hA γ (forestComponentChoiceLeftSubgraph_elements_subset A p hγ)

private theorem forestComponentChoiceRightSubgraph_hasNonemptyComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.HasNonemptyComponents) :
    (forestComponentChoiceRightSubgraph A p).HasNonemptyComponents := by
  intro γ hγ
  exact hA γ (forestComponentChoiceRightSubgraph_elements_subset A p hγ)

private theorem forestComponentChoiceLeftSubgraph_hasPositiveInternalEdgesComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hA : A.HasPositiveInternalEdgesComponents) :
    (forestComponentChoiceLeftSubgraph A p).HasPositiveInternalEdgesComponents := by
  intro γ hγ
  exact hA γ (forestComponentChoiceLeftSubgraph_elements_subset A p hγ)

private theorem forestComponentChoiceRightSubgraph_hasPositiveInternalEdgesComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hA : A.HasPositiveInternalEdgesComponents) :
    (forestComponentChoiceRightSubgraph A p).HasPositiveInternalEdgesComponents := by
  intro γ hγ
  exact hA γ (forestComponentChoiceRightSubgraph_elements_subset A p hγ)

private theorem admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
    {G : FeynmanGraph} [DivergenceMeasure G] {A : AdmissibleSubgraph G}
    (hPos : A.HasPositiveInternalEdgesComponents) (hNE : A.IsNonempty) :
    0 < A.internalEdges.card := by
  rcases hNE with ⟨γ, hγ⟩
  have hγPos : 0 < γ.internalEdges.card := hPos γ hγ
  rw [Multiset.card_pos_iff_exists_mem] at ⊢
  rw [Multiset.card_pos_iff_exists_mem] at hγPos
  rcases hγPos with ⟨e, he⟩
  exact ⟨e, AdmissibleSubgraph.mem_internalEdges.mpr ⟨γ, hγ, he⟩⟩

private theorem forestComponentChoiceLeftSubgraph_internalEdges_card_pos
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hPos : A.HasPositiveInternalEdgesComponents)
    (hLeft : forestComponentChoiceHasLeft A p) :
    0 < (forestComponentChoiceLeftSubgraph A p).internalEdges.card :=
  admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
    (forestComponentChoiceLeftSubgraph_hasPositiveInternalEdgesComponents A p hPos)
    ((forestComponentChoiceLeftSubgraph_isNonempty_iff A p).2 hLeft)

private theorem forestComponentChoiceRightSubgraph_internalEdges_card_pos
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hPos : A.HasPositiveInternalEdgesComponents)
    (hRight : forestComponentChoiceHasRight A p) :
    0 < (forestComponentChoiceRightSubgraph A p).internalEdges.card :=
  admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
    (forestComponentChoiceRightSubgraph_hasPositiveInternalEdgesComponents A p hPos)
    ((forestComponentChoiceRightSubgraph_isNonempty_iff A p).2 hRight)

private theorem forestComponentChoiceLeftSubgraph_mem_nonemptyDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hDisj : A.IsPairwiseDisjoint)
    (hLeft : forestComponentChoiceHasLeft A p) :
    forestComponentChoiceLeftSubgraph A p ∈
      G.nonemptyDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
    G.mem_disjointAdmissibleDivergentSubgraphs]
  exact ⟨⟨G.mem_admissibleDivergentSubgraphs _,
      forestComponentChoiceLeftSubgraph_isPairwiseDisjoint A p hDisj⟩,
    (forestComponentChoiceLeftSubgraph_isNonempty_iff A p).2 hLeft⟩

private theorem forestComponentChoiceRightSubgraph_mem_nonemptyDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hDisj : A.IsPairwiseDisjoint)
    (hRight : forestComponentChoiceHasRight A p) :
    forestComponentChoiceRightSubgraph A p ∈
      G.nonemptyDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
    G.mem_disjointAdmissibleDivergentSubgraphs]
  exact ⟨⟨G.mem_admissibleDivergentSubgraphs _,
      forestComponentChoiceRightSubgraph_isPairwiseDisjoint A p hDisj⟩,
    (forestComponentChoiceRightSubgraph_isNonempty_iff A p).2 hRight⟩

private theorem forestComponentChoiceLeftSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hLeft : forestComponentChoiceHasLeft A p) :
    forestComponentChoiceLeftSubgraph A p ∈
      G.properDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_properDisjointAdmissibleDivergentSubgraphs]
  exact ⟨
    forestComponentChoiceLeftSubgraph_mem_nonemptyDisjoint A p
      (G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA) hLeft,
    forestComponentChoiceLeftSubgraph_hasNonemptyComponents A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hA),
    forestComponentChoiceLeftSubgraph_internalEdges_card_pos A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents hA)
      hLeft,
    forestComponentChoiceLeftSubgraph_hasPositiveInternalEdgesComponents A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents hA)⟩

private theorem forestComponentChoiceRightSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hRight : forestComponentChoiceHasRight A p) :
    forestComponentChoiceRightSubgraph A p ∈
      G.properDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_properDisjointAdmissibleDivergentSubgraphs]
  exact ⟨
    forestComponentChoiceRightSubgraph_mem_nonemptyDisjoint A p
      (G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA) hRight,
    forestComponentChoiceRightSubgraph_hasNonemptyComponents A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hA),
    forestComponentChoiceRightSubgraph_internalEdges_card_pos A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents hA)
      hRight,
    forestComponentChoiceRightSubgraph_hasPositiveInternalEdgesComponents A p
      (G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents hA)⟩

/-- The `toHopfH` of the left-selected component subgraph is the product of
the left indicator factors over the original component carrier. -/
private theorem forestComponentChoiceLeftSubgraph_toHopfH_eq_indicator_product
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceLeftSubgraph A p).toHopfH =
      ∏ γ ∈ A.elements.attach,
        if p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left then
          (MvPolynomial.X
            (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
        else 1 := by
  classical
  unfold AdmissibleSubgraph.toHopfH
  rw [forestComponentChoiceLeftSubgraph_elements]
  rw [Finset.prod_filter]
  rw [← Finset.prod_attach A.elements
    (fun γ : FeynmanSubgraph G =>
      if forestComponentChoiceIsLeft A p γ then
        (forestComponentChoiceLeftSubgraph A p).componentToHopfH γ
      else 1)]
  apply Finset.prod_congr rfl
  intro γ _hγ
  by_cases hLeft :
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left
  · have hγLeft :
        γ.1 ∈ (forestComponentChoiceLeftSubgraph A p).elements := by
      rw [forestComponentChoiceLeftSubgraph_elements]
      refine Finset.mem_filter.mpr ⟨γ.2, ?_⟩
      unfold forestComponentChoiceIsLeft
      rw [dif_pos γ.2]
      simpa using hLeft
    have hIsLeft : forestComponentChoiceIsLeft A p γ.1 := by
      unfold forestComponentChoiceIsLeft
      rw [dif_pos γ.2]
      simpa using hLeft
    rw [if_pos hIsLeft, if_pos hLeft]
    unfold AdmissibleSubgraph.componentToHopfH gen
    rw [dif_pos hγLeft]
  · have hNotLeft :
        ¬ forestComponentChoiceIsLeft A p γ.1 := by
      unfold forestComponentChoiceIsLeft
      rw [dif_pos γ.2]
      simpa using hLeft
    rw [if_neg hNotLeft, if_neg hLeft]

/-- The `toHopfH` of the right-selected component subgraph is the product of
the right indicator factors over the original component carrier. -/
private theorem forestComponentChoiceRightSubgraph_toHopfH_eq_indicator_product
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (forestComponentChoiceRightSubgraph A p).toHopfH =
      ∏ γ ∈ A.elements.attach,
        if p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right then
          (MvPolynomial.X
            (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
        else 1 := by
  classical
  unfold AdmissibleSubgraph.toHopfH
  rw [forestComponentChoiceRightSubgraph_elements]
  rw [Finset.prod_filter]
  rw [← Finset.prod_attach A.elements
    (fun γ : FeynmanSubgraph G =>
      if forestComponentChoiceIsRight A p γ then
        (forestComponentChoiceRightSubgraph A p).componentToHopfH γ
      else 1)]
  apply Finset.prod_congr rfl
  intro γ _hγ
  by_cases hRight :
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right
  · have hγRight :
        γ.1 ∈ (forestComponentChoiceRightSubgraph A p).elements := by
      rw [forestComponentChoiceRightSubgraph_elements]
      refine Finset.mem_filter.mpr ⟨γ.2, ?_⟩
      unfold forestComponentChoiceIsRight
      rw [dif_pos γ.2]
      simpa using hRight
    have hIsRight : forestComponentChoiceIsRight A p γ.1 := by
      unfold forestComponentChoiceIsRight
      rw [dif_pos γ.2]
      simpa using hRight
    rw [if_pos hIsRight, if_pos hRight]
    unfold AdmissibleSubgraph.componentToHopfH gen
    rw [dif_pos hγRight]
  · have hNotRight :
        ¬ forestComponentChoiceIsRight A p γ.1 := by
      unfold forestComponentChoiceIsRight
      rw [dif_pos γ.2]
      simpa using hRight
    rw [if_neg hNotRight, if_neg hRight]

/-- If no component chooses a genuine forest summand, then the component
product splits into the left-selected and right-selected admissible products. -/
private theorem forestComponentChoiceProductTerm_eq_leftRightSubgraphs_of_noForest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hNoForest : ¬ forestComponentChoiceHasForest A p) :
    forestComponentChoiceProductTerm A p =
      (forestComponentChoiceLeftSubgraph A p).toHopfH ⊗ₜ[ℚ]
        (forestComponentChoiceRightSubgraph A p).toHopfH := by
  classical
  unfold forestComponentChoiceProductTerm
  have hFactor :
      (∏ γ ∈ A.elements.attach.attach,
          forestCoproductChoiceTerm
            (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
            (p γ.1 γ.2)) =
        ∏ γ ∈ A.elements.attach.attach,
          ((if p γ.1 γ.2 = forestCoproductChoice.left then
              (MvPolynomial.X
                (γ.1.1.toHopfGen
                  (A.isConnectedDivergent_of_mem γ.1.2)) : HopfH)
            else 1) ⊗ₜ[ℚ]
            (if p γ.1 γ.2 = forestCoproductChoice.right then
              (MvPolynomial.X
                (γ.1.1.toHopfGen
                  (A.isConnectedDivergent_of_mem γ.1.2)) : HopfH)
            else 1)) := by
    apply Finset.prod_congr rfl
    intro γ _hγ
    exact forestCoproductChoiceTerm_eq_leftRightIndicators_of_not_forest
      (γ.1.1.toHopfGen (A.isConnectedDivergent_of_mem γ.1.2))
      (p γ.1 γ.2)
      (by
        intro B hB
        exact hNoForest ⟨γ.1, B, hB⟩)
  rw [hFactor]
  rw [tensorProduct_prod_tmul A.elements.attach.attach
    (fun γ =>
      if p γ.1 γ.2 = forestCoproductChoice.left then
        (MvPolynomial.X
          (γ.1.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.1.2)) : HopfH)
      else 1)
    (fun γ =>
      if p γ.1 γ.2 = forestCoproductChoice.right then
        (MvPolynomial.X
          (γ.1.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.1.2)) : HopfH)
      else 1)]
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      if p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left then
        (MvPolynomial.X
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
      else 1)]
  rw [Finset.prod_attach A.elements.attach
    (fun γ : {γ : FeynmanSubgraph G // γ ∈ A.elements} =>
      if p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right then
        (MvPolynomial.X
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
      else 1)]
  rw [← forestComponentChoiceLeftSubgraph_toHopfH_eq_indicator_product A p,
    ← forestComponentChoiceRightSubgraph_toHopfH_eq_indicator_product A p]

/-- The remnant contribution to the second tensor factor of a component-choice
product.  Only genuine component-forest choices contribute a contracted
right factor; boundary choices contribute `1`. -/
private noncomputable def forestComponentChoiceRemnantInnerTensorFactor
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) : HopfH :=
  match p γ hγ with
  | forestCoproductChoice.forest B =>
      if hB :
          B ∈ ((repG (γ.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          ).properDisjointAdmissibleDivergentSubgraphs then
        forestRightHopfH
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B hB
      else
        1
  | _ => 1

/-- The second tensor-factor product splits into the right-selected original
components and the genuine component-forest remnant factors. -/
private theorem forestComponentChoiceInnerTensorFactor_product_eq_right_mul_remnant
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hp : p ∈ forestComponentCoreChoiceIndex A) :
    (∏ γ ∈ A.elements.attach,
        forestComponentChoiceInnerTensorFactorOfCore A p hp γ
          (Finset.mem_attach A.elements γ)) =
      (forestComponentChoiceRightSubgraph A p).toHopfH *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoiceRemnantInnerTensorFactor A p hp γ
            (Finset.mem_attach A.elements γ)) := by
  classical
  have hPoint :
      ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        forestComponentChoiceInnerTensorFactorOfCore A p hp γ
            (Finset.mem_attach A.elements γ) =
          (if p γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.right then
            (MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
          else 1) *
            forestComponentChoiceRemnantInnerTensorFactor A p hp γ
              (Finset.mem_attach A.elements γ) := by
    intro γ
    cases hChoice : p γ (Finset.mem_attach A.elements γ) with
    | left =>
        simp [forestComponentChoiceInnerTensorFactorOfCore,
          forestComponentChoiceRemnantInnerTensorFactor, hChoice]
    | right =>
        simp [forestComponentChoiceInnerTensorFactorOfCore,
          forestComponentChoiceRemnantInnerTensorFactor, hChoice]
    | forest B =>
        have hBmem :
            B ∈ ((repG (γ.1.toHopfGen
              (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            ).properDisjointAdmissibleDivergentSubgraphs :=
          forestComponentChoice_forest_mem_properDisjoint_of_core_mem hp γ hChoice
        have hNotRight :
            ¬ p γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.right := by
          rw [hChoice]
          intro h
          cases h
        have hInner :
            forestComponentChoiceInnerTensorFactorOfCore A p hp γ
                (Finset.mem_attach A.elements γ) =
              forestRightHopfH
                (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B
                hBmem := by
          simp [forestComponentChoiceInnerTensorFactorOfCore, hChoice, hBmem]
        have hRemnant :
            forestComponentChoiceRemnantInnerTensorFactor A p hp γ
                (Finset.mem_attach A.elements γ) =
              forestRightHopfH
                (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) B
                hBmem := by
          simp [forestComponentChoiceRemnantInnerTensorFactor, hChoice, hBmem]
        rw [hInner, hRemnant]
        simp [hChoice]
  calc
    (∏ γ ∈ A.elements.attach,
        forestComponentChoiceInnerTensorFactorOfCore A p hp γ
          (Finset.mem_attach A.elements γ))
        =
      ∏ γ ∈ A.elements.attach,
        ((if p γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.right then
            (MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
          else 1) *
            forestComponentChoiceRemnantInnerTensorFactor A p hp γ
              (Finset.mem_attach A.elements γ)) := by
          apply Finset.prod_congr rfl
          intro γ _hγ
          exact hPoint γ
    _ =
      (∏ γ ∈ A.elements.attach,
        if p γ (Finset.mem_attach A.elements γ) =
            forestCoproductChoice.right then
          (MvPolynomial.X
            (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
        else 1) *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoiceRemnantInnerTensorFactor A p hp γ
            (Finset.mem_attach A.elements γ)) := by
          rw [Finset.prod_mul_distrib]
    _ =
      (forestComponentChoiceRightSubgraph A p).toHopfH *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoiceRemnantInnerTensorFactor A p hp γ
            (Finset.mem_attach A.elements γ)) := by
          rw [forestComponentChoiceRightSubgraph_toHopfH_eq_indicator_product]

/-- The promoted-forest contribution to the first tensor factor of a
component-choice product.  Non-forest component choices contribute `1`. -/
private noncomputable def forestComponentChoicePromotedOuterTensorFactor
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) : HopfH :=
  match p γ hγ with
  | forestCoproductChoice.forest B => B.toHopfH
  | _ => 1

/-- The first tensor-factor product splits into the left-selected original
components and the promoted genuine-forest selections. -/
private theorem forestComponentChoiceOuterTensorFactor_product_eq_left_mul_promoted
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    (∏ γ ∈ A.elements.attach,
        forestComponentChoiceOuterTensorFactor A p γ
          (Finset.mem_attach A.elements γ)) =
      (forestComponentChoiceLeftSubgraph A p).toHopfH *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoicePromotedOuterTensorFactor A p γ
            (Finset.mem_attach A.elements γ)) := by
  classical
  have hPoint :
      ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        forestComponentChoiceOuterTensorFactor A p γ
            (Finset.mem_attach A.elements γ) =
          (if p γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.left then
            (MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
          else 1) *
            forestComponentChoicePromotedOuterTensorFactor A p γ
              (Finset.mem_attach A.elements γ) := by
    intro γ
    cases hChoice : p γ (Finset.mem_attach A.elements γ) with
    | left =>
        simp [forestComponentChoiceOuterTensorFactor,
          forestComponentChoicePromotedOuterTensorFactor, hChoice]
    | right =>
        simp [forestComponentChoiceOuterTensorFactor,
          forestComponentChoicePromotedOuterTensorFactor, hChoice]
    | forest B =>
        simp [forestComponentChoiceOuterTensorFactor,
          forestComponentChoicePromotedOuterTensorFactor, hChoice]
  calc
    (∏ γ ∈ A.elements.attach,
        forestComponentChoiceOuterTensorFactor A p γ
          (Finset.mem_attach A.elements γ))
        =
      ∏ γ ∈ A.elements.attach,
        ((if p γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.left then
            (MvPolynomial.X
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
          else 1) *
            forestComponentChoicePromotedOuterTensorFactor A p γ
              (Finset.mem_attach A.elements γ)) := by
          apply Finset.prod_congr rfl
          intro γ _hγ
          exact hPoint γ
    _ =
      (∏ γ ∈ A.elements.attach,
        if p γ (Finset.mem_attach A.elements γ) =
            forestCoproductChoice.left then
          (MvPolynomial.X
            (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) : HopfH)
        else 1) *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoicePromotedOuterTensorFactor A p γ
            (Finset.mem_attach A.elements γ)) := by
          rw [Finset.prod_mul_distrib]
    _ =
      (forestComponentChoiceLeftSubgraph A p).toHopfH *
        (∏ γ ∈ A.elements.attach,
          forestComponentChoicePromotedOuterTensorFactor A p γ
            (Finset.mem_attach A.elements γ)) := by
          rw [forestComponentChoiceLeftSubgraph_toHopfH_eq_indicator_product]

/-- Membership in the mixed boundary component-choice regime supplies both
left and right selected components. -/
private theorem mem_forestComponentMixedBoundaryChoiceCoreIndex_hasLeft_right
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentMixedBoundaryChoiceCoreIndex A) :
    forestComponentChoiceHasLeft A p ∧ forestComponentChoiceHasRight A p := by
  classical
  unfold forestComponentMixedBoundaryChoiceCoreIndex at hp
  rcases Finset.mem_filter.mp hp with ⟨hpCore, hpNoForest⟩
  rcases forestComponentCoreChoice_has_forest_or_mixed_boundary hpCore with
    hForest | hMixed
  · exact False.elim (hpNoForest hForest)
  · exact hMixed

/-- The RHS outer forest selected by a mixed left/right LHS component-choice
index is exactly the left-selected component subgraph. -/
private noncomputable def forestComponentMixedBoundaryOuterIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestOuterProperIndex g :=
  ⟨forestComponentChoiceLeftSubgraph q.1.1 q.2,
    by
      have hp :
          q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
        (Finset.mem_sigma.mp hq).2
      exact forestComponentChoiceLeftSubgraph_mem_properDisjoint q.1.1 q.2
        q.1.2
        (mem_forestComponentMixedBoundaryChoiceCoreIndex_hasLeft_right hp).1⟩

@[simp] private theorem forestComponentMixedBoundaryOuterIndex_val
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryOuterIndex g q hq).1 =
      forestComponentChoiceLeftSubgraph q.1.1 q.2 := rfl

/-- In the mixed boundary regime, the right-selected component subgraph is
also a proper admissible forest in the original ambient graph.  The remaining
φ construction has to transport this forest through the left-selected forest
quotient. -/
private theorem forestComponentMixedBoundaryRightSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentChoiceRightSubgraph q.1.1 q.2 ∈
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
  have hp :
      q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  exact forestComponentChoiceRightSubgraph_mem_properDisjoint q.1.1 q.2
    q.1.2
    (mem_forestComponentMixedBoundaryChoiceCoreIndex_hasLeft_right hp).2

/-- The mixed-boundary component product already factors as the selected
outer forest times the original right-selected component forest.  The remaining
mixed product payload is exactly the transport of this right factor into the
representative quotient. -/
private theorem forestComponentMixedBoundary_productTerm_eq_leftRightSubgraphs
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentChoiceProductTerm q.1.1 q.2 =
      (forestComponentMixedBoundaryOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
        (forestComponentChoiceRightSubgraph q.1.1 q.2).toHopfH := by
  classical
  have hp :
      q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hNoForest : ¬ forestComponentChoiceHasForest q.1.1 q.2 := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp
    exact (Finset.mem_filter.mp hp).2
  rw [forestComponentMixedBoundaryOuterIndex_val]
  exact forestComponentChoiceProductTerm_eq_leftRightSubgraphs_of_noForest
    q.1.1 q.2 hNoForest

/-- A component cannot be selected simultaneously on the right and on the left. -/
private theorem forestComponentChoiceRightSubgraph_not_mem_left
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    {γ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements) :
    γ ∉ (forestComponentChoiceLeftSubgraph A p).elements := by
  classical
  rw [forestComponentChoiceRightSubgraph_elements] at hγR
  rcases Finset.mem_filter.mp hγR with ⟨hγA, hRight⟩
  intro hγL
  rw [forestComponentChoiceLeftSubgraph_elements] at hγL
  rcases Finset.mem_filter.mp hγL with ⟨_hγA', hLeft⟩
  unfold forestComponentChoiceIsRight at hRight
  unfold forestComponentChoiceIsLeft at hLeft
  rw [dif_pos hγA] at hRight
  rw [dif_pos hγA] at hLeft
  rw [hLeft] at hRight
  cases hRight

/-- In a pairwise-disjoint admissible carrier, right-selected and left-selected
components are vertex-disjoint. -/
private theorem forestComponentChoiceRightLeft_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ δ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements)
    (hδL : δ ∈ (forestComponentChoiceLeftSubgraph A p).elements) :
    γ.Disjoint δ := by
  have hγA : γ ∈ A.elements :=
    forestComponentChoiceRightSubgraph_elements_subset A p hγR
  have hδA : δ ∈ A.elements :=
    forestComponentChoiceLeftSubgraph_elements_subset A p hδL
  have hne : γ ≠ δ := by
    intro hEq
    subst δ
    exact forestComponentChoiceRightSubgraph_not_mem_left A p hγR hδL
  exact hA hγA hδA hne

/-- Vertices of a right-selected component do not lie in the left-selected
admissible carrier. -/
private theorem forestComponentChoiceRight_vertices_not_mem_leftSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements)
    {v : VertexId} (hv : v ∈ γ.vertices) :
    v ∉ (forestComponentChoiceLeftSubgraph A p).vertices := by
  intro hvLeft
  rcases AdmissibleSubgraph.mem_vertices.mp hvLeft with ⟨δ, hδL, hvδ⟩
  have hdisj := forestComponentChoiceRightLeft_disjoint A p hA hγR hδL
  exact (Finset.disjoint_left.mp hdisj hv) hvδ

-- Helpers `multiset_count_finset_sum`,
-- `admissibleSubgraph_internalEdges_le_of_pairwise`, and
-- `feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem`
-- moved to `Coproduct.lean` as public admissible-forest internal-edge API.
-- They are reused by Sprint E's antipode termination argument and any
-- future forest-based reasoning, so `Coproduct.lean` is now their owner.

private theorem admissibleSubgraph_complementEdges_card_pos_of_internalEdges_le
    {G : FeynmanGraph} [DivergenceMeasure G] {A B : AdmissibleSubgraph G}
    (hBA : B.internalEdges ≤ A.internalEdges)
    (hAcomp : 0 < A.complementEdges.card) :
    0 < B.complementEdges.card := by
  classical
  rcases Multiset.card_pos_iff_exists_mem.mp hAcomp with ⟨e, he⟩
  have hltA := A.count_lt_of_mem_complementEdges he
  have hleBA : B.internalEdges.count e ≤ A.internalEdges.count e :=
    Multiset.count_le_of_le e hBA
  have hltB : B.internalEdges.count e < G.internalEdges.count e :=
    lt_of_le_of_lt hleBA hltA
  refine Multiset.card_pos_iff_exists_mem.mpr ⟨e, ?_⟩
  unfold AdmissibleSubgraph.complementEdges
  rw [Multiset.mem_sub]
  exact hltB

private theorem multiset_sub_card_pos_of_left_le
    {M N B : Multiset FeynmanEdge} (hMN : M ≤ N)
    (hpos : 0 < (M - B).card) :
    0 < (N - B).card := by
  classical
  rcases Multiset.card_pos_iff_exists_mem.mp hpos with ⟨e, he⟩
  rw [Multiset.mem_sub] at he
  have hle : M.count e ≤ N.count e := Multiset.count_le_of_le e hMN
  have hlt : B.count e < N.count e := lt_of_lt_of_le he hle
  refine Multiset.card_pos_iff_exists_mem.mpr ⟨e, ?_⟩
  rw [Multiset.mem_sub]
  exact hlt

private theorem admissibleSubgraph_internalEdges_count_eq_component_of_mem
    {G : FeynmanGraph} [DivergenceMeasure G] (A : AdmissibleSubgraph G)
    (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G} (hγ : γ ∈ A.elements)
    {e : FeynmanEdge} (heγ : e ∈ γ.internalEdges) :
    Multiset.count e A.internalEdges = Multiset.count e γ.internalEdges := by
  classical
  have hzero :
      ∀ δ ∈ A.elements, δ ≠ γ → δ.internalEdges.count e = 0 := by
    intro δ hδ hne
    by_cases heδ : e ∈ δ.internalEdges
    · have hdisj := hA hδ hγ hne
      have hsuppδ := δ.edges_supported e heδ
      have hsuppγ := γ.edges_supported e heγ
      simp [FeynmanEdge.SupportedOn] at hsuppδ hsuppγ
      exact False.elim ((Finset.disjoint_left.mp hdisj hsuppδ.1) hsuppγ.1)
    · exact Multiset.count_eq_zero.mpr heδ
  unfold AdmissibleSubgraph.internalEdges
  rw [multiset_count_finset_sum]
  rw [Finset.sum_eq_single γ]
  · intro δ hδ hne
    exact hzero δ hδ hne
  · intro hγnot
    exact False.elim (hγnot hγ)

-- `admissibleSubgraph_internalEdges_le_of_components_le` moved to
-- `Coproduct.lean` as public admissible-forest internal-edge API.

/-- If no internal edge of `γ` is removed by an admissible carrier, then every
internal edge of `γ` lies in that carrier's complement multiset. -/
private theorem feynmanSubgraph_internalEdges_le_admissible_complementEdges_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (γ : FeynmanSubgraph G)
    (hNot : ∀ e ∈ γ.internalEdges, e ∉ A.internalEdges) :
    γ.internalEdges ≤ A.complementEdges := by
  rw [Multiset.le_iff_count]
  intro e
  by_cases heγ : e ∈ γ.internalEdges
  · have hAcount : Multiset.count e A.internalEdges = 0 :=
      Multiset.count_eq_zero.mpr (hNot e heγ)
    unfold AdmissibleSubgraph.complementEdges
    rw [Multiset.count_sub, hAcount, tsub_zero]
    exact Multiset.count_le_of_le e γ.internalEdges_le
  · rw [Multiset.count_eq_zero.mpr heγ]
    exact Nat.zero_le _

/-- Right-selected components survive deletion of the left-selected component
internal edges. -/
private theorem forestComponentChoiceRight_internalEdges_le_left_complement
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements) :
    γ.internalEdges ≤ (forestComponentChoiceLeftSubgraph A p).complementEdges := by
  refine feynmanSubgraph_internalEdges_le_admissible_complementEdges_of_not_mem
    (forestComponentChoiceLeftSubgraph A p) γ ?_
  intro e heγ heLeft
  rcases AdmissibleSubgraph.mem_internalEdges.mp heLeft with ⟨δ, hδL, heδ⟩
  have hdisj := forestComponentChoiceRightLeft_disjoint A p hA hγR hδL
  have hsuppγ := γ.edges_supported e heγ
  have hsuppδ := δ.edges_supported e heδ
  simp [FeynmanEdge.SupportedOn] at hsuppγ hsuppδ
  exact (Finset.disjoint_left.mp hdisj hsuppγ.1) hsuppδ.1

/-- Flatten the LHS genuine-forest component-choice regime. -/
private theorem forestTermEComponentForestChoicesDistributed_eq_sigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentForestChoicesDistributed g =
      ∑ q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q := by
  classical
  unfold forestTermEComponentForestChoicesDistributed
    forestComponentForestChoiceSigmaIndex forestOuterProperFinset
  unfold forestCoproductProperForestIndex
  exact sum_dite_filter_sigma_attach
    ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    (fun A => 0 < A.complementEdges.card)
    (fun A => forestComponentForestChoiceCoreIndex A)
    (fun A hA p => forestComponentChoiceSigmaTerm g ⟨⟨A, hA⟩, p⟩)

/-- Flatten the LHS mixed left/right boundary component-choice regime. -/
private theorem forestTermEComponentMixedBoundaryChoicesDistributed_eq_sigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentMixedBoundaryChoicesDistributed g =
      ∑ q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q := by
  classical
  unfold forestTermEComponentMixedBoundaryChoicesDistributed
    forestComponentMixedBoundaryChoiceSigmaIndex forestOuterProperFinset
  unfold forestCoproductProperForestIndex
  exact sum_dite_filter_sigma_attach
    ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    (fun A => 0 < A.complementEdges.card)
    (fun A => forestComponentMixedBoundaryChoiceCoreIndex A)
    (fun A hA p => forestComponentChoiceSigmaTerm g ⟨⟨A, hA⟩, p⟩)

/-- The quotient Hopf generator associated to an attached outer forest. -/
private noncomputable def forestOuterQuotientHopfGen
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) : HopfGen :=
  FeynmanGraph.admissibleForestRightWithCanonicalStars
    (repG g).toFeynmanGraph (forestCanonicalHCD g) A.1 A.2

/-- The representative graph used for the quotient Hopf generator. -/
private noncomputable def forestOuterQuotientGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) : FeynmanGraph :=
  (repG (forestOuterQuotientHopfGen g A)).toFeynmanGraph

/-- The actual canonical quotient graph before choosing the `repG`
representative of its Hopf generator. -/
private noncomputable def forestOuterActualQuotientGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) : FeynmanGraph :=
  FeynmanGraph.admissibleForestContractGraphWithStars
    (repG g).toFeynmanGraph A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)

/-- The actual canonical quotient graph is the graph class packaged by the
outer quotient Hopf generator. -/
private theorem forestOuterActualQuotientGraph_toClass_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterActualQuotientGraph g A).toClass =
      (forestOuterQuotientHopfGen g A).val := by
  unfold forestOuterActualQuotientGraph forestOuterQuotientHopfGen
  exact (FeynmanGraph.admissibleForestRightWithCanonicalStars_val
    (repG g).toFeynmanGraph (forestCanonicalHCD g) A.1 A.2).symm

/-- The chosen representative graph has the graph class of the outer quotient
Hopf generator. -/
private theorem forestOuterQuotientGraph_toClass_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterQuotientGraph g A).toClass =
      (forestOuterQuotientHopfGen g A).val := by
  unfold forestOuterQuotientGraph
  exact repG_toClass (forestOuterQuotientHopfGen g A)

/-- Actual canonical quotient and representative quotient are isomorphic. -/
private theorem forestOuterActualQuotientGraph_toClass_eq_rep
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterActualQuotientGraph g A).toClass =
      (forestOuterQuotientGraph g A).toClass := by
  rw [forestOuterActualQuotientGraph_toClass_eq,
    forestOuterQuotientGraph_toClass_eq]

/-- Graph-level transport from the actual quotient to its `repG`
representative. -/
private theorem forestOuterActualQuotientGraph_isIso_rep
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterActualQuotientGraph g A).IsIso
      (forestOuterQuotientGraph g A) :=
  (FeynmanGraph.toClass_eq_iff _ _).mp
    (forestOuterActualQuotientGraph_toClass_eq_rep g A)

/-- A fixed permutation witnessing the actual-to-representative quotient
transport. -/
private noncomputable def forestOuterActualToRepPerm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) : Equiv.Perm VertexId :=
  Classical.choose (forestOuterActualQuotientGraph_isIso_rep g A)

/-- The actual-to-representative permutation realizes the representative
quotient graph as a permuted actual quotient graph. -/
private theorem forestOuterActualToRepPerm_spec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    forestOuterQuotientGraph g A =
      (forestOuterActualQuotientGraph g A).mapPerm
        (forestOuterActualToRepPerm g A) :=
  Classical.choose_spec (forestOuterActualQuotientGraph_isIso_rep g A)

/-- Transport a quotient-side subgraph from the actual canonical quotient to
the chosen representative quotient graph. -/
private noncomputable def forestOuterActualToRepSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (γ : FeynmanSubgraph (forestOuterActualQuotientGraph g A)) :
    FeynmanSubgraph (forestOuterQuotientGraph g A) :=
  mapPermSubgraph (forestOuterActualToRepPerm_spec g A) γ

/-- Retarget one ambient subgraph into an admissible-forest quotient graph.
The edge hypothesis says that the subgraph survives deletion of the outer
forest's component-internal edges. -/
private noncomputable def admissibleSubgraphRetargetSubgraph
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) (hEdges : γ.internalEdges ≤ A.complementEdges) :
    FeynmanSubgraph (A.contractWithStars starOf) where
  vertices := γ.vertices.image (A.retargetVertex starOf)
  internalEdges := γ.internalEdges.map (A.retargetEdge starOf)
  externalLegs := γ.externalLegs.map (A.retargetExternalLeg starOf)
  vertices_subset := by
    intro v hv
    rcases Finset.mem_image.mp hv with ⟨u, hu, rfl⟩
    exact A.retargetVertex_mem_contractWithStars_vertices starOf
      (γ.vertices_subset hu)
  internalEdges_le := by
    rw [AdmissibleSubgraph.contractWithStars_internalEdges]
    exact Multiset.map_le_map hEdges
  externalLegs_le := by
    rw [AdmissibleSubgraph.contractWithStars_externalLegs]
    exact Multiset.map_le_map γ.externalLegs_le
  edges_supported := by
    intro e' he'
    rcases Multiset.mem_map.mp he' with ⟨e, he, rfl⟩
    have hsupp := γ.edges_supported e he
    simp [FeynmanEdge.SupportedOn] at hsupp ⊢
    exact ⟨⟨e.source, hsupp.1, rfl⟩,
      ⟨e.target, hsupp.2, rfl⟩⟩
  legs_supported := by
    intro ℓ' hℓ'
    rcases Multiset.mem_map.mp hℓ' with ⟨ℓ, hℓ, rfl⟩
    have hsupp := γ.legs_supported ℓ hℓ
    simp [ExternalLeg.SupportedOn] at hsupp ⊢
    exact ⟨ℓ.attachedTo, hsupp, rfl⟩

/-- The part of `γ.internalEdges` that remains after deleting the internal
edges of an admissible outer forest lies in the outer complement. -/
private theorem feynmanSubgraph_internalEdges_sub_admissible_internalEdges_le_complement
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (γ : FeynmanSubgraph G) :
    γ.internalEdges - A.internalEdges ≤ A.complementEdges := by
  rw [Multiset.le_iff_count]
  intro e
  unfold AdmissibleSubgraph.complementEdges
  rw [Multiset.count_sub, Multiset.count_sub]
  have hle := Multiset.count_le_of_le e γ.internalEdges_le
  omega

/-- Retarget the quotient remnant of an ambient subgraph through an admissible
outer forest.  Unlike `admissibleSubgraphRetargetSubgraph`, this removes the
outer forest's internal edges from the source subgraph first; this is the
graph-level shape of a selected component remnant `γ / B` after `B` has been
spliced into the outer forest. -/
noncomputable def admissibleSubgraphQuotientRemainderSubgraph
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) :
    FeynmanSubgraph (A.contractWithStars starOf) where
  vertices := γ.vertices.image (A.retargetVertex starOf)
  internalEdges := (γ.internalEdges - A.internalEdges).map
    (A.retargetEdge starOf)
  externalLegs := γ.externalLegs.map (A.retargetExternalLeg starOf)
  vertices_subset := by
    intro v hv
    rcases Finset.mem_image.mp hv with ⟨u, hu, rfl⟩
    exact A.retargetVertex_mem_contractWithStars_vertices starOf
      (γ.vertices_subset hu)
  internalEdges_le := by
    rw [AdmissibleSubgraph.contractWithStars_internalEdges]
    exact Multiset.map_le_map
      (feynmanSubgraph_internalEdges_sub_admissible_internalEdges_le_complement
        A γ)
  externalLegs_le := by
    rw [AdmissibleSubgraph.contractWithStars_externalLegs]
    exact Multiset.map_le_map γ.externalLegs_le
  edges_supported := by
    intro e' he'
    rcases Multiset.mem_map.mp he' with ⟨e, he, rfl⟩
    have heγ : e ∈ γ.internalEdges :=
      Multiset.mem_of_le (Multiset.sub_le_self _ _) he
    have hsupp := γ.edges_supported e heγ
    simp [FeynmanEdge.SupportedOn] at hsupp ⊢
    exact ⟨⟨e.source, hsupp.1, rfl⟩,
      ⟨e.target, hsupp.2, rfl⟩⟩
  legs_supported := by
    intro ℓ' hℓ'
    rcases Multiset.mem_map.mp hℓ' with ⟨ℓ, hℓ, rfl⟩
    have hsupp := γ.legs_supported ℓ hℓ
    simp [ExternalLeg.SupportedOn] at hsupp ⊢
    exact ⟨ℓ.attachedTo, hsupp, rfl⟩

@[simp] private theorem admissibleSubgraphQuotientRemainderSubgraph_vertices
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) :
    (admissibleSubgraphQuotientRemainderSubgraph A starOf γ).vertices =
      γ.vertices.image (A.retargetVertex starOf) := rfl

@[simp] private theorem admissibleSubgraphQuotientRemainderSubgraph_internalEdges
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) :
    (admissibleSubgraphQuotientRemainderSubgraph A starOf γ).internalEdges =
      (γ.internalEdges - A.internalEdges).map (A.retargetEdge starOf) := rfl

@[simp] private theorem admissibleSubgraphQuotientRemainderSubgraph_externalLegs
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) :
    (admissibleSubgraphQuotientRemainderSubgraph A starOf γ).externalLegs =
      γ.externalLegs.map (A.retargetExternalLeg starOf) := rfl

/--
**Reverse forest-contraction divergence reflection** (remainder level) — the
additivity companion of `IsDivergencePreservedByAdmissibleForestContract`,
stated at the granularity of `admissibleSubgraphQuotientRemainderSubgraph`
actually used by the forest cover.

The forward class says contracting a divergent source along a disjoint admissible
forest of *divergent* subdivergences yields a divergent quotient.  This class is
the *reverse* (reflection) direction: if the quotient remainder of `γ` along such
a forest is divergent **and every forest component is itself divergent**, then
`γ` itself is divergent.

Mathematically this is the Weinberg / CK power-counting additivity
`ω(γ) = ω(remainder) + Σ_{η ∈ A ∩ γ} ω(η)`: each summand is `≥ 0` under the
stated hypotheses, so `ω(γ) ≥ 0`.  It is **not** a flat-carrier semantic gap
(no counterexample — true for any power-counting measure with additivity); it
belongs to the same abstract `DivergenceMeasure` environment tier as the forward
preservation classes (`IsDivergencePreservedByAdmissibleForestContract`,
`IsAmbientInvariantDivergence`, ...), and is abstracted as a typeclass for the
same reason: its concrete derivation depends on the specific power-counting
measure in use.

Placement/visibility note: stated here (not in `ContractionPreservation`) because
it is phrased at the granularity of the `Coassoc`-local
`admissibleSubgraphQuotientRemainderSubgraph` (whose definition depends on a
`Coassoc`-local edge-subtraction lemma), which is the granularity the forest
cover actually uses.  It is **public** so the cross-file Hopf instance assembly
(`Bialgebra`/`HopfAlgebra`, which import `Coassoc`) can synthesize
`CoassocStrictForestH58CoverData` from it. -/
class IsDivergenceReflectedByAdmissibleForestContract : Prop where
  remainder_isDivergent_reflect :
    ∀ {G : FeynmanGraph} (A : AdmissibleSubgraph G)
      (_hDisj : A.IsPairwiseDisjoint)
      (_hCompNE : A.HasNonemptyComponents)
      (_hForestDiv : ∀ η ∈ A.elements, η.IsDivergent)
      (starOf : FeynmanSubgraph G → VertexId)
      (_hFresh : A.IsFreshStarAssignment starOf)
      (γ : FeynmanSubgraph G)
      (_hRemDiv :
        (admissibleSubgraphQuotientRemainderSubgraph A starOf γ).IsDivergent),
      γ.IsDivergent

/-- Re-export of the reverse forest-contraction divergence reflection with
arguments in the order used by the forest-cover source-subgraph API. -/
private theorem admissibleSubgraphQuotientRemainderSubgraph_isDivergent_reflect
    [IsDivergenceReflectedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (hDisj : A.IsPairwiseDisjoint) (hCompNE : A.HasNonemptyComponents)
    (hForestDiv : ∀ η ∈ A.elements, η.IsDivergent)
    (starOf : FeynmanSubgraph G → VertexId) (hFresh : A.IsFreshStarAssignment starOf)
    (γ : FeynmanSubgraph G)
    (hRemDiv :
      (admissibleSubgraphQuotientRemainderSubgraph A starOf γ).IsDivergent) :
    γ.IsDivergent :=
  IsDivergenceReflectedByAdmissibleForestContract.remainder_isDivergent_reflect
    A hDisj hCompNE hForestDiv starOf hFresh γ hRemDiv

/-- Sprint F2-Track-B-forest-2a-pre1: generic "source vertices" for a remainder
subgraph `δ` in the contracted graph `A.contractWithStars starOf`.  Mirror of
`forestQuotientForestSigmaForestCoverSourceVertices` with the cover-side
`r.1.1.1` carrier replaced by a generic admissible `A` and a generic star map.
Lifts `δ` back to the uncontracted graph: keep its non-star vertices, and splice
in the full vertex set of every `A`-component whose star appears in `δ`.  Used
by the `forest_inj` parent-recovery (B-forest-2). -/
private noncomputable def admissibleSubgraphRemainderSourceVertices
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (δ : FeynmanSubgraph (A.contractWithStars starOf)) :
    Finset VertexId :=
  (δ.vertices \ A.starVertices starOf) ∪
    A.elements.biUnion (fun η => if starOf η ∈ δ.vertices then η.vertices else ∅)

/-- Sprint F2-Track-B-forest-2a-pre1: membership characterization of the generic
remainder source vertices. -/
private theorem mem_admissibleSubgraphRemainderSourceVertices
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (δ : FeynmanSubgraph (A.contractWithStars starOf)) {v : VertexId} :
    v ∈ admissibleSubgraphRemainderSourceVertices A starOf δ ↔
      (v ∈ δ.vertices ∧ v ∉ A.starVertices starOf) ∨
      (∃ η ∈ A.elements, starOf η ∈ δ.vertices ∧ v ∈ η.vertices) := by
  classical
  unfold admissibleSubgraphRemainderSourceVertices
  rw [Finset.mem_union, Finset.mem_sdiff, Finset.mem_biUnion]
  constructor
  · rintro (h | ⟨η, hη, hv⟩)
    · exact Or.inl h
    · by_cases hc : starOf η ∈ δ.vertices
      · rw [if_pos hc] at hv; exact Or.inr ⟨η, hη, hc, hv⟩
      · rw [if_neg hc] at hv; simp at hv
  · rintro (h | ⟨η, hη, hc, hv⟩)
    · exact Or.inl h
    · exact Or.inr ⟨η, hη, by rw [if_pos hc]; exact hv⟩

/-- Sprint F2-Track-B-forest-2a-pre2: the canonical star of an `A`-component `η`
appears in the remainder vertices of `γ` iff `η` shares a vertex with `γ`.
Forward: a γ-vertex retargeting to `starOf η` must lie in η's component (the
non-carrier branch is excluded because canonical stars are fresh, outside `G`).
Backward: a shared vertex retargets to `starOf η` (`retargetVertex_of_mem_component`). -/
private theorem admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
    {G : FeynmanGraph}
    (A : AdmissibleSubgraph G)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (γ : FeynmanSubgraph G) {η : FeynmanSubgraph G} (hη : η ∈ A.elements) :
    FeynmanGraph.admissibleForestCanonicalStarOf G A hA η ∈
        (admissibleSubgraphQuotientRemainderSubgraph A
          (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) γ).vertices ↔
      ∃ v, v ∈ η.vertices ∧ v ∈ γ.vertices := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf G A hA with hstarOf
  have hPD : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hFresh : A.IsFreshStarAssignment starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment G A hA
  rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
  constructor
  · intro h
    obtain ⟨v, hvγ, hret⟩ := Finset.mem_image.mp h
    by_cases hvA : v ∈ A.vertices
    · have hcomp : A.retargetVertex starOf v = starOf (A.componentAt hvA) := by
        rw [AdmissibleSubgraph.retargetVertex, A.componentAt?_of_mem hvA]
      rw [hcomp] at hret
      have hCompEq : A.componentAt hvA = η :=
        hFresh.eq_of_star_eq (A.componentAt_mem hvA) hη hret
      exact ⟨v, by rw [← hCompEq]; exact A.componentAt_vertex_mem hvA, hvγ⟩
    · rw [AdmissibleSubgraph.retargetVertex_of_not_mem A starOf hvA] at hret
      -- hret : v = starOf η, but v ∈ γ.vertices ⊆ G.vertices and starOf η ∉ G.vertices
      exact absurd (hret ▸ γ.vertices_subset hvγ) (hFresh.fresh hη)
  · rintro ⟨v, hvη, hvγ⟩
    exact Finset.mem_image.mpr
      ⟨v, hvγ, AdmissibleSubgraph.retargetVertex_of_mem_component hPD starOf hη hvη⟩

/-- If every vertex of `γ` lies outside the outer admissible carrier, then
retargeting `γ` through that outer forest leaves the vertex carrier unchanged. -/
private theorem admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) (hEdges : γ.internalEdges ≤ A.complementEdges)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).vertices =
      γ.vertices := by
  ext v
  constructor
  · intro hv
    rcases Finset.mem_image.mp hv with ⟨u, hu, huv⟩
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem A starOf (hV u hu)] at huv
    exact huv ▸ hu
  · intro hv
    exact Finset.mem_image.mpr
      ⟨v, hv, AdmissibleSubgraph.retargetVertex_of_not_mem A starOf (hV v hv)⟩

/-- If `γ` is vertex-disjoint from the outer carrier, edge retargeting is the
identity on every internal edge of `γ`. -/
private theorem admissibleSubgraphRetargetEdge_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices)
    {e : FeynmanEdge} (he : e ∈ γ.internalEdges) :
    A.retargetEdge starOf e = e := by
  have hsupp := γ.edges_supported e he
  simp [FeynmanEdge.SupportedOn] at hsupp
  cases e
  simp [AdmissibleSubgraph.retargetEdge,
    AdmissibleSubgraph.retargetVertex_of_not_mem A starOf (hV _ hsupp.1),
    AdmissibleSubgraph.retargetVertex_of_not_mem A starOf (hV _ hsupp.2)]

/-- If `γ` is vertex-disjoint from the outer carrier, external-leg retargeting
is the identity on every external leg of `γ`. -/
private theorem admissibleSubgraphRetargetExternalLeg_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices)
    {ℓ : ExternalLeg} (hℓ : ℓ ∈ γ.externalLegs) :
    A.retargetExternalLeg starOf ℓ = ℓ := by
  have hsupp := γ.legs_supported ℓ hℓ
  simp [ExternalLeg.SupportedOn] at hsupp
  cases ℓ
  simp [AdmissibleSubgraph.retargetExternalLeg,
    AdmissibleSubgraph.retargetVertex_of_not_mem A starOf (hV _ hsupp)]

/-- If every vertex of `γ` lies outside the outer admissible carrier, then
retargeting `γ` through that outer forest leaves its internal-edge carrier
unchanged. -/
private theorem admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) (hEdges : γ.internalEdges ≤ A.complementEdges)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).internalEdges =
      γ.internalEdges := by
  calc
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).internalEdges
        = γ.internalEdges.map id := by
          exact Multiset.map_congr rfl
            (fun e he => admissibleSubgraphRetargetEdge_eq_of_not_mem
              A starOf γ hV he)
    _ = γ.internalEdges := Multiset.map_id _

/-- If every vertex of `γ` lies outside the outer admissible carrier, then
retargeting `γ` through that outer forest leaves its external-leg carrier
unchanged. -/
private theorem admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) (hEdges : γ.internalEdges ≤ A.complementEdges)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).externalLegs =
      γ.externalLegs := by
  calc
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).externalLegs
        = γ.externalLegs.map id := by
          exact Multiset.map_congr rfl
            (fun ℓ hℓ => admissibleSubgraphRetargetExternalLeg_eq_of_not_mem
              A starOf γ hV hℓ)
    _ = γ.externalLegs := Multiset.map_id _

/-- If `γ` is vertex-disjoint from the outer carrier, its retargeted quotient
subgraph has the same intrinsic graph as `γ`. -/
private theorem admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ : FeynmanSubgraph G) (hEdges : γ.internalEdges ≤ A.complementEdges)
    (hV : ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    (admissibleSubgraphRetargetSubgraph A starOf γ hEdges).toFeynmanGraph =
      γ.toFeynmanGraph := by
  apply FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr
  exact ⟨
    admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      A starOf γ hEdges hV,
    admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
      A starOf γ hEdges hV,
    admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
      A starOf γ hEdges hV⟩

/-- Nonnegativity of the divergence degree of a full self-subgraph transports
across literal equality of ambient graphs. -/
private theorem feynmanGraph_self_degree_nonneg_of_eq
    {G₁ G₂ : FeynmanGraph}
    (hEq : G₂ = G₁) (hWF₁ : G₁.WellFormed) (hWF₂ : G₂.WellFormed)
    (h : 0 ≤ DivergenceMeasure.degree (FeynmanSubgraph.self G₁ hWF₁)) :
    0 ≤ DivergenceMeasure.degree (FeynmanSubgraph.self G₂ hWF₂) := by
  cases hEq
  simpa using h

/-- Connected-divergence transports across literal equality of intrinsic
subgraph graphs. -/
private theorem feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq
    {G₁ G₂ : FeynmanGraph}
    {γ₁ : FeynmanSubgraph G₁} {γ₂ : FeynmanSubgraph G₂}
    (hEq : γ₂.toFeynmanGraph = γ₁.toFeynmanGraph)
    (hγ : γ₁.IsConnectedDivergent) :
    γ₂.IsConnectedDivergent := by
  refine ⟨?_, ?_, ?_⟩
  · show γ₂.toFeynmanGraph.IsSupportConnected
    rw [hEq]
    exact hγ.isConnected
  · show γ₂.toFeynmanGraph.IsOnePI
    rw [hEq]
    exact hγ.isOnePI
  · unfold FeynmanSubgraph.IsDivergent FeynmanSubgraph.divergenceDegree
    rw [← IsAmbientInvariantDivergence.degree_self_eq γ₂]
    have hγDiv : 0 ≤ DivergenceMeasure.degree γ₁ := by
      simpa [FeynmanSubgraph.IsDivergent, FeynmanSubgraph.divergenceDegree]
        using hγ.isDivergent
    have hSelf :
        0 ≤ DivergenceMeasure.degree
          (FeynmanSubgraph.self γ₁.toFeynmanGraph
            γ₁.toFeynmanGraph_wellFormed) := by
      rw [IsAmbientInvariantDivergence.degree_self_eq γ₁]
      exact hγDiv
    exact feynmanGraph_self_degree_nonneg_of_eq hEq
      γ₁.toFeynmanGraph_wellFormed γ₂.toFeynmanGraph_wellFormed hSelf

/-- Forest contraction with an arbitrary fresh component-star assignment
preserves connected-divergence under the same ambient preservation hypotheses
used by the canonical-star API. -/
private theorem admissibleForestContractGraphWithStars_isConnectedDivergent
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (hGwf : G.WellFormed)
    (hG1PI : G.IsOnePI) (hGCD : G.IsConnectedDivergent)
    (A : AdmissibleSubgraph G)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (starOf : FeynmanSubgraph G → VertexId)
    (hFresh : A.IsFreshStarAssignment starOf) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
      ).IsConnectedDivergent := by
  let Q := FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
  have hDisj : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hCompNE : A.HasNonemptyComponents :=
    G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hA
  have hWF : Q.WellFormed := by
    dsimp [Q, FeynmanGraph.admissibleForestContractGraphWithStars]
    exact A.contractWithStars_wellFormed starOf hGwf
  have hConn : Q.IsSupportConnected := by
    dsimp [Q, FeynmanGraph.admissibleForestContractGraphWithStars]
    exact A.contractWithStars_isSupportConnected hG1PI.isSupportConnected
      hDisj hCompNE starOf
  have hEraseConn :
      ∀ e : FeynmanEdge, e ∈ Q.internalEdges →
        (Q.eraseInternalEdge e).IsSupportConnected := by
    intro e' he'
    dsimp [Q, FeynmanGraph.admissibleForestContractGraphWithStars] at he' ⊢
    rcases AdmissibleSubgraph.mem_contractWithStars_internalEdges.mp he' with
      ⟨e, he, heq⟩
    rw [← heq]
    have heG : e ∈ G.internalEdges :=
      A.mem_ambientInternalEdges_of_mem_complementEdges he
    have hNoBridge : ¬ G.IsBridge e := hG1PI.no_bridge e heG
    have hGErase : (G.eraseInternalEdge e).IsSupportConnected := by
      by_contra hnot
      exact hNoBridge ⟨heG, hnot⟩
    exact A.contractWithStars_eraseInternalEdge_isSupportConnected
      he hGErase hDisj hCompNE starOf
  have hOnePI : Q.IsOnePI := by
    refine ⟨hConn, ?_⟩
    intro e he hBridge
    exact hBridge.not_supportConnected_of_erase (hEraseConn e he)
  have hDiv :
      (FeynmanSubgraph.self Q hWF).IsDivergent := by
    have hGDiv : (FeynmanSubgraph.self G hGwf).IsDivergent := by
      convert hGCD.self_isConnectedDivergent.isDivergent
    dsimp [Q, FeynmanGraph.admissibleForestContractGraphWithStars] at hWF ⊢
    exact A.contractWithStars_isDivergent hGwf hGDiv hDisj hCompNE
      starOf hFresh hWF
  exact ⟨hWF, hConn, hOnePI, hDiv⟩

/-- Promote an inner subgraph from the component ambient
`γ_outer.toFeynmanGraph` back to the original ambient graph.  The data fields
are unchanged; only the subset witnesses are composed. -/
private def feynmanSubgraphPromote
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    FeynmanSubgraph G where
  vertices := γ_inner.vertices
  internalEdges := γ_inner.internalEdges
  externalLegs := γ_inner.externalLegs
  vertices_subset := γ_inner.vertices_subset.trans γ_outer.vertices_subset
  internalEdges_le := γ_inner.internalEdges_le.trans γ_outer.internalEdges_le
  externalLegs_le := γ_inner.externalLegs_le.trans γ_outer.externalLegs_le
  edges_supported := γ_inner.edges_supported
  legs_supported := γ_inner.legs_supported

@[simp] private theorem feynmanSubgraphPromote_vertices
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).vertices =
      γ_inner.vertices := rfl

@[simp] private theorem feynmanSubgraphPromote_internalEdges
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).internalEdges =
      γ_inner.internalEdges := rfl

@[simp] private theorem feynmanSubgraphPromote_externalLegs
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).externalLegs =
      γ_inner.externalLegs := rfl

@[simp] private theorem feynmanSubgraphPromote_toFeynmanGraph
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).toFeynmanGraph =
      γ_inner.toFeynmanGraph := rfl

/-- Connected-divergence is unchanged by component-to-ambient promotion. -/
private theorem feynmanSubgraphPromote_isConnectedDivergent
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph}
    (hγ : γ_inner.IsConnectedDivergent) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).IsConnectedDivergent :=
  feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq
    (γ₁ := γ_inner)
    (γ₂ := feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner)
    rfl hγ

/-- Component-to-ambient promotion is injective on the raw subgraph data. -/
private theorem feynmanSubgraphPromote_injective
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G} :
    Function.Injective
      (fun γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph =>
        feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner) := by
  intro γ₁ γ₂ h
  apply FeynmanSubgraph.ext_iff.mpr
  exact ⟨by simpa [feynmanSubgraphPromote] using
        congrArg FeynmanSubgraph.vertices h,
    by simpa [feynmanSubgraphPromote] using
        congrArg FeynmanSubgraph.internalEdges h,
    by simpa [feynmanSubgraphPromote] using
        congrArg FeynmanSubgraph.externalLegs h⟩

/-- Zimmermann compatibility is unchanged by component-to-ambient promotion. -/
private theorem feynmanSubgraphPromote_nestedOrDisjoint
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {γ₁ γ₂ : FeynmanSubgraph γ_outer.toFeynmanGraph}
    (h : γ₁.NestedOrDisjoint γ₂) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ₁).NestedOrDisjoint
      (feynmanSubgraphPromote (γ_outer := γ_outer) γ₂) := by
  simpa [FeynmanSubgraph.NestedOrDisjoint, FeynmanSubgraph.Nested,
    FeynmanSubgraph.Disjoint, FeynmanSubgraph.le_def] using h

/-- Promote every component of an admissible forest living in
`γ_outer.toFeynmanGraph` back to the original ambient graph. -/
private noncomputable def feynmanSubgraphPromoteAdmissibleSubgraph
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (B : AdmissibleSubgraph γ_outer.toFeynmanGraph) :
    AdmissibleSubgraph G :=
  AdmissibleSubgraph.ofElements
    (B.elements.attach.image fun γ =>
      feynmanSubgraphPromote (γ_outer := γ_outer) γ.1)
    (by
      constructor
      · intro γ' hγ'
        rcases Finset.mem_image.mp hγ' with ⟨γ, _hγ, rfl⟩
        exact feynmanSubgraphPromote_isConnectedDivergent
          (B.isConnectedDivergent γ.1 γ.2)
      · intro γ₁' h₁ γ₂' h₂ hne
        rcases Finset.mem_image.mp h₁ with ⟨γ₁, _hγ₁, rfl⟩
        rcases Finset.mem_image.mp h₂ with ⟨γ₂, _hγ₂, rfl⟩
        have hne' : γ₁.1 ≠ γ₂.1 := by
          intro hEq
          apply hne
          rw [hEq]
        exact feynmanSubgraphPromote_nestedOrDisjoint
          (B.forest.nestedOrDisjoint γ₁.2 γ₂.2 hne'))

@[simp] private theorem feynmanSubgraphPromoteAdmissibleSubgraph_elements
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (B : AdmissibleSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).elements =
      B.elements.attach.image fun γ =>
        feynmanSubgraphPromote (γ_outer := γ_outer) γ.1 := rfl

@[simp] private theorem feynmanSubgraphPromoteAdmissibleSubgraph_internalEdges
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (B : AdmissibleSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).internalEdges = B.internalEdges := by
  classical
  unfold AdmissibleSubgraph.internalEdges
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements]
  rw [Finset.sum_image]
  · simpa using (B.elements.sum_attach fun γ => γ.internalEdges)
  · intro γ₁ _ γ₂ _ hEq
    exact Subtype.ext (feynmanSubgraphPromote_injective hEq)

/-- Component-to-ambient promotion preserves nonempty subgraphs. -/
private theorem feynmanSubgraphPromote_isNonempty
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph}
    (hγ : γ_inner.IsNonempty) :
    (feynmanSubgraphPromote (γ_outer := γ_outer) γ_inner).IsNonempty := by
  unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hγ ⊢
  simpa using hγ

/-- Pairwise disjointness is preserved by promoting every component. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_isPairwiseDisjoint
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (hB : B.IsPairwiseDisjoint) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).IsPairwiseDisjoint := by
  intro γ₁' h₁ γ₂' h₂ hne
  change γ₁' ∈ (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).elements at h₁
  change γ₂' ∈ (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).elements at h₂
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at h₁ h₂
  rcases Finset.mem_image.mp h₁ with ⟨γ₁, _hγ₁, rfl⟩
  rcases Finset.mem_image.mp h₂ with ⟨γ₂, _hγ₂, rfl⟩
  have hne' : γ₁.1 ≠ γ₂.1 := by
    intro hEq
    apply hne
    rw [hEq]
  have hDisj : γ₁.1.Disjoint γ₂.1 := hB γ₁.2 γ₂.2 hne'
  unfold FeynmanSubgraph.Disjoint at hDisj ⊢
  simpa using hDisj

/-- Nonemptiness is preserved by promoting every component. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_isNonempty
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (hB : B.IsNonempty) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).IsNonempty := by
  rcases hB with ⟨γ, hγ⟩
  refine ⟨feynmanSubgraphPromote (γ_outer := γ_outer) γ, ?_⟩
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements]
  exact Finset.mem_image.mpr ⟨⟨γ, hγ⟩, Finset.mem_attach _ _, rfl⟩

/-- Component nonemptiness is preserved by promoting every component. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_hasNonemptyComponents
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (hB : B.HasNonemptyComponents) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).HasNonemptyComponents := by
  intro γ' hγ'
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hγ'
  rcases Finset.mem_image.mp hγ' with ⟨γ, _hγ, rfl⟩
  exact feynmanSubgraphPromote_isNonempty (hB γ.1 γ.2)

/-- Positive internal-edge components are preserved by promoting every
component. -/
private theorem
    feynmanSubgraphPromoteAdmissibleSubgraph_hasPositiveInternalEdgesComponents
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (hB : B.HasPositiveInternalEdgesComponents) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).HasPositiveInternalEdgesComponents := by
  intro γ' hγ'
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hγ'
  rcases Finset.mem_image.mp hγ' with ⟨γ, _hγ, rfl⟩
  simpa using hB γ.1 γ.2

/-- Proper-disjoint membership is preserved by promoting a component forest
to the original ambient graph. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_mem_properDisjoint
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (hB : B ∈ γ_outer.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs) :
    feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ_outer) B ∈
      G.properDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_properDisjointAdmissibleDivergentSubgraphs]
  have hBProper :=
    (γ_outer.toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs B).mp hB
  have hBNonemptyDisjoint :
      B ∈ γ_outer.toFeynmanGraph.nonemptyDisjointAdmissibleDivergentSubgraphs :=
    hBProper.1
  have hBDisjoint :
      B ∈ γ_outer.toFeynmanGraph.disjointAdmissibleDivergentSubgraphs :=
    ((γ_outer.toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs B).mp
      hBNonemptyDisjoint).1
  have hBIsDisjoint : B.IsPairwiseDisjoint :=
    ((γ_outer.toFeynmanGraph.mem_disjointAdmissibleDivergentSubgraphs B).mp
      hBDisjoint).2
  have hBIsNonempty : B.IsNonempty :=
    ((γ_outer.toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs B).mp
      hBNonemptyDisjoint).2
  have hTargetDisjoint :
      (feynmanSubgraphPromoteAdmissibleSubgraph
        (γ_outer := γ_outer) B).IsPairwiseDisjoint :=
    feynmanSubgraphPromoteAdmissibleSubgraph_isPairwiseDisjoint hBIsDisjoint
  have hTargetNonempty :
      (feynmanSubgraphPromoteAdmissibleSubgraph
        (γ_outer := γ_outer) B).IsNonempty :=
    feynmanSubgraphPromoteAdmissibleSubgraph_isNonempty hBIsNonempty
  have hTargetNonemptyComponents :
      (feynmanSubgraphPromoteAdmissibleSubgraph
        (γ_outer := γ_outer) B).HasNonemptyComponents :=
    feynmanSubgraphPromoteAdmissibleSubgraph_hasNonemptyComponents
      hBProper.2.1
  have hTargetPositiveComponents :
      (feynmanSubgraphPromoteAdmissibleSubgraph
        (γ_outer := γ_outer) B).HasPositiveInternalEdgesComponents :=
    feynmanSubgraphPromoteAdmissibleSubgraph_hasPositiveInternalEdgesComponents
      hBProper.2.2.2
  refine ⟨?_, hTargetNonemptyComponents, ?_, hTargetPositiveComponents⟩
  · rw [G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
      G.mem_disjointAdmissibleDivergentSubgraphs]
    exact ⟨⟨G.mem_admissibleDivergentSubgraphs _,
        hTargetDisjoint⟩, hTargetNonempty⟩
  · exact admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
      hTargetPositiveComponents hTargetNonempty

/-- One promoted component has the same Hopf generator as its source
component in the intrinsic component graph. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_componentToHopfH_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (B : AdmissibleSubgraph γ_outer.toFeynmanGraph)
    (γ : FeynmanSubgraph γ_outer.toFeynmanGraph) (hγ : γ ∈ B.elements) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).componentToHopfH
        (feynmanSubgraphPromote (γ_outer := γ_outer) γ) =
      B.componentToHopfH γ := by
  classical
  unfold AdmissibleSubgraph.componentToHopfH
  have hγ' :
      feynmanSubgraphPromote (γ_outer := γ_outer) γ ∈
        (feynmanSubgraphPromoteAdmissibleSubgraph
          (γ_outer := γ_outer) B).elements := by
    rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements]
    exact Finset.mem_image.mpr ⟨⟨γ, hγ⟩, Finset.mem_attach _ _, rfl⟩
  rw [dif_pos hγ', dif_pos hγ]
  have hGen :
      (feynmanSubgraphPromote (γ_outer := γ_outer) γ).toHopfGen
          ((feynmanSubgraphPromoteAdmissibleSubgraph
            (γ_outer := γ_outer) B).isConnectedDivergent_of_mem hγ') =
        γ.toHopfGen (B.isConnectedDivergent_of_mem hγ) :=
    Subtype.ext rfl
  rw [hGen]

/-- Promoting an admissible component forest back to the ambient graph
preserves the Hopf product of its components. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_toHopfH
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    (B : AdmissibleSubgraph γ_outer.toFeynmanGraph) :
    (feynmanSubgraphPromoteAdmissibleSubgraph
      (γ_outer := γ_outer) B).toHopfH = B.toHopfH := by
  classical
  unfold AdmissibleSubgraph.toHopfH
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements]
  rw [Finset.prod_image]
  · rw [← Finset.prod_attach B.elements
      (fun γ => B.componentToHopfH γ)]
    exact Finset.prod_congr rfl
      (fun γ _hγ =>
        feynmanSubgraphPromoteAdmissibleSubgraph_componentToHopfH_eq
          B γ.1 γ.2)
  · intro γ₁ _ γ₂ _ heq
    exact Subtype.ext (feynmanSubgraphPromote_injective heq)

/-- Zimmermann compatibility transports across retargeting when both source
subgraphs are untouched by the outer carrier. -/
private theorem admissibleSubgraphRetargetSubgraph_nestedOrDisjoint_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (γ₁ γ₂ : FeynmanSubgraph G)
    (hEdges₁ : γ₁.internalEdges ≤ A.complementEdges)
    (hEdges₂ : γ₂.internalEdges ≤ A.complementEdges)
    (hV₁ : ∀ v ∈ γ₁.vertices, v ∉ A.vertices)
    (hV₂ : ∀ v ∈ γ₂.vertices, v ∉ A.vertices)
    (h : γ₁.NestedOrDisjoint γ₂) :
    (admissibleSubgraphRetargetSubgraph A starOf γ₁ hEdges₁).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂ hEdges₂) := by
  have hVeq₁ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
    A starOf γ₁ hEdges₁ hV₁
  have hVeq₂ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
    A starOf γ₂ hEdges₂ hV₂
  have hIeq₁ := admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    A starOf γ₁ hEdges₁ hV₁
  have hIeq₂ := admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    A starOf γ₂ hEdges₂ hV₂
  have hEeq₁ := admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
    A starOf γ₁ hEdges₁ hV₁
  have hEeq₂ := admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
    A starOf γ₂ hEdges₂ hV₂
  rcases h with hNested | hDisj
  · left
    rcases hNested with hle | hle
    · left
      rw [FeynmanSubgraph.le_def] at hle ⊢
      exact ⟨by simpa [hVeq₁, hVeq₂] using hle.1,
        by simpa [hIeq₁, hIeq₂] using hle.2.1,
        by simpa [hEeq₁, hEeq₂] using hle.2.2⟩
    · right
      rw [FeynmanSubgraph.le_def] at hle ⊢
      exact ⟨by simpa [hVeq₁, hVeq₂] using hle.1,
        by simpa [hIeq₁, hIeq₂] using hle.2.1,
        by simpa [hEeq₁, hEeq₂] using hle.2.2⟩
  · right
    unfold FeynmanSubgraph.Disjoint at hDisj ⊢
    simpa [hVeq₁, hVeq₂] using hDisj

/-- Retarget a source admissible forest into `G / A`.  The caller supplies the
graph facts that the retargeted components are connected-divergent and remain
Zimmermann-compatible.  This is the shared quotient-side constructor used by
the right-selected forest and by promoted genuine forest choices. -/
private noncomputable def admissibleSubgraphRetarget
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A starOf γ₁
        (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂
        (hEdges γ₂ hγ₂))) :
    AdmissibleSubgraph (A.contractWithStars starOf) :=
  AdmissibleSubgraph.ofElements
    (B.elements.attach.image fun γ =>
      admissibleSubgraphRetargetSubgraph A starOf γ.1
        (hEdges γ.1 γ.2))
    (by
      constructor
      · intro γ' hγ'
        rcases Finset.mem_image.mp hγ' with ⟨γ, _hγ, rfl⟩
        exact hCD γ.1 γ.2
      · intro γ₁' h₁ γ₂' h₂ _hne
        rcases Finset.mem_image.mp h₁ with ⟨γ₁, _hγ₁, rfl⟩
        rcases Finset.mem_image.mp h₂ with ⟨γ₂, _hγ₂, rfl⟩
        exact hCompat γ₁.1 γ₁.2 γ₂.1 γ₂.2)

@[simp] private theorem admissibleSubgraphRetarget_elements
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A starOf γ₁
        (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂
        (hEdges γ₂ hγ₂))) :
    (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements =
      B.elements.attach.image fun γ =>
        admissibleSubgraphRetargetSubgraph A starOf γ.1
          (hEdges γ.1 γ.2) := rfl

/-- Retargeting components untouched by the outer carrier is injective on the
source admissible forest. -/
private theorem admissibleSubgraphRetarget_injective_of_not_mem
    {G : FeynmanGraph}
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    Function.Injective (fun γ : {γ : FeynmanSubgraph G // γ ∈ B.elements} =>
      admissibleSubgraphRetargetSubgraph A starOf γ.1
        (hEdges γ.1 γ.2)) := by
  intro γ₁ γ₂ heq
  apply Subtype.ext
  apply FeynmanSubgraph.ext_iff.mpr
  have hVeq₁ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
    A starOf γ₁.1 (hEdges γ₁.1 γ₁.2) (hV γ₁.1 γ₁.2)
  have hVeq₂ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
    A starOf γ₂.1 (hEdges γ₂.1 γ₂.2) (hV γ₂.1 γ₂.2)
  have hIeq₁ := admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    A starOf γ₁.1 (hEdges γ₁.1 γ₁.2) (hV γ₁.1 γ₁.2)
  have hIeq₂ := admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    A starOf γ₂.1 (hEdges γ₂.1 γ₂.2) (hV γ₂.1 γ₂.2)
  have hEeq₁ := admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
    A starOf γ₁.1 (hEdges γ₁.1 γ₁.2) (hV γ₁.1 γ₁.2)
  have hEeq₂ := admissibleSubgraphRetargetSubgraph_externalLegs_eq_of_not_mem
    A starOf γ₂.1 (hEdges γ₂.1 γ₂.2) (hV γ₂.1 γ₂.2)
  refine ⟨?_, ?_, ?_⟩
  · have h := congrArg FeynmanSubgraph.vertices heq
    simpa [hVeq₁, hVeq₂] using h
  · have h := congrArg FeynmanSubgraph.internalEdges heq
    simpa [hIeq₁, hIeq₂] using h
  · have h := congrArg FeynmanSubgraph.externalLegs heq
    simpa [hEeq₁, hEeq₂] using h

/-- One component's Hopf factor is unchanged by retargeting when the component
is vertex-disjoint from the outer carrier. -/
private theorem admissibleSubgraphRetarget_componentToHopfH_eq_of_not_mem
    {G : FeynmanGraph}
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A starOf γ₁
        (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂
        (hEdges γ₂ hγ₂)))
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.vertices)
    (γ : FeynmanSubgraph G) (hγ : γ ∈ B.elements) :
    (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).componentToHopfH
      (admissibleSubgraphRetargetSubgraph A starOf γ (hEdges γ hγ)) =
        B.componentToHopfH γ := by
  classical
  unfold AdmissibleSubgraph.componentToHopfH
  have hγ' :
      admissibleSubgraphRetargetSubgraph A starOf γ (hEdges γ hγ) ∈
        (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements := by
    rw [admissibleSubgraphRetarget_elements]
    exact Finset.mem_image.mpr
      ⟨⟨γ, hγ⟩, Finset.mem_attach B.elements ⟨γ, hγ⟩, rfl⟩
  rw [dif_pos hγ', dif_pos hγ]
  have hGraphEq :=
    admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem
      A starOf γ (hEdges γ hγ) (hV γ hγ)
  have hGen :
      (admissibleSubgraphRetargetSubgraph A starOf γ
          (hEdges γ hγ)).toHopfGen
          ((admissibleSubgraphRetarget A starOf B hEdges hCD hCompat
            ).isConnectedDivergent_of_mem hγ') =
        γ.toHopfGen (B.isConnectedDivergent_of_mem hγ) :=
    Subtype.ext (congrArg FeynmanGraph.toClass hGraphEq)
  rw [hGen]

/-- Retargeting an untouched admissible forest into an outer quotient preserves
its Hopf product. -/
private theorem admissibleSubgraphRetarget_toHopfH_eq_of_not_mem
    {G : FeynmanGraph}
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A starOf γ₁
        (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂
        (hEdges γ₂ hγ₂)))
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).toHopfH =
      B.toHopfH := by
  classical
  unfold AdmissibleSubgraph.toHopfH
  rw [admissibleSubgraphRetarget_elements]
  rw [Finset.prod_image]
  · refine Finset.prod_bij (fun γ _ => γ.1) ?_ ?_ ?_ ?_
    · intro γ _
      exact γ.2
    · intro γ₁ _ γ₂ _ hγ
      exact Subtype.ext hγ
    · intro γ hγ
      exact ⟨⟨γ, hγ⟩, Finset.mem_attach B.elements ⟨γ, hγ⟩, rfl⟩
    · intro γ _
      exact admissibleSubgraphRetarget_componentToHopfH_eq_of_not_mem
        A starOf B hEdges hCD hCompat hV γ.1 γ.2
  · intro γ₁ _ γ₂ _ heq
    exact admissibleSubgraphRetarget_injective_of_not_mem
      A starOf B hEdges hV heq

/-- Proper-disjoint membership survives retargeting for a source forest whose
components are untouched by the outer admissible carrier. -/
private theorem admissibleSubgraphRetarget_mem_properDisjoint_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    (B : AdmissibleSubgraph G)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A starOf γ₁
        (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A starOf γ₂
        (hEdges γ₂ hγ₂)))
    (hB :
      B ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.vertices) :
    admissibleSubgraphRetarget A starOf B hEdges hCD hCompat ∈
      (A.contractWithStars starOf).properDisjointAdmissibleDivergentSubgraphs := by
  classical
  let R := admissibleSubgraphRetarget A starOf B hEdges hCD hCompat
  rw [(A.contractWithStars starOf).mem_properDisjointAdmissibleDivergentSubgraphs]
  have hBProper :=
    (G.mem_properDisjointAdmissibleDivergentSubgraphs B).mp hB
  have hBNonemptyDisjoint :
      B ∈ G.nonemptyDisjointAdmissibleDivergentSubgraphs :=
    hBProper.1
  have hBDisjoint :
      B ∈ G.disjointAdmissibleDivergentSubgraphs :=
    ((G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs B).mp
      hBNonemptyDisjoint).1
  have hBIsDisjoint : B.IsPairwiseDisjoint :=
    ((G.mem_disjointAdmissibleDivergentSubgraphs B).mp hBDisjoint).2
  have hBIsNonempty : B.IsNonempty :=
    ((G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs B).mp
      hBNonemptyDisjoint).2
  have hTargetDisjoint : R.IsPairwiseDisjoint := by
    intro δ₁ hδ₁ δ₂ hδ₂ hne
    change δ₁ ∈
      (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements at hδ₁
    change δ₂ ∈
      (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements at hδ₂
    rw [admissibleSubgraphRetarget_elements] at hδ₁ hδ₂
    rcases Finset.mem_image.mp hδ₁ with ⟨γ₁, _hγ₁, rfl⟩
    rcases Finset.mem_image.mp hδ₂ with ⟨γ₂, _hγ₂, rfl⟩
    by_cases hγ : γ₁.1 = γ₂.1
    · have hγSubtype : γ₁ = γ₂ := Subtype.ext hγ
      subst γ₂
      exact False.elim (hne rfl)
    · have hDisj : γ₁.1.Disjoint γ₂.1 :=
        hBIsDisjoint γ₁.2 γ₂.2 hγ
      have hVeq₁ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        A starOf γ₁.1 (hEdges γ₁.1 γ₁.2) (hV γ₁.1 γ₁.2)
      have hVeq₂ := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        A starOf γ₂.1 (hEdges γ₂.1 γ₂.2) (hV γ₂.1 γ₂.2)
      unfold FeynmanSubgraph.Disjoint at hDisj ⊢
      simpa [hVeq₁, hVeq₂] using hDisj
  have hTargetNonempty : R.IsNonempty := by
    rcases hBIsNonempty with ⟨γ, hγ⟩
    refine ⟨admissibleSubgraphRetargetSubgraph A starOf γ
      (hEdges γ hγ), ?_⟩
    change admissibleSubgraphRetargetSubgraph A starOf γ
        (hEdges γ hγ) ∈
          (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements
    rw [admissibleSubgraphRetarget_elements]
    exact Finset.mem_image.mpr ⟨⟨γ, hγ⟩,
      Finset.mem_attach B.elements ⟨γ, hγ⟩, rfl⟩
  have hTargetNonemptyComponents : R.HasNonemptyComponents := by
    intro δ hδ
    change δ ∈
      (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements at hδ
    rw [admissibleSubgraphRetarget_elements] at hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, _hγ, rfl⟩
    have hVeq := admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      A starOf γ.1 (hEdges γ.1 γ.2) (hV γ.1 γ.2)
    have hSource : γ.1.IsNonempty := hBProper.2.1 γ.1 γ.2
    unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hSource ⊢
    simpa [hVeq] using hSource
  have hTargetPositiveComponents : R.HasPositiveInternalEdgesComponents := by
    intro δ hδ
    change δ ∈
      (admissibleSubgraphRetarget A starOf B hEdges hCD hCompat).elements at hδ
    rw [admissibleSubgraphRetarget_elements] at hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, _hγ, rfl⟩
    have hIeq := admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
      A starOf γ.1 (hEdges γ.1 γ.2) (hV γ.1 γ.2)
    simpa [hIeq] using hBProper.2.2.2 γ.1 γ.2
  refine ⟨?_, hTargetNonemptyComponents, ?_, hTargetPositiveComponents⟩
  · rw [(A.contractWithStars starOf).mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
      (A.contractWithStars starOf).mem_disjointAdmissibleDivergentSubgraphs]
    exact ⟨⟨(A.contractWithStars starOf).mem_admissibleDivergentSubgraphs R,
      hTargetDisjoint⟩, hTargetNonempty⟩
  · exact admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
      hTargetPositiveComponents hTargetNonempty

/-- Actual quotient-side retargeting for an attached outer forest.  The source
forest `B` is an ambient forest in `Γ`; in applications it is either the
right-selected forest or a promoted genuine forest-choice carrier. -/
private noncomputable def forestOuterActualRetargetAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.1.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₁ (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₂ (hEdges γ₂ hγ₂))) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g A) :=
  admissibleSubgraphRetarget A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    B hEdges hCD hCompat

/-- Vertex-disjointness is preserved by the ambient graph permutation
transport used by `mapPermSubgraph`. -/
private theorem mapPermSubgraph_disjoint
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {γ₁ γ₂ : FeynmanSubgraph G₁}
    (h : γ₁.Disjoint γ₂) :
    (mapPermSubgraph hπ γ₁).Disjoint (mapPermSubgraph hπ γ₂) := by
  unfold mapPermSubgraph
  subst hπ
  exact (FeynmanSubgraph.mapPerm_disjoint_iff π γ₁ γ₂).mpr h

/-- Zimmermann compatibility is preserved by the ambient graph permutation
transport used by `mapPermSubgraph`. -/
private theorem mapPermSubgraph_nestedOrDisjoint
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {γ₁ γ₂ : FeynmanSubgraph G₁}
    (h : γ₁.NestedOrDisjoint γ₂) :
    (mapPermSubgraph hπ γ₁).NestedOrDisjoint
      (mapPermSubgraph hπ γ₂) := by
  unfold mapPermSubgraph
  subst hπ
  exact (FeynmanSubgraph.mapPerm_nestedOrDisjoint_iff π γ₁ γ₂).mpr h

/-- Nonemptiness of a component is preserved by `mapPermSubgraph`. -/
private theorem mapPermSubgraph_isNonempty
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {γ : FeynmanSubgraph G₁}
    (h : γ.IsNonempty) :
    (mapPermSubgraph hπ γ).IsNonempty := by
  unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at h ⊢
  rw [mapPermSubgraph_vertices]
  simpa [Finset.card_image_of_injective _ π.injective] using h

/-- Transport an admissible forest along an ambient graph permutation. -/
private noncomputable def mapPermAdmissibleSubgraph
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    AdmissibleSubgraph G₂ :=
  AdmissibleSubgraph.ofElements
    (A.elements.image (mapPermSubgraph hπ))
    (by
      constructor
      · intro γ' hγ'
        rcases Finset.mem_image.mp hγ' with ⟨γ, hγ, rfl⟩
        exact mapPermSubgraph_isConnectedDivergent hπ
          (A.isConnectedDivergent γ hγ)
      · intro γ₁' h₁ γ₂' h₂ hne
        rcases Finset.mem_image.mp h₁ with ⟨γ₁, hγ₁, rfl⟩
        rcases Finset.mem_image.mp h₂ with ⟨γ₂, hγ₂, rfl⟩
        have hne' : γ₁ ≠ γ₂ := by
          intro hγ
          apply hne
          rw [hγ]
        exact mapPermSubgraph_nestedOrDisjoint hπ
          (A.forest.nestedOrDisjoint hγ₁ hγ₂ hne'))

@[simp] private theorem mapPermAdmissibleSubgraph_elements
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    (mapPermAdmissibleSubgraph hπ A).elements =
      A.elements.image (mapPermSubgraph hπ) := rfl

/-- Permutation transport on subgraphs is injective. -/
private theorem mapPermSubgraph_injective
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) :
    Function.Injective (mapPermSubgraph hπ :
      FeynmanSubgraph G₁ → FeynmanSubgraph G₂) := by
  intro γ₁ γ₂ heq
  apply FeynmanSubgraph.ext_iff.mpr
  have hELInj : Function.Injective (ExternalLeg.map π) := by
    intro ℓ₁ ℓ₂ h
    cases ℓ₁ with
    | mk a₁ s₁ =>
        cases ℓ₂ with
        | mk a₂ s₂ =>
            have hπa : π a₁ = π a₂ := congrArg ExternalLeg.attachedTo h
            have hs : s₁ = s₂ := congrArg ExternalLeg.sector h
            have : a₁ = a₂ := π.injective hπa
            subst this
            subst hs
            rfl
  refine ⟨?_, ?_, ?_⟩
  · have h := congrArg FeynmanSubgraph.vertices heq
    rw [mapPermSubgraph_vertices, mapPermSubgraph_vertices] at h
    exact Finset.image_injective π.injective h
  · have h := congrArg FeynmanSubgraph.internalEdges heq
    rw [mapPermSubgraph_internalEdges, mapPermSubgraph_internalEdges] at h
    exact Multiset.map_injective
      (FeynmanGraph.FeynmanEdge_map_injective π) h
  · have h := congrArg FeynmanSubgraph.externalLegs heq
    rw [mapPermSubgraph_externalLegs, mapPermSubgraph_externalLegs] at h
    exact Multiset.map_injective hELInj h

/-- One component's Hopf factor is unchanged by permutation transport. -/
private theorem mapPermAdmissibleSubgraph_componentToHopfH_eq
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁)
    (γ : FeynmanSubgraph G₁) (hγ : γ ∈ A.elements) :
    (mapPermAdmissibleSubgraph hπ A).componentToHopfH
      (mapPermSubgraph hπ γ) =
        A.componentToHopfH γ := by
  classical
  unfold AdmissibleSubgraph.componentToHopfH
  have hγ' :
      mapPermSubgraph hπ γ ∈ (mapPermAdmissibleSubgraph hπ A).elements := by
    rw [mapPermAdmissibleSubgraph_elements]
    exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩
  rw [dif_pos hγ', dif_pos hγ]
  have hGen :
      (mapPermSubgraph hπ γ).toHopfGen
          ((mapPermAdmissibleSubgraph hπ A).isConnectedDivergent_of_mem hγ') =
        γ.toHopfGen (A.isConnectedDivergent_of_mem hγ) :=
    Subtype.ext (mapPermSubgraph_toClass_eq hπ γ)
  rw [hGen]

/-- The admissible-forest Hopf product is unchanged by permutation transport. -/
private theorem mapPermAdmissibleSubgraph_toHopfH
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    (mapPermAdmissibleSubgraph hπ A).toHopfH = A.toHopfH := by
  classical
  unfold AdmissibleSubgraph.toHopfH
  rw [mapPermAdmissibleSubgraph_elements]
  rw [Finset.prod_image]
  · exact Finset.prod_congr rfl
      (fun γ hγ => mapPermAdmissibleSubgraph_componentToHopfH_eq hπ A γ hγ)
  · intro γ₁ _ γ₂ _ heq
    exact mapPermSubgraph_injective hπ heq

/-- Transport an admissible forest in the reverse direction of
`mapPermAdmissibleSubgraph`. -/
private noncomputable def mapPermAdmissibleSubgraphPreimage
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    AdmissibleSubgraph G₁ :=
  have h₁ : G₁ = G₂.mapPerm π⁻¹ := by
    subst hπ
    rw [← FeynmanGraph.mapPerm_mul]
    simp
  mapPermAdmissibleSubgraph h₁ A

@[simp] private theorem mapPermAdmissibleSubgraphPreimage_elements
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    (mapPermAdmissibleSubgraphPreimage hπ A).elements =
      A.elements.image (mapPermSubgraph (by
        subst hπ
        rw [← FeynmanGraph.mapPerm_mul]
        simp : G₁ = G₂.mapPerm π⁻¹)) := rfl

/-- Pairwise-disjoint admissible forests remain pairwise-disjoint after
permutation transport. -/
private theorem mapPermAdmissibleSubgraph_isPairwiseDisjoint
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₁}
    (hA : A.IsPairwiseDisjoint) :
    (mapPermAdmissibleSubgraph hπ A).IsPairwiseDisjoint := by
  intro γ₁' h₁ γ₂' h₂ hne
  change γ₁' ∈ (mapPermAdmissibleSubgraph hπ A).elements at h₁
  change γ₂' ∈ (mapPermAdmissibleSubgraph hπ A).elements at h₂
  rw [mapPermAdmissibleSubgraph_elements] at h₁ h₂
  rcases Finset.mem_image.mp h₁ with ⟨γ₁, hγ₁, rfl⟩
  rcases Finset.mem_image.mp h₂ with ⟨γ₂, hγ₂, rfl⟩
  have hne' : γ₁ ≠ γ₂ := by
    intro hγ
    apply hne
    rw [hγ]
  exact mapPermSubgraph_disjoint hπ (hA hγ₁ hγ₂ hne')

/-- Nonempty admissible forests remain nonempty after permutation transport. -/
private theorem mapPermAdmissibleSubgraph_isNonempty
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₁}
    (hA : A.IsNonempty) :
    (mapPermAdmissibleSubgraph hπ A).IsNonempty := by
  rcases hA with ⟨γ, hγ⟩
  refine ⟨mapPermSubgraph hπ γ, ?_⟩
  rw [mapPermAdmissibleSubgraph_elements]
  exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩

/-- Component nonemptiness remains component nonemptiness after permutation
transport. -/
private theorem mapPermAdmissibleSubgraph_hasNonemptyComponents
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₁}
    (hA : A.HasNonemptyComponents) :
    (mapPermAdmissibleSubgraph hπ A).HasNonemptyComponents := by
  intro γ' hγ'
  rw [mapPermAdmissibleSubgraph_elements] at hγ'
  rcases Finset.mem_image.mp hγ' with ⟨γ, hγ, rfl⟩
  exact mapPermSubgraph_isNonempty hπ (hA γ hγ)

/-- Positive internal-edge components remain positive after permutation
transport. -/
private theorem mapPermAdmissibleSubgraph_hasPositiveInternalEdgesComponents
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₁}
    (hA : A.HasPositiveInternalEdgesComponents) :
    (mapPermAdmissibleSubgraph hπ A).HasPositiveInternalEdgesComponents := by
  intro γ' hγ'
  rw [mapPermAdmissibleSubgraph_elements] at hγ'
  rcases Finset.mem_image.mp hγ' with ⟨γ, hγ, rfl⟩
  rw [mapPermSubgraph_internalEdges_card]
  exact hA γ hγ

/-- Proper-disjoint admissible forest membership is preserved by permutation
transport. -/
private theorem mapPermAdmissibleSubgraph_mem_properDisjoint
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₁}
    (hA : A ∈ G₁.properDisjointAdmissibleDivergentSubgraphs) :
    mapPermAdmissibleSubgraph hπ A ∈
      G₂.properDisjointAdmissibleDivergentSubgraphs := by
  rw [G₂.mem_properDisjointAdmissibleDivergentSubgraphs]
  have hAProper := (G₁.mem_properDisjointAdmissibleDivergentSubgraphs A).mp hA
  have hANonemptyDisjoint :
      A ∈ G₁.nonemptyDisjointAdmissibleDivergentSubgraphs := hAProper.1
  have hADisjoint :
      A ∈ G₁.disjointAdmissibleDivergentSubgraphs :=
    ((G₁.mem_nonemptyDisjointAdmissibleDivergentSubgraphs A).mp
      hANonemptyDisjoint).1
  have hAIsDisjoint : A.IsPairwiseDisjoint :=
    ((G₁.mem_disjointAdmissibleDivergentSubgraphs A).mp hADisjoint).2
  have hAIsNonempty : A.IsNonempty :=
    ((G₁.mem_nonemptyDisjointAdmissibleDivergentSubgraphs A).mp
      hANonemptyDisjoint).2
  have hTargetDisjoint :
      (mapPermAdmissibleSubgraph hπ A).IsPairwiseDisjoint :=
    mapPermAdmissibleSubgraph_isPairwiseDisjoint hπ hAIsDisjoint
  have hTargetNonempty :
      (mapPermAdmissibleSubgraph hπ A).IsNonempty :=
    mapPermAdmissibleSubgraph_isNonempty hπ hAIsNonempty
  have hTargetNonemptyComponents :
      (mapPermAdmissibleSubgraph hπ A).HasNonemptyComponents :=
    mapPermAdmissibleSubgraph_hasNonemptyComponents hπ hAProper.2.1
  have hTargetPositiveComponents :
      (mapPermAdmissibleSubgraph hπ A).HasPositiveInternalEdgesComponents :=
    mapPermAdmissibleSubgraph_hasPositiveInternalEdgesComponents hπ hAProper.2.2.2
  refine ⟨?_, hTargetNonemptyComponents, ?_, hTargetPositiveComponents⟩
  · rw [G₂.mem_nonemptyDisjointAdmissibleDivergentSubgraphs]
    refine ⟨?_, hTargetNonempty⟩
    rw [G₂.mem_disjointAdmissibleDivergentSubgraphs]
    exact ⟨G₂.mem_admissibleDivergentSubgraphs
      (mapPermAdmissibleSubgraph hπ A), hTargetDisjoint⟩
  · exact admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
      hTargetPositiveComponents hTargetNonempty

/-- Proper-disjoint membership is preserved by reverse permutation
transport. -/
private theorem mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) {A : AdmissibleSubgraph G₂}
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs) :
    mapPermAdmissibleSubgraphPreimage hπ A ∈
      G₁.properDisjointAdmissibleDivergentSubgraphs := by
  unfold mapPermAdmissibleSubgraphPreimage
  exact mapPermAdmissibleSubgraph_mem_properDisjoint
    (by
      subst hπ
      rw [← FeynmanGraph.mapPerm_mul]
      simp)
    hA

/-- Reverse permutation transport also preserves the Hopf product. -/
private theorem mapPermAdmissibleSubgraphPreimage_toHopfH
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    (mapPermAdmissibleSubgraphPreimage hπ A).toHopfH = A.toHopfH := by
  unfold mapPermAdmissibleSubgraphPreimage
  exact mapPermAdmissibleSubgraph_toHopfH
    (by
      subst hπ
      rw [← FeynmanGraph.mapPerm_mul]
      simp)
    A

/-- Applying `mapPerm` to a subgraph and then taking the canonical preimage
along the same permutation recovers the original subgraph. -/
private theorem mapPermSubgraph_preimage_mapPerm_eq
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (γ : FeynmanSubgraph G₁) :
    mapPermSubgraph_preimage hπ (mapPermSubgraph hπ γ) = γ :=
  mapPermSubgraph_injective hπ
    (by simpa using
      mapPermSubgraph_preimage_eq hπ (mapPermSubgraph hπ γ))

/-- Applying `mapPerm` to an admissible forest and then taking the canonical
preimage along the same permutation recovers the original admissible forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    mapPermAdmissibleSubgraphPreimage hπ
      (mapPermAdmissibleSubgraph hπ A) = A := by
  unfold mapPermAdmissibleSubgraphPreimage
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  change
    (mapPermAdmissibleSubgraph
      (by
        subst hπ
        rw [← FeynmanGraph.mapPerm_mul]
        simpa using (FeynmanGraph.mapPerm_one G₁).symm)
      (mapPermAdmissibleSubgraph hπ A)).elements = A.elements
  rw [mapPermAdmissibleSubgraph_elements, mapPermAdmissibleSubgraph_elements]
  ext γ
  constructor
  · intro hγ
    rcases Finset.mem_image.mp hγ with ⟨γ', hγ', hγ'eq⟩
    rcases Finset.mem_image.mp hγ' with ⟨δ, hδ, rfl⟩
    change mapPermSubgraph_preimage hπ (mapPermSubgraph hπ δ) = γ at hγ'eq
    have hγδ : γ = δ :=
      hγ'eq.symm.trans (mapPermSubgraph_preimage_mapPerm_eq hπ δ)
    simpa [hγδ] using hδ
  · intro hγ
    refine Finset.mem_image.mpr ?_
    refine ⟨mapPermSubgraph hπ γ, ?_, ?_⟩
    · exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩
    · change mapPermSubgraph_preimage hπ (mapPermSubgraph hπ γ) = γ
      exact mapPermSubgraph_preimage_mapPerm_eq hπ γ

/-- Vertex membership in a permutation preimage admissible forest is exactly
target forest membership after applying the ambient permutation. -/
private theorem mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂)
    {v : VertexId} :
    v ∈ (mapPermAdmissibleSubgraphPreimage hπ A).vertices ↔
      π v ∈ A.vertices := by
  constructor
  · intro hv
    rw [AdmissibleSubgraph.mem_vertices] at hv ⊢
    rcases hv with ⟨δ, hδ, hvδ⟩
    rw [mapPermAdmissibleSubgraphPreimage_elements] at hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, hγ, rfl⟩
    refine ⟨γ, hγ, ?_⟩
    have hV := mapPermSubgraph_preimage_vertices hπ γ
    rw [← hV]
    rw [mapPermSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨v, hvδ, rfl⟩
  · intro hv
    rw [AdmissibleSubgraph.mem_vertices] at hv ⊢
    rcases hv with ⟨γ, hγ, hπvγ⟩
    refine ⟨mapPermSubgraph_preimage hπ γ, ?_, ?_⟩
    · rw [mapPermAdmissibleSubgraphPreimage_elements]
      exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩
    · have hV := mapPermSubgraph_preimage_vertices hπ γ
      rw [← hV] at hπvγ
      rw [mapPermSubgraph_vertices] at hπvγ
      rcases Finset.mem_image.mp hπvγ with ⟨u, hu, huv⟩
      have huv' : u = v := π.injective huv
      simpa [huv'] using hu

/-- Internal-edge carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_internalEdges_map
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    (mapPermAdmissibleSubgraphPreimage hπ A).internalEdges.map
        (FeynmanEdge.map π) =
      A.internalEdges := by
  classical
  unfold AdmissibleSubgraph.internalEdges
  change (Multiset.mapAddMonoidHom (FeynmanEdge.map π))
      (∑ γ ∈ (mapPermAdmissibleSubgraphPreimage hπ A).elements,
        γ.internalEdges) =
    ∑ γ ∈ A.elements, γ.internalEdges
  rw [map_sum (Multiset.mapAddMonoidHom (FeynmanEdge.map π))]
  rw [mapPermAdmissibleSubgraphPreimage_elements]
  rw [Finset.sum_image]
  · apply Finset.sum_congr rfl
    intro γ hγ
    rw [mapPermSubgraph_internalEdges]
    change (γ.internalEdges.map (FeynmanEdge.map π⁻¹)).map
        (FeynmanEdge.map π) =
      γ.internalEdges
    rw [Multiset.map_map]
    have hcomp : (FeynmanEdge.map π) ∘ (FeynmanEdge.map π⁻¹) = id := by
      funext e
      cases e with
      | mk src tgt sec =>
        show FeynmanEdge.map π (FeynmanEdge.map π⁻¹ ⟨src, tgt, sec⟩) =
          ⟨src, tgt, sec⟩
        simp [FeynmanEdge.map, π.apply_symm_apply]
    rw [hcomp, Multiset.map_id]
  · intro γ₁ hγ₁ γ₂ hγ₂ h
    have hpre :
        mapPermSubgraph_preimage hπ γ₁ =
          mapPermSubgraph_preimage hπ γ₂ := by
      simpa [mapPermSubgraph_preimage] using h
    have hmap := congrArg (mapPermSubgraph hπ) hpre
    simpa [mapPermSubgraph_preimage_eq hπ γ₁,
      mapPermSubgraph_preimage_eq hπ γ₂] using hmap

/-- `Multiset.map` distributes over subtraction along an injective map. -/
private theorem multiset_map_sub_of_injective {α β : Type*}
    [DecidableEq α] [DecidableEq β] {f : α → β}
    (hf : Function.Injective f) {A B : Multiset α} :
    (A - B).map f = A.map f - B.map f := by
  refine Multiset.ext.mpr (fun y => ?_)
  rw [Multiset.count_sub]
  by_cases hy : y ∈ A.map f
  · rcases Multiset.mem_map.mp hy with ⟨x, hxA, rfl⟩
    rw [Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_sub]
  · have hy_sub : y ∉ (A - B).map f := by
      intro h
      rcases Multiset.mem_map.mp h with ⟨x, hx, rfl⟩
      have hxA : x ∈ A := Multiset.mem_of_le (Multiset.sub_le_self _ _) hx
      exact hy (Multiset.mem_map.mpr ⟨x, hxA, rfl⟩)
    rw [Multiset.count_eq_zero_of_notMem hy_sub,
        Multiset.count_eq_zero_of_notMem hy]
    simp

/-- `Multiset.map` distributes over subtraction whenever the subtracted multiset
is actually contained in the source.  This avoids a global injectivity
requirement for retargeting maps that intentionally collapse component
vertices. -/
private theorem multiset_map_sub_of_le {α β : Type*} [DecidableEq α]
    [DecidableEq β] (f : α → β) {A B : Multiset α} (hBA : B ≤ A) :
    (A - B).map f = A.map f - B.map f := by
  calc
    (A - B).map f = ((A - B).map f + B.map f) - B.map f := by
      rw [Multiset.add_sub_cancel_right]
    _ = ((A - B + B).map f) - B.map f := by
      rw [Multiset.map_add]
    _ = A.map f - B.map f := by
      rw [Multiset.sub_add_cancel hBA]

/-- Internal-edge carrier transport for an admissible forest under an ambient
permutation. -/
private theorem mapPermAdmissibleSubgraph_internalEdges
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    (mapPermAdmissibleSubgraph hπ A).internalEdges =
      A.internalEdges.map (FeynmanEdge.map π) := by
  classical
  unfold AdmissibleSubgraph.internalEdges
  rw [mapPermAdmissibleSubgraph_elements]
  rw [Finset.sum_image]
  · change
      (∑ x ∈ A.elements, (mapPermSubgraph hπ x).internalEdges) =
        (Multiset.mapAddMonoidHom (FeynmanEdge.map π))
          (∑ γ ∈ A.elements, γ.internalEdges)
    rw [map_sum (Multiset.mapAddMonoidHom (FeynmanEdge.map π))]
    apply Finset.sum_congr rfl
    intro γ _hγ
    exact mapPermSubgraph_internalEdges hπ γ
  · intro γ₁ _ γ₂ _ hγ
    exact (mapPermSubgraph_injective hπ) hγ

/-- Complement-edge cardinality is preserved by admissible-forest permutation
transport. -/
private theorem mapPermAdmissibleSubgraph_complementEdges_card
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₁) :
    (mapPermAdmissibleSubgraph hπ A).complementEdges.card =
      A.complementEdges.card := by
  classical
  unfold AdmissibleSubgraph.complementEdges
  rw [mapPermAdmissibleSubgraph_internalEdges hπ A]
  have hG :
      G₂.internalEdges = G₁.internalEdges.map (FeynmanEdge.map π) := by
    subst hπ
    rfl
  rw [hG]
  rw [← multiset_map_sub_of_injective
    (FeynmanGraph.FeynmanEdge_map_injective π)]
  rw [Multiset.card_map]

/-- Complement-edge carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_complementEdges_map
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    (mapPermAdmissibleSubgraphPreimage hπ A).complementEdges.map
        (FeynmanEdge.map π) =
      A.complementEdges := by
  classical
  unfold AdmissibleSubgraph.complementEdges
  rw [multiset_map_sub_of_injective
    (FeynmanGraph.FeynmanEdge_map_injective π)]
  rw [mapPermAdmissibleSubgraphPreimage_internalEdges_map hπ A]
  have hGI : G₁.internalEdges.map (FeynmanEdge.map π) = G₂.internalEdges := by
    rw [hπ]
    rfl
  rw [hGI]

/-- External-leg carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_externalLegs_map
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) :
    G₁.externalLegs.map (ExternalLeg.map π) = G₂.externalLegs := by
  rw [hπ]
  rfl

/-- Generic graph-level contraction transport across a representative
permutation.  This is the remaining non-component-specific geometric fact:
contracting the permutation preimage of an admissible forest with any fresh
component-star assignment gives the same graph class as contracting the
representative forest with its canonical component stars. -/
private structure admissibleForestContractPreimageClassTransport : Prop where
  preimage_contract_class :
    ∀ {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
      (hπ : G₂ = G₁.mapPerm π)
      (A : AdmissibleSubgraph G₂)
      (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G₁ → VertexId),
        (mapPermAdmissibleSubgraphPreimage hπ A).IsFreshStarAssignment starOf →
        (FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A) starOf).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
          (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).toClass

/-- Star-choice invariance for admissible forest contractions in a fixed
ambient graph. -/
private structure admissibleForestContractFreshStarClassTransport : Prop where
  fresh_star_class :
    ∀ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G → VertexId),
        A.IsFreshStarAssignment starOf →
        (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars G A
          (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).toClass

/-- Field-level star-renaming data for a fixed admissible forest contraction:
after applying `τ`, the contraction using `starOf` is literally the
contraction using the canonical component stars. -/
private structure admissibleForestContractFreshStarRelabeling : Prop where
  relabel :
    ∀ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G → VertexId),
        A.IsFreshStarAssignment starOf →
        ∃ τ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)) =
          (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
            ).mapPerm τ

/-- Fieldwise version of fixed-forest fresh-star relabeling. -/
private structure admissibleForestContractFreshStarFieldRelabeling : Prop where
  field_relabel :
    ∀ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G → VertexId),
        A.IsFreshStarAssignment starOf →
        ∃ τ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).vertices =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm τ).vertices ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).internalEdges =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm τ).internalEdges ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).externalLegs =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm τ).externalLegs

/-- Concrete finite relabeling data for the fresh-star side: a permutation
which fixes every ambient vertex and sends each chosen fresh component star to
the canonical component star. -/
private structure admissibleForestContractFreshStarPermutationData : Prop where
  exists_perm :
    ∀ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G → VertexId),
        A.IsFreshStarAssignment starOf →
        ∃ τ : Equiv.Perm VertexId,
          (∀ v,
            (v ∈ G.vertices ∨
              (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
              (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) →
              τ v = v) ∧
          ∀ γ ∈ A.elements,
            τ (starOf γ) =
              FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ

/-- A finite partial vertex relabeling can be extended to a permutation of
`VertexId`: fix the finite set `S` and send the finite injective family
`src` to the finite injective family `dst`, provided both star families are
disjoint from `S`.  The construction is the finite-support one: extend the
partial map on the support subtype, then extend that permutation by the
identity outside the support. -/
private theorem finite_visible_star_permutation
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (S : Finset VertexId) (src dst : ι → VertexId)
    (hsrcInj : Function.Injective src)
    (hdstInj : Function.Injective dst)
    (hsrcS : ∀ i, src i ∉ S)
    (hdstS : ∀ i, dst i ∉ S) :
    ∃ τ : Equiv.Perm VertexId,
      (∀ v, v ∈ S → τ v = v) ∧
      ∀ i, τ (src i) = dst i := by
  classical
  let srcSet : Finset VertexId := Finset.univ.image src
  let dstSet : Finset VertexId := Finset.univ.image dst
  let support : Finset VertexId := S ∪ srcSet ∪ dstSet
  let p : {x // x ∈ support} → VertexId := fun x =>
    if h : ∃ i, src i = x.1 then dst h.choose else x.1
  let domain : Finset {x // x ∈ support} :=
    Finset.univ.filter (fun x : {x // x ∈ support} =>
      x.1 ∈ S ∨ ∃ i, src i = x.1)
  have hcard : Fintype.card {x // x ∈ support} = support.card :=
    Fintype.card_coe support
  have hp_subset : Finset.image p domain ⊆ support := by
    intro y hy
    rw [Finset.mem_image] at hy
    rcases hy with ⟨x, hx, rfl⟩
    dsimp [p]
    split
    · rename_i hsrc
      simp [support, dstSet]
    · exact x.2
  have hp_inj : Set.InjOn p (domain : Set {x // x ∈ support}) := by
    intro x hx y hy hxy
    have hx' : x.1 ∈ S ∨ ∃ i, src i = x.1 := by
      simpa [domain] using hx
    have hy' : y.1 ∈ S ∨ ∃ i, src i = y.1 := by
      simpa [domain] using hy
    rcases hx' with hxS | hxsrc
    · rcases hy' with hyS | hysrc
      · dsimp [p] at hxy
        have hxNotSrc : ¬ ∃ i, src i = x.1 := by
          rintro ⟨i, hi⟩
          exact hsrcS i (hi ▸ hxS)
        have hyNotSrc : ¬ ∃ i, src i = y.1 := by
          rintro ⟨i, hi⟩
          exact hsrcS i (hi ▸ hyS)
        simp [hxNotSrc, hyNotSrc] at hxy
        exact hxy
      · dsimp [p] at hxy
        have hxNotSrc : ¬ ∃ i, src i = x.1 := by
          rintro ⟨i, hi⟩
          exact hsrcS i (hi ▸ hxS)
        simp [hxNotSrc, hysrc] at hxy
        exact False.elim (hdstS hysrc.choose (hxy ▸ hxS))
    · rcases hy' with hyS | hysrc
      · dsimp [p] at hxy
        have hyNotSrc : ¬ ∃ i, src i = y.1 := by
          rintro ⟨i, hi⟩
          exact hsrcS i (hi ▸ hyS)
        simp [hxsrc, hyNotSrc] at hxy
        exact False.elim (hdstS hxsrc.choose (hxy.symm ▸ hyS))
      · dsimp [p] at hxy
        simp [hxsrc, hysrc] at hxy
        have hi :
            hxsrc.choose = hysrc.choose :=
          hdstInj hxy
        have hxval : x.1 = y.1 := by
          rw [← hxsrc.choose_spec, ← hysrc.choose_spec, hi]
        exact Subtype.ext hxval
  obtain ⟨σ, hσ⟩ :=
    Finset.exists_equiv_extend_of_card_eq hcard hp_subset hp_inj
  let τ : Equiv.Perm VertexId :=
    Equiv.Perm.extendDomain σ (Finset.equivToSet support)
  refine ⟨τ, ?_, ?_⟩
  · intro v hvS
    have hvSupport : v ∈ support := by
      simp [support, hvS]
    have hvDomain : (⟨v, hvSupport⟩ : {x // x ∈ support}) ∈ domain := by
      dsimp [domain]
      rw [Finset.mem_filter]
      exact ⟨Finset.mem_univ _, Or.inl hvS⟩
    have hpv : p ⟨v, hvSupport⟩ = v := by
      dsimp [p]
      have hvNotSrc : ¬ ∃ i, src i = v := by
        rintro ⟨i, hi⟩
        exact hsrcS i (hi ▸ hvS)
      simp [hvNotSrc]
    have hσv : (σ ⟨v, hvSupport⟩ : VertexId) = v := by
      simpa [hpv] using hσ ⟨v, hvSupport⟩ hvDomain
    have hτ :
        τ ((Finset.equivToSet support) ⟨v, hvSupport⟩) =
          (Finset.equivToSet support) (σ ⟨v, hvSupport⟩) :=
      Equiv.Perm.extendDomain_apply_image σ
        (Finset.equivToSet support) ⟨v, hvSupport⟩
    change τ v = (σ ⟨v, hvSupport⟩ : VertexId) at hτ
    exact hτ.trans hσv
  · intro i
    have hsrcSupport : src i ∈ support := by
      simp [support, srcSet]
    have hsrcDomain :
        (⟨src i, hsrcSupport⟩ : {x // x ∈ support}) ∈ domain := by
      dsimp [domain]
      rw [Finset.mem_filter]
      exact ⟨Finset.mem_univ _, Or.inr ⟨i, rfl⟩⟩
    have hp_src : p ⟨src i, hsrcSupport⟩ = dst i := by
      dsimp [p]
      split
      · rename_i h
        have hi : h.choose = i :=
          hsrcInj h.choose_spec
        exact congrArg dst hi
      · rename_i h
        exact False.elim (h ⟨i, rfl⟩)
    have hσsrc : (σ ⟨src i, hsrcSupport⟩ : VertexId) = dst i := by
      simpa [hp_src] using hσ ⟨src i, hsrcSupport⟩ hsrcDomain
    have hτ :
        τ ((Finset.equivToSet support) ⟨src i, hsrcSupport⟩) =
          (Finset.equivToSet support) (σ ⟨src i, hsrcSupport⟩) :=
      Equiv.Perm.extendDomain_apply_image σ
        (Finset.equivToSet support) ⟨src i, hsrcSupport⟩
    change τ (src i) = (σ ⟨src i, hsrcSupport⟩ : VertexId) at hτ
    exact hτ.trans hσsrc

/-- Actual fresh-star permutation construction for a well-formed ambient
graph.  The finite extension lemma is applied to the component carrier, fixing
ambient vertices and sending each caller-supplied fresh star to the canonical
component star.  Well-formedness then upgrades "fix ambient vertices" to the
visible-vertex condition used by the field relabeling. -/
private theorem admissibleForestContractFreshStarPermutation_of_wellFormed
    {G : FeynmanGraph} (hGwf : G.WellFormed)
    (A : AdmissibleSubgraph G)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (starOf : FeynmanSubgraph G → VertexId)
    (hFresh : A.IsFreshStarAssignment starOf) :
    ∃ τ : Equiv.Perm VertexId,
      (∀ v,
        (v ∈ G.vertices ∨
          (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
          (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) →
          τ v = v) ∧
      ∀ γ ∈ A.elements,
        τ (starOf γ) =
          FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ := by
  classical
  let src : {γ // γ ∈ A.elements} → VertexId := fun γ => starOf γ.1
  let dst : {γ // γ ∈ A.elements} → VertexId := fun γ =>
    FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ.1
  have hsrcInj : Function.Injective src := by
    intro γ₁ γ₂ h
    apply Subtype.ext
    exact hFresh.eq_of_star_eq γ₁.2 γ₂.2 h
  have hdstInj : Function.Injective dst := by
    intro γ₁ γ₂ h
    apply Subtype.ext
    exact AdmissibleSubgraph.componentFreshStar_eq_of_eq γ₁.2 (by
      simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using h)
  have hsrcS : ∀ γ : {γ // γ ∈ A.elements}, src γ ∉ G.vertices := by
    intro γ
    exact hFresh.fresh γ.2
  have hdstS : ∀ γ : {γ // γ ∈ A.elements}, dst γ ∉ G.vertices := by
    intro γ
    simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using
      A.componentFreshStar_not_mem_vertices γ.1
  rcases finite_visible_star_permutation G.vertices src dst
      hsrcInj hdstInj hsrcS hdstS with
    ⟨τ, hFixVertices, hStarSubtype⟩
  refine ⟨τ, ?_, ?_⟩
  · intro v hVisible
    apply hFixVertices v
    rcases hVisible with hv | hRest
    · exact hv
    rcases hRest with hEdge | hLeg
    · rcases hEdge with ⟨e, he, hev⟩
      have heG : e ∈ G.internalEdges :=
        A.mem_ambientInternalEdges_of_mem_complementEdges he
      have hsupp := FeynmanGraph.wellFormed_internal hGwf heG
      rcases hev with rfl | rfl
      · exact hsupp.1
      · exact hsupp.2
    · rcases hLeg with ⟨ℓ, hℓ, hℓv⟩
      have hsupp := FeynmanGraph.wellFormed_external hGwf hℓ
      exact hℓv ▸ hsupp
  · intro γ hγ
    simpa [src, dst] using hStarSubtype ⟨γ, hγ⟩

/-- Finite star-alignment permutation for the canonical mapPerm-preimage
side.  For `hπ : G₂ = G₁.mapPerm π`, it constructs `τ = σ * π` so that
ambient vertices are transported by `π`, while canonical stars of the
preimage forest are sent to the canonical stars of the target forest. -/
private theorem admissibleForestContractCanonicalPreimage_starPermutation
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs) :
    let Apre := mapPermAdmissibleSubgraphPreimage hπ A
    let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA
    ∃ τ : Equiv.Perm VertexId,
      (∀ v ∈ G₁.vertices, τ v = π v) ∧
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hπ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA
  let pre : {γ // γ ∈ A.elements} → FeynmanSubgraph G₁ :=
    fun γ => mapPermSubgraph_preimage hπ γ.1
  let src : {γ // γ ∈ A.elements} → VertexId := fun γ =>
    π (FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
      (pre γ))
  let dst : {γ // γ ∈ A.elements} → VertexId := fun γ =>
    FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ.1
  have hpre_mem : ∀ γ : {γ // γ ∈ A.elements}, pre γ ∈ Apre.elements := by
    intro γ
    rw [mapPermAdmissibleSubgraphPreimage_elements]
    refine Finset.mem_image.mpr ?_
    exact ⟨γ.1, γ.2, rfl⟩
  have hsrcInj : Function.Injective src := by
    intro γ₁ γ₂ h
    apply Subtype.ext
    have hstar :
        FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
            (pre γ₁) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
            (pre γ₂) :=
      π.injective h
    have hpre_eq : pre γ₁ = pre γ₂ :=
      (FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        G₁ Apre hApre).eq_of_star_eq (hpre_mem γ₁) (hpre_mem γ₂) hstar
    have hmap := congrArg (mapPermSubgraph hπ) hpre_eq
    simpa [pre, mapPermSubgraph_preimage_eq hπ γ₁.1,
      mapPermSubgraph_preimage_eq hπ γ₂.1] using hmap
  have hdstInj : Function.Injective dst := by
    intro γ₁ γ₂ h
    apply Subtype.ext
    exact AdmissibleSubgraph.componentFreshStar_eq_of_eq γ₁.2 (by
      simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using h)
  have hsrcS : ∀ γ : {γ // γ ∈ A.elements}, src γ ∉ G₂.vertices := by
    intro γ hmem
    have hsource_not :
        FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
            (pre γ) ∉ G₁.vertices := by
      simpa [FeynmanGraph.admissibleForestCanonicalStarOf] using
        Apre.componentFreshStar_not_mem_vertices (pre γ)
    subst hπ
    rw [FeynmanGraph.mapPerm_vertices, Finset.mem_image] at hmem
    rcases hmem with ⟨v, hv, hvπ⟩
    have hv_eq :
        v =
          FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
            (pre γ) :=
      π.injective hvπ
    exact hsource_not (hv_eq ▸ hv)
  have hdstS : ∀ γ : {γ // γ ∈ A.elements}, dst γ ∉ G₂.vertices := by
    intro γ
    simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using
      A.componentFreshStar_not_mem_vertices γ.1
  rcases finite_visible_star_permutation G₂.vertices src dst
      hsrcInj hdstInj hsrcS hdstS with
    ⟨σ, hσFix, hσStar⟩
  refine ⟨σ * π, ?_, ?_⟩
  · intro v hv
    have hπv : π v ∈ G₂.vertices := by
      subst hπ
      rw [FeynmanGraph.mapPerm_vertices]
      exact Finset.mem_image.mpr ⟨v, hv, rfl⟩
    simp [Equiv.Perm.mul_apply, hσFix (π v) hπv]
  · intro γ hγ
    simpa [src, dst, pre, Equiv.Perm.mul_apply] using
      hσStar ⟨γ, hγ⟩

/-- Vertex field transport for the canonical mapPerm-preimage contraction,
assuming the explicit star-alignment permutation data. -/
private theorem admissibleForestContractCanonicalPreimage_vertices_eq_of_starPermutation
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).vertices =
    ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
      (mapPermAdmissibleSubgraphPreimage hπ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁
        (mapPermAdmissibleSubgraphPreimage hπ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hπ hA))).mapPerm τ).vertices := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hπ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices,
    FeynmanGraph.mapPerm_vertices]
  ext v
  constructor
  · intro hv
    rw [Finset.mem_union] at hv
    rw [Finset.mem_image]
    rcases hv with hvRest | hvStar
    · have hvG₂ : v ∈ G₂.vertices := (Finset.mem_sdiff.mp hvRest).1
      have hvA : v ∉ A.vertices := (Finset.mem_sdiff.mp hvRest).2
      have hG₂verts : G₂.vertices = G₁.vertices.image π := by
        rw [hπ]
        rfl
      rw [hG₂verts, Finset.mem_image] at hvG₂
      rcases hvG₂ with ⟨u, huG₁, huv⟩
      refine ⟨u, ?_, ?_⟩
      · rw [Finset.mem_union]
        left
        rw [Finset.mem_sdiff]
        refine ⟨huG₁, ?_⟩
        intro huApre
        have hπuA : π u ∈ A.vertices :=
          (mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
            hπ A).mp huApre
        exact hvA (by simpa [huv] using hπuA)
      · exact (hτV u huG₁).trans huv
    · rw [AdmissibleSubgraph.mem_starVertices] at hvStar
      rcases hvStar with ⟨γ, hγ, hγv⟩
      refine ⟨
        FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre
          (mapPermSubgraph_preimage hπ γ), ?_, ?_⟩
      · rw [Finset.mem_union]
        right
        rw [AdmissibleSubgraph.mem_starVertices]
        refine ⟨mapPermSubgraph_preimage hπ γ, ?_, rfl⟩
        rw [mapPermAdmissibleSubgraphPreimage_elements]
        exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩
      · exact (hτStar γ hγ).trans hγv
  · intro hv
    rw [Finset.mem_image] at hv
    rcases hv with ⟨u, hu, huv⟩
    rw [Finset.mem_union] at hu ⊢
    rcases hu with huRest | huStar
    · left
      rw [Finset.mem_sdiff] at huRest ⊢
      have hτu : τ u = π u := hτV u huRest.1
      have huvπ : v = π u := by
        rw [← huv, hτu]
      refine ⟨?_, ?_⟩
      · have hG₂verts : G₂.vertices = G₁.vertices.image π := by
          rw [hπ]
          rfl
        rw [hG₂verts]
        exact Finset.mem_image.mpr ⟨u, huRest.1, huvπ.symm⟩
      · intro hvA
        have hπuA : π u ∈ A.vertices := by
          simpa [huvπ] using hvA
        exact huRest.2
          ((mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
            hπ A).mpr hπuA)
    · right
      rw [AdmissibleSubgraph.mem_starVertices] at huStar ⊢
      rcases huStar with ⟨δ, hδ, hδu⟩
      rw [mapPermAdmissibleSubgraphPreimage_elements] at hδ
      rcases Finset.mem_image.mp hδ with ⟨γ, hγ, rfl⟩
      refine ⟨γ, hγ, ?_⟩
      rw [← huv, ← hδu]
      have hstar := hτStar γ hγ
      unfold mapPermSubgraph_preimage at hstar
      exact hstar.symm

/-- Pointwise retarget transport for canonical mapPerm-preimage contractions.
When `v` is an ambient vertex of `G₁`, applying the star-alignment
permutation after preimage retargeting agrees with target retargeting after
applying the ambient permutation. -/
private theorem admissibleForestContractCanonicalPreimage_retargetVertex_map
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ)
    {v : VertexId} (hvG₁ : v ∈ G₁.vertices) :
    τ ((mapPermAdmissibleSubgraphPreimage hπ A).retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)) v) =
      A.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA) (π v) := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hπ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA
  have hDisjA : A.IsPairwiseDisjoint :=
    G₂.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hDisjPre : Apre.IsPairwiseDisjoint :=
    G₁.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hApre
  by_cases hvApre : v ∈ Apre.vertices
  · let δ := Apre.componentAt hvApre
    have hδ : δ ∈ Apre.elements := Apre.componentAt_mem hvApre
    have hvδ : v ∈ δ.vertices := Apre.componentAt_vertex_mem hvApre
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisjPre
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre) hδ hvδ]
    rw [mapPermAdmissibleSubgraphPreimage_elements] at hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, hγ, hδeq⟩
    rw [← hδeq] at hvδ ⊢
    have hπvγ : π v ∈ γ.vertices := by
      have hV := mapPermSubgraph_preimage_vertices hπ γ
      rw [← hV]
      rw [mapPermSubgraph_vertices]
      exact Finset.mem_image.mpr ⟨v, hvδ, rfl⟩
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisjA
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA) hγ hπvγ]
    have hstar := hτStar γ hγ
    unfold mapPermSubgraph_preimage at hstar
    exact hstar
  · have hπvA : π v ∉ A.vertices := by
      intro h
      exact hvApre
        ((mapPermAdmissibleSubgraphPreimage_mem_vertices_iff hπ A).mpr h)
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem Apre
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre hApre) hvApre]
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA) hπvA]
    exact hτV v hvG₁

/-- Internal-edge retarget transport for canonical mapPerm-preimage
contractions over a well-formed source ambient graph. -/
private theorem admissibleForestContractCanonicalPreimage_retargetEdge_map
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ)
    {e : FeynmanEdge}
    (he : e ∈ (mapPermAdmissibleSubgraphPreimage hπ A).complementEdges) :
    FeynmanEdge.map τ
        ((mapPermAdmissibleSubgraphPreimage hπ A).retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)) e) =
      A.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)
        (FeynmanEdge.map π e) := by
  have heG₁ : e ∈ G₁.internalEdges :=
    (mapPermAdmissibleSubgraphPreimage hπ A).mem_ambientInternalEdges_of_mem_complementEdges he
  have hsupp := FeynmanGraph.wellFormed_internal hG₁wf heG₁
  apply FeynmanEdge.mk.injEq _ _ _ _ _ _ |>.mpr
  exact ⟨
    admissibleForestContractCanonicalPreimage_retargetVertex_map hπ A hA
      hτV hτStar hsupp.1,
    admissibleForestContractCanonicalPreimage_retargetVertex_map hπ A hA
      hτV hτStar hsupp.2,
    rfl⟩

/-- External-leg retarget transport for canonical mapPerm-preimage
contractions over a well-formed source ambient graph. -/
private theorem admissibleForestContractCanonicalPreimage_retargetExternalLeg_map
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ)
    {ℓ : ExternalLeg} (hℓ : ℓ ∈ G₁.externalLegs) :
    ExternalLeg.map τ
        ((mapPermAdmissibleSubgraphPreimage hπ A).retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)) ℓ) =
      A.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)
        (ExternalLeg.map π ℓ) := by
  have hsupp := FeynmanGraph.wellFormed_external hG₁wf hℓ
  apply ExternalLeg.mk.injEq _ _ _ _ |>.mpr
  exact ⟨
    admissibleForestContractCanonicalPreimage_retargetVertex_map hπ A hA
      hτV hτStar hsupp,
    rfl⟩

/-- Internal-edge field transport for canonical mapPerm-preimage contractions
over a well-formed source ambient graph. -/
private theorem admissibleForestContractCanonicalPreimage_internalEdges_eq_of_starPermutation
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).internalEdges =
    ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
      (mapPermAdmissibleSubgraphPreimage hπ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁
        (mapPermAdmissibleSubgraphPreimage hπ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hπ hA))).mapPerm τ).internalEdges := by
  classical
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges,
    FeynmanGraph.mapPerm_internalEdges]
  let Apre := mapPermAdmissibleSubgraphPreimage hπ A
  let starPre := FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre
    (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
  let starTarget := FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA
  calc
    A.complementEdges.map (A.retargetEdge starTarget)
        =
      (Apre.complementEdges.map (FeynmanEdge.map π)).map
        (A.retargetEdge starTarget) := by
          rw [mapPermAdmissibleSubgraphPreimage_complementEdges_map hπ A]
    _ = Apre.complementEdges.map
        ((A.retargetEdge starTarget) ∘ (FeynmanEdge.map π)) := by
          rw [Multiset.map_map]
    _ = Apre.complementEdges.map
        ((FeynmanEdge.map τ) ∘ (Apre.retargetEdge starPre)) := by
          refine Multiset.map_congr rfl ?_
          intro e he
          exact (admissibleForestContractCanonicalPreimage_retargetEdge_map
            hπ hG₁wf A hA hτV hτStar he).symm
    _ = (Apre.complementEdges.map (Apre.retargetEdge starPre)).map
        (FeynmanEdge.map τ) := by
          rw [Multiset.map_map]

/-- External-leg field transport for canonical mapPerm-preimage contractions
over a well-formed source ambient graph. -/
private theorem admissibleForestContractCanonicalPreimage_externalLegs_eq_of_starPermutation
    {G₁ G₂ : FeynmanGraph} {π τ : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs)
    (hτV : ∀ v ∈ G₁.vertices, τ v = π v)
    (hτStar :
      ∀ γ ∈ A.elements,
        τ (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            (mapPermSubgraph_preimage hπ γ)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA γ) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).externalLegs =
    ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
      (mapPermAdmissibleSubgraphPreimage hπ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁
        (mapPermAdmissibleSubgraphPreimage hπ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hπ hA))).mapPerm τ).externalLegs := by
  classical
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_externalLegs,
    FeynmanGraph.mapPerm_externalLegs]
  let Apre := mapPermAdmissibleSubgraphPreimage hπ A
  let starPre := FeynmanGraph.admissibleForestCanonicalStarOf G₁ Apre
    (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
  let starTarget := FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA
  calc
    G₂.externalLegs.map (A.retargetExternalLeg starTarget)
        =
      (G₁.externalLegs.map (ExternalLeg.map π)).map
        (A.retargetExternalLeg starTarget) := by
          rw [mapPermAdmissibleSubgraphPreimage_externalLegs_map hπ]
    _ = G₁.externalLegs.map
        ((A.retargetExternalLeg starTarget) ∘ (ExternalLeg.map π)) := by
          rw [Multiset.map_map]
    _ = G₁.externalLegs.map
        ((ExternalLeg.map τ) ∘ (Apre.retargetExternalLeg starPre)) := by
          refine Multiset.map_congr rfl ?_
          intro ℓ hℓ
          exact (admissibleForestContractCanonicalPreimage_retargetExternalLeg_map
            hπ hG₁wf A hA hτV hτStar hℓ).symm
    _ = (G₁.externalLegs.map (Apre.retargetExternalLeg starPre)).map
        (ExternalLeg.map τ) := by
          rw [Multiset.map_map]

/-- Canonical mapPerm-preimage field relabeling for a well-formed source
ambient graph, using the finite star-alignment permutation. -/
private theorem admissibleForestContractCanonicalPreimage_fieldRelabeling_of_wellFormed
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs) :
    ∃ τ : Equiv.Perm VertexId,
      (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).vertices =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hπ hA))).mapPerm τ).vertices ∧
      (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).internalEdges =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hπ hA))).mapPerm τ).internalEdges ∧
      (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
        (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).externalLegs =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hπ hA))).mapPerm τ).externalLegs := by
  rcases admissibleForestContractCanonicalPreimage_starPermutation hπ A hA with
    ⟨τ, hτV, hτStar⟩
  refine ⟨τ, ?_, ?_, ?_⟩
  · exact admissibleForestContractCanonicalPreimage_vertices_eq_of_starPermutation
      hπ A hA hτV hτStar
  · exact admissibleForestContractCanonicalPreimage_internalEdges_eq_of_starPermutation
      hπ hG₁wf A hA hτV hτStar
  · exact admissibleForestContractCanonicalPreimage_externalLegs_eq_of_starPermutation
      hπ hG₁wf A hA hτV hτStar

/-- Well-formed canonical mapPerm-preimage class invariance. -/
private theorem admissibleForestContractCanonicalPreimageClass_of_wellFormed
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₂)
    (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G₁
      (mapPermAdmissibleSubgraphPreimage hπ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁
        (mapPermAdmissibleSubgraphPreimage hπ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hπ hA))).toClass =
    (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).toClass := by
  rcases admissibleForestContractCanonicalPreimage_fieldRelabeling_of_wellFormed
      hπ hG₁wf A hA with
    ⟨τ, hV, hI, hE⟩
  exact (FeynmanGraph.toClass_eq_iff _ _).mpr
    ⟨τ, FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr ⟨hV, hI, hE⟩⟩

/-- Canonical forest contraction is invariant under transporting the ambient
graph and admissible forest by a permutation. -/
private theorem admissibleForestContractMapPermClass_of_wellFormed
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π)
    (hG₁wf : G₁.WellFormed)
    (A : AdmissibleSubgraph G₁)
    (hA : A ∈ G₁.properDisjointAdmissibleDivergentSubgraphs) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G₁ A
      (FeynmanGraph.admissibleForestCanonicalStarOf G₁ A hA)).toClass =
    (FeynmanGraph.admissibleForestContractGraphWithStars G₂
      (mapPermAdmissibleSubgraph hπ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G₂
        (mapPermAdmissibleSubgraph hπ A)
        (mapPermAdmissibleSubgraph_mem_properDisjoint hπ hA))).toClass := by
  have hpre :
      mapPermAdmissibleSubgraphPreimage hπ
        (mapPermAdmissibleSubgraph hπ A) = A :=
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq hπ A
  simpa [hpre] using
    admissibleForestContractCanonicalPreimageClass_of_wellFormed
      hπ hG₁wf (mapPermAdmissibleSubgraph hπ A)
      (mapPermAdmissibleSubgraph_mem_properDisjoint hπ hA)

private theorem admissibleForestContractFreshStar_retargetVertex_map
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (hDisj : A.IsPairwiseDisjoint)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    {starOf : FeynmanSubgraph G → VertexId}
    {τ : Equiv.Perm VertexId}
    (hFix : ∀ v,
      (v ∈ G.vertices ∨
        (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
        (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) →
        τ v = v)
    (hStar : ∀ γ ∈ A.elements,
      τ (starOf γ) =
        FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ)
    {v : VertexId}
    (hVisible :
      v ∈ G.vertices ∨
        (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
        (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) :
    τ (A.retargetVertex starOf v) =
      A.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) v := by
  by_cases hvA : v ∈ A.vertices
  · let γ := A.componentAt hvA
    have hγ : γ ∈ A.elements := A.componentAt_mem hvA
    have hvγ : v ∈ γ.vertices := A.componentAt_vertex_mem hvA
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisj starOf hγ hvγ,
      AdmissibleSubgraph.retargetVertex_of_mem_component hDisj
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) hγ hvγ]
    exact hStar γ hγ
  · rw [AdmissibleSubgraph.retargetVertex_of_not_mem A starOf hvA,
      AdmissibleSubgraph.retargetVertex_of_not_mem A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) hvA]
    exact hFix v hVisible

private theorem admissibleForestContractFreshStar_retargetEdge_map
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (hDisj : A.IsPairwiseDisjoint)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    {starOf : FeynmanSubgraph G → VertexId}
    {τ : Equiv.Perm VertexId}
    (hFix : ∀ v,
      (v ∈ G.vertices ∨
        (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
        (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) →
        τ v = v)
    (hStar : ∀ γ ∈ A.elements,
      τ (starOf γ) =
        FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ)
    {e : FeynmanEdge} (he : e ∈ A.complementEdges) :
    FeynmanEdge.map τ (A.retargetEdge starOf e) =
      A.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) e := by
  apply FeynmanEdge.mk.injEq _ _ _ _ _ _ |>.mpr
  exact ⟨
    admissibleForestContractFreshStar_retargetVertex_map A hDisj hA
      hFix hStar (Or.inr (Or.inl ⟨e, he, Or.inl rfl⟩)),
    admissibleForestContractFreshStar_retargetVertex_map A hDisj hA
      hFix hStar (Or.inr (Or.inl ⟨e, he, Or.inr rfl⟩)),
    rfl⟩

private theorem admissibleForestContractFreshStar_retargetExternalLeg_map
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (hDisj : A.IsPairwiseDisjoint)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    {starOf : FeynmanSubgraph G → VertexId}
    {τ : Equiv.Perm VertexId}
    (hFix : ∀ v,
      (v ∈ G.vertices ∨
        (∃ e ∈ A.complementEdges, e.source = v ∨ e.target = v) ∨
        (∃ ℓ ∈ G.externalLegs, ℓ.attachedTo = v)) →
        τ v = v)
    (hStar : ∀ γ ∈ A.elements,
      τ (starOf γ) =
        FeynmanGraph.admissibleForestCanonicalStarOf G A hA γ)
    {ℓ : ExternalLeg} (hℓ : ℓ ∈ G.externalLegs) :
    ExternalLeg.map τ (A.retargetExternalLeg starOf ℓ) =
      A.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) ℓ := by
  apply ExternalLeg.mk.injEq _ _ _ _ |>.mpr
  exact ⟨
    admissibleForestContractFreshStar_retargetVertex_map A hDisj hA
      hFix hStar (Or.inr (Or.inr ⟨ℓ, hℓ, rfl⟩)),
    rfl⟩

/-- The visible-vertex permutation data proves the three literal field
equalities for fixed-forest fresh-star relabeling. -/
private noncomputable def
    admissibleForestContractFreshStarFieldRelabelingOfPermutationData
    (T : admissibleForestContractFreshStarPermutationData) :
    admissibleForestContractFreshStarFieldRelabeling where
  field_relabel := by
    intro G A hA starOf hFresh
    rcases T.exists_perm A hA starOf hFresh with ⟨τ, hFix, hStar⟩
    have hDisj : A.IsPairwiseDisjoint :=
      G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
    refine ⟨τ, ?_, ?_, ?_⟩
    · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
        AdmissibleSubgraph.contractWithStars_vertices,
        FeynmanGraph.mapPerm_vertices]
      ext v
      constructor
      · intro hv
        rw [Finset.mem_union] at hv
        rw [Finset.mem_image]
        rcases hv with hvRest | hvStar
        · refine ⟨v, ?_, ?_⟩
          · rw [Finset.mem_union]
            exact Or.inl hvRest
          · exact hFix v (Or.inl (Finset.mem_sdiff.mp hvRest).1)
        · rw [AdmissibleSubgraph.mem_starVertices] at hvStar
          rcases hvStar with ⟨γ, hγ, hγv⟩
          refine ⟨starOf γ, ?_, ?_⟩
          · rw [Finset.mem_union]
            right
            rw [AdmissibleSubgraph.mem_starVertices]
            exact ⟨γ, hγ, rfl⟩
          · rw [hStar γ hγ, hγv]
      · intro hv
        rw [Finset.mem_image] at hv
        rcases hv with ⟨u, hu, huv⟩
        rw [Finset.mem_union] at hu ⊢
        rcases hu with huRest | huStar
        · left
          have hfixu : τ u = u :=
            hFix u (Or.inl (Finset.mem_sdiff.mp huRest).1)
          simpa [← huv, hfixu] using huRest
        · right
          rw [AdmissibleSubgraph.mem_starVertices] at huStar ⊢
          rcases huStar with ⟨γ, hγ, hγu⟩
          refine ⟨γ, hγ, ?_⟩
          rw [← huv, ← hγu, hStar γ hγ]
    · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
        AdmissibleSubgraph.contractWithStars_internalEdges,
        FeynmanGraph.mapPerm_internalEdges]
      rw [Multiset.map_map]
      refine Multiset.map_congr rfl ?_
      intro e he
      exact (admissibleForestContractFreshStar_retargetEdge_map A hDisj hA
        hFix hStar he).symm
    · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
        AdmissibleSubgraph.contractWithStars_externalLegs,
        FeynmanGraph.mapPerm_externalLegs]
      rw [Multiset.map_map]
      refine Multiset.map_congr rfl ?_
      intro ℓ hℓ
      exact (admissibleForestContractFreshStar_retargetExternalLeg_map A hDisj hA
        hFix hStar hℓ).symm

/-- Well-formed fixed-forest fresh-star relabeling, using the finite
visible-star permutation construction directly. -/
private theorem admissibleForestContractFreshStarFieldRelabeling_of_wellFormed
    {G : FeynmanGraph} (hGwf : G.WellFormed)
    (A : AdmissibleSubgraph G)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (starOf : FeynmanSubgraph G → VertexId)
    (hFresh : A.IsFreshStarAssignment starOf) :
    ∃ τ : Equiv.Perm VertexId,
      (FeynmanGraph.admissibleForestContractGraphWithStars G A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).vertices =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
          ).mapPerm τ).vertices ∧
      (FeynmanGraph.admissibleForestContractGraphWithStars G A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).internalEdges =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
          ).mapPerm τ).internalEdges ∧
      (FeynmanGraph.admissibleForestContractGraphWithStars G A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).externalLegs =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
          ).mapPerm τ).externalLegs := by
  classical
  rcases admissibleForestContractFreshStarPermutation_of_wellFormed
      hGwf A hA starOf hFresh with
    ⟨τ, hFix, hStar⟩
  have hDisj : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  refine ⟨τ, ?_, ?_, ?_⟩
  · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices,
      FeynmanGraph.mapPerm_vertices]
    ext v
    constructor
    · intro hv
      rw [Finset.mem_union] at hv
      rw [Finset.mem_image]
      rcases hv with hvRest | hvStar
      · refine ⟨v, ?_, ?_⟩
        · rw [Finset.mem_union]
          exact Or.inl hvRest
        · exact hFix v (Or.inl (Finset.mem_sdiff.mp hvRest).1)
      · rw [AdmissibleSubgraph.mem_starVertices] at hvStar
        rcases hvStar with ⟨γ, hγ, hγv⟩
        refine ⟨starOf γ, ?_, ?_⟩
        · rw [Finset.mem_union]
          right
          rw [AdmissibleSubgraph.mem_starVertices]
          exact ⟨γ, hγ, rfl⟩
        · rw [hStar γ hγ, hγv]
    · intro hv
      rw [Finset.mem_image] at hv
      rcases hv with ⟨u, hu, huv⟩
      rw [Finset.mem_union] at hu ⊢
      rcases hu with huRest | huStar
      · left
        have hfixu : τ u = u :=
          hFix u (Or.inl (Finset.mem_sdiff.mp huRest).1)
        simpa [← huv, hfixu] using huRest
      · right
        rw [AdmissibleSubgraph.mem_starVertices] at huStar ⊢
        rcases huStar with ⟨γ, hγ, hγu⟩
        refine ⟨γ, hγ, ?_⟩
        rw [← huv, ← hγu, hStar γ hγ]
  · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges,
      FeynmanGraph.mapPerm_internalEdges]
    rw [Multiset.map_map]
    refine Multiset.map_congr rfl ?_
    intro e he
    exact (admissibleForestContractFreshStar_retargetEdge_map A hDisj hA
      hFix hStar he).symm
  · simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_externalLegs,
      FeynmanGraph.mapPerm_externalLegs]
    rw [Multiset.map_map]
    refine Multiset.map_congr rfl ?_
    intro ℓ hℓ
    exact (admissibleForestContractFreshStar_retargetExternalLeg_map A hDisj hA
      hFix hStar hℓ).symm

/-- Well-formed fixed-forest fresh-star class invariance. -/
private theorem admissibleForestContractFreshStarClass_of_wellFormed
    {G : FeynmanGraph} (hGwf : G.WellFormed)
    (A : AdmissibleSubgraph G)
    (hA : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (starOf : FeynmanSubgraph G → VertexId)
    (hFresh : A.IsFreshStarAssignment starOf) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars G A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).toClass := by
  rcases admissibleForestContractFreshStarFieldRelabeling_of_wellFormed
      hGwf A hA starOf hFresh with
    ⟨τ, hV, hI, hE⟩
  exact (FeynmanGraph.toClass_eq_iff _ _).mpr
    ⟨τ, FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr ⟨hV, hI, hE⟩⟩

/-- Fieldwise fresh-star relabeling supplies the literal graph relabeling. -/
private noncomputable def
    admissibleForestContractFreshStarRelabelingOfFields
    (T : admissibleForestContractFreshStarFieldRelabeling) :
    admissibleForestContractFreshStarRelabeling where
  relabel := by
    intro G A hA starOf hFresh
    rcases T.field_relabel A hA starOf hFresh with
      ⟨τ, hV, hI, hE⟩
    exact ⟨τ, FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr ⟨hV, hI, hE⟩⟩

/-- A literal star-renaming witness supplies the fixed-forest class
invariance. -/
private noncomputable def admissibleForestContractFreshStarClassTransportOfRelabeling
    (T : admissibleForestContractFreshStarRelabeling) :
    admissibleForestContractFreshStarClassTransport where
  fresh_star_class := by
    intro G A hA starOf hFresh
    rcases T.relabel A hA starOf hFresh with ⟨τ, hτ⟩
    exact (FeynmanGraph.toClass_eq_iff _ _).mpr ⟨τ, hτ⟩

/-- Canonical-star invariance for admissible forest contractions under
permutation-preimage transport. -/
private structure admissibleForestContractCanonicalPreimageClassTransport : Prop where
  canonical_preimage_class :
    ∀ {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
      (hπ : G₂ = G₁.mapPerm π)
      (A : AdmissibleSubgraph G₂)
      (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs),
        (FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hπ hA))).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
          (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).toClass

/-- Literal field-level data for the canonical-star contraction under
permutation-preimage transport. -/
private structure admissibleForestContractCanonicalPreimageRelabeling : Prop where
  relabel :
    ∀ {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
      (hπ : G₂ = G₁.mapPerm π)
      (A : AdmissibleSubgraph G₂)
      (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs),
        ∃ τ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)) =
          (FeynmanGraph.admissibleForestContractGraphWithStars G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (FeynmanGraph.admissibleForestCanonicalStarOf G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                hπ hA))).mapPerm τ

/-- Fieldwise version of canonical mapPerm-preimage relabeling. -/
private structure admissibleForestContractCanonicalPreimageFieldRelabeling : Prop where
  field_relabel :
    ∀ {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
      (hπ : G₂ = G₁.mapPerm π)
      (A : AdmissibleSubgraph G₂)
      (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs),
        ∃ τ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).vertices =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).vertices ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).internalEdges =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).internalEdges ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).externalLegs =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).externalLegs

/-- Concrete field-transport data for the canonical preimage side.  The
permutation is allowed to depend on the forest and on the ambient
representative permutation; it must carry each contracted field literally to
the representative-side canonical contraction field. -/
private structure admissibleForestContractCanonicalPreimagePermutationData : Prop where
  exists_perm :
    ∀ {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
      (hπ : G₂ = G₁.mapPerm π)
      (A : AdmissibleSubgraph G₂)
      (hA : A ∈ G₂.properDisjointAdmissibleDivergentSubgraphs),
        ∃ τ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).vertices =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).vertices ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).internalEdges =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).internalEdges ∧
          (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
            (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).externalLegs =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G₁
              (mapPermAdmissibleSubgraphPreimage hπ A)
              (FeynmanGraph.admissibleForestCanonicalStarOf G₁
                (mapPermAdmissibleSubgraphPreimage hπ A)
                (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
                  hπ hA))).mapPerm τ).externalLegs

/-- Canonical preimage permutation data is exactly the field relabeling
payload expected by the final H5.8 cut. -/
private noncomputable def
    admissibleForestContractCanonicalPreimageFieldRelabelingOfPermutationData
    (T : admissibleForestContractCanonicalPreimagePermutationData) :
    admissibleForestContractCanonicalPreimageFieldRelabeling where
  field_relabel := by
    intro G₁ G₂ π hπ A hA
    exact T.exists_perm hπ A hA

/-- Fieldwise canonical preimage relabeling supplies the literal graph
relabeling. -/
private noncomputable def
    admissibleForestContractCanonicalPreimageRelabelingOfFields
    (T : admissibleForestContractCanonicalPreimageFieldRelabeling) :
    admissibleForestContractCanonicalPreimageRelabeling where
  relabel := by
    intro G₁ G₂ π hπ A hA
    rcases T.field_relabel hπ A hA with
      ⟨τ, hV, hI, hE⟩
    exact ⟨τ, FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr ⟨hV, hI, hE⟩⟩

/-- A literal relabeling witness supplies canonical preimage class
invariance. -/
private noncomputable def
    admissibleForestContractCanonicalPreimageClassTransportOfRelabeling
    (T : admissibleForestContractCanonicalPreimageRelabeling) :
    admissibleForestContractCanonicalPreimageClassTransport where
  canonical_preimage_class := by
    intro G₁ G₂ π hπ A hA
    rcases T.relabel hπ A hA with ⟨τ, hτ⟩
    exact (FeynmanGraph.toClass_eq_iff _ _).mpr ⟨τ, hτ⟩

/-- Star-choice invariance plus canonical permutation-preimage invariance
imply the one-piece graph transport used by the component remnant bridge. -/
private noncomputable def
    admissibleForestContractPreimageClassTransportOfFreshAndCanonical
    (Tfresh : admissibleForestContractFreshStarClassTransport)
    (Tcanonical : admissibleForestContractCanonicalPreimageClassTransport) :
    admissibleForestContractPreimageClassTransport where
  preimage_contract_class := by
    intro G₁ G₂ π hπ A hA starOf hFresh
    calc
      (FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A) starOf).toClass
          =
        (FeynmanGraph.admissibleForestContractGraphWithStars G₁
          (mapPermAdmissibleSubgraphPreimage hπ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G₁
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hπ hA))).toClass := by
          exact Tfresh.fresh_star_class
            (mapPermAdmissibleSubgraphPreimage hπ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hπ hA)
            starOf hFresh
      _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars G₂ A
          (FeynmanGraph.admissibleForestCanonicalStarOf G₂ A hA)).toClass := by
          exact Tcanonical.canonical_preimage_class hπ A hA

/-- The chosen representative of `γ.toHopfGen` is isomorphic to
`γ.toFeynmanGraph`, with source orientation suited for `mapPermSubgraph`. -/
private theorem feynmanSubgraphToHopfGen_rep_isIso
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent) :
    γ.toFeynmanGraph.IsIso (repG (γ.toHopfGen hγ)).toFeynmanGraph := by
  have hRepClass :
      (repG (γ.toHopfGen hγ)).toFeynmanGraph.toClass =
        γ.toFeynmanGraph.toClass := by
    rw [repG_toClass, FeynmanSubgraph.toHopfGen_val]
  exact (FeynmanGraph.toClass_eq_iff
    γ.toFeynmanGraph (repG (γ.toHopfGen hγ)).toFeynmanGraph).mp
    hRepClass.symm

/-- Fixed permutation from a component graph to the selected representative of
its `HopfGen` class. -/
private noncomputable def feynmanSubgraphToHopfGenRepPerm
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent) : Equiv.Perm VertexId :=
  Classical.choose (feynmanSubgraphToHopfGen_rep_isIso γ hγ)

/-- Specification of `feynmanSubgraphToHopfGenRepPerm`. -/
private theorem feynmanSubgraphToHopfGenRepPerm_spec
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent) :
    (repG (γ.toHopfGen hγ)).toFeynmanGraph =
      γ.toFeynmanGraph.mapPerm
        (feynmanSubgraphToHopfGenRepPerm γ hγ) :=
  Classical.choose_spec (feynmanSubgraphToHopfGen_rep_isIso γ hγ)

/-- Transport an admissible forest from the representative
`repG (γ.toHopfGen hγ)` back to the intrinsic component graph
`γ.toFeynmanGraph`. -/
private noncomputable def feynmanSubgraphRepToComponentAdmissibleSubgraph
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph) :
    AdmissibleSubgraph γ.toFeynmanGraph :=
  mapPermAdmissibleSubgraphPreimage
    (feynmanSubgraphToHopfGenRepPerm_spec γ hγ) B

/-- Proper-disjoint membership survives transport from the representative
component graph back to the actual component graph. -/
private theorem feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    {B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph}
    (hB : B ∈
      ((repG (γ.toHopfGen hγ)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs) :
    feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B ∈
      γ.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
  mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
    (feynmanSubgraphToHopfGenRepPerm_spec γ hγ) hB

/-- Pulling a selected forest from the representative component graph back to
the intrinsic component graph preserves the Hopf product. -/
private theorem feynmanSubgraphRepToComponentAdmissibleSubgraph_toHopfH
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph) :
    (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B).toHopfH =
      B.toHopfH :=
  mapPermAdmissibleSubgraphPreimage_toHopfH
    (feynmanSubgraphToHopfGenRepPerm_spec γ hγ) B

/-- Transport a representative component forest back to its component graph,
then promote it into the original ambient graph. -/
private noncomputable def feynmanSubgraphRepForestPromoteAdmissibleSubgraph
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph) :
    AdmissibleSubgraph G :=
  feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ)
    (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B)

@[simp] private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph) :
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B).internalEdges =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B).internalEdges := by
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph
  simp

/-- The ambient promoted version of a representative component forest has the
same Hopf product as the original representative forest. -/
private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_toHopfH
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph) :
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B).toHopfH =
      B.toHopfH := by
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_toHopfH,
    feynmanSubgraphRepToComponentAdmissibleSubgraph_toHopfH]

/-- A proper representative component forest remains a proper ambient forest
after representative transport and promotion. -/
private theorem
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_mem_properDisjoint
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    {B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph}
    (hB : B ∈
      ((repG (γ.toHopfGen hγ)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs) :
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B ∈
      G.properDisjointAdmissibleDivergentSubgraphs :=
  feynmanSubgraphPromoteAdmissibleSubgraph_mem_properDisjoint
    (feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
      γ hγ hB)

/-- A component-choice forest summand, once transported through the component
representative and promoted, is a proper ambient forest. -/
private theorem forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
      (A.isConnectedDivergent_of_mem γ.2) B ∈
      G.properDisjointAdmissibleDivergentSubgraphs :=
  feynmanSubgraphRepForestPromoteAdmissibleSubgraph_mem_properDisjoint γ.1
    (A.isConnectedDivergent_of_mem γ.2)
    (forestComponentChoice_forest_mem_properDisjoint_of_core_mem hp γ hB)

/-- A promoted representative forest component still lies inside the original
outer component that supplied it. -/
private theorem
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph)
    {δ : FeynmanSubgraph G}
    (hδ :
      δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B).elements) :
    δ.vertices ⊆ γ.vertices := by
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hδ
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hδ
  rcases Finset.mem_image.mp hδ with ⟨η, _hη, rfl⟩
  intro v hv
  exact η.1.vertices_subset hv

private theorem
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_le_outer
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph)
    {δ : FeynmanSubgraph G}
    (hδ :
      δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B).elements) :
    δ.internalEdges ≤ γ.internalEdges := by
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hδ
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hδ
  rcases Finset.mem_image.mp hδ with ⟨η, _hη, rfl⟩
  exact η.1.internalEdges_le

/-- Raw ambient carrier of all promoted forest components selected by a
component-choice function.  Components selected as `left` or `right` contribute
nothing here; only genuine `forest B` choices are spliced into the outer
carrier. -/
private noncomputable def forestComponentChoicePromotedForestComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) : Finset (FeynmanSubgraph G) :=
  A.elements.attach.biUnion fun γ =>
    match p γ (Finset.mem_attach A.elements γ) with
    | forestCoproductChoice.left => ∅
    | forestCoproductChoice.right => ∅
    | forestCoproductChoice.forest B =>
        (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (A.isConnectedDivergent_of_mem γ.2) B).elements

/-- The promoted component carrier contributed by one original component
choice. -/
private noncomputable def forestComponentChoicePromotedForestComponentsForChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hγ : γ ∈ A.elements.attach) : Finset (FeynmanSubgraph G) :=
  match p γ hγ with
  | forestCoproductChoice.left => ∅
  | forestCoproductChoice.right => ∅
  | forestCoproductChoice.forest B =>
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).elements

private theorem forestComponentChoicePromotedForestComponents_eq_biUnion_forChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) :
    forestComponentChoicePromotedForestComponents A p =
      A.elements.attach.biUnion fun γ =>
        forestComponentChoicePromotedForestComponentsForChoice A p γ
          (Finset.mem_attach A.elements γ) := by
  rfl

private theorem forestComponentChoicePromotedForestComponents_mem_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B)
    {δ : FeynmanSubgraph G}
    (hδ :
      δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).elements) :
    δ ∈ forestComponentChoicePromotedForestComponents A p := by
  unfold forestComponentChoicePromotedForestComponents
  rw [Finset.mem_biUnion]
  refine ⟨γ, Finset.mem_attach A.elements γ, ?_⟩
  simpa [hB] using hδ

private theorem forestComponentChoicePromotedForestComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) {δ : FeynmanSubgraph G}
    (hδ : δ ∈ forestComponentChoicePromotedForestComponents A p) :
    ∃ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
      ∃ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        p γ (Finset.mem_attach A.elements γ) =
          forestCoproductChoice.forest B ∧
        δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (A.isConnectedDivergent_of_mem γ.2) B).elements := by
  unfold forestComponentChoicePromotedForestComponents at hδ
  rw [Finset.mem_biUnion] at hδ
  rcases hδ with ⟨γ, _hγ, hδγ⟩
  cases hChoice : p γ (Finset.mem_attach A.elements γ) with
  | left =>
      simp [hChoice] at hδγ
  | right =>
      simp [hChoice] at hδγ
  | forest B =>
      exact ⟨γ, B, hChoice, by simpa [hChoice] using hδγ⟩

private theorem forestComponentChoicePromotedForestComponents_isConnectedDivergent
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) {δ : FeynmanSubgraph G}
    (hδ : δ ∈ forestComponentChoicePromotedForestComponents A p) :
    δ.IsConnectedDivergent := by
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ with
    ⟨γ, B, _hB, hδB⟩
  exact (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
    (A.isConnectedDivergent_of_mem γ.2) B).isConnectedDivergent_of_mem hδB

/-- Hopf product over the raw promoted component carrier. -/
private noncomputable def forestComponentChoicePromotedComponentsHopfProduct
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) : HopfH :=
  ∏ δ ∈ forestComponentChoicePromotedForestComponents A p,
    if hδ : δ ∈ forestComponentChoicePromotedForestComponents A p then
      (MvPolynomial.X
        (δ.toHopfGen
          (forestComponentChoicePromotedForestComponents_isConnectedDivergent
            A p hδ)) : HopfH)
    else 1

private theorem forestComponentChoicePromotedForestComponents_mem_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) {δ : FeynmanSubgraph G}
    (hδ : δ ∈ forestComponentChoicePromotedForestComponents A p) :
    ∃ γ ∈ A.elements, δ.vertices ⊆ γ.vertices := by
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ with
    ⟨γ, B, _hB, hδB⟩
  exact ⟨γ.1, γ.2,
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γ.1 (A.isConnectedDivergent_of_mem γ.2) B hδB⟩

/-- Promoted component carriers contributed by distinct original components
are disjoint as finite carriers. -/
private theorem forestComponentChoicePromotedForestComponentsForChoice_pairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    Set.PairwiseDisjoint (↑A.elements.attach)
      (fun γ =>
        forestComponentChoicePromotedForestComponentsForChoice A p γ
          (Finset.mem_attach A.elements γ)) := by
  classical
  intro γ _hγ η _hη hγη
  change Disjoint
    (forestComponentChoicePromotedForestComponentsForChoice A p γ
      (Finset.mem_attach A.elements γ))
    (forestComponentChoicePromotedForestComponentsForChoice A p η
      (Finset.mem_attach A.elements η))
  rw [Finset.disjoint_left]
  intro δ hδγ hδη
  cases hγChoice : p γ (Finset.mem_attach A.elements γ) with
  | left =>
      simp [forestComponentChoicePromotedForestComponentsForChoice, hγChoice] at hδγ
  | right =>
      simp [forestComponentChoicePromotedForestComponentsForChoice, hγChoice] at hδγ
  | forest Bγ =>
      cases hηChoice : p η (Finset.mem_attach A.elements η) with
      | left =>
          simp [forestComponentChoicePromotedForestComponentsForChoice, hηChoice] at hδη
      | right =>
          simp [forestComponentChoicePromotedForestComponentsForChoice, hηChoice] at hδη
      | forest Bη =>
          have hδγ' :
              δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
                (A.isConnectedDivergent_of_mem γ.2) Bγ).elements := by
            simpa [forestComponentChoicePromotedForestComponentsForChoice,
              hγChoice] using hδγ
          have hδη' :
              δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph η.1
                (A.isConnectedDivergent_of_mem η.2) Bη).elements := by
            simpa [forestComponentChoicePromotedForestComponentsForChoice,
              hηChoice] using hδη
          have hγVal : γ.1 ≠ η.1 := by
            intro h
            exact hγη (Subtype.ext h)
          have hSourceDisj : γ.1.Disjoint η.1 := hA γ.2 η.2 hγVal
          have hδSubsetγ :
              δ.vertices ⊆ γ.1.vertices :=
            feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
              γ.1 (A.isConnectedDivergent_of_mem γ.2) Bγ hδγ'
          have hδSubsetη :
              δ.vertices ⊆ η.1.vertices :=
            feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
              η.1 (A.isConnectedDivergent_of_mem η.2) Bη hδη'
          have hPromotedProper :
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
                (A.isConnectedDivergent_of_mem γ.2) Bγ ∈
                G.properDisjointAdmissibleDivergentSubgraphs :=
            forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
              hp γ hγChoice
          have hδNonempty : δ.IsNonempty :=
            G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
              hPromotedProper δ hδγ'
          unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hδNonempty
          rcases Finset.card_pos.mp hδNonempty with ⟨v, hv⟩
          exact (Finset.disjoint_left.mp hSourceDisj
            (hδSubsetγ hv)) (hδSubsetη hv)

/-- The γ-indexed product of promoted representative forests is the product
over the actual promoted component carrier. -/
private theorem
    forestComponentChoicePromotedOuterTensorFactor_product_eq_promotedComponentsHopfProduct_of_core
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    (∏ γ ∈ A.elements.attach,
        forestComponentChoicePromotedOuterTensorFactor A p γ
          (Finset.mem_attach A.elements γ)) =
      forestComponentChoicePromotedComponentsHopfProduct A p := by
  classical
  unfold forestComponentChoicePromotedComponentsHopfProduct
  symm
  change
    (∏ δ ∈ A.elements.attach.biUnion (fun γ =>
        forestComponentChoicePromotedForestComponentsForChoice A p γ
          (Finset.mem_attach A.elements γ)),
      if hδ : δ ∈ forestComponentChoicePromotedForestComponents A p then
        (MvPolynomial.X
          (δ.toHopfGen
            (forestComponentChoicePromotedForestComponents_isConnectedDivergent
              A p hδ)) : HopfH)
      else 1) =
      ∏ γ ∈ A.elements.attach,
        forestComponentChoicePromotedOuterTensorFactor A p γ
          (Finset.mem_attach A.elements γ)
  rw [Finset.prod_biUnion
    (forestComponentChoicePromotedForestComponentsForChoice_pairwiseDisjoint
      hp hA)]
  apply Finset.prod_congr rfl
  intro γ _hγ
  cases hChoice : p γ (Finset.mem_attach A.elements γ) with
  | left =>
      simp [forestComponentChoicePromotedForestComponentsForChoice,
        forestComponentChoicePromotedOuterTensorFactor, hChoice]
  | right =>
      simp [forestComponentChoicePromotedForestComponentsForChoice,
        forestComponentChoicePromotedOuterTensorFactor, hChoice]
  | forest B =>
      let P :=
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (A.isConnectedDivergent_of_mem γ.2) B
      have hToHopf :
          P.toHopfH = B.toHopfH := by
        simpa [P] using
          feynmanSubgraphRepForestPromoteAdmissibleSubgraph_toHopfH
            γ.1 (A.isConnectedDivergent_of_mem γ.2) B
      have hProd :
          (∏ δ ∈ forestComponentChoicePromotedForestComponentsForChoice A p γ
              (Finset.mem_attach A.elements γ),
            if hδ : δ ∈ forestComponentChoicePromotedForestComponents A p then
              (MvPolynomial.X
                (δ.toHopfGen
                  (forestComponentChoicePromotedForestComponents_isConnectedDivergent
                    A p hδ)) : HopfH)
            else 1) = P.toHopfH := by
        unfold AdmissibleSubgraph.toHopfH
        have hCarrier :
            forestComponentChoicePromotedForestComponentsForChoice A p γ
              (Finset.mem_attach A.elements γ) = P.elements := by
          simp [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P]
        rw [hCarrier]
        apply Finset.prod_congr rfl
        intro δ hδ
        unfold AdmissibleSubgraph.componentToHopfH gen
        have hδGlobalBiUnion :
            δ ∈ A.elements.attach.biUnion (fun γ =>
              forestComponentChoicePromotedForestComponentsForChoice A p γ
                (Finset.mem_attach A.elements γ)) := by
          rw [Finset.mem_biUnion]
          refine ⟨γ, Finset.mem_attach A.elements γ, ?_⟩
          simpa [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P] using hδ
        have hδGlobal :
            δ ∈ forestComponentChoicePromotedForestComponents A p := by
          rw [forestComponentChoicePromotedForestComponents_eq_biUnion_forChoice]
          exact hδGlobalBiUnion
        have hδP : δ ∈ P.elements := by
          simpa [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P] using hδ
        rw [dif_pos hδGlobal, dif_pos hδP]
      calc
        (∏ δ ∈ forestComponentChoicePromotedForestComponentsForChoice A p γ
              (Finset.mem_attach A.elements γ),
            if hδ : δ ∈ forestComponentChoicePromotedForestComponents A p then
              (MvPolynomial.X
                (δ.toHopfGen
                  (forestComponentChoicePromotedForestComponents_isConnectedDivergent
                    A p hδ)) : HopfH)
            else 1)
            = P.toHopfH := hProd
        _ = B.toHopfH := hToHopf
        _ = forestComponentChoicePromotedOuterTensorFactor A p γ
              (Finset.mem_attach A.elements γ) := by
              simp [forestComponentChoicePromotedOuterTensorFactor, hChoice]

/-- A left-selected original component is vertex-disjoint from every promoted
forest component coming from a genuine forest choice. -/
private theorem forestComponentChoiceLeft_promotedForestComponent_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ δ : FeynmanSubgraph G}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph A p).elements)
    (hδF : δ ∈ forestComponentChoicePromotedForestComponents A p) :
    γ.Disjoint δ := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδF with
    ⟨η, B, hB, hδB⟩
  have hγA : γ ∈ A.elements :=
    forestComponentChoiceLeftSubgraph_elements_subset A p hγL
  have hδSubset :
      δ.vertices ⊆ η.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      η.1 (A.isConnectedDivergent_of_mem η.2) B hδB
  by_cases hγη : γ = η.1
  · subst γ
    rw [forestComponentChoiceLeftSubgraph_elements] at hγL
    rcases Finset.mem_filter.mp hγL with ⟨_hηA, hLeft⟩
    unfold forestComponentChoiceIsLeft at hLeft
    rw [dif_pos η.2] at hLeft
    rw [hB] at hLeft
    cases hLeft
  · have hdisj : γ.Disjoint η.1 := hA hγA η.2 hγη
    unfold FeynmanSubgraph.Disjoint at hdisj ⊢
    exact Finset.disjoint_left.mpr fun v hvγ hvδ =>
      (Finset.disjoint_left.mp hdisj hvγ) (hδSubset hvδ)

/-- Promoted forest components are pairwise Zimmermann-compatible; components
from the same original component use the selected forest, while components
from different original components use the disjointness of the outer carrier. -/
private theorem forestComponentChoicePromotedForestComponents_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {δ₁ δ₂ : FeynmanSubgraph G}
    (hδ₁ : δ₁ ∈ forestComponentChoicePromotedForestComponents A p)
    (hδ₂ : δ₂ ∈ forestComponentChoicePromotedForestComponents A p)
    (hne : δ₁ ≠ δ₂) :
    δ₁.NestedOrDisjoint δ₂ := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ₁ with
    ⟨γ₁, B₁, hB₁, hδB₁⟩
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ₂ with
    ⟨γ₂, B₂, hB₂, hδB₂⟩
  by_cases hγ : γ₁.1 = γ₂.1
  · have hγSubtype : γ₁ = γ₂ := Subtype.ext hγ
    subst γ₂
    have hB : B₁ = B₂ := by
      apply forestCoproductChoice_forest_injective
        (γ₁.1.toHopfGen (A.isConnectedDivergent_of_mem γ₁.2))
      rw [← hB₁, ← hB₂]
    subst B₂
    exact (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ₁.1
      (A.isConnectedDivergent_of_mem γ₁.2) B₁).forest.nestedOrDisjoint
        hδB₁ hδB₂ hne
  · have hdisjOuter : γ₁.1.Disjoint γ₂.1 := hA γ₁.2 γ₂.2 hγ
    have hδ₁Subset :
        δ₁.vertices ⊆ γ₁.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ₁.1 (A.isConnectedDivergent_of_mem γ₁.2) B₁ hδB₁
    have hδ₂Subset :
        δ₂.vertices ⊆ γ₂.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ₂.1 (A.isConnectedDivergent_of_mem γ₂.2) B₂ hδB₂
    refine Or.inr ?_
    unfold FeynmanSubgraph.Disjoint at hdisjOuter ⊢
    exact Finset.disjoint_left.mpr fun v hv₁ hv₂ =>
      (Finset.disjoint_left.mp hdisjOuter (hδ₁Subset hv₁)) (hδ₂Subset hv₂)

/-- The graph-level outer forest for the genuine-forest component-choice
regime: keep every left-selected original component and splice in all
promoted components of every selected genuine component forest. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    AdmissibleSubgraph G :=
  AdmissibleSubgraph.ofElements
    ((forestComponentChoiceLeftSubgraph A p).elements ∪
      forestComponentChoicePromotedForestComponents A p)
    (by
      constructor
      · intro δ hδ
        rcases Finset.mem_union.mp hδ with hδL | hδF
        · exact (forestComponentChoiceLeftSubgraph A p).isConnectedDivergent_of_mem hδL
        · exact forestComponentChoicePromotedForestComponents_isConnectedDivergent
            A p hδF
      · intro δ₁ hδ₁ δ₂ hδ₂ hne
        rcases Finset.mem_union.mp hδ₁ with hδ₁L | hδ₁F
        · rcases Finset.mem_union.mp hδ₂ with hδ₂L | hδ₂F
          · exact (forestComponentChoiceLeftSubgraph A p).forest.nestedOrDisjoint
              hδ₁L hδ₂L hne
          · exact Or.inr
              (forestComponentChoiceLeft_promotedForestComponent_disjoint
                A p hA hδ₁L hδ₂F)
        · rcases Finset.mem_union.mp hδ₂ with hδ₂L | hδ₂F
          · exact Or.inr
              (forestComponentChoiceLeft_promotedForestComponent_disjoint
                A p hA hδ₂L hδ₁F).symm
          · exact forestComponentChoicePromotedForestComponents_nestedOrDisjoint
              A p hA hδ₁F hδ₂F hne)

@[simp] private theorem forestComponentForestChoiceOuterSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).elements =
      (forestComponentChoiceLeftSubgraph A p).elements ∪
        forestComponentChoicePromotedForestComponents A p := rfl

/-- Sprint F2-Track-B-forest-2a-pre3: a genuine-forest `OuterSubgraph` element
that meets a forest-choice parent `γ` is contained in `γ`.  Left elements are
distinct A-components (disjoint from γ); promoted elements lie in their parent
component, which must be `γ` when it meets `γ` (pairwise disjointness). -/
private theorem forestComponentForestChoiceOuterSubgraph_elt_subset_parent_of_meets
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G} (hγ : γ ∈ A.elements)
    {η : FeynmanSubgraph G}
    (hη : η ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements)
    (hmeet : ∃ v, v ∈ η.vertices ∧ v ∈ γ.vertices) :
    η.vertices ⊆ γ.vertices := by
  classical
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hη
  rcases Finset.mem_union.mp hη with hηL | hηP
  · -- Left component: η ∈ A.elements; either η = γ (refl) or disjoint (contradiction).
    have hηA : η ∈ A.elements :=
      forestComponentChoiceLeftSubgraph_elements_subset A p hηL
    by_cases hηγ : η = γ
    · subst hηγ; exact Finset.Subset.refl _
    · obtain ⟨v, hvη, hvγ⟩ := hmeet
      exact absurd ((hA hηA hγ hηγ : η.Disjoint γ)) (by
        rw [FeynmanSubgraph.Disjoint, Finset.disjoint_left]
        exact fun hd => hd hvη hvγ)
  · -- Promoted component: lies in its parent γ', which meets γ ⇒ γ' = γ.
    rcases forestComponentChoicePromotedForestComponents_mem_exists A p hηP with
      ⟨γ', B', _hpγ', hηγ'⟩
    have hηSub : η.vertices ⊆ γ'.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ'.1 (A.isConnectedDivergent_of_mem γ'.2) B' hηγ'
    obtain ⟨v, hvη, hvγ⟩ := hmeet
    have hγ'γ : γ'.1 = γ :=
      hA.eq_of_mem_vertices γ'.2 hγ (hηSub hvη) hvγ
    rw [← hγ'γ]; exact hηSub

/-- Sprint F2-Track-B-forest-2a: **parent vertex recovery**.  The generic source
vertices of the remnant of a forest-choice parent `γ` (in the contracted graph
`OuterSubgraph A p hA`) recover exactly `γ.vertices`.  Forward: a non-star
source vertex un-retargets to itself in γ; a promoted source vertex lies in an
`OuterSubgraph` component meeting γ, hence ⊆ γ (pre3).  Backward: an Aout-vertex
of γ contributes through its component's star (pre2); a non-Aout vertex stays
identity in the remnant and is not a (fresh) star. -/
private theorem forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (hAoutPD : forestComponentForestChoiceOuterSubgraph A p hA ∈
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph} (hγ : γ ∈ A.elements) :
    admissibleSubgraphRemainderSourceVertices
        (forestComponentForestChoiceOuterSubgraph A p hA)
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterSubgraph A p hA) hAoutPD)
        (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterSubgraph A p hA)
          (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterSubgraph A p hA) hAoutPD)
          γ) = γ.vertices := by
  classical
  set Aout := forestComponentForestChoiceOuterSubgraph A p hA with hAoutDef
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
    Aout hAoutPD with hstarOf
  have hFresh := FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
    (repG g).toFeynmanGraph Aout hAoutPD
  ext v
  rw [mem_admissibleSubgraphRemainderSourceVertices]
  constructor
  · rintro (⟨hvδ, hvNotStar⟩ | ⟨η, hηAout, hStar, hvη⟩)
    · rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hvδ
      obtain ⟨u, huγ, hret⟩ := Finset.mem_image.mp hvδ
      by_cases huAout : u ∈ Aout.vertices
      · exfalso
        apply hvNotStar
        rw [← hret, AdmissibleSubgraph.retargetVertex, Aout.componentAt?_of_mem huAout,
          AdmissibleSubgraph.mem_starVertices]
        exact ⟨Aout.componentAt huAout, Aout.componentAt_mem huAout, rfl⟩
      · rw [AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf huAout] at hret
        rw [← hret]; exact huγ
    · have hMeet :=
        (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
          Aout hAoutPD γ hηAout).mp hStar
      exact forestComponentForestChoiceOuterSubgraph_elt_subset_parent_of_meets
        A p hA hγ hηAout hMeet hvη
  · intro hvγ
    by_cases hvAout : v ∈ Aout.vertices
    · refine Or.inr ⟨Aout.componentAt hvAout, Aout.componentAt_mem hvAout, ?_,
        Aout.componentAt_vertex_mem hvAout⟩
      exact (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
        Aout hAoutPD γ (Aout.componentAt_mem hvAout)).mpr
        ⟨v, Aout.componentAt_vertex_mem hvAout, hvγ⟩
    · refine Or.inl ⟨?_, ?_⟩
      · rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
        exact Finset.mem_image.mpr
          ⟨v, hvγ, AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hvAout⟩
      · intro hvStar
        exact (hFresh.star_not_mem_vertices hvStar) (γ.vertices_subset hvγ)

/-- **Track B-forest-inj-finalize — CK graph-insertion uniqueness facade.**

`forest_inj` (genuine-forest same-branch injectivity for the H5.8 split-φ
indexed classifier) reduces, after the constructive vertex recovery
(`forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices`),
to recovering a forest-choice **parent** `γ` from its quotient image.  The
remnant `γ/B` contracts the promoted children to their stars; boundary-crossing
internal edges of `γ` collapse onto those stars, so `remnant(γ).internalEdges`
is **not** injective in `γ` on its own.  Morally the lost boundary data lives in
the promoted children's `externalLegs`, but `FeynmanSubgraph` keeps
`externalLegs` as an independent multiset (only `attachedTo + sector`, not the
collapsed interior endpoint), so uniqueness of re-insertion is a genuine
*semantic* kernel — the formalization has exposed CK 1998's implicit
graph-insertion uniqueness.

This facade isolates exactly that: two forest-choice parents with the same
promoted contribution (in `OuterSubgraph`) and the same remnant (in
`RepQuotient`) are equal.  It is the genuine-forest analogue of the
`mixed_q1_recovery` step, where the off-carrier (data-preserving) case made the
recovery constructive without a uniqueness assumption. -/
class ForestGraphInsertionUniquenessModel : Prop where
  parent_eq_of_remnant_eq :
    ∀ {G : FeynmanGraph} [DivergenceMeasure G]
      (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
      {γ₁ γ₂ : FeynmanSubgraph G},
        -- vertices already recovered (B-forest-2a); the remnant (contraction
        -- `γ/A`) records edges-up-to-star-collapse and the full external legs.
        -- The semantic kernel: this data determines the parent uniquely
        -- (CK graph-insertion uniqueness, exposed by the flexible carrier).
        γ₁.vertices = γ₂.vertices →
        admissibleSubgraphQuotientRemainderSubgraph A starOf γ₁ =
          admissibleSubgraphQuotientRemainderSubgraph A starOf γ₂ →
        γ₁ = γ₂

/-- Membership in the genuine-forest component-choice regime gives both the
core component-choice membership and an actual forest summand. -/
private theorem mem_forestComponentForestChoiceCoreIndex_core_hasForest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentForestChoiceCoreIndex A) :
    p ∈ forestComponentCoreChoiceIndex A ∧
      forestComponentChoiceHasForest A p := by
  classical
  unfold forestComponentForestChoiceCoreIndex at hp
  exact Finset.mem_filter.mp hp

/-- In the proper genuine-forest regime, promoted forest components are
pairwise vertex-disjoint. -/
private theorem forestComponentChoicePromotedForestComponents_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    {δ₁ δ₂ : FeynmanSubgraph G}
    (hδ₁ : δ₁ ∈ forestComponentChoicePromotedForestComponents A p)
    (hδ₂ : δ₂ ∈ forestComponentChoicePromotedForestComponents A p)
    (hne : δ₁ ≠ δ₂) :
    δ₁.Disjoint δ₂ := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ₁ with
    ⟨γ₁, B₁, hB₁, hδB₁⟩
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδ₂ with
    ⟨γ₂, B₂, hB₂, hδB₂⟩
  by_cases hγ : γ₁.1 = γ₂.1
  · have hγSubtype : γ₁ = γ₂ := Subtype.ext hγ
    subst γ₂
    have hB : B₁ = B₂ := by
      apply forestCoproductChoice_forest_injective
        (γ₁.1.toHopfGen (A.isConnectedDivergent_of_mem γ₁.2))
      rw [← hB₁, ← hB₂]
    subst B₂
    have hPromotedProper :
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ₁.1
          (A.isConnectedDivergent_of_mem γ₁.2) B₁ ∈
          G.properDisjointAdmissibleDivergentSubgraphs :=
      forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
        hp γ₁ hB₁
    exact G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hPromotedProper hδB₁ hδB₂ hne
  · have hdisjOuter : γ₁.1.Disjoint γ₂.1 := hA γ₁.2 γ₂.2 hγ
    have hδ₁Subset :
        δ₁.vertices ⊆ γ₁.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ₁.1 (A.isConnectedDivergent_of_mem γ₁.2) B₁ hδB₁
    have hδ₂Subset :
        δ₂.vertices ⊆ γ₂.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ₂.1 (A.isConnectedDivergent_of_mem γ₂.2) B₂ hδB₂
    unfold FeynmanSubgraph.Disjoint at hdisjOuter ⊢
    exact Finset.disjoint_left.mpr fun v hv₁ hv₂ =>
      (Finset.disjoint_left.mp hdisjOuter (hδ₁Subset hv₁)) (hδ₂Subset hv₂)

private theorem forestComponentForestChoiceOuterSubgraph_isPairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).IsPairwiseDisjoint := by
  intro δ₁ hδ₁ δ₂ hδ₂ hne
  change δ₁ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements at hδ₁
  change δ₂ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements at hδ₂
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδ₁ hδ₂
  rcases Finset.mem_union.mp hδ₁ with hδ₁L | hδ₁F
  · rcases Finset.mem_union.mp hδ₂ with hδ₂L | hδ₂F
    · exact forestComponentChoiceLeftSubgraph_isPairwiseDisjoint A p hA
        hδ₁L hδ₂L hne
    · exact forestComponentChoiceLeft_promotedForestComponent_disjoint
        A p hA hδ₁L hδ₂F
  · rcases Finset.mem_union.mp hδ₂ with hδ₂L | hδ₂F
    · exact (forestComponentChoiceLeft_promotedForestComponent_disjoint
        A p hA hδ₂L hδ₁F).symm
    · exact forestComponentChoicePromotedForestComponents_disjoint
        hp hA hδ₁F hδ₂F hne

private theorem forestComponentForestChoiceOuterSubgraph_isNonempty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hHasForest : forestComponentChoiceHasForest A p)
    (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).IsNonempty := by
  rcases hHasForest with ⟨γ, B, hB⟩
  have hPromotedProper :
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B ∈
        G.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
      hp γ hB
  rcases properDisjointAdmissibleDivergentSubgraphs_isNonempty hPromotedProper with
    ⟨δ, hδ⟩
  refine ⟨δ, ?_⟩
  rw [forestComponentForestChoiceOuterSubgraph_elements]
  exact Finset.mem_union_right _
    (forestComponentChoicePromotedForestComponents_mem_of_forest A p γ hB hδ)

private theorem forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hAProper : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents := by
  intro δ hδ
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδ
  rcases Finset.mem_union.mp hδ with hδL | hδF
  · exact G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      hAProper δ (forestComponentChoiceLeftSubgraph_elements_subset A p hδL)
  · rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδF with
      ⟨γ, B, hB, hδB⟩
    have hPromotedProper :
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (A.isConnectedDivergent_of_mem γ.2) B ∈
          G.properDisjointAdmissibleDivergentSubgraphs :=
      forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
        hp γ hB
    exact G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      hPromotedProper δ hδB

private theorem
    forestComponentForestChoiceOuterSubgraph_hasPositiveInternalEdgesComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hAProper : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).HasPositiveInternalEdgesComponents := by
  intro δ hδ
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδ
  rcases Finset.mem_union.mp hδ with hδL | hδF
  · exact G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      hAProper δ (forestComponentChoiceLeftSubgraph_elements_subset A p hδL)
  · rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδF with
      ⟨γ, B, hB, hδB⟩
    have hPromotedProper :
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (A.isConnectedDivergent_of_mem γ.2) B ∈
          G.properDisjointAdmissibleDivergentSubgraphs :=
      forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
        hp γ hB
    exact G.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      hPromotedProper δ hδB

private theorem forestComponentForestChoiceOuterSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hAProper : A ∈ G.properDisjointAdmissibleDivergentSubgraphs)
    (hpForest : p ∈ forestComponentForestChoiceCoreIndex A) :
    forestComponentForestChoiceOuterSubgraph A p
      (G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hAProper) ∈
      G.properDisjointAdmissibleDivergentSubgraphs := by
  rw [G.mem_properDisjointAdmissibleDivergentSubgraphs]
  have hpCore : p ∈ forestComponentCoreChoiceIndex A :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hHasForest : forestComponentChoiceHasForest A p :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
  let hA : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hAProper
  have hTargetDisjoint :
      (forestComponentForestChoiceOuterSubgraph A p hA).IsPairwiseDisjoint :=
    forestComponentForestChoiceOuterSubgraph_isPairwiseDisjoint hpCore hA
  have hTargetNonempty :
      (forestComponentForestChoiceOuterSubgraph A p hA).IsNonempty :=
    forestComponentForestChoiceOuterSubgraph_isNonempty hpCore hHasForest hA
  have hTargetNonemptyComponents :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents
      hpCore hAProper hA
  have hTargetPositiveComponents :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasPositiveInternalEdgesComponents :=
    forestComponentForestChoiceOuterSubgraph_hasPositiveInternalEdgesComponents
      hpCore hAProper hA
  refine ⟨?_, hTargetNonemptyComponents, ?_, hTargetPositiveComponents⟩
  · rw [G.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
      G.mem_disjointAdmissibleDivergentSubgraphs]
    exact ⟨⟨G.mem_admissibleDivergentSubgraphs _,
        hTargetDisjoint⟩, hTargetNonempty⟩
  · exact admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
      hTargetPositiveComponents hTargetNonempty

/-- The RHS outer forest for a genuine-forest component-choice term. -/
private noncomputable def forestComponentForestChoiceOuterIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestOuterProperIndex g :=
  ⟨forestComponentForestChoiceOuterSubgraph q.1.1 q.2
      ((repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2),
    by
      exact forestComponentForestChoiceOuterSubgraph_mem_properDisjoint
        q.1.2 (Finset.mem_sigma.mp hq).2⟩

@[simp] private theorem forestComponentForestChoiceOuterIndex_val
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceOuterIndex g q hq).1 =
      forestComponentForestChoiceOuterSubgraph q.1.1 q.2
        ((repG g).toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2) := rfl

/-- Every component of the genuine-forest outer splice is supported inside one
of the original outer components. -/
private theorem forestComponentForestChoiceOuterSubgraph_mem_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {δ : FeynmanSubgraph G}
    (hδ : δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements) :
    ∃ γ ∈ A.elements, δ.vertices ⊆ γ.vertices := by
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδ
  rcases Finset.mem_union.mp hδ with hδL | hδF
  · exact ⟨δ, forestComponentChoiceLeftSubgraph_elements_subset A p hδL,
      fun _ hv => hv⟩
  · exact forestComponentChoicePromotedForestComponents_mem_source A p hδF

private theorem forestComponentForestChoiceOuterSubgraph_mem_source_internalEdges_le
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {δ : FeynmanSubgraph G}
    (hδ : δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements) :
    ∃ γ ∈ A.elements, δ.internalEdges ≤ γ.internalEdges := by
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδ
  rcases Finset.mem_union.mp hδ with hδL | hδF
  · exact ⟨δ, forestComponentChoiceLeftSubgraph_elements_subset A p hδL,
      le_rfl⟩
  · rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδF with
      ⟨γ, B, _hB, hδB⟩
    exact ⟨γ.1, γ.2,
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_le_outer
        γ.1 (A.isConnectedDivergent_of_mem γ.2) B hδB⟩

private theorem forestComponentForestChoiceOuterSubgraph_internalEdges_le_original
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).internalEdges ≤
      A.internalEdges := by
  classical
  let Aout := forestComponentForestChoiceOuterSubgraph A p hA
  have hAoutDisj : Aout.IsPairwiseDisjoint := by
    simpa [Aout] using
      forestComponentForestChoiceOuterSubgraph_isPairwiseDisjoint hp hA
  refine admissibleSubgraph_internalEdges_le_of_components_le
    Aout hAoutDisj ?_
  intro δ hδ
  rcases forestComponentForestChoiceOuterSubgraph_mem_source_internalEdges_le
      A p hA (by simpa [Aout] using hδ) with
    ⟨γ, hγA, hδγ⟩
  exact hδγ.trans
    (feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem
      A hA hγA)

/-- Source partition foothold (Sprint F1a): every outer component `δ` of the
genuine-forest splice has a **unique** original source component `γ ∈ A.elements`
covering it, since `A` is pairwise disjoint. The existence half is
`_mem_source`; this strengthens it to uniqueness, which is the building block
for the recovery map underpinning forest-branch injectivity. -/
private theorem forestComponentForestChoiceOuterSubgraph_mem_source_unique
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {δ : FeynmanSubgraph G}
    (hδ : δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements)
    (hδNE : δ.IsNonempty)
    {γ₁ γ₂ : FeynmanSubgraph G}
    (hγ₁ : γ₁ ∈ A.elements) (hγ₂ : γ₂ ∈ A.elements)
    (hδγ₁ : δ.vertices ⊆ γ₁.vertices) (hδγ₂ : δ.vertices ⊆ γ₂.vertices) :
    γ₁ = γ₂ := by
  rcases Finset.card_pos.mp hδNE with ⟨v, hv⟩
  exact hA.eq_of_mem_vertices hγ₁ hγ₂ (hδγ₁ hv) (hδγ₂ hv)

/-- Source partition map (Sprint F1b): each outer component `δ` of the
genuine-forest splice is mapped to **some** original source component
`γ ∈ A.elements` covering it. Existence is `_mem_source`; uniqueness on
nonempty `δ` is recorded by `_sourcePartition_unique` below. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph_sourcePartition
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}) :
    {γ : FeynmanSubgraph G // γ ∈ A.elements} :=
  let h := forestComponentForestChoiceOuterSubgraph_mem_source A p hA δ.2
  ⟨h.choose, h.choose_spec.1⟩

private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}) :
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1
      ∈ A.elements :=
  (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).2

private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}) :
    δ.1.vertices ⊆
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1.vertices :=
  (forestComponentForestChoiceOuterSubgraph_mem_source A p hA δ.2).choose_spec.2

private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements})
    (hδNE : δ.1.IsNonempty)
    {γ : FeynmanSubgraph G} (hγ : γ ∈ A.elements)
    (hsub : δ.1.vertices ⊆ γ.vertices) :
    γ = (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1 :=
  forestComponentForestChoiceOuterSubgraph_mem_source_unique A p hA δ.2 hδNE
    hγ
    (forestComponentForestChoiceOuterSubgraph_sourcePartition_mem A p hA δ)
    hsub
    (forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p hA δ)

/-- Per-source slot (Sprint F1c): collects the outer components assigned to
`γ ∈ A.elements` by the source partition map. The `Finset` lives on the
`attach`ed subtype so that membership pairs naturally with the existing
`sourcePartition` API. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph_slotAt
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}) :
    Finset {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements} := by
  classical
  exact ((forestComponentForestChoiceOuterSubgraph A p hA).elements.attach).filter
    (fun δ =>
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1
        = γ.1)

private theorem forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}) :
    δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ ↔
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1
        = γ.1 := by
  classical
  unfold forestComponentForestChoiceOuterSubgraph_slotAt
  rw [Finset.mem_filter]
  exact ⟨fun h => h.2, fun h => ⟨Finset.mem_attach _ _, h⟩⟩

private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}}
    {δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hδ : δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ) :
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1
      = γ.1 :=
  (forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff A p hA γ δ).mp hδ

private theorem forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}}
    {δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hsp : (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1
        = γ.1) :
    δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ :=
  (forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff A p hA γ δ).mpr hsp

/-- Disjoint cover (Sprint F1d): the slots over `A.elements.attach` cover the
entire `attach`ed outer carrier. Each outer δ lands in the slot keyed by its
`sourcePartition`. -/
private theorem forestComponentForestChoiceOuterSubgraph_biUnion_slotAt_eq_attach
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    (A.elements.attach.biUnion
        (fun γ => forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ))
      = (forestComponentForestChoiceOuterSubgraph A p hA).elements.attach := by
  classical
  ext δ
  refine ⟨fun _ => Finset.mem_attach _ _, fun _ => ?_⟩
  refine Finset.mem_biUnion.mpr
    ⟨forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ,
      Finset.mem_attach _ _, ?_⟩
  exact forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
    A p hA rfl

/-- Slots indexed by distinct source components are disjoint. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ₁ γ₂ : {γ : FeynmanSubgraph G // γ ∈ A.elements}}
    (hne : γ₁.1 ≠ γ₂.1) :
    Disjoint (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ₁)
      (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ₂) := by
  classical
  rw [Finset.disjoint_left]
  intro δ hδ₁ hδ₂
  have h₁ := forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
    A p hA hδ₁
  have h₂ := forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
    A p hA hδ₂
  exact hne (h₁.symm.trans h₂)

/-- Sum reindexing (Sprint F1e): a sum over `attach`ed outer components splits
into a γ-indexed sum over the source slots. -/
private theorem forestComponentForestChoiceOuterSubgraph_sum_attach_eq_sum_slotAt
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {M : Type*} [AddCommMonoid M]
    (f : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements} → M) :
    ∑ δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements.attach, f δ
      = ∑ γ ∈ A.elements.attach,
          ∑ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ, f δ := by
  classical
  rw [← forestComponentForestChoiceOuterSubgraph_biUnion_slotAt_eq_attach A p hA]
  refine Finset.sum_biUnion ?_
  intro γ₁ _ γ₂ _ hne
  refine forestComponentForestChoiceOuterSubgraph_slotAt_disjoint A p hA ?_
  intro hVal
  exact hne (Subtype.ext hVal)

/-- Left-branch classification (Sprint F1f): when `p γ = .left`, the source
component `γ` itself appears as an outer element and lands in `slotAt γ`. -/
private theorem forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hLeft : p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left) :
    ∃ δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements},
      δ.1 = γ.1 ∧
      δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ := by
  classical
  have hIsLeft : forestComponentChoiceIsLeft A p γ.1 := by
    unfold forestComponentChoiceIsLeft
    rw [dif_pos γ.2]
    -- the attach-membership term inside the def is propositionally `mem_attach`,
    -- and `p γ ⟨γ.1, γ.2⟩ _ = .left` reduces to `hLeft` after Subtype.eta
    convert hLeft
  have hγLeftMem : γ.1 ∈ (forestComponentChoiceLeftSubgraph A p).elements := by
    rw [forestComponentChoiceLeftSubgraph_elements]
    exact Finset.mem_filter.mpr ⟨γ.2, hIsLeft⟩
  have hγOuter : γ.1 ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements := by
    rw [forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_left _ hγLeftMem
  refine ⟨⟨γ.1, hγOuter⟩, rfl, ?_⟩
  -- slot membership via uniqueness: δ.vertices = γ.vertices ⇒ sourcePartition δ = γ
  refine forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
    A p hA ?_
  -- δ.1 = γ.1, so we need (sourcePartition ⟨γ.1, _⟩).1 = γ.1
  have hδNE : (γ.1 : FeynmanSubgraph G).IsNonempty := hCompNE γ.1 γ.2
  symm
  refine forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
    A p hA ⟨γ.1, hγOuter⟩ hδNE γ.2 ?_
  exact fun _ hv => hv

/-- If a vertex of a source component selected as a genuine forest lies in the
spliced outer forest, then the chosen outer component containing that vertex is
still supported inside the same source component. -/
private theorem
    forestComponentForestChoiceOuterSubgraph_componentAt_vertices_subset_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (_hB :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B)
    {u : VertexId} (huγ : u ∈ γ.1.vertices)
    (huOuter : u ∈ (forestComponentForestChoiceOuterSubgraph A p hA).vertices) :
    ((forestComponentForestChoiceOuterSubgraph A p hA).componentAt
      huOuter).vertices ⊆ γ.1.vertices := by
  classical
  let Aout := forestComponentForestChoiceOuterSubgraph A p hA
  have hc :
      Aout.componentAt huOuter ∈
        (forestComponentForestChoiceOuterSubgraph A p hA).elements := by
    simpa [Aout] using Aout.componentAt_mem huOuter
  have huC :
      u ∈ (Aout.componentAt huOuter).vertices := by
    exact Aout.componentAt_vertex_mem huOuter
  rcases forestComponentForestChoiceOuterSubgraph_mem_source
      A p hA hc with
    ⟨η, hηA, hCη⟩
  have huη : u ∈ η.vertices := hCη huC
  by_cases hηγ : η = γ.1
  · subst η
    exact hCη
  · have hdisj : η.Disjoint γ.1 := hA hηA γ.2 hηγ
    exact False.elim ((Finset.disjoint_left.mp hdisj huη) huγ)

/-- A right-selected original component is vertex-disjoint from every promoted
forest component coming from a genuine forest choice. -/
private theorem forestComponentChoiceRight_promotedForestComponent_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ δ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements)
    (hδF : δ ∈ forestComponentChoicePromotedForestComponents A p) :
    γ.Disjoint δ := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hδF with
    ⟨η, B, hB, hδB⟩
  have hγA : γ ∈ A.elements :=
    forestComponentChoiceRightSubgraph_elements_subset A p hγR
  have hδSubset :
      δ.vertices ⊆ η.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      η.1 (A.isConnectedDivergent_of_mem η.2) B hδB
  by_cases hγη : γ = η.1
  · subst γ
    rw [forestComponentChoiceRightSubgraph_elements] at hγR
    rcases Finset.mem_filter.mp hγR with ⟨_hηA, hRight⟩
    unfold forestComponentChoiceIsRight at hRight
    rw [dif_pos η.2] at hRight
    rw [hB] at hRight
    cases hRight
  · have hdisj : γ.Disjoint η.1 := hA hγA η.2 hγη
    unfold FeynmanSubgraph.Disjoint at hdisj ⊢
    exact Finset.disjoint_left.mpr fun v hvγ hvδ =>
      (Finset.disjoint_left.mp hdisj hvγ) (hδSubset hvδ)

/-- Vertices of a right-selected component do not lie in the genuine-forest
outer splice. -/
private theorem forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements)
    {v : VertexId} (hv : v ∈ γ.vertices) :
    v ∉ (forestComponentForestChoiceOuterSubgraph A p hA).vertices := by
  intro hvOuter
  rcases AdmissibleSubgraph.mem_vertices.mp hvOuter with ⟨δ, hδOuter, hvδ⟩
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδOuter
  rcases Finset.mem_union.mp hδOuter with hδL | hδF
  · have hdisj := forestComponentChoiceRightLeft_disjoint A p hA hγR hδL
    exact (Finset.disjoint_left.mp hdisj hv) hvδ
  · have hdisj := forestComponentChoiceRight_promotedForestComponent_disjoint
      A p hA hγR hδF
    exact (Finset.disjoint_left.mp hdisj hv) hvδ

/-- Right-branch slot classification (Sprint F1f-2): when `p γ = .right`,
the slot at `γ` is empty. Any δ in the slot would inject a vertex of γ into
the outer splice, contradicting
`forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph`. The outer
nonempty-components hypothesis `hCompOuter` is the natural shape supplied by
call sites in the proper-disjoint regime. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hRight : p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right) :
    forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅ := by
  classical
  refine Finset.eq_empty_iff_forall_notMem.mpr ?_
  intro δ hδ
  have hsp :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1 = γ.1 :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
      A p hA hδ
  have hδγ : δ.1.vertices ⊆ γ.1.vertices := by
    have h := forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p hA δ
    rw [hsp] at h
    exact h
  have hδNE : δ.1.IsNonempty := hCompOuter δ.1 δ.2
  have hγR : γ.1 ∈ (forestComponentChoiceRightSubgraph A p).elements := by
    rw [forestComponentChoiceRightSubgraph_elements]
    refine Finset.mem_filter.mpr ⟨γ.2, ?_⟩
    unfold forestComponentChoiceIsRight
    rw [dif_pos γ.2]
    convert hRight
  rcases Finset.card_pos.mp hδNE with ⟨v, hvδ⟩
  have hvγ : v ∈ γ.1.vertices := hδγ hvδ
  have hvOuter : v ∈ (forestComponentForestChoiceOuterSubgraph A p hA).vertices :=
    AdmissibleSubgraph.mem_vertices.mpr ⟨δ.1, δ.2, hvδ⟩
  exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
    A p hA hγR hvγ hvOuter

/-- Forest-branch slot observation (Sprint F1g): when `p γ = .forest B`, every
`δ` in `slotAt γ` falls on the promoted-forest side of the outer splice
(rather than the left-selected original side). Equality with the promoted
components of `B` is *not* claimed here — just that left-side membership is
ruled out. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest : p γ (Finset.mem_attach A.elements γ) =
      forestCoproductChoice.forest B)
    {δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hδ : δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ) :
    δ.1 ∈ forestComponentChoicePromotedForestComponents A p := by
  classical
  -- Decompose outer.elements = Left ∪ Promoted via simp (congr-aware)
  have hδOuter :
      δ.1 ∈ (forestComponentChoiceLeftSubgraph A p).elements ∪
        forestComponentChoicePromotedForestComponents A p := by
    have hδ0 := δ.2
    simp only [forestComponentForestChoiceOuterSubgraph_elements] at hδ0
    exact hδ0
  rcases Finset.mem_union.mp hδOuter with hδL | hδP
  · -- δ ∈ Left: derive δ ∈ A.elements and `p ⟨δ.1, _⟩ ... = .left`
    simp only [forestComponentChoiceLeftSubgraph_elements] at hδL
    rcases Finset.mem_filter.mp hδL with ⟨hδA, hIsLeft⟩
    -- sourcePartition δ.1 = γ.1, δ.vertices ⊆ γ.1.vertices, δ.IsNonempty
    have hsp :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1 = γ.1 :=
      forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
        A p hA hδ
    have hδγ : δ.1.vertices ⊆ γ.1.vertices := by
      have h := forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
        A p hA δ
      rw [hsp] at h
      exact h
    have hδNE : δ.1.IsNonempty := hCompOuter δ.1 δ.2
    -- δ ⊆ γ in A.elements with hA disjoint ⇒ δ = γ (as FeynmanSubgraph)
    rcases Finset.card_pos.mp hδNE with ⟨v, hvδ⟩
    have hδEq : δ.1 = γ.1 :=
      hA.eq_of_mem_vertices hδA γ.2 hvδ (hδγ hvδ)
    -- hIsLeft says `p ⟨δ.1, hδA⟩ ... = .left`. Convert subtype to γ.
    unfold forestComponentChoiceIsLeft at hIsLeft
    rw [dif_pos hδA] at hIsLeft
    have hγEq : (⟨δ.1, hδA⟩ : {x // x ∈ A.elements}) = γ := Subtype.ext hδEq
    -- substitute γ into hIsLeft to get `p γ ... = .left`, then conflict with hForest
    have hLeftAtγ :
        p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left := by
      rw [← hγEq]; exact hIsLeft
    rw [hLeftAtγ] at hForest
    cases hForest
  · exact hδP

/-- Forest-branch source equality (Sprint F1h): when `δ ∈ slotAt γ` lands on
the promoted side and is witnessed by a source `γ' ∈ A.elements` with promoted
forest `B'`, then `γ'.1 = γ.1`. The B'-vs-B identification is *not* claimed
here; only the source equality. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_promoted_source_eq_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hδ : δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ)
    {γ' : {γ : FeynmanSubgraph G // γ ∈ A.elements}}
    {B' : AdmissibleSubgraph
        (repG (γ'.1.toHopfGen (A.isConnectedDivergent_of_mem γ'.2))).toFeynmanGraph}
    (_hPγ' : p γ' (Finset.mem_attach A.elements γ') =
        forestCoproductChoice.forest B')
    (hδB' :
      δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ'.1
        (A.isConnectedDivergent_of_mem γ'.2) B').elements) :
    γ'.1 = γ.1 := by
  classical
  -- (a) sourcePartition δ.1 = γ.1 from slotAt membership
  have hsp :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA δ).1 = γ.1 :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
      A p hA hδ
  -- (b) δ.vertices ⊆ γ.1.vertices
  have hδγ : δ.1.vertices ⊆ γ.1.vertices := by
    have h := forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p hA δ
    rw [hsp] at h
    exact h
  -- (c) δ.vertices ⊆ γ'.1.vertices via promoted witness
  have hδγ' : δ.1.vertices ⊆ γ'.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γ'.1 (A.isConnectedDivergent_of_mem γ'.2) B' hδB'
  -- (d) δ.IsNonempty + hA disjoint ⇒ γ'.1 = γ.1
  have hδNE : δ.1.IsNonempty := hCompOuter δ.1 δ.2
  rcases Finset.card_pos.mp hδNE with ⟨v, hvδ⟩
  exact hA.eq_of_mem_vertices γ'.2 γ.2 (hδγ' hvδ) (hδγ hvδ)

/-- Forest-branch promoted retarget (Sprint F1i): when `δ ∈ slotAt γ` is
witnessed by a promoted source `(γ', B')`, F1h gives `γ'.1 = γ.1`.  After
`subst`, the witness `B'` becomes a forest at γ; the existential conclusion
records the γ-side data directly.  No `HEq`, no `B' = B`. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hδ : δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ)
    {γ' : {γ : FeynmanSubgraph G // γ ∈ A.elements}}
    {B' : AdmissibleSubgraph
        (repG (γ'.1.toHopfGen (A.isConnectedDivergent_of_mem γ'.2))).toFeynmanGraph}
    (hPγ' : p γ' (Finset.mem_attach A.elements γ') =
        forestCoproductChoice.forest B')
    (hδB' :
      δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ'.1
        (A.isConnectedDivergent_of_mem γ'.2) B').elements) :
    ∃ Bγ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
      p γ (Finset.mem_attach A.elements γ) =
          forestCoproductChoice.forest Bγ ∧
      δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) Bγ).elements := by
  classical
  -- F1h: γ'.1 = γ.1
  have hSrc : γ'.1 = γ.1 :=
    forestComponentForestChoiceOuterSubgraph_slotAt_promoted_source_eq_of_forest
      A p hA γ hCompOuter hδ hPγ' hδB'
  -- Lift to subtype equality and subst
  have hSrcSub : γ' = γ := Subtype.ext hSrc
  subst hSrcSub
  -- Now `B' : AdmissibleSubgraph (repG (γ.1.toHopfGen ...)).toFeynmanGraph`
  -- and `hPγ'`, `hδB'` are stated at γ.
  exact ⟨B', hPγ', hδB'⟩

/-- 3-way classify (Sprint F1j): per source `γ`, `slotAt γ` is observed via a
disjunction matching `p γ`'s outcome.  Forest-side existence is placed
*inside* the `∀ δ` so the per-δ promoted witness from F1i is reusable; the
shared B is recovered later when uniqueness is wired in. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_classify
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    (p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left ∧
       ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
         δ.1 = γ.1) ∨
    (p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right ∧
       forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅) ∨
    (∀ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
       ∃ Bγ : AdmissibleSubgraph
           (repG (γ.1.toHopfGen
             (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
         p γ (Finset.mem_attach A.elements γ) =
             forestCoproductChoice.forest Bγ ∧
         δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
           (A.isConnectedDivergent_of_mem γ.2) Bγ).elements) := by
  classical
  -- Use the existing 3-way enumeration lemma to avoid motive-rewriting that
  -- contaminates the goal's `p γ ...` references.
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p γ (Finset.mem_attach A.elements γ)) with hChoice | hChoice | ⟨B, hChoice⟩
  · -- left
    rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
      A p hA γ hCompNE hChoice with ⟨δ, hδEq, hδSlot⟩
    exact Or.inl ⟨hChoice, δ, hδSlot, hδEq⟩
  · -- right
    exact Or.inr (Or.inl ⟨hChoice,
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p hA γ hCompOuter hChoice⟩)
  · -- forest B
    refine Or.inr (Or.inr ?_)
    intro δ hδ
    have hProm : δ.1 ∈ forestComponentChoicePromotedForestComponents A p :=
      forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
        A p hA γ hCompOuter hChoice hδ
    rcases forestComponentChoicePromotedForestComponents_mem_exists A p hProm
      with ⟨γ', B', hPγ', hδB'⟩
    exact forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
      A p hA γ hCompOuter hδ hPγ' hδB'

/-- Forest-branch shared-B (Sprint F1k): when `p γ = .forest B` is fixed by
the caller, every `δ ∈ slotAt γ` lies in the **same** promoted carrier
`promoted γ B`.  This collapses the per-δ existential of F1i/F1j to the
externally supplied `B`. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest : p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    ∀ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
      δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).elements := by
  classical
  intro δ hδ
  -- Promoted side via F1g
  have hProm : δ.1 ∈ forestComponentChoicePromotedForestComponents A p :=
    forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
      A p hA γ hCompOuter hForest hδ
  -- Witness `(γ', B')` from mem_exists
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hProm
    with ⟨γ', B', hPγ', hδB'⟩
  -- F1i lifts to γ-side: ∃ Bγ, p γ ... = forest Bγ ∧ δ ∈ promoted γ Bγ
  rcases forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
    A p hA γ hCompOuter hδ hPγ' hδB' with ⟨Bγ, hPBγ, hδBγ⟩
  -- Shared B identification: hForest and hPBγ both speak about p γ ...
  have hEqChoice : forestCoproductChoice.forest Bγ = forestCoproductChoice.forest B :=
    hPBγ.symm.trans hForest
  cases hEqChoice
  exact hδBγ

/-- Reverse direction (Sprint F1l-1 weak form): if `slotAt γ` is empty, then
`p γ ≠ .left`. Combined with a separate forest-exclusion (deferred), this
gives `p γ = .right` outright; for now we only rule out the left branch. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_ne_left_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅) :
    p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.left := by
  intro hLeft
  rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
    A p hA γ hCompNE hLeft with ⟨δ, _hδEq, hδSlot⟩
  rw [hEmpty] at hδSlot
  exact (Finset.notMem_empty δ) hδSlot

/-- Reverse direction (Sprint F1l-1, right outcome): if `slotAt γ` is empty
**and** the choice function lies in the strict core carrier, then `p γ = .right`.
The forest branch is excluded by a `B`-nonempty argument scheduled for a
follow-up sprint; for now the right outcome is gated on a forest-exclusion
hypothesis `hForestExcluded`. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_eq_right_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅)
    (hForestExcluded :
      ∀ B : AdmissibleSubgraph
          (repG (γ.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        p γ (Finset.mem_attach A.elements γ) ≠
          forestCoproductChoice.forest B) :
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p γ (Finset.mem_attach A.elements γ)) with hLeft | hRight | ⟨B, hForest⟩
  · exact absurd hLeft
      (forestComponentForestChoiceOuterSubgraph_pγ_ne_left_of_slotAt_empty
        A p hA γ hCompNE hEmpty)
  · exact hRight
  · exact absurd hForest (hForestExcluded B)

/-- Forest-branch slot nonempty (Sprint F1l-2): if `p ∈ core` and
`p γ = .forest B`, then `slotAt γ` has at least one element.  Together with
F1f-2 (right ⇒ slot empty) this gives the contrapositive needed by F1l-1. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest : p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ).Nonempty := by
  classical
  -- (1) Promoted γ B is a proper disjoint admissible forest in G.
  have hPromProper :
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B ∈
        G.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
      hp γ hForest
  -- (2) Properness gives nonempty components and IsNonempty.
  have hPromNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).IsNonempty :=
    properDisjointAdmissibleDivergentSubgraphs_isNonempty hPromProper
  have hPromCompNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).HasNonemptyComponents :=
    G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hPromProper
  -- (3) Pick a witness δ' ∈ (Promoted γ B).elements.
  rcases hPromNE with ⟨δ', hδ'Prom⟩
  -- (4) δ' lies in forestComponentChoicePromotedForestComponents A p.
  have hδ'Promoted :
      δ' ∈ forestComponentChoicePromotedForestComponents A p :=
    forestComponentChoicePromotedForestComponents_mem_of_forest A p γ hForest hδ'Prom
  -- (5) Promoted ⊆ outer.elements, so δ' ∈ outer.elements.
  have hδ'Outer :
      δ' ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements := by
    rw [forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_right _ hδ'Promoted
  -- (6) δ'.vertices ⊆ γ.1.vertices via the promoted-vertex-subset lemma.
  have hδ'Sub : δ'.vertices ⊆ γ.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γ.1 (A.isConnectedDivergent_of_mem γ.2) B hδ'Prom
  -- (7) δ' is nonempty because Promoted γ B has nonempty components.
  have hδ'NE : δ'.IsNonempty := hPromCompNE δ' hδ'Prom
  -- (8) sourcePartition (δ' as outer-subtype) = γ via uniqueness.
  let δ'sub : {δ : FeynmanSubgraph G //
      δ ∈ (forestComponentForestChoiceOuterSubgraph A p hA).elements} :=
    ⟨δ', hδ'Outer⟩
  have hsp : (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p hA δ'sub).1 = γ.1 := by
    have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
      A p hA δ'sub hδ'NE γ.2 hδ'Sub
    exact this.symm
  -- (9) δ' ∈ slotAt γ.
  exact ⟨δ'sub,
    forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
      A p hA hsp⟩

/-- Strong reverse direction (Sprint F1l-3): under `hp ∈ core`, an empty slot
forces `p γ = .right` outright.  Combines F1l-1b with F1l-2 (forest case
implies slot nonempty) to discharge the `hForestExcluded` hypothesis. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_eq_right_of_slotAt_empty_strong
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅) :
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right := by
  refine forestComponentForestChoiceOuterSubgraph_pγ_eq_right_of_slotAt_empty
    A p hA γ hCompNE hEmpty ?_
  intro B hForest
  have hNonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := A) (p := p) hp hA γ hForest
  rw [hEmpty] at hNonempty
  exact Finset.not_nonempty_empty hNonempty

/-- Reverse direction (Sprint F1l-4a): a self-vertex δ in `slotAt γ` rules
out `p γ = .right`.  Pure contrapositive of F1f-2. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_ne_right_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1) :
    p γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.right := by
  intro hRight
  rcases hSelf with ⟨δ, hδSlot, _⟩
  have hEmpty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
      A p hA γ hCompOuter hRight
  rw [hEmpty] at hδSlot
  exact (Finset.notMem_empty δ) hδSlot

/-- Reverse direction (Sprint F1l-4b): a self-vertex δ in `slotAt γ`,
combined with a forest-exclusion hypothesis, forces `p γ = .left`.  The
forest case is left as an external hypothesis here; see F1l-4c (future) for
the full strong form once `hp ⇒ forest excluded` is wired. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_eq_left_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1)
    (hForestExcluded :
      ∀ B : AdmissibleSubgraph
          (repG (γ.1.toHopfGen
            (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        p γ (Finset.mem_attach A.elements γ) ≠
          forestCoproductChoice.forest B) :
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p γ (Finset.mem_attach A.elements γ)) with hLeft | hRight | ⟨B, hForest⟩
  · exact hLeft
  · exact absurd hRight
      (forestComponentForestChoiceOuterSubgraph_pγ_ne_right_of_slotAt_self
        hA γ hCompOuter hSelf)
  · exact absurd hForest (hForestExcluded B)

/-- Reverse direction (Sprint F1m-1): if `slotAt γ` is nonempty and contains
no `self` element (no δ with δ.1 = γ.1), then `p γ` is on the forest branch.
This is the third observational handle paired with F1l-3 (right) and
F1l-4b (left), giving the full forward observation panel for `recoverAt`. -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_is_forest_of_slotAt_no_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNonempty :
      (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ).Nonempty)
    (hNoSelf :
      ∀ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 ≠ γ.1) :
    ∃ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p γ (Finset.mem_attach A.elements γ)) with hLeft | hRight | ⟨B, hForest⟩
  · -- left case: F1f-1 produces a self δ ∈ slotAt, contradicting hNoSelf
    rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
      A p hA γ hCompNE hLeft with ⟨δ, hδEq, hδSlot⟩
    exact absurd hδEq (hNoSelf δ hδSlot)
  · -- right case: F1f-2 forces slot = ∅, contradicting hNonempty
    have hEmpty :=
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p hA γ hCompOuter hRight
    rw [hEmpty] at hNonempty
    exact absurd hNonempty Finset.not_nonempty_empty
  · -- forest case: provide B directly
    exact ⟨B, hForest⟩

/-- Observed choice (Sprint F1m-2): a `forestCoproductChoice` value derived
purely from `slotAt γ`'s shape.  Note this still depends on `p` indirectly
(via `slotAt`).  The full equality `observedChoice = p γ` is deferred. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph_observedChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestCoproductChoice
      (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2)) := by
  classical
  by_cases hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅
  · exact forestCoproductChoice.right
  · by_cases hSelf :
        ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
          δ.1 = γ.1
    · exact forestCoproductChoice.left
    · have hNonempty :
          (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ).Nonempty :=
        Finset.nonempty_iff_ne_empty.mpr hEmpty
      have hNoSelf :
          ∀ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
            δ.1 ≠ γ.1 := by
        intro δ hδ hδEq
        exact hSelf ⟨δ, hδ, hδEq⟩
      have hForest :=
        forestComponentForestChoiceOuterSubgraph_pγ_is_forest_of_slotAt_no_self
          (A := A) (p := p) hA γ hCompNE hCompOuter hNonempty hNoSelf
      exact forestCoproductChoice.forest (Classical.choose hForest)

/-- Spec lemma 1: `slotAt γ = ∅ ⇒ observedChoice = .right`. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_right_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ = ∅) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter = forestCoproductChoice.right := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_pos hEmpty]

/-- Spec lemma 2: a self δ in `slotAt γ` ⇒ observedChoice = .left. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_left_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ ≠ ∅)
    (hSelf :
      ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter = forestCoproductChoice.left := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_pos hSelf]

/-- Spec lemma 3: `slotAt γ` nonempty + no self ⇒ observedChoice is a forest. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_is_forest_of_nonempty_no_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ ≠ ∅)
    (hNoSelf :
      ¬ ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1) :
    ∃ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
      forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter = forestCoproductChoice.forest B := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_neg hNoSelf]
  exact ⟨_, rfl⟩

/-- Casewise spec (Sprint F1m-3, right): if `p γ = .right` then
`observedChoice = p γ`.  Forest-side exclusion is not needed because the
observation goes through F1f-2 (right ⇒ slot = ∅). -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_right
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hRight :
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter =
      p γ (Finset.mem_attach A.elements γ) := by
  have hEmpty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
      A p hA γ hCompOuter hRight
  rw [forestComponentForestChoiceOuterSubgraph_observedChoice_eq_right_of_slotAt_empty
        p hA γ hCompNE hCompOuter hEmpty, hRight]

/-- Casewise spec (Sprint F1m-3, left): if `p γ = .left` then
`observedChoice = p γ`.  Forest-side exclusion is not needed: the self
witness from F1f-1 routes the observation through `_eq_left_of_slotAt_self`. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_left
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hLeft :
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter =
      p γ (Finset.mem_attach A.elements γ) := by
  rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
    A p hA γ hCompNE hLeft with ⟨δ, hδEq, hδSlot⟩
  have hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ ≠ ∅ := by
    intro hEmpty
    rw [hEmpty] at hδSlot
    exact (Finset.notMem_empty δ) hδSlot
  have hSelf :
      ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1 := ⟨δ, hδSlot, hδEq⟩
  rw [forestComponentForestChoiceOuterSubgraph_observedChoice_eq_left_of_slotAt_self
        p hA γ hCompNE hCompOuter hNotEmpty hSelf, hLeft]

/-- Edge-count upper bound (Sprint F1n-2a): for a pairwise-disjoint admissible
subgraph, the aggregate internal-edge count is bounded above by the ambient
graph's.  Foundation lemma for the strictness chain (next: complement
positive ⇒ strict, then promoted-component edge bound, then `δ ≠ γ`). -/
private theorem admissibleSubgraph_internalEdges_card_le_ambient_of_pairwise
    {G : FeynmanGraph} (B : AdmissibleSubgraph G)
    (hB : B.IsPairwiseDisjoint) :
    B.internalEdges.card ≤ G.internalEdges.card :=
  Multiset.card_le_card
    (admissibleSubgraph_internalEdges_le_of_pairwise B hB)

/-- Strict edge-count drop (Sprint F1n-2b): if `B` has a positive complement,
its aggregate internal-edge count is strictly less than the ambient's.
Combines F1n-2a with `Multiset.card_sub` on the complement definition. -/
private theorem admissibleSubgraph_internalEdges_card_lt_ambient_of_complement_pos
    {G : FeynmanGraph} (B : AdmissibleSubgraph G)
    (hB : B.IsPairwiseDisjoint)
    (hBComp : 0 < B.complementEdges.card) :
    B.internalEdges.card < G.internalEdges.card := by
  have hle : B.internalEdges ≤ G.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise B hB
  -- B.complementEdges = G.internalEdges - B.internalEdges
  have hCompEq :
      B.complementEdges.card = G.internalEdges.card - B.internalEdges.card := by
    show (G.internalEdges - B.internalEdges).card = _
    exact Multiset.card_sub hle
  rw [hCompEq] at hBComp
  -- 0 < G.card - B.card  ⇒  B.card < G.card
  exact Nat.lt_of_sub_pos hBComp

/-- Promoted-component edge bound (Sprint F1n-2c): a promoted forest component
δ has internal-edge count bounded by the aggregate B (transported back to
the component graph).  Goes via:
  1. δ ∈ promoted ⇒ δ = promote γ η.1 for some η ∈ RepToComponent B
  2. δ.internalEdges = η.1.internalEdges (rfl, via promote)
  3. η.1.internalEdges ≤ (RepToComponent B).internalEdges (aggregate-le)
  4. (RepToComponent B).internalEdges ≤ ... = B.internalEdges via the perm-map
     transport (mapPermAdmissibleSubgraphPreimage_internalEdges_map). -/
private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_card_le_source
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (γ.toHopfGen hγ)).toFeynmanGraph)
    (hBcDisj :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B).IsPairwiseDisjoint)
    {δ : FeynmanSubgraph G}
    (hδ :
      δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B).elements) :
    δ.internalEdges.card ≤ B.internalEdges.card := by
  classical
  -- Step 1: promote step decomposition.
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hδ
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hδ
  rcases Finset.mem_image.mp hδ with ⟨η, _hηA, rfl⟩
  -- Step 3: η.1.internalEdges ≤ (RepToComponent γ hγ B).internalEdges.
  have hLe :
      η.1.internalEdges ≤
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B).internalEdges :=
    feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B) hBcDisj η.2
  -- Step 4: card transport via mapPerm preimage map.
  have hMap :=
    mapPermAdmissibleSubgraphPreimage_internalEdges_map
      (feynmanSubgraphToHopfGenRepPerm_spec γ hγ) B
  have hBcCard :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B).internalEdges.card
        = B.internalEdges.card := by
    have := congrArg Multiset.card hMap
    simpa [Multiset.card_map] using this
  -- δ.internalEdges = η.1.internalEdges (via @[simp]); chain card_le_card + hBcCard.
  simp only [feynmanSubgraphPromote_internalEdges]
  exact (Multiset.card_le_card hLe).trans hBcCard.le

/-- Class invariance specialize (Sprint F1n-2d): the canonical representative
`repG (γ.toHopfGen hγ)` has the same `internalEdges.card` as `γ` itself.
Wrapper combining `repG_internalEdges_card_eq_of_toClass` with
`FeynmanSubgraph.toHopfGen_val`. -/
private theorem repG_toHopfGen_internalEdges_card_eq_source
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent) :
    (repG (γ.toHopfGen hγ)).toFeynmanGraph.internalEdges.card =
      γ.internalEdges.card := by
  have h := repG_internalEdges_card_eq_of_toClass (γ.toHopfGen hγ)
    (G' := γ.toFeynmanGraph) (FeynmanSubgraph.toHopfGen_val hγ)
  simpa using h

/-- Forest-promoted self exclusion (Sprint F1n-2e): a promoted forest
component `δ ∈ promoted γ B` is never equal to the source component
`γ.1` itself.  This is the bridge from F1n-2a/2b/2c/2d to the recoverAt
forest case in F1m-3c.  Proof chain:
  δ.card ≤ B.card  (F1n-2c via Bc.IsPairwiseDisjoint)
        < (repG (γ.toHopfGen)).card  (F1n-2b via complement positive)
        = γ.1.card  (F1n-2d).
Hence δ.card < γ.1.card, contradicting `δ = γ.1`. -/
private theorem forestComponentChoicePromotedForestComponents_ne_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest :
      p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B)
    {δ : FeynmanSubgraph G}
    (hδ :
      δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B).elements) :
    δ ≠ γ.1 := by
  -- Local abbreviation for the connectedness witness (a Prop, so harmless).
  let hγCD : γ.1.IsConnectedDivergent := A.isConnectedDivergent_of_mem γ.2
  -- Step 1: B ∈ properDisjoint... in (repG (γ.1.toHopfGen hγCD)).toFeynmanGraph
  have hBProper :
      B ∈ ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_forest_mem_properDisjoint_of_core_mem
      hp γ hForest
  -- Step 2: B.IsPairwiseDisjoint and complement positive
  have hBDisj : B.IsPairwiseDisjoint :=
    ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hBProper
  have hBComp : 0 < B.complementEdges.card :=
    forestComponentChoice_forest_complementEdges_positive_of_core_mem
      hp γ hForest
  -- Step 3: Bc.IsPairwiseDisjoint via the perm-preimage transport
  have hBcProper :
      feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1 hγCD B ∈
        γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
      γ.1 hγCD hBProper
  have hBcDisj :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        hγCD B).IsPairwiseDisjoint :=
    γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hBcProper
  -- Step 4: chain F1n-2c, F1n-2b, F1n-2d
  have h2c : δ.internalEdges.card ≤ B.internalEdges.card :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_card_le_source
      γ.1 (A.isConnectedDivergent_of_mem γ.2) B hBcDisj hδ
  have h2b :
      B.internalEdges.card <
        (repG (γ.1.toHopfGen
          (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph.internalEdges.card :=
    admissibleSubgraph_internalEdges_card_lt_ambient_of_complement_pos
      B hBDisj hBComp
  have h2d :
      (repG (γ.1.toHopfGen
        (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph.internalEdges.card =
      γ.1.internalEdges.card :=
    repG_toHopfGen_internalEdges_card_eq_source γ.1
      (A.isConnectedDivergent_of_mem γ.2)
  -- Step 5: assemble δ.card < γ.1.card and rule out δ = γ.1
  have hLt : δ.internalEdges.card < γ.1.internalEdges.card := by
    rw [← h2d]
    exact lt_of_le_of_lt h2c h2b
  intro hEq
  rw [hEq] at hLt
  exact (Nat.lt_irrefl _) hLt

/-- Casewise spec (Sprint F1m-3c, forest): if `p γ = .forest B` and `hp ∈ core`,
then `observedChoice = p γ`.  Uses F1l-2 (slot nonempty), F1k + F1n-2e
(no self in slot), and Classical.choose_spec to pin the chosen B' to B. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest :
      p γ (Finset.mem_attach A.elements γ) =
        forestCoproductChoice.forest B) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter =
      p γ (Finset.mem_attach A.elements γ) := by
  classical
  -- Step 1: slot nonempty (F1l-2)
  have hNonempty :
      (forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ).Nonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := A) (p := p) hp hA γ hForest
  have hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ ≠ ∅ :=
    Finset.nonempty_iff_ne_empty.mp hNonempty
  -- Step 2: no self δ in slot (F1k for promoted membership, F1n-2e for ne_source)
  have hNoSelf :
      ¬ ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
          δ.1 = γ.1 := by
    rintro ⟨δ, hδSlot, hδEq⟩
    have hδPromoted :=
      forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
        A p hA γ hCompOuter hForest δ hδSlot
    exact forestComponentChoicePromotedForestComponents_ne_source
      hp γ hForest hδPromoted hδEq
  -- Step 3: unfold observedChoice into the forest branch directly so we can
  -- access the underlying Classical.choose witness and use choose_spec.
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_neg hNoSelf]
  -- Goal: forestCoproductChoice.forest (Classical.choose ...) = p γ ...
  -- Build the witness predicate that Classical.choose was applied to:
  set hForestEx :=
    forestComponentForestChoiceOuterSubgraph_pγ_is_forest_of_slotAt_no_self
      (A := A) (p := p) hA γ hCompNE hCompOuter hNonempty
      (fun δ hδ hEq => hNoSelf ⟨δ, hδ, hEq⟩)
  -- Classical.choose_spec: p γ ... = forest (Classical.choose hForestEx)
  have hSpec := hForestEx.choose_spec
  -- Combine with hForest: forest B = forest (Classical.choose hForestEx)
  rw [← hSpec, hForest]

/-- Full observed-choice spec (Sprint F1m-4): under `hp ∈ core`, the
slot-shape-based `observedChoice` agrees with the underlying `p γ` for every
γ.  Combines F1m-3a/3b/3c via `forestCoproductChoice_eq_left_or_right_or_forest`.
This is the bridge that turns `observedChoice` into a faithful witness of
`p γ` at the per-γ level, ready for the upcoming Pi-lift. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA γ hCompNE hCompOuter =
      p γ (Finset.mem_attach A.elements γ) := by
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p γ (Finset.mem_attach A.elements γ)) with hLeft | hRight | ⟨B, hForest⟩
  · exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_left
      hA γ hCompNE hCompOuter hLeft
  · exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_right
      hA γ hCompNE hCompOuter hRight
  · exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ_of_forest
      (A := A) (p := p) hp hA γ hCompNE hCompOuter hForest

/-- Pi-lift of `_observedChoice` (Sprint F1m-5): per-γ observation packaged
as a full `forestComponentChoiceFn A`.  The second `hγ` argument is the
attach-membership proof, which is trivially supplied at every call site. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph_observedChoiceFn
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestComponentChoiceFn A :=
  fun γ _ =>
    forestComponentForestChoiceOuterSubgraph_observedChoice
      p hA γ hCompNE hCompOuter

/-- Faithfulness (Sprint F1m-5): under `hp ∈ core`, the Pi-lifted
observation function reproduces the original `p` exactly. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoiceFn_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestComponentForestChoiceOuterSubgraph_observedChoiceFn
        p hA hCompNE hCompOuter =
      p := by
  funext γ hγ
  exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pγ
    (A := A) (p := p) hp hA γ hCompNE hCompOuter

/-- Source partition transport (Sprint F1o-1): if two component-choice
functions `p₁`, `p₂` produce the same outer subgraph, then for any outer
component `δ` they yield the same source `γ ∈ A.elements`.  This is the
foundation for `slotAt_eq_of_outer_eq` and ultimately for outer-injectivity.

Both source partitions cover the same nonempty `δ` with vertices contained
in `γᵢ.vertices`; `hA.eq_of_mem_vertices` then forces `γ₁ = γ₂`. -/
private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements}) :
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p₁ hA δ).1 =
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p₂ hA
      ⟨δ.1, by rw [← hEq]; exact δ.2⟩).1 := by
  classical
  -- (a) sp₁: δ.vertices ⊆ sp₁.vertices, sp₁.1 ∈ A.elements
  have hSub₁ : δ.1.vertices ⊆
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p₁ hA δ).1.vertices :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p₁ hA δ
  have hMem₁ :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p₁ hA δ).1 ∈ A.elements :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_mem A p₁ hA δ
  -- (b) sp₂: same shape, with δ transported across hEq
  let δ₂ : {δ : FeynmanSubgraph G //
      δ ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements} :=
    ⟨δ.1, by rw [← hEq]; exact δ.2⟩
  have hSub₂ : δ.1.vertices ⊆
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p₂ hA δ₂).1.vertices :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p₂ hA δ₂
  have hMem₂ :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p₂ hA δ₂).1 ∈ A.elements :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_mem A p₂ hA δ₂
  -- (c) δ.1 nonempty (via hCompOuter on the p₁ side)
  have hδNE : δ.1.IsNonempty := hCompOuter δ.1 δ.2
  rcases Finset.card_pos.mp hδNE with ⟨v, hvδ⟩
  -- (d) hA + common vertex v ⇒ sp₁.1 = sp₂.1
  exact hA.eq_of_mem_vertices hMem₁ hMem₂ (hSub₁ hvδ) (hSub₂ hvδ)

/-- slotAt membership transport (Sprint F1o-2a): under outer equality,
δ ∈ slotAt p₁ γ ↔ (δ transported) ∈ slotAt p₂ γ.  Foundation for the upcoming
observedChoice transport.  Uses `_mem_slotAt_iff` on both sides + F1o-1's
sourcePartition equality.  Stated at iff level to avoid Finset equality
across distinct subtype carriers. -/
private theorem forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (δ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements}) :
    δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ ↔
      (⟨δ.1, by rw [← hEq]; exact δ.2⟩ :
        {δ : FeynmanSubgraph G //
          δ ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements})
        ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ := by
  classical
  -- Bridge sp₁ ↔ sp₂ via F1o-1
  have hSPeq :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p₁ hA δ).1 =
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p₂ hA
        ⟨δ.1, by rw [← hEq]; exact δ.2⟩).1 :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_outer_eq
      (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter δ
  -- Apply mem_slotAt_iff on both sides and chain through hSPeq
  rw [forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff
        A p₁ hA γ δ,
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff
        A p₂ hA γ ⟨δ.1, by rw [← hEq]; exact δ.2⟩]
  exact ⟨fun h => hSPeq.symm.trans h, fun h => hSPeq.trans h⟩

/-- slotAt empty transport (Sprint F1o-2b): under outer equality, the
emptiness of `slotAt γ` is preserved.  Iff form to keep both directions
symmetric; uses F1o-2a's membership iff. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_empty_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}) :
    forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ = ∅ ↔
      forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ = ∅ := by
  classical
  -- p₂ side outer nonempty components, transported via hEq.
  have hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents := by
    rw [← hEq]; exact hCompOuter
  refine ⟨fun h₁ => ?_, fun h₂ => ?_⟩
  · refine Finset.eq_empty_iff_forall_notMem.mpr ?_
    intro δ₂ hδ₂
    let δ₁ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements} :=
      ⟨δ₂.1, by rw [hEq]; exact δ₂.2⟩
    have hδ₁ : δ₁ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter γ δ₁).mpr (by simpa using hδ₂))
    rw [h₁] at hδ₁
    exact (Finset.notMem_empty δ₁) hδ₁
  · refine Finset.eq_empty_iff_forall_notMem.mpr ?_
    intro δ₁ hδ₁
    have hδ₂ :
        (⟨δ₁.1, by rw [← hEq]; exact δ₁.2⟩ :
          {δ : FeynmanSubgraph G //
            δ ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements}) ∈
            forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter γ δ₁).mp hδ₁)
    rw [h₂] at hδ₂
    exact (Finset.notMem_empty _) hδ₂

/-- slotAt self-exists transport (Sprint F1o-2c): under outer equality, the
existence of a self-element δ (with `δ.1 = γ.1`) in `slotAt γ` is
preserved.  Iff form via F1o-2a's membership iff. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_self_exists_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements}) :
    (∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ,
        δ.1 = γ.1) ↔
      (∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ,
        δ.1 = γ.1) := by
  classical
  refine ⟨?_, ?_⟩
  · rintro ⟨δ₁, hδ₁Slot, hδ₁Eq⟩
    let δ₂ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements} :=
      ⟨δ₁.1, by rw [← hEq]; exact δ₁.2⟩
    have hiff :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (A := A) (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter γ δ₁
    refine ⟨δ₂, hiff.mp hδ₁Slot, ?_⟩
    simpa [δ₂] using hδ₁Eq
  · rintro ⟨δ₂, hδ₂Slot, hδ₂Eq⟩
    let δ₁ : {δ : FeynmanSubgraph G //
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements} :=
      ⟨δ₂.1, by rw [hEq]; exact δ₂.2⟩
    have hiff :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (A := A) (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter γ δ₁
    refine ⟨δ₁, hiff.mpr (by simpa [δ₁] using hδ₂Slot), ?_⟩
    simpa [δ₁] using hδ₂Eq

/-- Strong reverse direction (Sprint F1l-4c): under `hp ∈ core`, a self
δ ∈ slotAt γ forces `p γ = .left` outright.  Forest case is now closed via
F1k (slot ⊆ promoted) + F1n-2e (promoted component ≠ source). -/
private theorem forestComponentForestChoiceOuterSubgraph_pγ_eq_left_of_slotAt_self_strong
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p hA γ,
        δ.1 = γ.1) :
    p γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left := by
  classical
  rcases hSelf with ⟨δ, hδSlot, hδEq⟩
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p γ (Finset.mem_attach A.elements γ)) with hLeft | hRight | ⟨B, hForest⟩
  · exact hLeft
  · -- right case ruled out by F1l-4a
    exact absurd hRight
      (forestComponentForestChoiceOuterSubgraph_pγ_ne_right_of_slotAt_self
        hA γ hCompOuter ⟨δ, hδSlot, hδEq⟩)
  · -- forest case ruled out by F1k + F1n-2e
    have hδProm :=
      forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
        A p hA γ hCompOuter hForest δ hδSlot
    have hne :=
      forestComponentChoicePromotedForestComponents_ne_source
        hp γ hForest hδProm
    exact absurd hδEq hne

/-- Per-γ choice equality (Sprint F1o-3, partial): under outer equality and
both `p_i ∈ core`, the left and right outcomes of `p₁ γ` are matched by
`p₂ γ`.  The forest outcome requires identifying `B₁ = B₂`, which depends
on a promoted-carrier injectivity lemma not yet available; it is gated on
the per-γ `hForestMatch` hypothesis. -/
private theorem forestComponentForestChoiceOuterSubgraph_choice_at_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    (hForestMatch :
      ∀ {B₁ : AdmissibleSubgraph
            (repG (γ.1.toHopfGen
              (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph},
        p₁ γ (Finset.mem_attach A.elements γ) =
            forestCoproductChoice.forest B₁ →
        ∀ {B₂ : AdmissibleSubgraph
            (repG (γ.1.toHopfGen
              (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph},
        p₂ γ (Finset.mem_attach A.elements γ) =
            forestCoproductChoice.forest B₂ →
        (forestCoproductChoice.forest B₁ :
            forestCoproductChoice
              (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) =
          forestCoproductChoice.forest B₂) :
    p₁ γ (Finset.mem_attach A.elements γ) =
      p₂ γ (Finset.mem_attach A.elements γ) := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p₁ γ (Finset.mem_attach A.elements γ)) with hL₁ | hR₁ | ⟨B₁, hF₁⟩
  · -- left: p₁ γ = .left
    have hSelf₁ :
        ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ,
            δ.1 = γ.1 := by
      rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
          A p₁ hA γ hCompNE hL₁ with ⟨δ, hδEq, hδSlot⟩
      exact ⟨δ, hδSlot, hδEq⟩
    have hSelf₂ :
        ∃ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ,
            δ.1 = γ.1 :=
      (forestComponentForestChoiceOuterSubgraph_slotAt_self_exists_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ).mp hSelf₁
    have hL₂ :
        p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.left :=
      forestComponentForestChoiceOuterSubgraph_pγ_eq_left_of_slotAt_self_strong
        hp₂ hA γ hCompOuter₂ hSelf₂
    rw [hL₁, hL₂]
  · -- right: p₁ γ = .right
    have hEmpty₁ :
        forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ = ∅ :=
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p₁ hA γ hCompOuter₁ hR₁
    have hEmpty₂ :
        forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ = ∅ :=
      (forestComponentForestChoiceOuterSubgraph_slotAt_empty_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ).mp hEmpty₁
    have hR₂ :
        p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.right :=
      forestComponentForestChoiceOuterSubgraph_pγ_eq_right_of_slotAt_empty_strong
        hp₂ hA γ hCompNE hEmpty₂
    rw [hR₁, hR₂]
  · -- forest: p₁ γ = .forest B₁; derive p₂ γ = .forest B₂ via slot-shape
    -- transport, then identify .forest B₁ = .forest B₂ via `hForestMatch`.
    have hNonempty₁ :
        (forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ).Nonempty :=
      forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
        (A := A) (p := p₁) hp₁ hA γ hF₁
    have hNonempty₂ :
        (forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ).Nonempty := by
      rcases hNonempty₁ with ⟨δ₁, hδ₁⟩
      refine ⟨⟨δ₁.1, by rw [← hEq]; exact δ₁.2⟩, ?_⟩
      exact (forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ δ₁).mp hδ₁
    have hNoSelf₂ :
        ∀ δ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ,
            δ.1 ≠ γ.1 := by
      intro δ₂ hδ₂Slot hδ₂Eq
      let δ₁ : {δ : FeynmanSubgraph G //
          δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements} :=
        ⟨δ₂.1, by rw [hEq]; exact δ₂.2⟩
      have hδ₁Slot :
          δ₁ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ :=
        ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
          (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ δ₁).mpr
          (by simpa using hδ₂Slot))
      have hδ₁Prom :=
        forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
          A p₁ hA γ hCompOuter₁ hF₁ δ₁ hδ₁Slot
      have hne :=
        forestComponentChoicePromotedForestComponents_ne_source
          hp₁ γ hF₁ hδ₁Prom
      exact hne (by simpa [δ₁] using hδ₂Eq)
    rcases forestComponentForestChoiceOuterSubgraph_pγ_is_forest_of_slotAt_no_self
      (A := A) (p := p₂) hA γ hCompNE hCompOuter₂ hNonempty₂ hNoSelf₂
      with ⟨B₂, hF₂⟩
    rw [hF₁, hF₂]
    exact hForestMatch hF₁ hF₂

/-- Outer-injectivity skeleton (Sprint F1o-4): under `hp_i ∈ core` and outer
equality, the two component-choice functions agree, **modulo** a forest-case
B-identification hypothesis `hForestMatchAll`.  The proof is purely a
`funext` + F1o-3 application; the B-identification work is concentrated in
`hForestMatchAll`, which a future sprint will discharge canonically. -/
private theorem forestComponentForestChoiceOuterSubgraph_inj_of_forest_match
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (hForestMatchAll :
      ∀ γ : {γ : FeynmanSubgraph G // γ ∈ A.elements},
        ∀ {B₁ : AdmissibleSubgraph
              (repG (γ.1.toHopfGen
                (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph},
          p₁ γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.forest B₁ →
          ∀ {B₂ : AdmissibleSubgraph
              (repG (γ.1.toHopfGen
                (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph},
          p₂ γ (Finset.mem_attach A.elements γ) =
              forestCoproductChoice.forest B₂ →
          (forestCoproductChoice.forest B₁ :
              forestCoproductChoice
                (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) =
            forestCoproductChoice.forest B₂) :
    p₁ = p₂ := by
  funext γ hγ
  -- p_i γ hγ = p_i γ (Finset.mem_attach _ _) by proof-irrelevance
  -- F1o-3 returns the equality in the (Finset.mem_attach _ _) form.
  exact forestComponentForestChoiceOuterSubgraph_choice_at_eq_of_outer_eq
    (A := A) (p₁ := p₁) (p₂ := p₂)
    hp₁ hp₂ hA hCompNE hCompOuter₁ hCompOuter₂ hEq γ
    (hForestMatchAll γ)

/-- Promoted carrier membership transport (Sprint F1p-1): under outer
equality and `p_i γ = .forest B_i`, the promoted carriers of B₁ and B₂
contain the same δ.  The shared slot/sourcePartition machinery from F1g/F1h
+ F1o-2a does the transport.  Foundation for the `B_i` identification. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_mem_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B₁ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest₁ :
      p₁ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₁)
    (hForest₂ :
      p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₂)
    (δ : FeynmanSubgraph G) :
    δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
      (A.isConnectedDivergent_of_mem γ.2) B₁).elements ↔
    δ ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
      (A.isConnectedDivergent_of_mem γ.2) B₂).elements := by
  classical
  -- Helper: δ ∈ promoted γ Bᵢ in p_i ⇒ δ ∈ slot p_i γ
  -- (uses hForest_i + sourcePartition uniqueness via hCompOuter_i)
  -- Transport to the other side via F1o-2a, then apply F1k.
  -- We package this as a one-direction helper and apply both ways.
  -- Forward: B₁ → B₂.
  refine ⟨fun hδB₁ => ?_, fun hδB₂ => ?_⟩
  · -- (1) δ.1 ∈ promoted A p₁ via _mem_of_forest
    have hδProm₁ :
        δ ∈ forestComponentChoicePromotedForestComponents A p₁ :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        A p₁ γ hForest₁ hδB₁
    -- (2) δ ∈ outer p₁ via union-right
    have hδOuter₁ :
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact Finset.mem_union_right _ hδProm₁
    -- (3) δ.vertices ⊆ γ.1.vertices
    have hδSub : δ.vertices ⊆ γ.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ.1 (A.isConnectedDivergent_of_mem γ.2) B₁ hδB₁
    -- (4) δ.IsNonempty via hCompOuter₁
    have hδNE : δ.IsNonempty := hCompOuter₁ δ hδOuter₁
    -- (5) sourcePartition δ = γ on the p₁ side via uniqueness
    let δsub₁ : {η : FeynmanSubgraph G //
        η ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements} :=
      ⟨δ, hδOuter₁⟩
    have hsp₁ :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition
          A p₁ hA δsub₁).1 = γ.1 := by
      have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
        A p₁ hA δsub₁ hδNE γ.2 hδSub
      exact this.symm
    -- (6) δsub₁ ∈ slot p₁ γ
    have hδSlot₁ :
        δsub₁ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
        A p₁ hA hsp₁
    -- (7) Transport to slot p₂ γ via F1o-2a
    have hδSlot₂ :
        (⟨δsub₁.1, by rw [← hEq]; exact δsub₁.2⟩ :
          {η : FeynmanSubgraph G //
            η ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements}) ∈
            forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ δsub₁).mp hδSlot₁)
    -- (8) F1k on the p₂ side gives δ ∈ promoted γ B₂
    exact forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      A p₂ hA γ hCompOuter₂ hForest₂ _ hδSlot₂
  · -- Reverse direction: symmetric, with hEq.symm.
    have hδProm₂ :
        δ ∈ forestComponentChoicePromotedForestComponents A p₂ :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        A p₂ γ hForest₂ hδB₂
    have hδOuter₂ :
        δ ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact Finset.mem_union_right _ hδProm₂
    have hδSub : δ.vertices ⊆ γ.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ.1 (A.isConnectedDivergent_of_mem γ.2) B₂ hδB₂
    have hδNE : δ.IsNonempty := hCompOuter₂ δ hδOuter₂
    let δsub₂ : {η : FeynmanSubgraph G //
        η ∈ (forestComponentForestChoiceOuterSubgraph A p₂ hA).elements} :=
      ⟨δ, hδOuter₂⟩
    have hsp₂ :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition
          A p₂ hA δsub₂).1 = γ.1 := by
      have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
        A p₂ hA δsub₂ hδNE γ.2 hδSub
      exact this.symm
    have hδSlot₂ :
        δsub₂ ∈ forestComponentForestChoiceOuterSubgraph_slotAt A p₂ hA γ :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
        A p₂ hA hsp₂
    have hδSlot₁ :
        (⟨δsub₂.1, by rw [hEq]; exact δsub₂.2⟩ :
          {η : FeynmanSubgraph G //
            η ∈ (forestComponentForestChoiceOuterSubgraph A p₁ hA).elements}) ∈
            forestComponentForestChoiceOuterSubgraph_slotAt A p₁ hA γ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p₁ := p₁) (p₂ := p₂) hA hEq hCompOuter₁ γ
        ⟨δsub₂.1, by rw [hEq]; exact δsub₂.2⟩).mpr (by simpa using hδSlot₂))
    exact forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      A p₁ hA γ hCompOuter₁ hForest₁ _ hδSlot₁

/-- Promoted-carrier elements equality (Sprint F1p-2): F1p-1's membership iff
lifted to a Finset.elements equation via `Finset.ext`.  Foundation step for
the upcoming admissible-subgraph and B-equality lemmas. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_elements_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B₁ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest₁ :
      p₁ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₁)
    (hForest₂ :
      p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₂) :
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B₁).elements =
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B₂).elements := by
  ext δ
  exact forestComponentForestChoiceOuterSubgraph_promoted_mem_iff_of_outer_eq
    (A := A) (p₁ := p₁) (p₂ := p₂) hp₁ hp₂ hA
    hCompOuter₁ hCompOuter₂ hEq γ hForest₁ hForest₂ δ

/-- Promoted carrier equality (Sprint F1p-3): F1p-2's elements equality
lifted through `Forest.ext` and `AdmissibleSubgraph.ext` to a full
admissible-subgraph equation.  Foundation for the upcoming B-equality
identification. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B₁ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest₁ :
      p₁ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₁)
    (hForest₂ :
      p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₂) :
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B₁ =
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (A.isConnectedDivergent_of_mem γ.2) B₂ := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  simpa [AdmissibleSubgraph.elements] using
    forestComponentForestChoiceOuterSubgraph_promoted_elements_eq_of_outer_eq
      (A := A) (p₁ := p₁) (p₂ := p₂)
      hp₁ hp₂ hA hCompOuter₁ hCompOuter₂ hEq γ hForest₁ hForest₂

/-- `feynmanSubgraphPromoteAdmissibleSubgraph` injectivity (Sprint F1p-4a):
two admissible subgraphs of `γ_outer.toFeynmanGraph` whose ambient promotions
agree must be equal.  Proof goes through elements equality + Finset.image
injectivity (using `feynmanSubgraphPromote_injective`) + AdmissibleSubgraph
extensionality. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_injective
    {G : FeynmanGraph} {γ_outer : FeynmanSubgraph G}
    {B₁ B₂ : AdmissibleSubgraph γ_outer.toFeynmanGraph}
    (h :
      feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ_outer) B₁ =
      feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ_outer) B₂) :
    B₁ = B₂ := by
  classical
  -- Step 1: extract elements equality from the outer promoted equality.
  have hElemsOuter :
      (feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ_outer) B₁).elements =
      (feynmanSubgraphPromoteAdmissibleSubgraph (γ_outer := γ_outer) B₂).elements :=
    congrArg AdmissibleSubgraph.elements h
  -- Step 2: rewrite via the @[simp] lemma to expose the image expression.
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements,
      feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hElemsOuter
  -- Step 3: rewrite attach.image (fun γ => promote γ.1) =
  --   (attach.image Subtype.val).image promote = elements.image promote.
  have hAttach₁ :
      B₁.elements.attach.image (fun γ : {x // x ∈ B₁.elements} =>
          feynmanSubgraphPromote (γ_outer := γ_outer) γ.1) =
        B₁.elements.image (feynmanSubgraphPromote (γ_outer := γ_outer)) := by
    rw [show (fun γ : {x // x ∈ B₁.elements} =>
          feynmanSubgraphPromote (γ_outer := γ_outer) γ.1) =
        (feynmanSubgraphPromote (γ_outer := γ_outer)) ∘ Subtype.val from rfl,
      ← Finset.image_image, B₁.elements.attach_image_val]
  have hAttach₂ :
      B₂.elements.attach.image (fun γ : {x // x ∈ B₂.elements} =>
          feynmanSubgraphPromote (γ_outer := γ_outer) γ.1) =
        B₂.elements.image (feynmanSubgraphPromote (γ_outer := γ_outer)) := by
    rw [show (fun γ : {x // x ∈ B₂.elements} =>
          feynmanSubgraphPromote (γ_outer := γ_outer) γ.1) =
        (feynmanSubgraphPromote (γ_outer := γ_outer)) ∘ Subtype.val from rfl,
      ← Finset.image_image, B₂.elements.attach_image_val]
  rw [hAttach₁, hAttach₂] at hElemsOuter
  -- Step 4: Finset.image_injective on `feynmanSubgraphPromote_injective`.
  have hElemsInner : B₁.elements = B₂.elements :=
    Finset.image_injective feynmanSubgraphPromote_injective hElemsOuter
  -- Step 5: Forest.ext + AdmissibleSubgraph.ext lifts to B₁ = B₂.
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  exact hElemsInner

/-- `mapPermAdmissibleSubgraphPreimage` injectivity (Sprint F1p-4b): the
inverse-direction transport along a permutation is injective.  Proof uses
the round-trip identity `preimage h₁ ∘ preimage hπ = id` derived from the
definition `preimage hπ A = mapPermAdmissibleSubgraph h₁ A` and applying
`mapPermAdmissibleSubgraphPreimage_mapPerm_eq` along `h₁`. -/
private theorem mapPermAdmissibleSubgraphPreimage_injective
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) :
    Function.Injective (mapPermAdmissibleSubgraphPreimage hπ) := by
  intro A₁ A₂ hAB
  -- preimage hπ A := mapPermAdmissibleSubgraph h₁ A where h₁ : G₁ = G₂.mapPerm π⁻¹
  have h₁ : G₁ = G₂.mapPerm π⁻¹ := by
    subst hπ
    rw [← FeynmanGraph.mapPerm_mul]
    simp
  -- Apply round-trip preimage_mapPerm_eq h₁ A_i: roundtrip lands back at A_i.
  have hRT₁ :
      mapPermAdmissibleSubgraphPreimage h₁
          (mapPermAdmissibleSubgraph h₁ A₁) = A₁ :=
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq h₁ A₁
  have hRT₂ :
      mapPermAdmissibleSubgraphPreimage h₁
          (mapPermAdmissibleSubgraph h₁ A₂) = A₂ :=
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq h₁ A₂
  -- preimage hπ A_i = mapPermAdmissibleSubgraph h₁ A_i (definitional).
  have hDef₁ :
      mapPermAdmissibleSubgraphPreimage hπ A₁ =
        mapPermAdmissibleSubgraph h₁ A₁ := rfl
  have hDef₂ :
      mapPermAdmissibleSubgraphPreimage hπ A₂ =
        mapPermAdmissibleSubgraph h₁ A₂ := rfl
  -- From hAB and the def equations, mapPermAdmissibleSubgraph h₁ A₁ = h₁ A₂.
  have hMapEq :
      mapPermAdmissibleSubgraph h₁ A₁ = mapPermAdmissibleSubgraph h₁ A₂ := by
    rw [← hDef₁, ← hDef₂]; exact hAB
  -- Apply preimage h₁ to both sides and use hRT to recover A₁ = A₂.
  calc A₁
      = mapPermAdmissibleSubgraphPreimage h₁
          (mapPermAdmissibleSubgraph h₁ A₁) := hRT₁.symm
    _ = mapPermAdmissibleSubgraphPreimage h₁
          (mapPermAdmissibleSubgraph h₁ A₂) := by rw [hMapEq]
    _ = A₂ := hRT₂

/-- `feynmanSubgraphRepForestPromoteAdmissibleSubgraph` injectivity
(Sprint F1p-4c): the composition of representative-component transport
and ambient promotion is injective in `B`.  Combines F1p-4a (outer
promote injective) with F1p-4b (perm-preimage injective). -/
private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_injective
    {G : FeynmanGraph} (γ : FeynmanSubgraph G)
    (hγ : γ.IsConnectedDivergent) :
    Function.Injective
      (fun B : AdmissibleSubgraph
          (repG (γ.toHopfGen hγ)).toFeynmanGraph =>
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ hγ B) := by
  intro B₁ B₂ h
  -- Step 1: outer promote injective ⇒ RepToComponent equality.
  have hRep :
      feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B₁ =
        feynmanSubgraphRepToComponentAdmissibleSubgraph γ hγ B₂ :=
    feynmanSubgraphPromoteAdmissibleSubgraph_injective h
  -- Step 2: RepToComponent := mapPermAdmissibleSubgraphPreimage,
  -- so apply F1p-4b on the spec permutation.
  exact mapPermAdmissibleSubgraphPreimage_injective
    (feynmanSubgraphToHopfGenRepPerm_spec γ hγ) hRep

/-- B identification (Sprint F1p-5): under outer equality and `p_i γ = .forest B_i`,
the witnesses `B_i` are equal.  Pure composition of F1p-3 (promoted carrier
equality) and F1p-4c (promoted carrier injectivity in `B`). -/
private theorem forestComponentForestChoiceOuterSubgraph_B_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B₁ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest₁ :
      p₁ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₁)
    (hForest₂ :
      p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₂) :
    B₁ = B₂ := by
  have hPromEq :=
    forestComponentForestChoiceOuterSubgraph_promoted_eq_of_outer_eq
      (A := A) (p₁ := p₁) (p₂ := p₂)
      hp₁ hp₂ hA hCompOuter₁ hCompOuter₂ hEq γ hForest₁ hForest₂
  exact
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph_injective
      γ.1 (A.isConnectedDivergent_of_mem γ.2)) hPromEq

/-- Forest constructor equality (Sprint F1p-6): F1p-5's B equality wrapped
through `forestCoproductChoice.forest` so it matches the
`hForestMatchAll` shape required by F1o-4. -/
private theorem forestComponentForestChoiceOuterSubgraph_forestChoice_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA)
    (γ : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B₁ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
        (repG (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hForest₁ :
      p₁ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₁)
    (hForest₂ :
      p₂ γ (Finset.mem_attach A.elements γ) = forestCoproductChoice.forest B₂) :
    (forestCoproductChoice.forest B₁ :
        forestCoproductChoice
          (γ.1.toHopfGen (A.isConnectedDivergent_of_mem γ.2))) =
      forestCoproductChoice.forest B₂ :=
  congrArg forestCoproductChoice.forest
    (forestComponentForestChoiceOuterSubgraph_B_eq_of_outer_eq
      (A := A) (p₁ := p₁) (p₂ := p₂)
      hp₁ hp₂ hA hCompOuter₁ hCompOuter₂ hEq γ hForest₁ hForest₂)

/-- Outer-subgraph injectivity (Sprint F1p-7): unconditional outer-equality
implies `p₁ = p₂` in the core component-choice carrier.  The
`hForestMatchAll` gate from F1o-4 is now discharged by the canonical
F1p-6 lemma, completing the F1 forest-branch injectivity. -/
private theorem forestComponentForestChoiceOuterSubgraph_inj
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentCoreChoiceIndex A)
    (hp₂ : p₂ ∈ forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter₁ :
      (forestComponentForestChoiceOuterSubgraph A p₁ hA).HasNonemptyComponents)
    (hCompOuter₂ :
      (forestComponentForestChoiceOuterSubgraph A p₂ hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p₁ hA =
      forestComponentForestChoiceOuterSubgraph A p₂ hA) :
    p₁ = p₂ :=
  forestComponentForestChoiceOuterSubgraph_inj_of_forest_match
    hp₁ hp₂ hA hCompNE hCompOuter₁ hCompOuter₂ hEq
    (fun γ {_B₁} hForest₁ {_B₂} hForest₂ =>
      forestComponentForestChoiceOuterSubgraph_forestChoice_eq_of_outer_eq
        (A := A) (p₁ := p₁) (p₂ := p₂)
        hp₁ hp₂ hA hCompOuter₁ hCompOuter₂ hEq γ hForest₁ hForest₂)

/-- Mixed-boundary outer injectivity (Sprint F1r): in the mixed-boundary
regime (`hp_i` rules out forest choices), `LeftSubgraph` equality forces
`p₁ = p₂`.  No forest machinery used; this routes through `Finset.filter`
ext + the binary `.left`/`.right` case split. -/
private theorem forestComponentChoiceLeftSubgraph_inj_of_mixed_boundary
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p₁ p₂ : forestComponentChoiceFn A}
    (hp₁ : p₁ ∈ forestComponentMixedBoundaryChoiceCoreIndex A)
    (hp₂ : p₂ ∈ forestComponentMixedBoundaryChoiceCoreIndex A)
    (hLeftEq :
      forestComponentChoiceLeftSubgraph A p₁ =
      forestComponentChoiceLeftSubgraph A p₂) :
    p₁ = p₂ := by
  classical
  -- Step 1: extract element-level filter equality.
  have hElems :
      A.elements.filter (forestComponentChoiceIsLeft A p₁) =
      A.elements.filter (forestComponentChoiceIsLeft A p₂) := by
    have := congrArg AdmissibleSubgraph.elements hLeftEq
    simpa [forestComponentChoiceLeftSubgraph_elements] using this
  -- Step 2: extract noForest from mixed-boundary index membership.
  have hNoForest₁ : ¬ forestComponentChoiceHasForest A p₁ := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp₁
    exact (Finset.mem_filter.mp hp₁).2
  have hNoForest₂ : ¬ forestComponentChoiceHasForest A p₂ := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp₂
    exact (Finset.mem_filter.mp hp₂).2
  -- Step 3: pointwise equality via the filter ext.
  funext γ hγ
  have hγMem : γ.1 ∈ A.elements := γ.2
  -- Membership in the filtered set is iff IsLeft holds.
  have hMem₁ :
      γ.1 ∈ A.elements.filter (forestComponentChoiceIsLeft A p₁) ↔
      forestComponentChoiceIsLeft A p₁ γ.1 :=
    ⟨fun h => (Finset.mem_filter.mp h).2,
     fun h => Finset.mem_filter.mpr ⟨hγMem, h⟩⟩
  have hMem₂ :
      γ.1 ∈ A.elements.filter (forestComponentChoiceIsLeft A p₂) ↔
      forestComponentChoiceIsLeft A p₂ γ.1 :=
    ⟨fun h => (Finset.mem_filter.mp h).2,
     fun h => Finset.mem_filter.mpr ⟨hγMem, h⟩⟩
  -- IsLeft₁ ↔ IsLeft₂ via hElems.
  have hIff : forestComponentChoiceIsLeft A p₁ γ.1 ↔
              forestComponentChoiceIsLeft A p₂ γ.1 := by
    rw [← hMem₁, ← hMem₂, hElems]
  -- Unfold IsLeft to expose `p_i γ ... = .left`.
  unfold forestComponentChoiceIsLeft at hIff
  rw [dif_pos γ.2, dif_pos γ.2] at hIff
  -- Step 4: 3-way case split on `p_i γ`, ruling out forest by hNoForest_i.
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p₁ γ (Finset.mem_attach A.elements γ)) with hL₁ | hR₁ | ⟨B₁, hF₁⟩
  · -- p₁ γ = .left ⇒ p₂ γ = .left (via hIff).
    have hL₂ := hIff.mp hL₁
    rw [hL₁, hL₂]
  · -- p₁ γ = .right ⇒ p₂ γ ≠ .left, so p₂ γ ∈ {.right, .forest _}.
    -- Use hNoForest₂ to rule out forest, leaving p₂ γ = .right.
    have hNotL₁ : p₁ γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.left := by
      rw [hR₁]; intro h; cases h
    have hNotL₂ : p₂ γ (Finset.mem_attach A.elements γ) ≠ forestCoproductChoice.left :=
      fun h => hNotL₁ (hIff.mpr h)
    rcases forestCoproductChoice_eq_left_or_right_or_forest _
        (p₂ γ (Finset.mem_attach A.elements γ)) with hL₂ | hR₂ | ⟨B₂, hF₂⟩
    · exact absurd hL₂ hNotL₂
    · rw [hR₁, hR₂]
    · exact absurd ⟨γ, B₂, hF₂⟩ hNoForest₂
  · -- forest case ruled out by hNoForest₁.
    exact absurd ⟨γ, B₁, hF₁⟩ hNoForest₁

/-- Mixed-boundary core injectivity (Sprint F1r-2a): given that the outer
admissible component `q.1` is equal across `q₁` and `q₂`, equality of the
`MixedOuterIndex` values forces `q₁ = q₂`.  The `q₁.1 = q₂.1` hypothesis
is the natural side-condition which a downstream `ToQuotientForestSigma`
wrapper will discharge from RHS sigma equality. -/
private theorem forestComponentMixedBoundaryOuterIndex_inj_of_q1_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hQ1 : q₁.1 = q₂.1)
    (hOuter :
      forestComponentMixedBoundaryOuterIndex g q₁ hq₁ =
      forestComponentMixedBoundaryOuterIndex g q₂ hq₂) :
    q₁ = q₂ := by
  classical
  -- Step 1: extract LeftSubgraph equality from hOuter via Subtype.val.
  have hLeftEq :
      forestComponentChoiceLeftSubgraph q₁.1.1 q₁.2 =
      forestComponentChoiceLeftSubgraph q₂.1.1 q₂.2 := by
    have := congrArg Subtype.val hOuter
    simpa [forestComponentMixedBoundaryOuterIndex_val] using this
  -- Step 2: mixed-boundary core memberships for both p_i.
  have hpCore₁ :
      q₁.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q₁.1.1 :=
    (Finset.mem_sigma.mp hq₁).2
  have hpCore₂ :
      q₂.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q₂.1.1 :=
    (Finset.mem_sigma.mp hq₂).2
  -- Step 3: subst hQ1 to align the choice-fn types, then apply F1r.
  refine Sigma.ext hQ1 ?_
  rcases q₁ with ⟨A₁, p₁⟩
  rcases q₂ with ⟨A₂, p₂⟩
  cases hQ1
  -- After cases, A₁ = A₂. Goal: HEq p₁ p₂.
  refine heq_of_eq ?_
  exact forestComponentChoiceLeftSubgraph_inj_of_mixed_boundary
    hpCore₁ hpCore₂ hLeftEq

/-- Mixed-boundary sigma injectivity (Sprint F1r-2b): `MixedOuterIndex`
equality + `q₁.1 = q₂.1` ⇒ `q₁ = q₂`.  Same conclusion as F1r-2a but
expressed as a thin re-export aimed at downstream `ToQuotientForestSigma`
wrappers; `q₁.1 = q₂.1` is supplied externally because the
`MixedOuterIndex.1 = LeftSubgraph` value alone does not pin down the
outer admissible subgraph.  Cross/cover sites that index per `q.1` will
discharge it naturally. -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_inj_of_q1_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hQ1 : q₁.1 = q₂.1)
    (hOuter :
      forestComponentMixedBoundaryOuterIndex g q₁ hq₁ =
      forestComponentMixedBoundaryOuterIndex g q₂ hq₂) :
    q₁ = q₂ :=
  forestComponentMixedBoundaryOuterIndex_inj_of_q1_eq hq₁ hq₂ hQ1 hOuter

/-- Forest-vs-mixed cross disjointness, same outer-A case (Sprint F1s-1):
under `qF.1 = qM.1` (same outer admissible subgraph), the forest-branch
outer-subgraph cannot equal the mixed-boundary outer-subgraph.  Uses F1l-2
(forest ⇒ slot nonempty), F1k (slot ⊆ promoted), F1n-2e (promoted ≠ source),
plus pairwise-disjoint vertex argument on the shared outer A. -/
private theorem forestComponentForestChoice_mixedBoundary_cross_same_outer_false
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {qF qM : forestComponentChoiceSigma g}
    (hqF : qF ∈ forestComponentForestChoiceSigmaIndex g)
    (hqM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hSame : qF.1 = qM.1)
    (hCompOuterF :
      (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2
        (((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          qF.1.2)).HasNonemptyComponents)
    (hOuterEq :
      (forestComponentForestChoiceOuterIndex g qF hqF).1 =
      (forestComponentMixedBoundaryOuterIndex g qM hqM).1) :
    False := by
  classical
  -- Set up shared notation.
  have hAprop : qF.1.1 ∈
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := qF.1.2
  have hA : qF.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hAprop
  -- (1) Forest core: ∃ γ ∈ A.elements, ∃ B, qF.2 γ = .forest B.
  have hpForest :
      qF.2 ∈ forestComponentForestChoiceCoreIndex qF.1.1 :=
    (Finset.mem_sigma.mp hqF).2
  have hpCore : qF.2 ∈ forestComponentCoreChoiceIndex qF.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  rcases (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
    with ⟨γ, B, hPγ⟩
  -- (2) F1l-2: slot p_F γ has a witness δ.
  have hSlotNE :
      (forestComponentForestChoiceOuterSubgraph_slotAt qF.1.1 qF.2 hA γ).Nonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := qF.1.1) (p := qF.2) hpCore hA γ hPγ
  rcases hSlotNE with ⟨δ, hδSlot⟩
  -- (3) F1k: δ.1 ∈ promoted γ B.
  have hδProm :
      δ.1 ∈ (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (qF.1.1.isConnectedDivergent_of_mem γ.2) B).elements :=
    forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      qF.1.1 qF.2 hA γ hCompOuterF hPγ δ hδSlot
  -- (4) δ.1 ∈ outer p_F (already known via δ.2).
  have hδOuterF :
      δ.1 ∈ (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2 hA).elements :=
    δ.2
  -- (5) hOuterEq + simp ⇒ δ.1 ∈ mixed outer.elements = LeftSubgraph_M.elements.
  have hδMixed : δ.1 ∈ (forestComponentChoiceLeftSubgraph qM.1.1 qM.2).elements := by
    have hMem :
        δ.1 ∈ (forestComponentMixedBoundaryOuterIndex g qM hqM).1.elements := by
      rw [← hOuterEq]; exact hδOuterF
    simpa [forestComponentMixedBoundaryOuterIndex_val] using hMem
  -- (6) δ.1 ∈ qM.1.1.elements via filter subset.
  have hδAM : δ.1 ∈ qM.1.1.elements := by
    rw [forestComponentChoiceLeftSubgraph_elements] at hδMixed
    exact (Finset.mem_filter.mp hδMixed).1
  -- Use the `qM.1.1`-side pairwise-disjoint to avoid transporting `δ` through
  -- a `qF.1.1 = qM.1.1` rewrite (which triggers motive failure on δ's type).
  have hAM : qM.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      qM.1.2
  -- (7) F1n-2e: δ.1 ≠ γ.1.
  have hNeSource :
      δ.1 ≠ γ.1 :=
    forestComponentChoicePromotedForestComponents_ne_source
      hpCore γ hPγ hδProm
  -- (8) δ.1.vertices ⊆ γ.1.vertices via promoted vertex_subset.
  have hSub : δ.1.vertices ⊆ γ.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γ.1 (qF.1.1.isConnectedDivergent_of_mem γ.2) B hδProm
  -- γ.1 ∈ qM.1.1.elements via hSame (membership transport via congrArg).
  have hγM : γ.1 ∈ qM.1.1.elements := by
    have hSameVal : qF.1.1 = qM.1.1 := congrArg Subtype.val hSame
    exact hSameVal ▸ γ.2
  -- (9) δ.1.IsNonempty via hCompOuterF.
  have hδNE : δ.1.IsNonempty := hCompOuterF δ.1 hδOuterF
  rcases Finset.card_pos.mp hδNE with ⟨v, hv⟩
  -- (10) hAM.eq_of_mem_vertices on the qM.1.1 side ⇒ δ.1 = γ.1.
  have hδEqγ : δ.1 = γ.1 :=
    hAM.eq_of_mem_vertices hδAM hγM hv (hSub hv)
  exact hNeSource hδEqγ

private theorem forestComponentChoiceRight_internalEdges_le_forestOuter_complement
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γ : FeynmanSubgraph G}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph A p).elements) :
    γ.internalEdges ≤
      (forestComponentForestChoiceOuterSubgraph A p hA).complementEdges := by
  refine feynmanSubgraph_internalEdges_le_admissible_complementEdges_of_not_mem
    (forestComponentForestChoiceOuterSubgraph A p hA) γ ?_
  intro e heγ heOuter
  rcases AdmissibleSubgraph.mem_internalEdges.mp heOuter with
    ⟨δ, hδOuter, heδ⟩
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hδOuter
  have hsuppγ := γ.edges_supported e heγ
  have hsuppδ := δ.edges_supported e heδ
  simp [FeynmanEdge.SupportedOn] at hsuppγ hsuppδ
  rcases Finset.mem_union.mp hδOuter with hδL | hδF
  · have hdisj := forestComponentChoiceRightLeft_disjoint A p hA hγR hδL
    exact (Finset.disjoint_left.mp hdisj hsuppγ.1) hsuppδ.1
  · have hdisj := forestComponentChoiceRight_promotedForestComponent_disjoint
      A p hA hγR hδF
    exact (Finset.disjoint_left.mp hdisj hsuppγ.1) hsuppδ.1

/-- A right-selected original component is disjoint from the source component
of any genuine forest choice. -/
private theorem forestComponentChoiceRight_forestChoiceSource_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {γR : FeynmanSubgraph G}
    (hγR : γR ∈ (forestComponentChoiceRightSubgraph A p).elements)
    (γF : {γ : FeynmanSubgraph G // γ ∈ A.elements})
    {B : AdmissibleSubgraph
      (repG (γF.1.toHopfGen (A.isConnectedDivergent_of_mem γF.2))).toFeynmanGraph}
    (hB :
      p γF (Finset.mem_attach A.elements γF) =
        forestCoproductChoice.forest B) :
    γR.Disjoint γF.1 := by
  classical
  have hγRA : γR ∈ A.elements :=
    forestComponentChoiceRightSubgraph_elements_subset A p hγR
  by_cases hEq : γR = γF.1
  · subst γR
    rw [forestComponentChoiceRightSubgraph_elements] at hγR
    rcases Finset.mem_filter.mp hγR with ⟨_hγFA, hRight⟩
    unfold forestComponentChoiceIsRight at hRight
    rw [dif_pos γF.2] at hRight
    rw [hB] at hRight
    cases hRight
  · exact hA hγRA γF.2 hEq

/-- Transport an actual quotient-side admissible forest to the chosen
representative quotient graph. -/
private noncomputable def forestOuterActualToRepAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  mapPermAdmissibleSubgraph (forestOuterActualToRepPerm_spec g A) B

/-- The actual quotient graph by an outer admissible forest is well-formed. -/
private theorem forestOuterActualQuotientGraph_wellFormed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterActualQuotientGraph g A).WellFormed := by
  unfold forestOuterActualQuotientGraph
  exact A.1.contractWithStars_wellFormed
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    (repG_wellFormed g)

/-- Representative transport for quotient-side right-factor contractions:
contracting an actual quotient-side forest, then passing to graph class,
agrees with contracting its transported representative quotient forest. -/
private theorem forestOuterActualToRep_rightContractClass
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A))
    (hB : B ∈ (forestOuterActualQuotientGraph g A
      ).properDisjointAdmissibleDivergentSubgraphs) :
    (FeynmanGraph.admissibleForestContractGraphWithStars
      (forestOuterActualQuotientGraph g A) B
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g A) B hB)).toClass =
    (FeynmanGraph.admissibleForestContractGraphWithStars
      (forestOuterQuotientGraph g A)
      (forestOuterActualToRepAdmissibleSubgraph g A B)
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterQuotientGraph g A)
        (forestOuterActualToRepAdmissibleSubgraph g A B)
        (mapPermAdmissibleSubgraph_mem_properDisjoint
          (forestOuterActualToRepPerm_spec g A) hB))).toClass := by
  simpa [forestOuterActualToRepAdmissibleSubgraph] using
    admissibleForestContractMapPermClass_of_wellFormed
      (forestOuterActualToRepPerm_spec g A)
      (forestOuterActualQuotientGraph_wellFormed g A) B hB

/-- Proper quotient-side forest membership survives the actual-to-representative
transport. -/
private theorem forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    {B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)}
    (hB : B ∈
      (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterActualToRepAdmissibleSubgraph g A B ∈
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  mapPermAdmissibleSubgraph_mem_properDisjoint
    (forestOuterActualToRepPerm_spec g A) hB

/-- Compose actual quotient retargeting with transport to the chosen `repG`
representative quotient graph. -/
private noncomputable def forestOuterRepRetargetAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.1.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₁ (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₂ (hEdges γ₂ hγ₂))) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  forestOuterActualToRepAdmissibleSubgraph g A
    (forestOuterActualRetargetAdmissibleSubgraph g A B
      hEdges hCD hCompat)

/-- Properness in the actual quotient is enough to place the retargeted forest
in the representative quotient finite carrier. -/
private theorem forestOuterRepRetargetAdmissibleSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hEdges : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.1.complementEdges)
    (hCD : ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ (hEdges γ hγ)).IsConnectedDivergent)
    (hCompat : ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₁ (hEdges γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        γ₂ (hEdges γ₂ hγ₂)))
    (hProper :
      forestOuterActualRetargetAdmissibleSubgraph g A B
        hEdges hCD hCompat ∈
        (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterRepRetargetAdmissibleSubgraph g A B
      hEdges hCD hCompat ∈
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint g A hProper

/-- Certificate that an ambient source forest survives as an admissible forest
in the actual quotient by an attached outer forest.  This is used for
right-selected components that are disjoint from the chosen outer carrier;
genuine component forest choices are promoted into the ambient outer carrier
before quotienting. -/
private structure forestOuterActualRetargetCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph) : Type where
  edge_le : ∀ γ ∈ B.elements, γ.internalEdges ≤ A.1.complementEdges
  cd : ∀ γ hγ,
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      γ (edge_le γ hγ)).IsConnectedDivergent
  compat : ∀ γ₁ hγ₁ γ₂ hγ₂,
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      γ₁ (edge_le γ₁ hγ₁)).NestedOrDisjoint
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      γ₂ (edge_le γ₂ hγ₂))

/-- Actual quotient-side forest built from a retarget certificate. -/
private noncomputable def forestOuterActualRetargetAdmissibleSubgraphOfCert
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g A) :=
  forestOuterActualRetargetAdmissibleSubgraph g A B
    C.edge_le C.cd C.compat

/-- Representative quotient-side forest built from a retarget certificate. -/
private noncomputable def forestOuterRepRetargetAdmissibleSubgraphOfCert
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  forestOuterRepRetargetAdmissibleSubgraph g A B
    C.edge_le C.cd C.compat

/-- Properness of a certificate-built actual retargeted forest, when the
source forest is proper and untouched by the outer carrier. -/
private theorem forestOuterActualRetargetAdmissibleSubgraphOfCert_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hB :
      B ∈ (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.1.vertices) :
    forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C ∈
      (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  admissibleSubgraphRetarget_mem_properDisjoint_of_not_mem
    A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    B C.edge_le C.cd C.compat hB hV

/-- Properness survives the representative transport for certificate-built
retargeted forests. -/
private theorem forestOuterRepRetargetAdmissibleSubgraphOfCert_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hB :
      forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C ∈
        (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterRepRetargetAdmissibleSubgraphOfCert g A B C ∈
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint g A hB

/-- Certificate-built actual quotient retargeting preserves the Hopf product
when every source component is untouched by the outer carrier. -/
private theorem forestOuterActualRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.1.vertices) :
    (forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C).toHopfH =
      B.toHopfH := by
  unfold forestOuterActualRetargetAdmissibleSubgraphOfCert
    forestOuterActualRetargetAdmissibleSubgraph
  exact admissibleSubgraphRetarget_toHopfH_eq_of_not_mem
    A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    B C.edge_le C.cd C.compat hV

/-- Certificate-built representative quotient retargeting preserves the Hopf
product when every source component is untouched by the outer carrier. -/
private theorem forestOuterRepRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hV : ∀ γ ∈ B.elements, ∀ v ∈ γ.vertices, v ∉ A.1.vertices) :
    (forestOuterRepRetargetAdmissibleSubgraphOfCert g A B C).toHopfH =
      B.toHopfH := by
  unfold forestOuterRepRetargetAdmissibleSubgraphOfCert
    forestOuterRepRetargetAdmissibleSubgraph
    forestOuterActualToRepAdmissibleSubgraph
  rw [mapPermAdmissibleSubgraph_toHopfH]
  exact forestOuterActualRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    g A B C hV

/-- Certificate type for carrying the genuine-forest-regime right-selected
survivors into the quotient by the spliced outer forest. -/
private abbrev forestComponentForestChoiceRightRetargetCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type :=
  forestOuterActualRetargetCertificate g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentChoiceRightSubgraph q.1.1 q.2)

/-- The edge-survival field for the canonical genuine-forest right-retarget
certificate. -/
private theorem forestComponentForestChoiceRightRetarget_edge_le
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
      γ.internalEdges ≤
        (forestComponentForestChoiceOuterIndex g q hq).1.complementEdges := by
  intro γ hγ
  rw [forestComponentForestChoiceOuterIndex_val]
  exact forestComponentChoiceRight_internalEdges_le_forestOuter_complement
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2)
    hγ

/-- Connected-divergence for each right-selected survivor after retargeting
through the spliced quotient. -/
private theorem forestComponentForestChoiceRightRetarget_cd
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγ)).IsConnectedDivergent := by
  intro γ hγ
  let hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV :
      ∀ v ∈ γ.vertices,
        v ∉ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hγ hv
  have hGraphEq :=
    admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγ)
      hV
  exact feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq hGraphEq
    ((forestComponentChoiceRightSubgraph q.1.1 q.2).isConnectedDivergent_of_mem hγ)

/-- Zimmermann compatibility for right-selected survivors after retargeting
through the spliced quotient. -/
private theorem forestComponentForestChoiceRightRetarget_compat
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ₁
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ₂
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₂ hγ₂)) := by
  intro γ₁ hγ₁ γ₂ hγ₂
  let hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV₁ :
      ∀ v ∈ γ₁.vertices,
        v ∉ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hγ₁ hv
  have hV₂ :
      ∀ v ∈ γ₂.vertices,
        v ∉ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hγ₂ hv
  have hCompat : γ₁.NestedOrDisjoint γ₂ := by
    by_cases hEq : γ₁ = γ₂
    · subst γ₂
      exact Or.inl (Or.inl (FeynmanSubgraph.le_refl' γ₁))
    · exact (forestComponentChoiceRightSubgraph q.1.1 q.2).forest.nestedOrDisjoint
        hγ₁ hγ₂ hEq
  exact admissibleSubgraphRetargetSubgraph_nestedOrDisjoint_of_not_mem
    (forestComponentForestChoiceOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2)
    γ₁ γ₂
    (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₁ hγ₁)
    (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₂ hγ₂)
    hV₁ hV₂ hCompat

/-- Canonical certificate carrying genuine-forest-regime right-selected
survivors into the quotient by the spliced outer forest. -/
private noncomputable def forestComponentForestChoiceRightRetargetCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRightRetargetCertificate g q hq where
  edge_le := forestComponentForestChoiceRightRetarget_edge_le g q hq
  cd := forestComponentForestChoiceRightRetarget_cd g q hq
  compat := forestComponentForestChoiceRightRetarget_compat g q hq

/-- Actual quotient-side right-selected survivor forest in the genuine-forest
regime. -/
private noncomputable def forestComponentForestChoiceActualRightQuotientSubgraph
