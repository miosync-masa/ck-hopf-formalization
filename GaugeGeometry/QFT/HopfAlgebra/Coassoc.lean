omit [ForestComponentForestChoiceRepQuotientComplementPositiveModel] in
/-- Every original component in the genuine-forest branch is either selected
on the left, selected on the right, or supplies a genuine component forest. -/
private theorem forestComponentForestChoice_choice_left_or_right_or_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (_hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ : ő≥ ‚ąą q.1.1.elements) :
    ő≥ ‚ąą (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ‚ą®
      ő≥ ‚ąą (forestComponentChoiceRightSubgraph q.1.1 q.2).elements ‚ą®
      ‚ąÉ B : AdmissibleSubgraph
        (repG (ő≥.toHopfGen (q.1.1.isConnectedDivergent_of_mem hő≥))).toFeynmanGraph,
        q.2 ‚ü®ő≥, hő≥‚ü© (Finset.mem_attach q.1.1.elements ‚ü®ő≥, hő≥‚ü©) =
          forestCoproductChoice.forest B := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest
      (ő≥.toHopfGen (q.1.1.isConnectedDivergent_of_mem hő≥))
      (q.2 ‚ü®ő≥, hő≥‚ü© (Finset.mem_attach q.1.1.elements ‚ü®ő≥, hő≥‚ü©)) with
    hLeft | hRightOrForest
  ¬∑ exact Or.inl (by
      rw [forestComponentChoiceLeftSubgraph_elements]
      refine Finset.mem_filter.mpr ‚ü®hő≥, ?_‚ü©
      unfold forestComponentChoiceIsLeft
      rw [dif_pos hő≥]
      exact hLeft)
  ¬∑ rcases hRightOrForest with hRight | hForest
    ¬∑ exact Or.inr (Or.inl (by
        rw [forestComponentChoiceRightSubgraph_elements]
        refine Finset.mem_filter.mpr ‚ü®hő≥, ?_‚ü©
        unfold forestComponentChoiceIsRight
        rw [dif_pos hő≥]
        exact hRight))
    ¬∑ rcases hForest with ‚ü®B, hB‚ü©
      exact Or.inr (Or.inr ‚ü®B, hB‚ü©)

private theorem forestComponentForestChoiceSplitStarOf_point_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
