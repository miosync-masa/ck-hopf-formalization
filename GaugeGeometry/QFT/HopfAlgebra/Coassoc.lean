      using C.positive ő≥ B hB

/-- Component-complement positivity contains exactly the edge data needed by
the source-edge witness form: choose one edge from the component complement and
transport it back through the literal source/remnant complement identity. -/
private theorem
    forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq)
    (ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph //
        ő≥ ‚ąą q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph)
    (hB : q.2 ő≥ (Finset.mem_attach q.1.1.elements ő≥) =
      forestCoproductChoice.forest B) :
    ‚ąÉ e : FeynmanEdge,
      e ‚ąą ő≥.1.internalEdges -
        (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges := by
  have hpos := C.positive ő≥ B hB
  rcases Multiset.card_pos_iff_exists_mem.mp hpos with ‚ü®e, he‚ü©
  refine ‚ü®e, ?_‚ü©
  rwa [forestComponentForestChoice_gamma_internalEdges_sub_outer_eq_componentRemnant_complementEdges
    g q hq ő≥ hB]

/-- Component-complement positivity supplies the source-edge witness
certificate by choosing a surviving complement edge in each genuine
component-forest case. -/
private noncomputable def
    forestComponentForestChoiceRemnantSourceEdgeWitnessCertificateOfComponentComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq) :
    forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq where
  edge := fun ő≥ B hB =>
    Classical.choose
      (forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
        g q hq C ő≥ B hB)
  edge_mem := by
    intro ő≥ B hB
    exact Classical.choose_spec
      (forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
        g q hq C ő≥ B hB)

/-- Positive internal edges for the full genuine-forest quotient carrier
reduce to the remnant positivity payload; right-selected survivors are
canonical. -/
