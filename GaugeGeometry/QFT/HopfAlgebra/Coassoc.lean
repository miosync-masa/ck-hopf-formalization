/-- Certificate type for carrying the mixed-regime right-selected forest into
the quotient by the left-selected outer forest. -/
private abbrev forestComponentMixedBoundaryRightRetargetCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) : Type :=
  forestOuterActualRetargetCertificate g
    (forestComponentMixedBoundaryOuterIndex g q hq)
    (forestComponentChoiceRightSubgraph q.1.1 q.2)

/-- The edge-survival field for the canonical mixed-boundary right retarget
certificate. -/
private theorem forestComponentMixedBoundaryRightRetarget_edge_le
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ∀ γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
      γ.internalEdges ≤
        (forestComponentMixedBoundaryOuterIndex g q hq).1.complementEdges := by
  intro γ hγ
  rw [forestComponentMixedBoundaryOuterIndex_val]
  exact forestComponentChoiceRight_internalEdges_le_left_complement q.1.1 q.2
    ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2) hγ

/-- Connected-divergence for each right-selected component after retargeting
through the left-selected quotient. -/
private theorem forestComponentMixedBoundaryRightRetarget_cd
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ∀ γ hγ,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγ)).IsConnectedDivergent := by
  intro γ hγ
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hV :
      ∀ v ∈ γ.vertices,
        v ∉ (forestComponentMixedBoundaryOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentMixedBoundaryOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hγ hv
  have hGraphEq :=
    admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2)
      γ
      (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγ)
      hV
  exact feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq hGraphEq
    ((forestComponentChoiceRightSubgraph q.1.1 q.2).isConnectedDivergent_of_mem hγ)

/-- Zimmermann compatibility for the right-selected forest after retargeting
through the left-selected quotient. -/
private theorem forestComponentMixedBoundaryRightRetarget_compat
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ∀ γ₁ hγ₁ γ₂ hγ₂,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ₁
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₁ hγ₁)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ₂
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₂ hγ₂)) := by
  intro γ₁ hγ₁ γ₂ hγ₂
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hV₁ :
      ∀ v ∈ γ₁.vertices,
        v ∉ (forestComponentMixedBoundaryOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentMixedBoundaryOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hγ₁ hv
  have hV₂ :
      ∀ v ∈ γ₂.vertices,
        v ∉ (forestComponentMixedBoundaryOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentMixedBoundaryOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hγ₂ hv
  have hCompat : γ₁.NestedOrDisjoint γ₂ := by
    by_cases hEq : γ₁ = γ₂
    · subst γ₂
      exact Or.inl (Or.inl (FeynmanSubgraph.le_refl' γ₁))
    · exact (forestComponentChoiceRightSubgraph q.1.1 q.2).forest.nestedOrDisjoint
        hγ₁ hγ₂ hEq
  exact admissibleSubgraphRetargetSubgraph_nestedOrDisjoint_of_not_mem
    (forestComponentMixedBoundaryOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2)
    γ₁ γ₂
    (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₁ hγ₁)
    (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₂ hγ₂)
    hV₁ hV₂ hCompat

