        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceActualRightQuotientSubgraph g q hq
    (forestComponentForestChoiceRightRetargetCertificateCanonical g q hq)

/-- Canonical representative quotient-side right-selected survivor forest in
the genuine-forest regime. -/
private noncomputable def forestComponentForestChoiceRepRightQuotientSubgraphCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
