/-- The last concrete internal-edge payload for the genuine-forest split-star
model: the actual quotient-side carrier has exactly the internal edges obtained
by removing the spliced outer forest from the original component forest and
retargeting through the outer quotient. -/
private structure
    forestComponentForestChoiceActualQuotientInternalEdgesModel
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  internalEdges :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      (forestComponentForestChoiceActualQuotientSubgraphCanonical
        g q hq).internalEdges =
        (q.1.1.internalEdges -
          (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges).map
          ((forestComponentForestChoiceOuterIndex g q hq).1.retargetEdge
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (forestComponentForestChoiceOuterIndex g q hq).2))

/-- Source-side internal-edge decomposition for the genuine-forest branch.
After the spliced outer forest is removed from the original component forest,
the survivors are exactly the right-selected original components plus the
per-component remnants for genuine forest choices. -/
private structure forestComponentForestChoiceSourceInternalEdgesSplitModel
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  internalEdges :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      q.1.1.internalEdges -
          (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges =
        (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges +
          ∑ γ ∈ q.1.1.elements.attach,
            match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                γ.1.internalEdges -
                  (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges

/-- Count-level form of the source-side internal-edge split.  This is the
smallest arithmetic payload: after this point the remaining proof is just a
per-edge multiplicity calculation. -/
private structure forestComponentForestChoiceSourceInternalEdgesCountSplitModel
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  count :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ e : FeynmanEdge,
        Multiset.count e
            (q.1.1.internalEdges -
              (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges) =
          Multiset.count e
            ((forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges +
              ∑ γ ∈ q.1.1.elements.attach,
                match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
                | forestCoproductChoice.left => 0
                | forestCoproductChoice.right => 0
                | forestCoproductChoice.forest _B =>
                    γ.1.internalEdges -
                      (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges)

omit [ForestComponentForestChoiceRepQuotientComplementPositiveModel] in
private theorem forestComponentForestChoiceSourceInternalEdgesSplitModelOfCount
    [IsDivergencePreservedByAdmissibleForestContract]
    (K : forestComponentForestChoiceSourceInternalEdgesCountSplitModel) :
    forestComponentForestChoiceSourceInternalEdgesSplitModel where
  internalEdges := by
    intro g q hq
    exact Multiset.ext.mpr (K.count g q hq)

omit [ForestComponentForestChoiceRepQuotientComplementPositiveModel] in
private theorem forestComponentForestChoiceSourceInternalEdgesCountSplitCanonical
    [IsDivergencePreservedByAdmissibleForestContract] :
    forestComponentForestChoiceSourceInternalEdgesCountSplitModel where
  count := by
    intro g q hq e
    classical
    let A := q.1.1
    let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let R := forestComponentChoiceRightSubgraph A q.2
    let Fsum : Multiset FeynmanEdge :=
      ∑ γ ∈ A.elements.attach,
        match q.2 γ (Finset.mem_attach A.elements γ) with
        | forestCoproductChoice.left => 0
        | forestCoproductChoice.right => 0
        | forestCoproductChoice.forest _B =>
            γ.1.internalEdges - Aout.internalEdges
    have hADisj : A.IsPairwiseDisjoint := by
      dsimp [A]
      exact (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          q.1.2
    have hAoutDisj : Aout.IsPairwiseDisjoint := by
      dsimp [Aout]
      exact (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          (forestComponentForestChoiceOuterIndex g q hq).2
    have hRDisj : R.IsPairwiseDisjoint := by
      dsimp [R, A]
      exact forestComponentChoiceRightSubgraph_isPairwiseDisjoint
        q.1.1 q.2 hADisj
    have hR_subset_A :
        R.internalEdges ≤ A.internalEdges := by
      dsimp [R, A]
      exact admissibleSubgraph_internalEdges_le_of_components_le
        (forestComponentChoiceRightSubgraph q.1.1 q.2) hRDisj
        (fun γ hγ =>
          feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem
            q.1.1 hADisj
            (forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 hγ))
    by_cases heA : e ∈ A.internalEdges
    · rcases AdmissibleSubgraph.mem_internalEdges.mp heA with ⟨γ, hγA, heγ⟩
      have hAcount :
          Multiset.count e A.internalEdges =
            Multiset.count e γ.internalEdges :=
        admissibleSubgraph_internalEdges_count_eq_component_of_mem
          A hADisj hγA heγ
      have hRcount :
          Multiset.count e R.internalEdges =
            if hγR : γ ∈ R.elements then
              Multiset.count e γ.internalEdges
            else 0 := by
        by_cases hγR : γ ∈ R.elements
        · rw [dif_pos hγR]
          exact admissibleSubgraph_internalEdges_count_eq_component_of_mem
            R hRDisj hγR heγ
        · rw [dif_neg hγR]
          apply Multiset.count_eq_zero.mpr
          intro heR
          rcases AdmissibleSubgraph.mem_internalEdges.mp heR with
            ⟨δ, hδR, heδ⟩
          by_cases hδγ : δ = γ
          · subst δ
            exact hγR hδR
          · have hδA : δ ∈ A.elements :=
              forestComponentChoiceRightSubgraph_elements_subset A q.2 hδR
            have hdisj : δ.Disjoint γ := hADisj hδA hγA hδγ
            have hsuppδ := δ.edges_supported e heδ
            have hsuppγ := γ.edges_supported e heγ
            simp [FeynmanEdge.SupportedOn] at hsuppδ hsuppγ
            exact (Finset.disjoint_left.mp hdisj hsuppδ.1) hsuppγ.1
      have hFsum :
          Multiset.count e Fsum =
            match q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                Multiset.count e (γ.internalEdges - Aout.internalEdges) := by
        dsimp [Fsum]
        rw [multiset_count_finset_sum]
        rw [Finset.sum_eq_single ⟨γ, hγA⟩]
        · split <;> simp_all [Multiset.count_sub]
        · intro η _hη hne
          cases hηChoice : q.2 η (Finset.mem_attach A.elements η) with
          | left =>
              simp [hηChoice]
          | right =>
              simp [hηChoice]
          | forest B =>
              apply Multiset.count_eq_zero.mpr
              intro heSub
              have heη : e ∈ η.1.internalEdges :=
                Multiset.mem_of_le (Multiset.sub_le_self _ _) heSub
              have hηγ : η.1 ≠ γ := by
                intro hEq
                exact hne (Subtype.ext hEq)
              have hdisj : η.1.Disjoint γ :=
                hADisj (by simpa [A] using η.2) hγA hηγ
              have hsuppη := η.1.edges_supported e heη
              have hsuppγ := γ.edges_supported e heγ
              simp [FeynmanEdge.SupportedOn] at hsuppη hsuppγ
              exact (Finset.disjoint_left.mp hdisj hsuppη.1) hsuppγ.1
        · intro hnot
          exact False.elim (hnot (Finset.mem_attach A.elements ⟨γ, hγA⟩))
      rcases forestComponentForestChoice_choice_left_or_right_or_forest
          g q hq (by simpa [A] using hγA) with hγL | hγR | hγF
      · have hChoiceLeft :
            q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) =
              forestCoproductChoice.left := by
          rw [forestComponentChoiceLeftSubgraph_elements] at hγL
          have hLeft := (Finset.mem_filter.mp hγL).2
          unfold forestComponentChoiceIsLeft at hLeft
          rw [dif_pos (by simpa [A] using hγA)] at hLeft
          simpa [A] using hLeft
        have hγNotR : γ ∉ R.elements := by
          intro hγR
          exact forestComponentChoiceRightSubgraph_not_mem_left
            A q.2 hγR hγL
        have hAoutCount :
            Multiset.count e Aout.internalEdges =
              Multiset.count e γ.internalEdges := by
          have hγOut : γ ∈ Aout.elements := by
            dsimp [Aout, A] at *
            exact forestComponentForestChoiceOuterIndex_mem_of_left
              g q hq hγL
          exact admissibleSubgraph_internalEdges_count_eq_component_of_mem
            Aout hAoutDisj hγOut heγ
        rw [Multiset.count_sub, Multiset.count_add]
        rw [hAcount, hAoutCount, hRcount]
        have hFsumLeft : Multiset.count e Fsum = 0 := by
          trans
            (match q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                Multiset.count e (γ.internalEdges - Aout.internalEdges))
          · exact hFsum
          · let c :=
              q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩)
            change
              (match c with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  Multiset.count e (γ.internalEdges - Aout.internalEdges)) =
                0
            have hc : c = forestCoproductChoice.left := by
              dsimp [c]
              exact hChoiceLeft
            rw [hc]
        change
          Multiset.count e γ.internalEdges - Multiset.count e γ.internalEdges =
            (if hγR : γ ∈ R.elements then
              Multiset.count e γ.internalEdges
            else 0) + Multiset.count e Fsum
        rw [dif_neg hγNotR]
        rw [hFsumLeft]
        omega
      · have hChoiceRight :
            q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) =
              forestCoproductChoice.right := by
          rw [forestComponentChoiceRightSubgraph_elements] at hγR
          have hRight := (Finset.mem_filter.mp hγR).2
          unfold forestComponentChoiceIsRight at hRight
          rw [dif_pos (by simpa [A] using hγA)] at hRight
          simpa [A] using hRight
        have hAoutCount0 :
            Multiset.count e Aout.internalEdges = 0 := by
          apply Multiset.count_eq_zero.mpr
          intro heOut
          rcases AdmissibleSubgraph.mem_internalEdges.mp heOut with
            ⟨δ, hδOut, heδ⟩
          have hsuppγ := γ.edges_supported e heγ
          have hsuppδ := δ.edges_supported e heδ
          simp [FeynmanEdge.SupportedOn] at hsuppγ hsuppδ
          have hvOut : e.source ∈ Aout.vertices :=
            AdmissibleSubgraph.mem_vertices.mpr ⟨δ, hδOut, hsuppδ.1⟩
          have hnot :=
            forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
              A q.2 hADisj hγR hsuppγ.1
          exact hnot (by
            dsimp [Aout, A] at hvOut
            simpa [forestComponentForestChoiceOuterIndex_val] using hvOut)
        rw [Multiset.count_sub, Multiset.count_add]
        rw [hAcount, hAoutCount0, hRcount]
        have hFsumRight : Multiset.count e Fsum = 0 := by
          trans
            (match q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                Multiset.count e (γ.internalEdges - Aout.internalEdges))
          · exact hFsum
          · let c :=
              q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩)
            change
              (match c with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  Multiset.count e (γ.internalEdges - Aout.internalEdges)) =
                0
            have hc : c = forestCoproductChoice.right := by
              dsimp [c]
              exact hChoiceRight
            rw [hc]
        change
          Multiset.count e γ.internalEdges - 0 =
            (if hγR : γ ∈ R.elements then
              Multiset.count e γ.internalEdges
            else 0) + Multiset.count e Fsum
        have hγR' : γ ∈ R.elements := by
          simpa [R, A] using hγR
        rw [dif_pos hγR']
        rw [hFsumRight]
        omega
      · rcases hγF with ⟨B, hChoiceForest⟩
        have hγNotR : γ ∉ R.elements := by
          intro hγR
          rw [forestComponentChoiceRightSubgraph_elements] at hγR
          have hRight := (Finset.mem_filter.mp hγR).2
          unfold forestComponentChoiceIsRight at hRight
          rw [dif_pos (by simpa [A] using hγA)] at hRight
          have hRightChoice :
              q.2 ⟨γ, hγA⟩
                  (Finset.mem_attach A.elements ⟨γ, hγA⟩) =
                forestCoproductChoice.right := by
            simpa [A] using hRight
          rw [hChoiceForest] at hRightChoice
          cases hRightChoice
        have hChoiceForest' :
            q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) =
              forestCoproductChoice.forest B := by
          simpa [A] using hChoiceForest
        have hFsumForest :
            Multiset.count e Fsum =
              Multiset.count e (γ.internalEdges - Aout.internalEdges) := by
          trans
            (match q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                Multiset.count e (γ.internalEdges - Aout.internalEdges))
          · exact hFsum
          · let c :=
              q.2 ⟨γ, hγA⟩
                (Finset.mem_attach A.elements ⟨γ, hγA⟩)
            change
              (match c with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  Multiset.count e (γ.internalEdges - Aout.internalEdges)) =
                Multiset.count e (γ.internalEdges - Aout.internalEdges)
            have hc : c = forestCoproductChoice.forest B := by
              dsimp [c]
              exact hChoiceForest'
            rw [hc]
        rw [Multiset.count_sub, Multiset.count_add]
        rw [hAcount, hRcount]
        change
          Multiset.count e γ.internalEdges -
              Multiset.count e Aout.internalEdges =
            (if hγR : γ ∈ R.elements then
              Multiset.count e γ.internalEdges
            else 0) + Multiset.count e Fsum
        rw [dif_neg hγNotR]
        rw [hFsumForest, Multiset.count_sub]
        omega
    · have hAcount0 : Multiset.count e A.internalEdges = 0 :=
        Multiset.count_eq_zero.mpr heA
      have hRcount0 : Multiset.count e R.internalEdges = 0 := by
        apply Multiset.count_eq_zero.mpr
        intro heR
        exact heA (Multiset.mem_of_le hR_subset_A heR)
      have hFsum0 : Multiset.count e Fsum = 0 := by
        have hFterm_zero_of_not_mem_A :
            ∀ γ : {x : FeynmanSubgraph (repG g).toFeynmanGraph //
                x ∈ A.elements},
              Multiset.count e
                (match q.2 γ (Finset.mem_attach A.elements γ) with
                | forestCoproductChoice.left => 0
                | forestCoproductChoice.right => 0
                | forestCoproductChoice.forest _B =>
                    γ.1.internalEdges - Aout.internalEdges) = 0 := by
          intro γ
          cases hChoice : q.2 γ (Finset.mem_attach A.elements γ) with
          | left =>
              simp [hChoice]
          | right =>
              simp [hChoice]
          | forest B =>
              apply Multiset.count_eq_zero.mpr
              intro heSub
              have heγ : e ∈ γ.1.internalEdges :=
                Multiset.mem_of_le (Multiset.sub_le_self _ _) heSub
              exact heA (AdmissibleSubgraph.mem_internalEdges.mpr
                ⟨γ.1, by simpa [A] using γ.2, heγ⟩)
        dsimp [Fsum]
        rw [multiset_count_finset_sum]
        apply Finset.sum_eq_zero
        intro γ _hγ
        exact hFterm_zero_of_not_mem_A γ
      rw [Multiset.count_sub, Multiset.count_add]
      rw [hAcount0, hRcount0, hFsum0]
      simp

