/-- Sprint F2i-3o-2d: membership characterization for non-promoted components. -/
private theorem forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
