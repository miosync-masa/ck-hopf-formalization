        (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1).toFeynmanGraph.toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (γ.1.toHopfGen
            (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          B
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (γ.1.toHopfGen
              (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            B
            (forestComponentChoice_forest_mem_properDisjoint_of_core_mem
              (mem_forestComponentForestChoiceCoreIndex_core_hasForest
                ((Finset.mem_sigma.mp hq).2)).1
              γ hB))).toClass) :
    (∏ δ ∈ forestComponentForestChoiceRemnantComponentsForChoice
        g q hq γ (Finset.mem_attach q.1.1.elements γ),
      (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
        g q hq).componentToHopfH δ) =
    forestComponentChoiceRemnantInnerTensorFactor q.1.1 q.2
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest
        ((Finset.mem_sigma.mp hq).2)).1
      γ
      (Finset.mem_attach q.1.1.elements γ) := by
  classical
  let hpCore :
      q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      ((Finset.mem_sigma.mp hq).2)).1
  cases hChoice : q.2 γ (Finset.mem_attach q.1.1.elements γ) with
  | left =>
      simp [forestComponentForestChoiceRemnantComponentsForChoice,
        forestComponentChoiceRemnantInnerTensorFactor, hChoice]
  | right =>
      simp [forestComponentForestChoiceRemnantComponentsForChoice,
        forestComponentChoiceRemnantInnerTensorFactor, hChoice]
  | forest B =>
      let rem :
          FeynmanSubgraph
            (forestOuterActualQuotientGraph g
              (forestComponentForestChoiceOuterIndex g q hq)) :=
        admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1
      have hBmem :
