/-- RHS flat index associated to a mixed-boundary component-choice term. -/
private noncomputable def forestComponentMixedBoundaryToQuotientForestSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestQuotientForestSigma g :=
  ‚ü®forestComponentMixedBoundaryOuterIndex g q hq,
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q hq‚ü©

/-- Cross-disjointness skeleton, same-outer case (Sprint F1s-2): if the
forest-branch RHS image equals the mixed-branch RHS image and `qF.1 = qM.1`,
then `False`.  Pure wrapper over F1s-1 plus `congrArg Sigma.fst`. -/
private theorem forest_mixed_cross_false_of_same_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {qF qM : forestComponentChoiceSigma g}
    (hqF : qF ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hqM : qM ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hSame : qF.1 = qM.1)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g qF hqF =
      forestComponentMixedBoundaryToQuotientForestSigma g qM hqM) :
    False := by
  classical
  have hpForest : qF.2 ‚ąą forestComponentForestChoiceCoreIndex qF.1.1 :=
    (Finset.mem_sigma.mp hqF).2
  have hpCore : qF.2 ‚ąą forestComponentCoreChoiceIndex qF.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hAprop : qF.1.1 ‚ąą
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := qF.1.2
  have hA : qF.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hAprop
  have hCompOuterF :
      (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2 hA).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents
      hpCore hAprop hA
  have hOuterIndex :
      forestComponentForestChoiceOuterIndex g qF hqF =
        forestComponentMixedBoundaryOuterIndex g qM hqM :=
    congrArg Sigma.fst hEq
  have hOuter :
      (forestComponentForestChoiceOuterIndex g qF hqF).1 =
      (forestComponentMixedBoundaryOuterIndex g qM hqM).1 :=
    congrArg Subtype.val hOuterIndex
  exact forestComponentForestChoice_mixedBoundary_cross_same_outer_false
    hqF hqM hSame hCompOuterF hOuter

/-- F2d Target 1 (actual-version): in the mixed-boundary regime, every
component of the **actual** right-retarget quotient is vertex-disjoint
from the outer star carrier.  Right-selected sources sit in `A.elements`
but are filtered as `.right`, so they are disjoint from the
left-selected outer carrier; retargeting acts as identity on their
vertices, which lie outside `A.starVertices`. -/
private theorem forestComponentMixedBoundaryActualRightQuotientSubgraph_no_starVertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ‚ąÄ őī,
      őī ‚ąą (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq).elements ‚Üí
      Disjoint őī.vertices
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)) := by
  classical
  intro őī hőī
  -- Unfold the canonical construction down to retarget.image.
  unfold forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      forestComponentMixedBoundaryActualRightQuotientSubgraph
      forestOuterActualRetargetAdmissibleSubgraphOfCert
      forestOuterActualRetargetAdmissibleSubgraph
      admissibleSubgraphRetarget at hőī
  -- After unfolding, hőī : őī ‚ąą (ofElements s _).elements, which is defeq to őī ‚ąą s.
  rcases Finset.mem_image.mp hőī with ‚ü®ő≥R, hő≥RMem, hRetargetEq‚ü©
  -- ő≥R is right-selected ‚áí disjoint from left outer carrier; vertices stay identity.
  have hA : q.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hVertexId :
      ‚ąÄ v ‚ąą ő≥R.1.vertices,
        v ‚ąČ (forestComponentMixedBoundaryOuterIndex g q hq).1.vertices := by
    intro v hv
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hA ő≥R.2 hv
  -- őī.vertices = ő≥R.vertices (identity retarget for vertices outside outer carrier).
  have hőīVertices :
      őī.vertices = ő≥R.1.vertices := by
    rw [‚Üź hRetargetEq]
    exact admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      (forestComponentMixedBoundaryOuterIndex g q hq).1 _ ő≥R.1 _ hVertexId
  -- ő≥R.vertices ‚äÜ (repG g).toFeynmanGraph.vertices, which is disjoint from starVertices.
  rw [hőīVertices]
  have hFresh :
      (forestComponentMixedBoundaryOuterIndex g q hq).1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  have hGdisj := hFresh.disjoint_vertices_starVertices
  -- ő≥R ‚äÜ (repG g).toFG, so ő≥R.vertices ‚äÜ G.vertices.
  exact (Finset.disjoint_left).mpr fun v hv hStar =>
    (Finset.disjoint_left.mp hGdisj) (ő≥R.1.vertices_subset hv) hStar

/-- F2d Target 2 (actual-version): in the forest-choice regime, at least
one component of the actual quotient subgraph touches the outer star
carrier.  Witnessed by a remnant of a forest-selected `ő≥` whose
vertices contain a promoted-ő∑ image collapsed to `starOf ő∑`. -/
private theorem forestComponentForestChoiceActualQuotientSubgraph_exists_starVertex
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    ‚ąÉ őī,
      őī ‚ąą (forestComponentForestChoiceActualQuotientSubgraphCanonical
            g q hq).elements ‚ąß
      ¬¨ Disjoint őī.vertices
        ((forestComponentForestChoiceOuterIndex g q hq).1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)) := by
  classical
  -- Step 1: forest core ‚áí ‚ąÉ ő≥ ‚ąą q.1.1.elements, ‚ąÉ B, q.2 ő≥ = .forest B.
  have hpForest : q.2 ‚ąą forestComponentForestChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hpCore : q.2 ‚ąą forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  rcases (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
    with ‚ü®ő≥, B, hPő≥‚ü©
  -- Step 2: promoted ő≥ B is proper-disjoint and nonempty, pick ő∑.
  have hPromProper :
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (q.1.1.isConnectedDivergent_of_mem ő≥.2) B ‚ąą
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
      hpCore ő≥ hPő≥
  have hPromNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).IsNonempty :=
    properDisjointAdmissibleDivergentSubgraphs_isNonempty hPromProper
  have hPromCompNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).HasNonemptyComponents :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      hPromProper
  rcases hPromNE with ‚ü®ő∑, hő∑Prom‚ü©
  -- Step 3: candidate őī := admissibleSubgraphQuotientRemainderSubgraph forestOuter starOf ő≥.1.
  let A := forestComponentForestChoiceOuterIndex g q hq
  let starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2
  let őī := admissibleSubgraphQuotientRemainderSubgraph A.1 starOf ő≥.1
  -- őī ‚ąą remnant components (via _mem_of_forest).
  have hőīRemnant : őī ‚ąą forestComponentForestChoiceRemnantComponents g q hq :=
    forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq ő≥ hPő≥
  -- őī ‚ąą ActualQuotientSubgraphCanonical.elements via union-right.
  have hőīActual :
      őī ‚ąą (forestComponentForestChoiceActualQuotientSubgraphCanonical
            g q hq).elements := by
    rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
    unfold forestComponentForestChoiceActualQuotientComponents
    exact Finset.mem_union_right _ hőīRemnant
  refine ‚ü®őī, hőīActual, ?_‚ü©
  -- Step 4: exhibit a star vertex in őī.vertices.
  have hő∑VtxSub : ő∑.vertices ‚äÜ ő≥.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő≥.1 (q.1.1.isConnectedDivergent_of_mem ő≥.2) B hő∑Prom
  have hő∑NE : ő∑.IsNonempty := hPromCompNE ő∑ hő∑Prom
  rcases Finset.card_pos.mp hő∑NE with ‚ü®v, hvő∑‚ü©
  have hvő≥ : v ‚ąą ő≥.1.vertices := hő∑VtxSub hvő∑
  -- ő∑ ‚ąą forestOuter.elements (via Finset.mem_union_right of promoted).
  have hAdisjQ : q.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hő∑Outer : ő∑ ‚ąą A.1.elements := by
    have hő∑Promoted :
        ő∑ ‚ąą forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        q.1.1 q.2 ő≥ hPő≥ hő∑Prom
    show ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hAdisjQ).elements
    rw [forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_right _ hő∑Promoted
  -- The star of ő∑ is in starVertices and in őī.vertices via collapse.
  have hStar : starOf ő∑ ‚ąą A.1.starVertices starOf :=
    AdmissibleSubgraph.mem_starVertices.mpr ‚ü®ő∑, hő∑Outer, rfl‚ü©
  have hvOuter : v ‚ąą A.1.vertices :=
    AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő∑, hő∑Outer, hvő∑‚ü©
  have hRetV : A.1.retargetVertex starOf v = starOf ő∑ := by
    have hAdisj : A.1.IsPairwiseDisjoint :=
      ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        A.2
    rw [AdmissibleSubgraph.retargetVertex,
      AdmissibleSubgraph.componentAt?_eq_some_of_mem_vertices hAdisj hő∑Outer hvő∑]
  -- őī.vertices contains starOf ő∑.
  have hStarInDelta : starOf ő∑ ‚ąą őī.vertices := by
    rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ‚ü®v, hvő≥, hRetV‚ü©
  intro hdisj
  exact (Finset.disjoint_left.mp hdisj) hStarInDelta hStar

/-- Sprint F2e Step 1: pull a rep-side RHS quotient subgraph back to the
actual quotient graph via `mapPermAdmissibleSubgraphPreimage`.  This makes
ambient-side starVertices comparisons feasible (the rep version requires
transport across the `Classical.choose`-produced rep permutation, which
is unavailable). -/
private noncomputable def forestQuotientForestSigmaActualQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (r : forestQuotientForestSigma g) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g r.1) :=
  mapPermAdmissibleSubgraphPreimage (forestOuterActualToRepPerm_spec g r.1) r.2

/-- Sprint F2e Step 2 (mixed cancellation): actualization of the
mixed-branch RHS image is the canonical actual right quotient subgraph. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_mixed
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestQuotientForestSigmaActualQuotientSubgraph g
        (forestComponentMixedBoundaryToQuotientForestSigma g q hq) =
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq := by
  classical
  -- Rep canonical = forestOuterActualToRepAdmissibleSubgraph (Actual canonical).
  -- Preimage cancels: preimage h‚āĀ (mapPerm h A) = A by F1p-4b roundtrip.
  unfold forestQuotientForestSigmaActualQuotientSubgraph
    forestComponentMixedBoundaryToQuotientForestSigma
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
    forestComponentMixedBoundaryRepRightQuotientSubgraph
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    forestComponentMixedBoundaryActualRightQuotientSubgraph
    forestOuterRepRetargetAdmissibleSubgraphOfCert
    forestOuterRepRetargetAdmissibleSubgraph
    forestOuterActualRetargetAdmissibleSubgraphOfCert
  -- The rep version is `forestOuterActualToRepAdmissibleSubgraph` applied to
  -- the actual retarget; the preimage then cancels back.
  exact mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    (forestOuterActualToRepPerm_spec g (forestComponentMixedBoundaryOuterIndex g q hq)) _

/-- Sprint F2e Step 2 (forest cancellation): actualization of the
forest-branch RHS image is the canonical actual quotient subgraph. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    forestQuotientForestSigmaActualQuotientSubgraph g
        (forestComponentForestChoiceToQuotientForestSigma g q hq) =
      forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq := by
  classical
  unfold forestQuotientForestSigmaActualQuotientSubgraph
    forestComponentForestChoiceToQuotientForestSigma
    forestComponentForestChoiceRepQuotientSubgraphCanonical
    forestComponentForestChoiceRepQuotientSubgraph
    forestComponentForestChoiceActualQuotientSubgraphCanonical
    forestComponentForestChoiceActualQuotientSubgraph
  exact mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    (forestOuterActualToRepPerm_spec g (forestComponentForestChoiceOuterIndex g q hq)) _

/-- Sprint F2f Step 1: actualized branch discriminator.  An RHS flat index
`r` lies in the forest regime iff some component of its actual quotient
subgraph touches the outer star carrier.  This is the actual-level
predicate; the rep-level analogue is unavailable because the
`Classical.choose`-derived `forestOuterActualToRepPerm` carries no
starVertices-preservation spec. -/
private noncomputable def forestQuotientForestSigma_isForestByStar
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (r : forestQuotientForestSigma g) : Prop :=
  ‚ąÉ őī,
    őī ‚ąą (forestQuotientForestSigmaActualQuotientSubgraph g r).elements ‚ąß
    ¬¨ Disjoint őī.vertices
      (r.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1 r.1.2))

/-- Sprint F2f Step 2: the canonical forest-branch RHS image satisfies the
discriminator.  Direct composition of the F2e forest cancellation with the
F2d-2 actual-side ‚ąÉ-witness. -/
private theorem forestQuotientForestSigma_isForestByStar_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    forestQuotientForestSigma_isForestByStar g
      (forestComponentForestChoiceToQuotientForestSigma g q hq) := by
  classical
  unfold forestQuotientForestSigma_isForestByStar
  rw [forestQuotientForestSigmaActualQuotientSubgraph_forest g q hq]
  exact forestComponentForestChoiceActualQuotientSubgraph_exists_starVertex g q hq

/-- Sprint F2f Step 3: the canonical mixed-branch RHS image violates the
discriminator.  Direct composition of the F2e mixed cancellation with the
F2d-1 actual-side disjointness statement. -/
private theorem forestQuotientForestSigma_not_isForestByStar_of_mixed
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ¬¨ forestQuotientForestSigma_isForestByStar g
      (forestComponentMixedBoundaryToQuotientForestSigma g q hq) := by
  classical
  unfold forestQuotientForestSigma_isForestByStar
  rw [forestQuotientForestSigmaActualQuotientSubgraph_mixed g q hq]
  rintro ‚ü®őī, hőī, hNot‚ü©
  exact hNot
    (forestComponentMixedBoundaryActualRightQuotientSubgraph_no_starVertices
      g q hq őī hőī)

/-- Sprint F2g-0: vertex-level inverse for cover scaffolding.  Any vertex of
a quotient subgraph that is disjoint from the star carrier comes from the
ambient outer complement, i.e. lives in `(repG g).vertices` but outside
`A.vertices`.  This is the first step toward lifting no-star quotient
components back to ambient `FeynmanSubgraph`s; only vertex containment is
asserted here ‚ÄĒ neither subgraph lift nor `IsConnectedDivergent` are
attempted yet. -/
private theorem forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {v : VertexId} (hv : v ‚ąą őī.vertices) :
    v ‚ąą (repG g).toFeynmanGraph.vertices ‚ąß v ‚ąČ A.1.vertices := by
  classical
  have hvQ : v ‚ąą (forestOuterActualQuotientGraph g A).vertices :=
    őī.vertices_subset hv
  unfold forestOuterActualQuotientGraph at hvQ
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices] at hvQ
  rcases Finset.mem_union.mp hvQ with hRest | hStar
  ¬∑ exact ‚ü®(Finset.mem_sdiff.mp hRest).1, (Finset.mem_sdiff.mp hRest).2‚ü©
  ¬∑ exact absurd hStar (Finset.disjoint_left.mp hNoStar hv)

/-- Sprint F2g-1 (membership form, fallback per scout report).  An internal
edge of a no-star quotient component is already an internal edge of the
ambient graph `(repG g).toFG`.  Proof: pull back through
`contractWithStars_internalEdges = A.complementEdges.map (retargetEdge starOf)`,
then show the retarget acts as identity on the pre-image because no endpoint
can be in `A.vertices` (else it would retarget into `A.starVertices`, but
endpoints lie in `őī.vertices` which is disjoint from `A.starVertices`). -/
private theorem forestOuterActualQuotient_noStar_internalEdge_mem_ambient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {e : FeynmanEdge} (he : e ‚ąą őī.internalEdges) :
    e ‚ąą (repG g).toFeynmanGraph.internalEdges := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hSup : e.SupportedOn őī.vertices := őī.edges_supported e he
  have heQ : e ‚ąą (forestOuterActualQuotientGraph g A).internalEdges :=
    Multiset.mem_of_le őī.internalEdges_le he
  unfold forestOuterActualQuotientGraph at heQ
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges] at heQ
  rcases Multiset.mem_map.mp heQ with ‚ü®e_orig, heOrig, hRet‚ü©
  have hSrcNotStar : e.source ‚ąČ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup.1
  have hTgtNotStar : e.target ‚ąČ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup.2
  have hRetSrc : A.1.retargetVertex starOf e_orig.source = e.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRetTgt : A.1.retargetVertex starOf e_orig.target = e.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have hSrcOrigNotA : e_orig.source ‚ąČ A.1.vertices := by
    intro hvA
    apply hSrcNotStar
    rw [‚Üź hRetSrc, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hTgtOrigNotA : e_orig.target ‚ąČ A.1.vertices := by
    intro hvA
    apply hTgtNotStar
    rw [‚Üź hRetTgt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hRSrc := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hSrcOrigNotA
  have hRTgt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hTgtOrigNotA
  have hSrc : e_orig.source = e.source := hRSrc.symm.trans hRetSrc
  have hTgt : e_orig.target = e.target := hRTgt.symm.trans hRetTgt
  have hSec : e_orig.sector = e.sector := by
    have := congrArg FeynmanEdge.sector hRet
    simpa [AdmissibleSubgraph.retargetEdge] using this
  have hEqEdge : e_orig = e := by
    cases e_orig
    cases e
    exact (FeynmanEdge.mk.injEq _ _ _ _ _ _).mpr ‚ü®hSrc, hTgt, hSec‚ü©
  rw [‚Üź hEqEdge]
  exact AdmissibleSubgraph.mem_ambientInternalEdges_of_mem_complementEdges A.1 heOrig

/-- Sprint F2g-1 (membership form, external leg version).  An external leg of
a no-star quotient component is already an external leg of the ambient graph.
Proof is the leg analogue of the internal-edge version: the
`retargetExternalLeg` pre-image has `attachedTo ‚ąČ A.vertices` (else it would
retarget into `A.starVertices`), so the retarget acts as identity. -/
private theorem forestOuterActualQuotient_noStar_externalLeg_mem_ambient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {‚Ąď : ExternalLeg} (h‚Ąď : ‚Ąď ‚ąą őī.externalLegs) :
    ‚Ąď ‚ąą (repG g).toFeynmanGraph.externalLegs := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hSup : ‚Ąď.SupportedOn őī.vertices := őī.legs_supported ‚Ąď h‚Ąď
  have h‚ĄďQ : ‚Ąď ‚ąą (forestOuterActualQuotientGraph g A).externalLegs :=
    Multiset.mem_of_le őī.externalLegs_le h‚Ąď
  unfold forestOuterActualQuotientGraph at h‚ĄďQ
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq] at h‚ĄďQ
  change ‚Ąď ‚ąą (repG g).toFeynmanGraph.externalLegs.map
    (A.1.retargetExternalLeg starOf) at h‚ĄďQ
  rcases Multiset.mem_map.mp h‚ĄďQ with ‚ü®‚Ąď_orig, h‚ĄďOrig, hRet‚ü©
  have hAttNotStar : ‚Ąď.attachedTo ‚ąČ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup
  have hRetAtt : A.1.retargetVertex starOf ‚Ąď_orig.attachedTo = ‚Ąď.attachedTo := by
    have := congrArg ExternalLeg.attachedTo hRet; simpa using this
  have hAttOrigNotA : ‚Ąď_orig.attachedTo ‚ąČ A.1.vertices := by
    intro hvA
    apply hAttNotStar
    rw [‚Üź hRetAtt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hRAtt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hAttOrigNotA
  have hAtt : ‚Ąď_orig.attachedTo = ‚Ąď.attachedTo := hRAtt.symm.trans hRetAtt
  have hSec : ‚Ąď_orig.sector = ‚Ąď.sector := by
    have := congrArg ExternalLeg.sector hRet
    simpa [AdmissibleSubgraph.retargetExternalLeg] using this
  have hEqLeg : ‚Ąď_orig = ‚Ąď := by
    cases ‚Ąď_orig
    cases ‚Ąď
    exact (ExternalLeg.mk.injEq _ _ _ _).mpr ‚ü®hAtt, hSec‚ü©
  rw [‚Üź hEqLeg]; exact h‚ĄďOrig

/-- Sprint F2g-1b helper: retargetEdge uniqueness on no-star targets.  If a
canonical retarget sends `e_orig` to a no-star image `e`, then `e_orig = e`
(retarget acts as identity on edges whose endpoints lie outside both
`A.vertices` and `A.starVertices`).  Extracts the e_orig = e claim that was
inline in F2g-1; reused by the `_le` count chain below. -/
private theorem forestOuterActualQuotient_noStar_retargetEdge_eq_self
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {e_orig e : FeynmanEdge}
    (hRet : A.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2) e_orig = e)
    (hSrcS : e.source ‚ąČ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2))
    (hTgtS : e.target ‚ąČ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)) :
    e_orig = e := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hRSrc : A.1.retargetVertex starOf e_orig.source = e.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRTgt : A.1.retargetVertex starOf e_orig.target = e.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have hSrcNotA : e_orig.source ‚ąČ A.1.vertices := by
    intro hvA; apply hSrcS
    rw [‚Üź hRSrc, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hTgtNotA : e_orig.target ‚ąČ A.1.vertices := by
    intro hvA; apply hTgtS
    rw [‚Üź hRTgt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hRSId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hSrcNotA
  have hRTId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hTgtNotA
  have hSec : e_orig.sector = e.sector := by
    have := congrArg FeynmanEdge.sector hRet
    simpa [AdmissibleSubgraph.retargetEdge] using this
  cases e_orig; cases e
  exact (FeynmanEdge.mk.injEq _ _ _ _ _ _).mpr
    ‚ü®hRSId.symm.trans hRSrc, hRTId.symm.trans hRTgt, hSec‚ü©

/-- Sprint F2g-1b helper: retargetExternalLeg uniqueness on no-star targets.
Leg analogue of `_retargetEdge_eq_self`. -/
private theorem forestOuterActualQuotient_noStar_retargetLeg_eq_self
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {‚Ąď_orig ‚Ąď : ExternalLeg}
    (hRet : A.1.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2) ‚Ąď_orig = ‚Ąď)
    (hAttS : ‚Ąď.attachedTo ‚ąČ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)) :
    ‚Ąď_orig = ‚Ąď := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hRAtt : A.1.retargetVertex starOf ‚Ąď_orig.attachedTo = ‚Ąď.attachedTo := by
    have := congrArg ExternalLeg.attachedTo hRet; simpa using this
  have hAttNotA : ‚Ąď_orig.attachedTo ‚ąČ A.1.vertices := by
    intro hvA; apply hAttS
    rw [‚Üź hRAtt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ‚ü®A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl‚ü©
  have hRAId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hAttNotA
  have hSec : ‚Ąď_orig.sector = ‚Ąď.sector := by
    have := congrArg ExternalLeg.sector hRet
    simpa [AdmissibleSubgraph.retargetExternalLeg] using this
  cases ‚Ąď_orig; cases ‚Ąď
  exact (ExternalLeg.mk.injEq _ _ _ _).mpr ‚ü®hRAId.symm.trans hRAtt, hSec‚ü©

/-- Sprint F2g-1b: lift a no-star quotient component to an ambient
`FeynmanSubgraph` with carriers verbatim equal to those of `őī`.  Admissibility
fields use the helpers `_retargetEdge_eq_self` / `_retargetLeg_eq_self` for
the multiset `_le` proofs (count-chain through quotient ‚Üí A.complementEdges ‚Üí
G.internalEdges, with retarget reducing to identity on no-star elements). -/
private noncomputable def forestOuterActualQuotientNoStarComponentLift
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices := őī.vertices
  internalEdges := őī.internalEdges
  externalLegs := őī.externalLegs
  vertices_subset := fun _ hv =>
    (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement g A hNoStar hv).1
  internalEdges_le := by
    classical
    set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2 with hstarOf
    rw [Multiset.le_iff_count]
    intro e
    by_cases hcnt : 0 < Multiset.count e őī.internalEdges
    ¬∑ have he := Multiset.count_pos.mp hcnt
      have hSup := őī.edges_supported e he
      have hSrcStar : e.source ‚ąČ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup.1
      have hTgtStar : e.target ‚ąČ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup.2
      have hFilterLe : (A.1.complementEdges.filter
            (fun a => e = A.1.retargetEdge starOf a)) ‚Č§
          (A.1.complementEdges.filter (fun a => e = a)) := by
        rw [Multiset.le_iff_count]
        intro x
        rw [Multiset.count_filter, Multiset.count_filter]
        split_ifs with hp hq
        ¬∑ rfl
        ¬∑ exfalso; apply hq
          exact (forestOuterActualQuotient_noStar_retargetEdge_eq_self
            g A hp.symm hSrcStar hTgtStar).symm
        all_goals omega
      have hCountComp : Multiset.count e A.1.complementEdges =
          (A.1.complementEdges.filter (fun a => e = a)).card := by
        unfold Multiset.count; exact Multiset.countP_eq_card_filter _ _
      calc Multiset.count e őī.internalEdges
          ‚Č§ Multiset.count e (forestOuterActualQuotientGraph g A).internalEdges :=
            Multiset.count_le_of_le _ őī.internalEdges_le
        _ = (A.1.complementEdges.filter
              (fun a => e = A.1.retargetEdge starOf a)).card := by
            show Multiset.count e (A.1.contractWithStars starOf).internalEdges = _
            rw [AdmissibleSubgraph.contractWithStars_internalEdges, Multiset.count_map]
        _ ‚Č§ (A.1.complementEdges.filter (fun a => e = a)).card :=
            Multiset.card_le_card hFilterLe
        _ = Multiset.count e A.1.complementEdges := hCountComp.symm
        _ ‚Č§ Multiset.count e (repG g).toFeynmanGraph.internalEdges :=
            Multiset.count_le_of_le _ (Multiset.sub_le_self _ _)
    ¬∑ omega
  externalLegs_le := by
    classical
    set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2 with hstarOf
    rw [Multiset.le_iff_count]
    intro ‚Ąď
    by_cases hcnt : 0 < Multiset.count ‚Ąď őī.externalLegs
    ¬∑ have h‚Ąď := Multiset.count_pos.mp hcnt
      have hSup := őī.legs_supported ‚Ąď h‚Ąď
      have hAttStar : ‚Ąď.attachedTo ‚ąČ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup
      have hFilterLe : ((repG g).toFeynmanGraph.externalLegs.filter
            (fun a => ‚Ąď = A.1.retargetExternalLeg starOf a)) ‚Č§
          ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ‚Ąď = a)) := by
        rw [Multiset.le_iff_count]
        intro x
        rw [Multiset.count_filter, Multiset.count_filter]
        split_ifs with hp hq
        ¬∑ rfl
        ¬∑ exfalso; apply hq
          exact (forestOuterActualQuotient_noStar_retargetLeg_eq_self
            g A hp.symm hAttStar).symm
        all_goals omega
      have hCountG : Multiset.count ‚Ąď (repG g).toFeynmanGraph.externalLegs =
          ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ‚Ąď = a)).card := by
        unfold Multiset.count; exact Multiset.countP_eq_card_filter _ _
      calc Multiset.count ‚Ąď őī.externalLegs
          ‚Č§ Multiset.count ‚Ąď (forestOuterActualQuotientGraph g A).externalLegs :=
            Multiset.count_le_of_le _ őī.externalLegs_le
        _ = ((repG g).toFeynmanGraph.externalLegs.filter
              (fun a => ‚Ąď = A.1.retargetExternalLeg starOf a)).card := by
            show Multiset.count ‚Ąď (A.1.contractWithStars starOf).externalLegs = _
            rw [AdmissibleSubgraph.contractWithStars_externalLegs, Multiset.count_map]
        _ ‚Č§ ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ‚Ąď = a)).card :=
            Multiset.card_le_card hFilterLe
        _ = Multiset.count ‚Ąď (repG g).toFeynmanGraph.externalLegs := hCountG.symm
    ¬∑ omega
  edges_supported := őī.edges_supported
  legs_supported := őī.legs_supported

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).vertices = őī.vertices := rfl

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).internalEdges =
      őī.internalEdges := rfl

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).externalLegs =
      őī.externalLegs := rfl

/-- Sprint F2g-2: the lift has the same `toFeynmanGraph` as `őī`.  All three
carriers (vertices, internalEdges, externalLegs) coincide by definition of
the lift, so `toFeynmanGraph` is structurally equal. -/
@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_toFeynmanGraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).toFeynmanGraph =
      őī.toFeynmanGraph := rfl

/-- Sprint F2g-3: subgraph-level `IsConnectedDivergent` transports from `őī`
to its no-star lift.  `IsConnected` and `IsOnePI` are `toFeynmanGraph`-only
predicates so they transport definitionally (F2g-2 is `rfl`).  `IsDivergent`
requires `IsAmbientInvariantDivergence`: both sides reduce to the degree of
`FeynmanSubgraph.self őī.toFeynmanGraph _`, which is `rfl` after the F2g-2
cancellation. -/
private theorem forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint őī.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    (hőīCD : őī.IsConnectedDivergent) :
    (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).IsConnectedDivergent := by
  refine ‚ü®hőīCD.isConnected, hőīCD.isOnePI, ?_‚ü©
  -- IsDivergent: degree transport via IsAmbientInvariantDivergence.
  show 0 ‚Č§ (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).divergenceDegree
  have hDeg :
      (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar).divergenceDegree =
        őī.divergenceDegree := by
    show DivergenceMeasure.degree _ = DivergenceMeasure.degree _
    rw [‚Üź IsAmbientInvariantDivergence.degree_self_eq
          (forestOuterActualQuotientNoStarComponentLift g A őī hNoStar),
        ‚Üź IsAmbientInvariantDivergence.degree_self_eq őī]
    rfl
  rw [hDeg]
  exact hőīCD.isDivergent

/-- Sprint F2h-0 Step 1: in the mixed regime (RHS does NOT satisfy
`isForestByStar`), every component of the actualized RHS quotient subgraph
is disjoint from the outer star carrier.  Pure contrapositive of the
predicate definition. -/
private theorem forestQuotientForestSigma_all_noStar_of_not_isForestByStar
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ őī,
      őī ‚ąą (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ‚Üí
      Disjoint őī.vertices
        (r.1.1.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  intro őī hőī
  by_contra hDisj
  exact hNotForest ‚ü®őī, hőī, hDisj‚ü©

/-- Sprint F2h-0 Step 2: in the mixed regime, the actualized RHS quotient
components lift to a `Finset` of ambient `FeynmanSubgraph`s.  Each lifted
component is the F2g-1b no-star lift of the corresponding quotient
component, using the all-noStar disjointness from Step 1. -/
private noncomputable def forestQuotientForestSigmaMixedLiftedRightComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.attach.image
    (fun őī =>
      forestOuterActualQuotientNoStarComponentLift g r.1.1 őī.1
        (forestQuotientForestSigma_all_noStar_of_not_isForestByStar
          g r hNotForest őī.1 őī.2))

/-- Sprint F2h-0 Step 3: spec of mixed lifted right components.  Existence
form (the full iff is awkward because the lift's proof-argument depends on
őī); membership entails the existence of an actual-side őī whose
`toFeynmanGraph` matches the lifted component. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ : ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    ‚ąÉ őī, őī ‚ąą (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ‚ąß
      ő≥.toFeynmanGraph = őī.toFeynmanGraph := by
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hő≥
  rcases Finset.mem_image.mp hő≥ with ‚ü®‚ü®őī, hőī‚ü©, _, hEq‚ü©
  refine ‚ü®őī, hőī, ?_‚ü©
  rw [‚Üź hEq]
  exact forestOuterActualQuotientNoStarComponentLift_toFeynmanGraph
    g r.1.1 őī _

/-- Sprint F2h-0 Step 4: every lifted right component is connected-divergent
in the ambient.  Composition of `isConnectedDivergent_of_mem` on the
actualized RHS quotient subgraph with F2g-3 CD-transport. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_cd
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ ő≥,
      ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest ‚Üí
      ő≥.IsConnectedDivergent := by
  intro ő≥ hő≥
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hő≥
  rcases Finset.mem_image.mp hő≥ with ‚ü®‚ü®őī, hőī‚ü©, _, hEq‚ü©
  rw [‚Üź hEq]
  exact forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent
    g r.1.1 őī _
    ((forestQuotientForestSigmaActualQuotientSubgraph g r.1
      ).isConnectedDivergent_of_mem hőī)

/-- Sprint F2h-0 Step 5: every lifted right component is vertex-disjoint
from the outer subgraph `r.1.1.1`.  Each vertex of the lifted component
comes from `őī.vertices` (via the F2g-1b vertices simp), and F2g-0 gives
that no-star őī-vertices avoid `A.vertices`. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ ő≥,
      ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest ‚Üí
      Disjoint ő≥.vertices r.1.1.1.vertices := by
  intro ő≥ hő≥
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hő≥
  rcases Finset.mem_image.mp hő≥ with ‚ü®‚ü®őī, hőī‚ü©, _, hEq‚ü©
  rw [‚Üź hEq]
  rw [forestOuterActualQuotientNoStarComponentLift_vertices]
  refine Finset.disjoint_left.mpr fun v hv hvA => ?_
  have hNoStar :=
    forestQuotientForestSigma_all_noStar_of_not_isForestByStar
      g r hNotForest őī hőī
  exact (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
    g r.1.1 hNoStar hv).2 hvA

/-- Sprint F2h-1 Target 1: left-left `NestedOrDisjoint`.  Two distinct
components of `r.1.1.1.elements` are NOD by direct delegation to the
admissible-subgraph forest's `nestedOrDisjoint` field. -/
private theorem forestQuotientForestSigmaMixedCover_left_left_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (_hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ ő≥‚āĀ, ő≥‚āĀ ‚ąą r.1.1.1.elements ‚Üí
    ‚ąÄ ő≥‚āā, ő≥‚āā ‚ąą r.1.1.1.elements ‚Üí
    ő≥‚āĀ ‚Č† ő≥‚āā ‚Üí
      ő≥‚āĀ.NestedOrDisjoint ő≥‚āā := fun ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne =>
  r.1.1.1.forest.nestedOrDisjoint hő≥‚āĀ hő≥‚āā hne

/-- Sprint F2h-1 Target 2: right-right `NestedOrDisjoint`.  Each lifted
component carries the same three carrier fields as its source őī (F2g-1b
simp lemmas), so NOD transports from the actualized RHS quotient's
admissible forest along the carrier equalities. -/
private theorem forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ ő≥‚āĀ,
      ő≥‚āĀ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest ‚Üí
    ‚ąÄ ő≥‚āā,
      ő≥‚āā ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest ‚Üí
    ő≥‚āĀ ‚Č† ő≥‚āā ‚Üí
      ő≥‚āĀ.NestedOrDisjoint ő≥‚āā := by
  intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hő≥‚āĀ hő≥‚āā
  rcases Finset.mem_image.mp hő≥‚āĀ with ‚ü®‚ü®őī‚āĀ, hőī‚āĀ‚ü©, _, hEq‚āĀ‚ü©
  rcases Finset.mem_image.mp hő≥‚āā with ‚ü®‚ü®őī‚āā, hőī‚āā‚ü©, _, hEq‚āā‚ü©
  have hőīne : őī‚āĀ ‚Č† őī‚āā := by
    intro h
    apply hne
    rw [‚Üź hEq‚āĀ, ‚Üź hEq‚āā]
    subst h
    rfl
  have hőīNOD :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).forest.nestedOrDisjoint
      hőī‚āĀ hőī‚āā hőīne
  rw [‚Üź hEq‚āĀ, ‚Üź hEq‚āā]
  rcases hőīNOD with hN | hD
  ¬∑ refine Or.inl ?_
    rcases hN with h | h
    ¬∑ exact Or.inl ‚ü®h.1, h.2.1, h.2.2‚ü©
    ¬∑ exact Or.inr ‚ü®h.1, h.2.1, h.2.2‚ü©
  ¬∑ exact Or.inr hD

/-- Sprint F2h-1 Target 3: left-right `NestedOrDisjoint`.  Lifted right
components are vertex-disjoint from the outer (F2h-0 Step 5), and any
outer-element `ő≥L` has vertices contained in `r.1.1.1.vertices`, so the
case collapses to `Or.inr` (vertex-disjoint). -/
private theorem forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    ‚ąÄ ő≥L, ő≥L ‚ąą r.1.1.1.elements ‚Üí
    ‚ąÄ ő≥R,
      ő≥R ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest ‚Üí
      ő≥L.NestedOrDisjoint ő≥R := by
  intro ő≥L hő≥L ő≥R hő≥R
  refine Or.inr ?_
  have hOutDisj :=
    forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
      g r hNotForest ő≥R hő≥R
  refine Finset.disjoint_left.mpr fun v hvL hvR => ?_
  exact Finset.disjoint_left.mp hOutDisj hvR
    (AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő≥L, hő≥L, hvL‚ü©)

/-- Sprint F2h-2: mixed cover outer candidate.  Combines `r.1.1.1.elements`
(left-source admissible components) with the lifted right components
(F2h-0 Step 2) into a single ambient `AdmissibleSubgraph (repG g).toFG`.
CD is the union of outer-side `isConnectedDivergent_of_mem` and F2h-0
Step 4; pairwise `NestedOrDisjoint` dispatches via F2h-1 Targets 1/2/3
on the four `mem_union` cases (the right-left case applies Target 3 with
swapped args, then `.symm`).

This is the `q.1.1` candidate for the mixed branch preimage construction;
choice function `q.2` is built in a separate sprint. -/
private noncomputable def forestQuotientForestSigmaMixedCoverOuterCandidate
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (r.1.1.1.elements ‚ą™
      forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest)
    (by
      refine ‚ü®?cd, ?nod‚ü©
      case cd =>
        intro ő≥ hő≥
        rcases Finset.mem_union.mp hő≥ with hLeft | hRight
        ¬∑ exact r.1.1.1.isConnectedDivergent_of_mem hLeft
        ¬∑ exact forestQuotientForestSigmaMixedLiftedRightComponents_cd
            g r hNotForest ő≥ hRight
      case nod =>
        intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne
        rcases Finset.mem_union.mp hő≥‚āĀ with hL1 | hR1
        ¬∑ rcases Finset.mem_union.mp hő≥‚āā with hL2 | hR2
          ¬∑ exact forestQuotientForestSigmaMixedCover_left_left_nestedOrDisjoint
              g r hNotForest ő≥‚āĀ hL1 ő≥‚āā hL2 hne
          ¬∑ exact forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
              g r hNotForest ő≥‚āĀ hL1 ő≥‚āā hR2
        ¬∑ rcases Finset.mem_union.mp hő≥‚āā with hL2 | hR2
          ¬∑ exact (forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
              g r hNotForest ő≥‚āā hL2 ő≥‚āĀ hR1).symm
          ¬∑ exact forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
              g r hNotForest ő≥‚āĀ hR1 ő≥‚āā hR2 hne)

@[simp] private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_elements
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest).elements =
      r.1.1.1.elements ‚ą™
        forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := rfl

/-- Sprint F2h-3a Target 1: outer (left) and lifted-right components are
finset-disjoint.  Any ő≥ in both would have a vertex in `ő≥.vertices`
(ő≥.IsNonempty via outer `HasNonemptyComponents`), which would lie in
`r.1.1.1.vertices` (since ő≥ is a component of `r.1.1.1`), contradicting
F2h-0 Step 5 (lifted right components vertex-disjoint from outer). -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    Disjoint r.1.1.1.elements
      (forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) := by
  refine Finset.disjoint_left.mpr fun ő≥ hLeft hRight => ?_
  have hDisj :=
    forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
      g r hNotForest ő≥ hRight
  have hNE : ő≥.IsNonempty :=
    ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2) ő≥ hLeft
  rcases Finset.card_pos.mp hNE with ‚ü®v, hv‚ü©
  exact Finset.disjoint_left.mp hDisj hv
    (AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő≥, hLeft, hv‚ü©)

/-- Sprint F2h-3a Target 2: membership dichotomy.  Every element of the
mixed cover candidate is in either the outer (left) part or the lifted
right part.  Direct `mem_union` unpack via the F2h-2 elements simp. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_mem_left_or_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ :
      ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements) :
    ő≥ ‚ąą r.1.1.1.elements ‚ą®
      ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := by
  rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements] at hő≥
  exact Finset.mem_union.mp hő≥

/-- Sprint F2h-3a Target 3a: if `ő≥` is in the outer (left) part, it is not
in the lifted right part.  Wrapper over Target 1. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_not_right_of_left
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hLeft : ő≥ ‚ąą r.1.1.1.elements) :
    ő≥ ‚ąČ forestQuotientForestSigmaMixedLiftedRightComponents
      g r hNotForest := fun hRight =>
  Finset.disjoint_left.mp
    (forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
      g r hNotForest) hLeft hRight

/-- Sprint F2h-3a Target 3b: if `ő≥` is in the lifted right part, it is not
in the outer (left) part.  Symmetric wrapper over Target 1. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_not_left_of_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hRight :
      ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    ő≥ ‚ąČ r.1.1.1.elements := fun hLeft =>
  Finset.disjoint_left.mp
    (forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
      g r hNotForest) hLeft hRight

/-- Sprint F2h-3b: mixed cover choice function.  On the candidate outer
admissible subgraph, every component is either left-source (in
`r.1.1.1.elements`) or a lifted right component; assign `.left` to the
former and `.right` to the latter.  The `forest` branch is unused. -/
private noncomputable def forestQuotientForestSigmaMixedCoverChoiceFn
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceFn
      (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest) :=
  fun ő≥ _ =>
    if ő≥.1 ‚ąą r.1.1.1.elements then
      forestCoproductChoice.left
    else
      forestCoproductChoice.right

/-- Sprint F2h-3b evaluation lemma (left): on a left-source component, the
choice function returns `.left`. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ :
      ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    (hLeft : ő≥ ‚ąą r.1.1.1.elements) :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ‚ü®ő≥, hő≥‚ü©
      (Finset.mem_attach _ ‚ü®ő≥, hő≥‚ü©) =
      forestCoproductChoice.left := by
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs with h
  ¬∑ rfl
  ¬∑ exact absurd hLeft h

/-- Sprint F2h-3b evaluation lemma (right): on a lifted right component, the
choice function returns `.right`.  Uses F2h-3a Target 3b to rule out the
left branch. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ :
      ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    (hRight :
      ő≥ ‚ąą forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ‚ü®ő≥, hő≥‚ü©
      (Finset.mem_attach _ ‚ü®ő≥, hő≥‚ü©) =
      forestCoproductChoice.right := by
  have hNotLeft :=
    forestQuotientForestSigmaMixedCoverOuterCandidate_not_left_of_right
      g r hNotForest hRight
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs with h
  ¬∑ exact absurd h hNotLeft
  ¬∑ rfl

/-- Sprint F2h-3b evaluation lemma (no forest): the choice function never
returns a `.forest B` value.  By construction it is binary (left ‚äē right). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_ne_forest
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ :
      ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    {B : AdmissibleSubgraph
      (repG (ő≥.toHopfGen
        ((forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
          ).isConnectedDivergent_of_mem hő≥))).toFeynmanGraph} :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ‚ü®ő≥, hő≥‚ü©
      (Finset.mem_attach _ ‚ü®ő≥, hő≥‚ü©) ‚Č†
      forestCoproductChoice.forest B := by
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs <;> intro heq <;> cases heq

/-- Sprint F2h-3c: the LeftSubgraph of the mixed cover candidate equals the
original RHS outer `r.1.1.1`.  Reduces via `AdmissibleSubgraph.ext` +
`Forest.ext` to a Finset equality, then `Finset.ext` over the union
decomposition: outer elements stay (`isLeft = True` via F2h-3b left
evaluation), lifted-right elements are filtered out (`isLeft = False`
because F2h-3b right evaluation gives `.right ‚Č† .left`). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_leftSubgraph_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceLeftSubgraph
        (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)
      = r.1.1.1 := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  show (forestComponentChoiceLeftSubgraph
          (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
          (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)).elements =
         r.1.1.1.elements
  rw [forestComponentChoiceLeftSubgraph_elements,
    forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
  ext ő≥
  rw [Finset.mem_filter]
  constructor
  ¬∑ rintro ‚ü®hUnion, hIsLeft‚ü©
    rcases Finset.mem_union.mp hUnion with hL | hR
    ¬∑ exact hL
    ¬∑ exfalso
      have hCand : ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
          g r hNotForest).elements := by
        rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
        exact Finset.mem_union_right _ hR
      unfold forestComponentChoiceIsLeft at hIsLeft
      rw [dif_pos hCand] at hIsLeft
      rw [forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
        g r hNotForest hCand hR] at hIsLeft
      cases hIsLeft
  ¬∑ intro hL
    have hCand : ő≥ ‚ąą (forestQuotientForestSigmaMixedCoverOuterCandidate
        g r hNotForest).elements := by
      rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
      exact Finset.mem_union_left _ hL
    refine ‚ü®Finset.mem_union_left _ hL, ?_‚ü©
    unfold forestComponentChoiceIsLeft
    rw [dif_pos hCand]
    exact forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
      g r hNotForest hCand hL

/-- Sprint F2h-3d Step 1: lifted right components packaged as an
`AdmissibleSubgraph` of the ambient.  CD per element via F2h-0 Step 4;
pairwise NOD via F2h-1 Target 2 (right-right NOD). -/
private noncomputable def forestQuotientForestSigmaMixedCoverRightCandidate
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest)
    (by
      refine ‚ü®?cd, ?nod‚ü©
      case cd =>
        intro ő≥ hő≥
        exact forestQuotientForestSigmaMixedLiftedRightComponents_cd
          g r hNotForest ő≥ hő≥
      case nod =>
        intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne
        exact forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
          g r hNotForest ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne)

@[simp] private theorem forestQuotientForestSigmaMixedCoverRightCandidate_elements
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (hNotForest : ¬¨ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest).elements =
      forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := rfl

/-- Sprint F2h-3d Step 2: the RightSubgraph of the mixed cover candidate
equals the lifted-right candidate.  Symmetric mirror of F2h-3c: the
`isRight` filter retains lifted-right elements (`.right` evaluation via
F2h-3b) and discards left-source elements (F2h-3b left evaluation gives
`.left ‚Č† .right`). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_rightSubgraph_eq
    [IsAmbientInvariantDivergence]
