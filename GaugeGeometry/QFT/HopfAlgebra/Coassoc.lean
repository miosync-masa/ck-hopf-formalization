  ¬∑ subst őī
    rw [forestComponentChoiceLeftSubgraph_elements] at hőīLeft
    have hLeft := (Finset.mem_filter.mp hőīLeft).2
    unfold forestComponentChoiceIsLeft at hLeft
    rw [dif_pos ő≥.2] at hLeft
    rw [hB] at hLeft
    cases hLeft
  ¬∑ have hsuppőī := őī.edges_supported e heőī
    have hsuppő≥ := ő≥.1.edges_supported e heő≥
    simp [FeynmanEdge.SupportedOn] at hsuppőī hsuppő≥
    have hDisjA : q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
    have hdisj : őī.Disjoint ő≥.1 := hDisjA hőīA ő≥.2 hőīő≥
    exact (Finset.disjoint_left.mp hdisj hsuppőī.1) hsuppő≥.1

/-- The left-selected carrier and the promoted genuine-forest carrier are
disjoint as finite component carriers. -/
private theorem forestComponentForestChoice_left_promotedForestComponents_disjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    Disjoint (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements
      (forestComponentChoicePromotedForestComponents q.1.1 q.2) := by
  classical
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
