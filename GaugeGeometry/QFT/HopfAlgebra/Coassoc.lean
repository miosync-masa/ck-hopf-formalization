private theorem forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest : p ő≥ (Finset.mem_attach A.elements ő≥) =
      forestCoproductChoice.forest B)
    {őī : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hőī : őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥) :
    őī.1 ‚ąą forestComponentChoicePromotedForestComponents A p := by
  classical
  -- Decompose outer.elements = Left ‚ą™ Promoted via simp (congr-aware)
  have hőīOuter :
      őī.1 ‚ąą (forestComponentChoiceLeftSubgraph A p).elements ‚ą™
        forestComponentChoicePromotedForestComponents A p := by
    have hőī0 := őī.2
    simp only [forestComponentForestChoiceOuterSubgraph_elements] at hőī0
    exact hőī0
  rcases Finset.mem_union.mp hőīOuter with hőīL | hőīP
  ¬∑ -- őī ‚ąą Left: derive őī ‚ąą A.elements and `p ‚ü®őī.1, _‚ü© ... = .left`
    simp only [forestComponentChoiceLeftSubgraph_elements] at hőīL
    rcases Finset.mem_filter.mp hőīL with ‚ü®hőīA, hIsLeft‚ü©
    -- sourcePartition őī.1 = ő≥.1, őī.vertices ‚äÜ ő≥.1.vertices, őī.IsNonempty
    have hsp :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA őī).1 = ő≥.1 :=
      forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
        A p hA hőī
    have hőīő≥ : őī.1.vertices ‚äÜ ő≥.1.vertices := by
      have h := forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
        A p hA őī
      rw [hsp] at h
      exact h
    have hőīNE : őī.1.IsNonempty := hCompOuter őī.1 őī.2
    -- őī ‚äÜ ő≥ in A.elements with hA disjoint ‚áí őī = ő≥ (as FeynmanSubgraph)
    rcases Finset.card_pos.mp hőīNE with ‚ü®v, hvőī‚ü©
    have hőīEq : őī.1 = ő≥.1 :=
      hA.eq_of_mem_vertices hőīA ő≥.2 hvőī (hőīő≥ hvőī)
    -- hIsLeft says `p ‚ü®őī.1, hőīA‚ü© ... = .left`. Convert subtype to ő≥.
    unfold forestComponentChoiceIsLeft at hIsLeft
    rw [dif_pos hőīA] at hIsLeft
    have hő≥Eq : (‚ü®őī.1, hőīA‚ü© : {x // x ‚ąą A.elements}) = ő≥ := Subtype.ext hőīEq
    -- substitute ő≥ into hIsLeft to get `p ő≥ ... = .left`, then conflict with hForest
    have hLeftAtő≥ :
        p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left := by
      rw [‚Üź hő≥Eq]; exact hIsLeft
    rw [hLeftAtő≥] at hForest
    cases hForest
  ¬∑ exact hőīP

/-- Forest-branch source equality (Sprint F1h): when `őī ‚ąą slotAt ő≥` lands on
the promoted side and is witnessed by a source `ő≥' ‚ąą A.elements` with promoted
forest `B'`, then `ő≥'.1 = ő≥.1`. The B'-vs-B identification is *not* claimed
here; only the source equality. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_promoted_source_eq_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {őī : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hőī : őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥)
    {ő≥' : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements}}
    {B' : AdmissibleSubgraph
        (repG (ő≥'.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥'.2))).toFeynmanGraph}
    (_hPő≥' : p ő≥' (Finset.mem_attach A.elements ő≥') =
        forestCoproductChoice.forest B')
    (hőīB' :
      őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥'.1
        (A.isConnectedDivergent_of_mem ő≥'.2) B').elements) :
    ő≥'.1 = ő≥.1 := by
  classical
  -- (a) sourcePartition őī.1 = ő≥.1 from slotAt membership
  have hsp :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p hA őī).1 = ő≥.1 :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_mem_slotAt
      A p hA hőī
  -- (b) őī.vertices ‚äÜ ő≥.1.vertices
  have hőīő≥ : őī.1.vertices ‚äÜ ő≥.1.vertices := by
    have h := forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p hA őī
    rw [hsp] at h
    exact h
  -- (c) őī.vertices ‚äÜ ő≥'.1.vertices via promoted witness
  have hőīő≥' : őī.1.vertices ‚äÜ ő≥'.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő≥'.1 (A.isConnectedDivergent_of_mem ő≥'.2) B' hőīB'
  -- (d) őī.IsNonempty + hA disjoint ‚áí ő≥'.1 = ő≥.1
  have hőīNE : őī.1.IsNonempty := hCompOuter őī.1 őī.2
  rcases Finset.card_pos.mp hőīNE with ‚ü®v, hvőī‚ü©
  exact hA.eq_of_mem_vertices ő≥'.2 ő≥.2 (hőīő≥' hvőī) (hőīő≥ hvőī)

/-- Forest-branch promoted retarget (Sprint F1i): when `őī ‚ąą slotAt ő≥` is
witnessed by a promoted source `(ő≥', B')`, F1h gives `ő≥'.1 = ő≥.1`.  After
`subst`, the witness `B'` becomes a forest at ő≥; the existential conclusion
records the ő≥-side data directly.  No `HEq`, no `B' = B`. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {őī : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements}}
    (hőī : őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥)
    {ő≥' : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements}}
    {B' : AdmissibleSubgraph
        (repG (ő≥'.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥'.2))).toFeynmanGraph}
    (hPő≥' : p ő≥' (Finset.mem_attach A.elements ő≥') =
        forestCoproductChoice.forest B')
    (hőīB' :
      őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥'.1
        (A.isConnectedDivergent_of_mem ő≥'.2) B').elements) :
    ‚ąÉ Bő≥ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
      p ő≥ (Finset.mem_attach A.elements ő≥) =
          forestCoproductChoice.forest Bő≥ ‚ąß
      őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) Bő≥).elements := by
  classical
  -- F1h: ő≥'.1 = ő≥.1
  have hSrc : ő≥'.1 = ő≥.1 :=
    forestComponentForestChoiceOuterSubgraph_slotAt_promoted_source_eq_of_forest
      A p hA ő≥ hCompOuter hőī hPő≥' hőīB'
  -- Lift to subtype equality and subst
  have hSrcSub : ő≥' = ő≥ := Subtype.ext hSrc
  subst hSrcSub
  -- Now `B' : AdmissibleSubgraph (repG (ő≥.1.toHopfGen ...)).toFeynmanGraph`
  -- and `hPő≥'`, `hőīB'` are stated at ő≥.
  exact ‚ü®B', hPő≥', hőīB'‚ü©

/-- 3-way classify (Sprint F1j): per source `ő≥`, `slotAt ő≥` is observed via a
disjunction matching `p ő≥`'s outcome.  Forest-side existence is placed
*inside* the `‚ąÄ őī` so the per-őī promoted witness from F1i is reusable; the
shared B is recovered later when uniqueness is wired in. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_classify
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    (p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left ‚ąß
       ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
         őī.1 = ő≥.1) ‚ą®
    (p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.right ‚ąß
       forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ) ‚ą®
    (‚ąÄ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
       ‚ąÉ Bő≥ : AdmissibleSubgraph
           (repG (ő≥.1.toHopfGen
             (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
         p ő≥ (Finset.mem_attach A.elements ő≥) =
             forestCoproductChoice.forest Bő≥ ‚ąß
         őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
           (A.isConnectedDivergent_of_mem ő≥.2) Bő≥).elements) := by
  classical
  -- Use the existing 3-way enumeration lemma to avoid motive-rewriting that
  -- contaminates the goal's `p ő≥ ...` references.
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p ő≥ (Finset.mem_attach A.elements ő≥)) with hChoice | hChoice | ‚ü®B, hChoice‚ü©
  ¬∑ -- left
    rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
      A p hA ő≥ hCompNE hChoice with ‚ü®őī, hőīEq, hőīSlot‚ü©
    exact Or.inl ‚ü®hChoice, őī, hőīSlot, hőīEq‚ü©
  ¬∑ -- right
    exact Or.inr (Or.inl ‚ü®hChoice,
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p hA ő≥ hCompOuter hChoice‚ü©)
  ¬∑ -- forest B
    refine Or.inr (Or.inr ?_)
    intro őī hőī
    have hProm : őī.1 ‚ąą forestComponentChoicePromotedForestComponents A p :=
      forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
        A p hA ő≥ hCompOuter hChoice hőī
    rcases forestComponentChoicePromotedForestComponents_mem_exists A p hProm
      with ‚ü®ő≥', B', hPő≥', hőīB'‚ü©
    exact forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
      A p hA ő≥ hCompOuter hőī hPő≥' hőīB'

/-- Forest-branch shared-B (Sprint F1k): when `p ő≥ = .forest B` is fixed by
the caller, every `őī ‚ąą slotAt ő≥` lies in the **same** promoted carrier
`promoted ő≥ B`.  This collapses the per-őī existential of F1i/F1j to the
externally supplied `B`. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest : p ő≥ (Finset.mem_attach A.elements ő≥) =
        forestCoproductChoice.forest B) :
    ‚ąÄ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
      őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B).elements := by
  classical
  intro őī hőī
  -- Promoted side via F1g
  have hProm : őī.1 ‚ąą forestComponentChoicePromotedForestComponents A p :=
    forestComponentForestChoiceOuterSubgraph_slotAt_mem_promoted_of_forest
      A p hA ő≥ hCompOuter hForest hőī
  -- Witness `(ő≥', B')` from mem_exists
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hProm
    with ‚ü®ő≥', B', hPő≥', hőīB'‚ü©
  -- F1i lifts to ő≥-side: ‚ąÉ Bő≥, p ő≥ ... = forest Bő≥ ‚ąß őī ‚ąą promoted ő≥ Bő≥
  rcases forestComponentForestChoiceOuterSubgraph_slotAt_promoted_exists_at_source
    A p hA ő≥ hCompOuter hőī hPő≥' hőīB' with ‚ü®Bő≥, hPBő≥, hőīBő≥‚ü©
  -- Shared B identification: hForest and hPBő≥ both speak about p ő≥ ...
  have hEqChoice : forestCoproductChoice.forest Bő≥ = forestCoproductChoice.forest B :=
    hPBő≥.symm.trans hForest
  cases hEqChoice
  exact hőīBő≥

/-- Reverse direction (Sprint F1l-1 weak form): if `slotAt ő≥` is empty, then
`p ő≥ ‚Č† .left`. Combined with a separate forest-exclusion (deferred), this
gives `p ő≥ = .right` outright; for now we only rule out the left branch. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_ne_left_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ) :
    p ő≥ (Finset.mem_attach A.elements ő≥) ‚Č† forestCoproductChoice.left := by
  intro hLeft
  rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
    A p hA ő≥ hCompNE hLeft with ‚ü®őī, _hőīEq, hőīSlot‚ü©
  rw [hEmpty] at hőīSlot
  exact (Finset.notMem_empty őī) hőīSlot

/-- Reverse direction (Sprint F1l-1, right outcome): if `slotAt ő≥` is empty
**and** the choice function lies in the strict core carrier, then `p ő≥ = .right`.
The forest branch is excluded by a `B`-nonempty argument scheduled for a
follow-up sprint; for now the right outcome is gated on a forest-exclusion
hypothesis `hForestExcluded`. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_eq_right_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ)
    (hForestExcluded :
      ‚ąÄ B : AdmissibleSubgraph
          (repG (ő≥.1.toHopfGen
            (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
        p ő≥ (Finset.mem_attach A.elements ő≥) ‚Č†
          forestCoproductChoice.forest B) :
    p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.right := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p ő≥ (Finset.mem_attach A.elements ő≥)) with hLeft | hRight | ‚ü®B, hForest‚ü©
  ¬∑ exact absurd hLeft
      (forestComponentForestChoiceOuterSubgraph_pő≥_ne_left_of_slotAt_empty
        A p hA ő≥ hCompNE hEmpty)
  ¬∑ exact hRight
  ¬∑ exact absurd hForest (hForestExcluded B)

/-- Forest-branch slot nonempty (Sprint F1l-2): if `p ‚ąą core` and
`p ő≥ = .forest B`, then `slotAt ő≥` has at least one element.  Together with
F1f-2 (right ‚áí slot empty) this gives the contrapositive needed by F1l-1. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest : p ő≥ (Finset.mem_attach A.elements ő≥) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥).Nonempty := by
  classical
  -- (1) Promoted ő≥ B is a proper disjoint admissible forest in G.
  have hPromProper :
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B ‚ąą
        G.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
      hp ő≥ hForest
  -- (2) Properness gives nonempty components and IsNonempty.
  have hPromNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B).IsNonempty :=
    properDisjointAdmissibleDivergentSubgraphs_isNonempty hPromProper
  have hPromCompNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B).HasNonemptyComponents :=
    G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hPromProper
  -- (3) Pick a witness őī' ‚ąą (Promoted ő≥ B).elements.
  rcases hPromNE with ‚ü®őī', hőī'Prom‚ü©
  -- (4) őī' lies in forestComponentChoicePromotedForestComponents A p.
  have hőī'Promoted :
      őī' ‚ąą forestComponentChoicePromotedForestComponents A p :=
    forestComponentChoicePromotedForestComponents_mem_of_forest A p ő≥ hForest hőī'Prom
  -- (5) Promoted ‚äÜ outer.elements, so őī' ‚ąą outer.elements.
  have hőī'Outer :
      őī' ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements := by
    rw [forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_right _ hőī'Promoted
  -- (6) őī'.vertices ‚äÜ ő≥.1.vertices via the promoted-vertex-subset lemma.
  have hőī'Sub : őī'.vertices ‚äÜ ő≥.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) B hőī'Prom
  -- (7) őī' is nonempty because Promoted ő≥ B has nonempty components.
  have hőī'NE : őī'.IsNonempty := hPromCompNE őī' hőī'Prom
  -- (8) sourcePartition (őī' as outer-subtype) = ő≥ via uniqueness.
  let őī'sub : {őī : FeynmanSubgraph G //
      őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements} :=
    ‚ü®őī', hőī'Outer‚ü©
  have hsp : (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p hA őī'sub).1 = ő≥.1 := by
    have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
      A p hA őī'sub hőī'NE ő≥.2 hőī'Sub
    exact this.symm
  -- (9) őī' ‚ąą slotAt ő≥.
  exact ‚ü®őī'sub,
    forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
      A p hA hsp‚ü©

/-- Strong reverse direction (Sprint F1l-3): under `hp ‚ąą core`, an empty slot
forces `p ő≥ = .right` outright.  Combines F1l-1b with F1l-2 (forest case
implies slot nonempty) to discharge the `hForestExcluded` hypothesis. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_eq_right_of_slotAt_empty_strong
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ) :
    p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.right := by
  refine forestComponentForestChoiceOuterSubgraph_pő≥_eq_right_of_slotAt_empty
    A p hA ő≥ hCompNE hEmpty ?_
  intro B hForest
  have hNonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := A) (p := p) hp hA ő≥ hForest
  rw [hEmpty] at hNonempty
  exact Finset.not_nonempty_empty hNonempty

/-- Reverse direction (Sprint F1l-4a): a self-vertex őī in `slotAt ő≥` rules
out `p ő≥ = .right`.  Pure contrapositive of F1f-2. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_ne_right_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1) :
    p ő≥ (Finset.mem_attach A.elements ő≥) ‚Č† forestCoproductChoice.right := by
  intro hRight
  rcases hSelf with ‚ü®őī, hőīSlot, _‚ü©
  have hEmpty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
      A p hA ő≥ hCompOuter hRight
  rw [hEmpty] at hőīSlot
  exact (Finset.notMem_empty őī) hőīSlot

/-- Reverse direction (Sprint F1l-4b): a self-vertex őī in `slotAt ő≥`,
combined with a forest-exclusion hypothesis, forces `p ő≥ = .left`.  The
forest case is left as an external hypothesis here; see F1l-4c (future) for
the full strong form once `hp ‚áí forest excluded` is wired. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_eq_left_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1)
    (hForestExcluded :
      ‚ąÄ B : AdmissibleSubgraph
          (repG (ő≥.1.toHopfGen
            (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
        p ő≥ (Finset.mem_attach A.elements ő≥) ‚Č†
          forestCoproductChoice.forest B) :
    p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p ő≥ (Finset.mem_attach A.elements ő≥)) with hLeft | hRight | ‚ü®B, hForest‚ü©
  ¬∑ exact hLeft
  ¬∑ exact absurd hRight
      (forestComponentForestChoiceOuterSubgraph_pő≥_ne_right_of_slotAt_self
        hA ő≥ hCompOuter hSelf)
  ¬∑ exact absurd hForest (hForestExcluded B)

/-- Reverse direction (Sprint F1m-1): if `slotAt ő≥` is nonempty and contains
no `self` element (no őī with őī.1 = ő≥.1), then `p ő≥` is on the forest branch.
This is the third observational handle paired with F1l-3 (right) and
F1l-4b (left), giving the full forward observation panel for `recoverAt`. -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_is_forest_of_slotAt_no_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNonempty :
      (forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥).Nonempty)
    (hNoSelf :
      ‚ąÄ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 ‚Č† ő≥.1) :
    ‚ąÉ B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen
          (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
      p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
    (p ő≥ (Finset.mem_attach A.elements ő≥)) with hLeft | hRight | ‚ü®B, hForest‚ü©
  ¬∑ -- left case: F1f-1 produces a self őī ‚ąą slotAt, contradicting hNoSelf
    rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
      A p hA ő≥ hCompNE hLeft with ‚ü®őī, hőīEq, hőīSlot‚ü©
    exact absurd hőīEq (hNoSelf őī hőīSlot)
  ¬∑ -- right case: F1f-2 forces slot = ‚ąÖ, contradicting hNonempty
    have hEmpty :=
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p hA ő≥ hCompOuter hRight
    rw [hEmpty] at hNonempty
    exact absurd hNonempty Finset.not_nonempty_empty
  ¬∑ -- forest case: provide B directly
    exact ‚ü®B, hForest‚ü©

/-- Observed choice (Sprint F1m-2): a `forestCoproductChoice` value derived
purely from `slotAt ő≥`'s shape.  Note this still depends on `p` indirectly
(via `slotAt`).  The full equality `observedChoice = p ő≥` is deferred. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph_observedChoice
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestCoproductChoice
      (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2)) := by
  classical
  by_cases hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ
  ¬∑ exact forestCoproductChoice.right
  ¬∑ by_cases hSelf :
        ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
          őī.1 = ő≥.1
    ¬∑ exact forestCoproductChoice.left
    ¬∑ have hNonempty :
          (forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥).Nonempty :=
        Finset.nonempty_iff_ne_empty.mpr hEmpty
      have hNoSelf :
          ‚ąÄ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
            őī.1 ‚Č† ő≥.1 := by
        intro őī hőī hőīEq
        exact hSelf ‚ü®őī, hőī, hőīEq‚ü©
      have hForest :=
        forestComponentForestChoiceOuterSubgraph_pő≥_is_forest_of_slotAt_no_self
          (A := A) (p := p) hA ő≥ hCompNE hCompOuter hNonempty hNoSelf
      exact forestCoproductChoice.forest (Classical.choose hForest)

/-- Spec lemma 1: `slotAt ő≥ = ‚ąÖ ‚áí observedChoice = .right`. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_right_of_slotAt_empty
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ = ‚ąÖ) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter = forestCoproductChoice.right := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_pos hEmpty]

/-- Spec lemma 2: a self őī in `slotAt ő≥` ‚áí observedChoice = .left. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_left_of_slotAt_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ ‚Č† ‚ąÖ)
    (hSelf :
      ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter = forestCoproductChoice.left := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_pos hSelf]

/-- Spec lemma 3: `slotAt ő≥` nonempty + no self ‚áí observedChoice is a forest. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_is_forest_of_nonempty_no_self
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ ‚Č† ‚ąÖ)
    (hNoSelf :
      ¬¨ ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1) :
    ‚ąÉ B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen
          (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
      forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter = forestCoproductChoice.forest B := by
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_neg hNoSelf]
  exact ‚ü®_, rfl‚ü©

/-- Casewise spec (Sprint F1m-3, right): if `p ő≥ = .right` then
`observedChoice = p ő≥`.  Forest-side exclusion is not needed because the
observation goes through F1f-2 (right ‚áí slot = ‚ąÖ). -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_right
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hRight :
      p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.right) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter =
      p ő≥ (Finset.mem_attach A.elements ő≥) := by
  have hEmpty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
      A p hA ő≥ hCompOuter hRight
  rw [forestComponentForestChoiceOuterSubgraph_observedChoice_eq_right_of_slotAt_empty
        p hA ő≥ hCompNE hCompOuter hEmpty, hRight]

/-- Casewise spec (Sprint F1m-3, left): if `p ő≥ = .left` then
`observedChoice = p ő≥`.  Forest-side exclusion is not needed: the self
witness from F1f-1 routes the observation through `_eq_left_of_slotAt_self`. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_left
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hLeft :
      p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter =
      p ő≥ (Finset.mem_attach A.elements ő≥) := by
  rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
    A p hA ő≥ hCompNE hLeft with ‚ü®őī, hőīEq, hőīSlot‚ü©
  have hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ ‚Č† ‚ąÖ := by
    intro hEmpty
    rw [hEmpty] at hőīSlot
    exact (Finset.notMem_empty őī) hőīSlot
  have hSelf :
      ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1 := ‚ü®őī, hőīSlot, hőīEq‚ü©
  rw [forestComponentForestChoiceOuterSubgraph_observedChoice_eq_left_of_slotAt_self
        p hA ő≥ hCompNE hCompOuter hNotEmpty hSelf, hLeft]

/-- Edge-count upper bound (Sprint F1n-2a): for a pairwise-disjoint admissible
subgraph, the aggregate internal-edge count is bounded above by the ambient
graph's.  Foundation lemma for the strictness chain (next: complement
positive ‚áí strict, then promoted-component edge bound, then `őī ‚Č† ő≥`). -/
private theorem admissibleSubgraph_internalEdges_card_le_ambient_of_pairwise
    {G : FeynmanGraph} (B : AdmissibleSubgraph G)
    (hB : B.IsPairwiseDisjoint) :
    B.internalEdges.card ‚Č§ G.internalEdges.card :=
  Multiset.card_le_card
    (admissibleSubgraph_internalEdges_le_of_pairwise B hB)

/-- Strict edge-count drop (Sprint F1n-2b): if `B` has a positive complement,
its aggregate internal-edge count is strictly less than the ambient's.
Combines F1n-2a with `Multiset.card_sub` on the complement definition. -/
private theorem admissibleSubgraph_internalEdges_card_lt_ambient_of_complement_pos
    {G : FeynmanGraph} (B : AdmissibleSubgraph G)
    (hB : B.IsPairwiseDisjoint)
    (hBComp : 0 < B.complementEdges.card) :
    B.internalEdges.card < G.internalEdges.card := by
  have hle : B.internalEdges ‚Č§ G.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise B hB
  -- B.complementEdges = G.internalEdges - B.internalEdges
  have hCompEq :
      B.complementEdges.card = G.internalEdges.card - B.internalEdges.card := by
    show (G.internalEdges - B.internalEdges).card = _
    exact Multiset.card_sub hle
  rw [hCompEq] at hBComp
  -- 0 < G.card - B.card  ‚áí  B.card < G.card
  exact Nat.lt_of_sub_pos hBComp

/-- Promoted-component edge bound (Sprint F1n-2c): a promoted forest component
őī has internal-edge count bounded by the aggregate B (transported back to
the component graph).  Goes via:
  1. őī ‚ąą promoted ‚áí őī = promote ő≥ ő∑.1 for some ő∑ ‚ąą RepToComponent B
  2. őī.internalEdges = ő∑.1.internalEdges (rfl, via promote)
  3. ő∑.1.internalEdges ‚Č§ (RepToComponent B).internalEdges (aggregate-le)
  4. (RepToComponent B).internalEdges ‚Č§ ... = B.internalEdges via the perm-map
     transport (mapPermAdmissibleSubgraphPreimage_internalEdges_map). -/
private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_card_le_source
    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent)
    (B : AdmissibleSubgraph (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph)
    (hBcDisj :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B).IsPairwiseDisjoint)
    {őī : FeynmanSubgraph G}
    (hőī :
      őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥ hő≥ B).elements) :
    őī.internalEdges.card ‚Č§ B.internalEdges.card := by
  classical
  -- Step 1: promote step decomposition.
  unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hőī
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hőī
  rcases Finset.mem_image.mp hőī with ‚ü®ő∑, _hő∑A, rfl‚ü©
  -- Step 3: ő∑.1.internalEdges ‚Č§ (RepToComponent ő≥ hő≥ B).internalEdges.
  have hLe :
      ő∑.1.internalEdges ‚Č§
        (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B).internalEdges :=
    feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem
      (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B) hBcDisj ő∑.2
  -- Step 4: card transport via mapPerm preimage map.
  have hMap :=
    mapPermAdmissibleSubgraphPreimage_internalEdges_map
      (feynmanSubgraphToHopfGenRepPerm_spec ő≥ hő≥) B
  have hBcCard :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B).internalEdges.card
        = B.internalEdges.card := by
    have := congrArg Multiset.card hMap
    simpa [Multiset.card_map] using this
  -- őī.internalEdges = ő∑.1.internalEdges (via @[simp]); chain card_le_card + hBcCard.
  simp only [feynmanSubgraphPromote_internalEdges]
  exact (Multiset.card_le_card hLe).trans hBcCard.le

/-- Class invariance specialize (Sprint F1n-2d): the canonical representative
`repG (ő≥.toHopfGen hő≥)` has the same `internalEdges.card` as `ő≥` itself.
Wrapper combining `repG_internalEdges_card_eq_of_toClass` with
`FeynmanSubgraph.toHopfGen_val`. -/
private theorem repG_toHopfGen_internalEdges_card_eq_source
    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent) :
    (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph.internalEdges.card =
      ő≥.internalEdges.card := by
  have h := repG_internalEdges_card_eq_of_toClass (ő≥.toHopfGen hő≥)
    (G' := ő≥.toFeynmanGraph) (FeynmanSubgraph.toHopfGen_val hő≥)
  simpa using h

/-- Forest-promoted self exclusion (Sprint F1n-2e): a promoted forest
component `őī ‚ąą promoted ő≥ B` is never equal to the source component
`ő≥.1` itself.  This is the bridge from F1n-2a/2b/2c/2d to the recoverAt
forest case in F1m-3c.  Proof chain:
  őī.card ‚Č§ B.card  (F1n-2c via Bc.IsPairwiseDisjoint)
        < (repG (ő≥.toHopfGen)).card  (F1n-2b via complement positive)
        = ő≥.1.card  (F1n-2d).
Hence őī.card < ő≥.1.card, contradicting `őī = ő≥.1`. -/
private theorem forestComponentChoicePromotedForestComponents_ne_source
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest :
      p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B)
    {őī : FeynmanSubgraph G}
    (hőī :
      őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B).elements) :
    őī ‚Č† ő≥.1 := by
  -- Local abbreviation for the connectedness witness (a Prop, so harmless).
  let hő≥CD : ő≥.1.IsConnectedDivergent := A.isConnectedDivergent_of_mem ő≥.2
  -- Step 1: B ‚ąą properDisjoint... in (repG (ő≥.1.toHopfGen hő≥CD)).toFeynmanGraph
  have hBProper :
      B ‚ąą ((repG (ő≥.1.toHopfGen hő≥CD)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_forest_mem_properDisjoint_of_core_mem
      hp ő≥ hForest
  -- Step 2: B.IsPairwiseDisjoint and complement positive
  have hBDisj : B.IsPairwiseDisjoint :=
    ((repG (ő≥.1.toHopfGen hő≥CD)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hBProper
  have hBComp : 0 < B.complementEdges.card :=
    forestComponentChoice_forest_complementEdges_positive_of_core_mem
      hp ő≥ hForest
  -- Step 3: Bc.IsPairwiseDisjoint via the perm-preimage transport
  have hBcProper :
      feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1 hő≥CD B ‚ąą
        ő≥.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
      ő≥.1 hő≥CD hBProper
  have hBcDisj :
      (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
        hő≥CD B).IsPairwiseDisjoint :=
    ő≥.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hBcProper
  -- Step 4: chain F1n-2c, F1n-2b, F1n-2d
  have h2c : őī.internalEdges.card ‚Č§ B.internalEdges.card :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges_card_le_source
      ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) B hBcDisj hőī
  have h2b :
      B.internalEdges.card <
        (repG (ő≥.1.toHopfGen
          (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph.internalEdges.card :=
    admissibleSubgraph_internalEdges_card_lt_ambient_of_complement_pos
      B hBDisj hBComp
  have h2d :
      (repG (ő≥.1.toHopfGen
        (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph.internalEdges.card =
      ő≥.1.internalEdges.card :=
    repG_toHopfGen_internalEdges_card_eq_source ő≥.1
      (A.isConnectedDivergent_of_mem ő≥.2)
  -- Step 5: assemble őī.card < ő≥.1.card and rule out őī = ő≥.1
  have hLt : őī.internalEdges.card < ő≥.1.internalEdges.card := by
    rw [‚Üź h2d]
    exact lt_of_le_of_lt h2c h2b
  intro hEq
  rw [hEq] at hLt
  exact (Nat.lt_irrefl _) hLt

/-- Casewise spec (Sprint F1m-3c, forest): if `p ő≥ = .forest B` and `hp ‚ąą core`,
then `observedChoice = p ő≥`.  Uses F1l-2 (slot nonempty), F1k + F1n-2e
(no self in slot), and Classical.choose_spec to pin the chosen B' to B. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    {B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest :
      p ő≥ (Finset.mem_attach A.elements ő≥) =
        forestCoproductChoice.forest B) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter =
      p ő≥ (Finset.mem_attach A.elements ő≥) := by
  classical
  -- Step 1: slot nonempty (F1l-2)
  have hNonempty :
      (forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥).Nonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := A) (p := p) hp hA ő≥ hForest
  have hNotEmpty :
      forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥ ‚Č† ‚ąÖ :=
    Finset.nonempty_iff_ne_empty.mp hNonempty
  -- Step 2: no self őī in slot (F1k for promoted membership, F1n-2e for ne_source)
  have hNoSelf :
      ¬¨ ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
          őī.1 = ő≥.1 := by
    rintro ‚ü®őī, hőīSlot, hőīEq‚ü©
    have hőīPromoted :=
      forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
        A p hA ő≥ hCompOuter hForest őī hőīSlot
    exact forestComponentChoicePromotedForestComponents_ne_source
      hp ő≥ hForest hőīPromoted hőīEq
  -- Step 3: unfold observedChoice into the forest branch directly so we can
  -- access the underlying Classical.choose witness and use choose_spec.
  unfold forestComponentForestChoiceOuterSubgraph_observedChoice
  rw [dif_neg hNotEmpty, dif_neg hNoSelf]
  -- Goal: forestCoproductChoice.forest (Classical.choose ...) = p ő≥ ...
  -- Build the witness predicate that Classical.choose was applied to:
  set hForestEx :=
    forestComponentForestChoiceOuterSubgraph_pő≥_is_forest_of_slotAt_no_self
      (A := A) (p := p) hA ő≥ hCompNE hCompOuter hNonempty
      (fun őī hőī hEq => hNoSelf ‚ü®őī, hőī, hEq‚ü©)
  -- Classical.choose_spec: p ő≥ ... = forest (Classical.choose hForestEx)
  have hSpec := hForestEx.choose_spec
  -- Combine with hForest: forest B = forest (Classical.choose hForestEx)
  rw [‚Üź hSpec, hForest]

/-- Full observed-choice spec (Sprint F1m-4): under `hp ‚ąą core`, the
slot-shape-based `observedChoice` agrees with the underlying `p ő≥` for every
ő≥.  Combines F1m-3a/3b/3c via `forestCoproductChoice_eq_left_or_right_or_forest`.
This is the bridge that turns `observedChoice` into a faithful witness of
`p ő≥` at the per-ő≥ level, ready for the upcoming Pi-lift. -/
private theorem forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents) :
    forestComponentForestChoiceOuterSubgraph_observedChoice
        p hA ő≥ hCompNE hCompOuter =
      p ő≥ (Finset.mem_attach A.elements ő≥) := by
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p ő≥ (Finset.mem_attach A.elements ő≥)) with hLeft | hRight | ‚ü®B, hForest‚ü©
  ¬∑ exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_left
      hA ő≥ hCompNE hCompOuter hLeft
  ¬∑ exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_right
      hA ő≥ hCompNE hCompOuter hRight
  ¬∑ exact forestComponentForestChoiceOuterSubgraph_observedChoice_eq_pő≥_of_forest
      (A := A) (p := p) hp hA ő≥ hCompNE hCompOuter hForest

