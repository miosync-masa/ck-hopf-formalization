    (hγ : γ ∈ q.1.1.elements) :
    γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∨
      γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements := by
  classical
  let γs : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements} := ⟨γ, hγ⟩
  have hp :
      q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hNoForest : ¬ forestComponentChoiceHasForest q.1.1 q.2 := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp
    exact (Finset.mem_filter.mp hp).2
  rcases forestCoproductChoice_eq_left_or_right_or_forest
      (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγ))
      (q.2 γs (Finset.mem_attach q.1.1.elements γs)) with
    hLeft | hRightOrForest
  · left
    rw [forestComponentChoiceLeftSubgraph_elements]
    refine Finset.mem_filter.mpr ⟨hγ, ?_⟩
    unfold forestComponentChoiceIsLeft
    rw [dif_pos hγ]
    simpa [γs] using hLeft
  · rcases hRightOrForest with hRight | hForest
    · right
      rw [forestComponentChoiceRightSubgraph_elements]
      refine Finset.mem_filter.mpr ⟨hγ, ?_⟩
      unfold forestComponentChoiceIsRight
      rw [dif_pos hγ]
      simpa [γs] using hRight
    · rcases hForest with ⟨B, hB⟩
      exact False.elim (hNoForest ⟨γs, B, by simpa [γs] using hB⟩)

private theorem forestComponentMixedBoundary_left_union_right_elements
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
        (forestComponentChoiceRightSubgraph q.1.1 q.2).elements =
      q.1.1.elements := by
  ext γ
  constructor
  · intro hγ
    rcases Finset.mem_union.mp hγ with hγL | hγR
    · exact forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hγL
    · exact forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 hγR
  · intro hγ
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ hγ with
      hγL | hγR
    · exact Finset.mem_union_left _ hγL
    · exact Finset.mem_union_right _ hγR

private theorem forestComponentMixedBoundary_left_union_right_vertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).vertices ∪
        (forestComponentChoiceRightSubgraph q.1.1 q.2).vertices =
      q.1.1.vertices := by
  ext v
  constructor
  · intro hv
    rcases Finset.mem_union.mp hv with hvL | hvR
    · rcases AdmissibleSubgraph.mem_vertices.mp hvL with ⟨γ, hγ, hvγ⟩
      exact AdmissibleSubgraph.mem_vertices.mpr
        ⟨γ, forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hγ,
          hvγ⟩
    · rcases AdmissibleSubgraph.mem_vertices.mp hvR with ⟨γ, hγ, hvγ⟩
      exact AdmissibleSubgraph.mem_vertices.mpr
        ⟨γ, forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 hγ,
          hvγ⟩
  · intro hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ⟨γ, hγ, hvγ⟩
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ hγ with
      hγL | hγR
    · exact Finset.mem_union_left _
        (AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hγL, hvγ⟩)
    · exact Finset.mem_union_right _
        (AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hγR, hvγ⟩)

private theorem forestComponentMixedBoundary_left_union_right_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    q.1.1.internalEdges =
      (forestComponentChoiceLeftSubgraph q.1.1 q.2).internalEdges +
        (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges := by
  classical
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  have hUnion : L.elements ∪ R.elements = q.1.1.elements := by
    simpa [L, R] using
      forestComponentMixedBoundary_left_union_right_elements g q hq
  have hDisj : Disjoint L.elements R.elements := by
    rw [Finset.disjoint_left]
    intro γ hγL hγR
    exact forestComponentChoiceRightSubgraph_not_mem_left q.1.1 q.2 hγR hγL
  unfold AdmissibleSubgraph.internalEdges
  rw [← hUnion]
  rw [Finset.sum_union hDisj]

private theorem forestComponentMixedBoundary_right_internalEdges_le_left_complement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges ≤
      (forestComponentChoiceLeftSubgraph q.1.1 q.2).complementEdges := by
  classical
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  have hA_le : q.1.1.internalEdges ≤ (repG g).toFeynmanGraph.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise q.1.1 hDisj
  have hSplit :
      q.1.1.internalEdges = L.internalEdges + R.internalEdges := by
    simpa [L, R] using
      forestComponentMixedBoundary_left_union_right_internalEdges g q hq
  change R.internalEdges ≤ L.complementEdges
  rw [Multiset.le_iff_count]
  intro e
  unfold AdmissibleSubgraph.complementEdges
  rw [Multiset.count_sub]
  have hCountA : q.1.1.internalEdges.count e ≤
      (repG g).toFeynmanGraph.internalEdges.count e :=
    Multiset.count_le_of_le e hA_le
  have hCountSplit :
      q.1.1.internalEdges.count e =
        L.internalEdges.count e + R.internalEdges.count e := by
    simpa [Multiset.count_add] using congrArg (Multiset.count e) hSplit
  omega

/-- The split-star assignment for the mixed-boundary actual right contraction:
left components keep the outer contraction stars, while right components use
the canonical stars of their retargeted quotient-side components. -/
private noncomputable def forestComponentMixedBoundarySplitStarOf
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    FeynmanSubgraph (repG g).toFeynmanGraph → VertexId :=
  fun γ =>
    if hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements then
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2 γ
    else if hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements then
      FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g
          (forestComponentMixedBoundaryOuterIndex g q hq))
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq)
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
          g q hq)
        (admissibleSubgraphRetargetSubgraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          γ
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR))
    else
      q.1.1.componentFreshStar γ

@[simp] private theorem forestComponentMixedBoundarySplitStarOf_left
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    forestComponentMixedBoundarySplitStarOf g q hq γ =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2 γ := by
  unfold forestComponentMixedBoundarySplitStarOf
  rw [dif_pos hγL]

@[simp] private theorem forestComponentMixedBoundarySplitStarOf_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    forestComponentMixedBoundarySplitStarOf g q hq γ =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g
          (forestComponentMixedBoundaryOuterIndex g q hq))
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq)
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
          g q hq)
        (admissibleSubgraphRetargetSubgraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          γ
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR)) := by
  have hnotL :
      γ ∉ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements :=
    forestComponentChoiceRightSubgraph_not_mem_left q.1.1 q.2 hγR
  unfold forestComponentMixedBoundarySplitStarOf
  rw [dif_neg hnotL, dif_pos hγR]

/-- Left-selected mixed components receive genuinely fresh original-ambient
stars from the outer forest contraction. -/
private theorem forestComponentMixedBoundarySplitStarOf_left_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    forestComponentMixedBoundarySplitStarOf g q hq γ ∉
      (repG g).toFeynmanGraph.vertices := by
  have hFresh :
      (forestComponentMixedBoundaryOuterIndex g q hq).1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  rw [forestComponentMixedBoundarySplitStarOf_left g q hq hγL]
  exact hFresh.fresh (by simpa [forestComponentMixedBoundaryOuterIndex_val] using hγL)

private theorem freshVertex_le_componentFreshStar
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (γ : FeynmanSubgraph G) :
    FeynmanGraph.freshVertex G.vertices ≤ A.componentFreshStar γ := by
  unfold AdmissibleSubgraph.componentFreshStar
  exact Nat.le_add_right _ _

private theorem lt_freshVertex_of_mem {V : Finset VertexId} {v : VertexId}
    (hv : v ∈ V) :
    v < FeynmanGraph.freshVertex V := by
  unfold FeynmanGraph.freshVertex
  exact Nat.lt_succ_of_le (Finset.le_sup (f := id) hv)

private theorem not_mem_of_freshVertex_le {V : Finset VertexId} {v : VertexId}
    (hv : FeynmanGraph.freshVertex V ≤ v) :
    v ∉ V := by
  intro hmem
  exact (Nat.not_lt_of_ge hv) (lt_freshVertex_of_mem hmem)

private theorem forestComponentMixedBoundary_left_star_mem_outer_quotient_vertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2 γ ∈
      (forestOuterActualQuotientGraph g
        (forestComponentMixedBoundaryOuterIndex g q hq)).vertices := by
  change
    (forestComponentMixedBoundaryOuterIndex g q hq).1.componentFreshStar γ ∈
      ((forestComponentMixedBoundaryOuterIndex g q hq).1.contractWithStars
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)).vertices
  rw [AdmissibleSubgraph.contractWithStars_vertices]
  refine Finset.mem_union.mpr (Or.inr ?_)
  rw [AdmissibleSubgraph.mem_starVertices]
  exact ⟨γ, by simpa [forestComponentMixedBoundaryOuterIndex_val] using hγL, rfl⟩

private theorem forestComponentMixedBoundary_left_star_ge_original_freshVertex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph) :
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2 γ := by
  change
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      (forestComponentMixedBoundaryOuterIndex g q hq).1.componentFreshStar γ
  exact freshVertex_le_componentFreshStar
    (forestComponentMixedBoundaryOuterIndex g q hq).1 γ

private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR) ∈
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq).elements := by
  change
    admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ
        ((forestComponentMixedBoundaryRightRetargetCertificateCanonical
          g q hq).edge_le γ hγR) ∈
      ((forestComponentChoiceRightSubgraph q.1.1 q.2).elements.attach.image
        fun γ =>
          admissibleSubgraphRetargetSubgraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentMixedBoundaryOuterIndex g q hq).1
              (forestComponentMixedBoundaryOuterIndex g q hq).2)
            γ.1
            ((forestComponentMixedBoundaryRightRetargetCertificateCanonical
              g q hq).edge_le γ.1 γ.2))
  exact Finset.mem_image.mpr
    ⟨⟨γ, hγR⟩, Finset.mem_attach _ _, rfl⟩

private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentMixedBoundaryOuterIndex g q hq))}
    (hδ :
      δ ∈
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq).elements) :
    ∃ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements},
      δ =
        admissibleSubgraphRetargetSubgraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          γ.1
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1 γ.2) := by
  change δ ∈
    ((forestComponentChoiceRightSubgraph q.1.1 q.2).elements.attach.image
      fun γ =>
        admissibleSubgraphRetargetSubgraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          γ.1
          ((forestComponentMixedBoundaryRightRetargetCertificateCanonical
            g q hq).edge_le γ.1 γ.2)) at hδ
  rcases Finset.mem_image.mp hδ with ⟨γ, _hγ, rfl⟩
  exact ⟨γ, rfl⟩

private theorem forestComponentMixedBoundarySplitStarOf_right_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    forestComponentMixedBoundarySplitStarOf g q hq γ ∉
      (repG g).toFeynmanGraph.vertices := by
  let Q :=
    forestOuterActualQuotientGraph g
      (forestComponentMixedBoundaryOuterIndex g q hq)
  let δ :=
    admissibleSubgraphRetargetSubgraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (forestComponentMixedBoundaryOuterIndex g q hq).2)
      γ
      (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR)
  have hp :
      q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  rcases (mem_forestComponentMixedBoundaryChoiceCoreIndex_hasLeft_right hp).1 with
    ⟨γL, hγLChoice⟩
  have hγL :
      γL.1 ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements := by
    rw [forestComponentChoiceLeftSubgraph_elements]
    refine Finset.mem_filter.mpr ⟨γL.2, ?_⟩
    unfold forestComponentChoiceIsLeft
    rw [dif_pos γL.2]
    exact hγLChoice
  have hLeftMem :
      FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2 γL.1 ∈
        Q.vertices := by
    simpa [Q] using
      forestComponentMixedBoundary_left_star_mem_outer_quotient_vertices
        g q hq hγL
  have hLeftGe :
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2 γL.1 :=
    forestComponentMixedBoundary_left_star_ge_original_freshVertex
      g q hq γL.1
  have hLeftLtQ :
      FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2 γL.1 <
        FeynmanGraph.freshVertex Q.vertices :=
    lt_freshVertex_of_mem hLeftMem
  have hQle :
      FeynmanGraph.freshVertex Q.vertices ≤
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq).componentFreshStar δ := by
    simpa [Q, δ] using
      freshVertex_le_componentFreshStar
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq)
        δ
  have hOrigLe :
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        forestComponentMixedBoundarySplitStarOf g q hq γ := by
    rw [forestComponentMixedBoundarySplitStarOf_right g q hq hγR]
    change
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq).componentFreshStar δ
    exact Nat.le_trans hLeftGe
      (Nat.le_trans (Nat.le_of_lt hLeftLtQ) hQle)
  exact not_mem_of_freshVertex_le hOrigLe

private theorem forestComponentMixedBoundarySplitStarOf_isFresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    q.1.1.IsFreshStarAssignment
      (forestComponentMixedBoundarySplitStarOf g q hq) := by
  classical
  constructor
  · intro γ hγ
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ hγ with
      hγL | hγR
    · exact forestComponentMixedBoundarySplitStarOf_left_fresh g q hq hγL
    · exact forestComponentMixedBoundarySplitStarOf_right_fresh g q hq hγR
  · intro γ₁ hγ₁ γ₂ hγ₂ hstar
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ₁ hγ₁ with
      hγ₁L | hγ₁R
    · rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ₂ hγ₂ with
        hγ₂L | hγ₂R
      · have hFreshOuter :
            (forestComponentMixedBoundaryOuterIndex g q hq).1.IsFreshStarAssignment
              (FeynmanGraph.admissibleForestCanonicalStarOf
                (repG g).toFeynmanGraph
                (forestComponentMixedBoundaryOuterIndex g q hq).1
                (forestComponentMixedBoundaryOuterIndex g q hq).2) :=
          FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2
        apply hFreshOuter.eq_of_star_eq
        · simpa [forestComponentMixedBoundaryOuterIndex_val] using hγ₁L
        · simpa [forestComponentMixedBoundaryOuterIndex_val] using hγ₂L
        · simpa [forestComponentMixedBoundarySplitStarOf_left g q hq hγ₁L,
            forestComponentMixedBoundarySplitStarOf_left g q hq hγ₂L] using hstar
      · let Q :=
            forestOuterActualQuotientGraph g
              (forestComponentMixedBoundaryOuterIndex g q hq)
        have hLeftMem :
            forestComponentMixedBoundarySplitStarOf g q hq γ₁ ∈ Q.vertices := by
          simpa [Q, forestComponentMixedBoundarySplitStarOf_left g q hq hγ₁L] using
            forestComponentMixedBoundary_left_star_mem_outer_quotient_vertices
              g q hq hγ₁L
        have hFreshQ :
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
              g q hq).IsFreshStarAssignment
              (FeynmanGraph.admissibleForestCanonicalStarOf
                Q
                (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                  g q hq)
                (by
                  simpa [Q] using
                    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                      g q hq)) := by
          exact
            FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
              Q
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                g q hq)
              (by
                simpa [Q] using
                  forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                    g q hq)
        have hRightFresh :
            forestComponentMixedBoundarySplitStarOf g q hq γ₂ ∉ Q.vertices := by
          rw [forestComponentMixedBoundarySplitStarOf_right g q hq hγ₂R]
          exact hFreshQ.fresh
            (by
              simpa [Q] using
                forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
                  g q hq hγ₂R)
        exact False.elim (hRightFresh (by simpa [hstar] using hLeftMem))
    · rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ₂ hγ₂ with
        hγ₂L | hγ₂R
      · let Q :=
            forestOuterActualQuotientGraph g
              (forestComponentMixedBoundaryOuterIndex g q hq)
        have hLeftMem :
            forestComponentMixedBoundarySplitStarOf g q hq γ₂ ∈ Q.vertices := by
          simpa [Q, forestComponentMixedBoundarySplitStarOf_left g q hq hγ₂L] using
            forestComponentMixedBoundary_left_star_mem_outer_quotient_vertices
              g q hq hγ₂L
        have hFreshQ :
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
              g q hq).IsFreshStarAssignment
              (FeynmanGraph.admissibleForestCanonicalStarOf
                Q
                (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                  g q hq)
                (by
                  simpa [Q] using
                    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                      g q hq)) := by
          exact
            FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
              Q
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                g q hq)
              (by
                simpa [Q] using
                  forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                    g q hq)
        have hRightFresh :
            forestComponentMixedBoundarySplitStarOf g q hq γ₁ ∉ Q.vertices := by
          rw [forestComponentMixedBoundarySplitStarOf_right g q hq hγ₁R]
          exact hFreshQ.fresh
            (by
              simpa [Q] using
                forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
                  g q hq hγ₁R)
        exact False.elim (hRightFresh (by simpa [hstar.symm] using hLeftMem))
      · let Q :=
            forestOuterActualQuotientGraph g
              (forestComponentMixedBoundaryOuterIndex g q hq)
        let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
        let starOf :=
          FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2
        let δ₁ :=
          admissibleSubgraphRetargetSubgraph
            Aout starOf γ₁
            (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₁ hγ₁R)
        let δ₂ :=
          admissibleSubgraphRetargetSubgraph
            Aout starOf γ₂
            (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ₂ hγ₂R)
        have hFreshQ :
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
              g q hq).IsFreshStarAssignment
              (FeynmanGraph.admissibleForestCanonicalStarOf
                Q
                (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                  g q hq)
                (by
                  simpa [Q] using
                    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                      g q hq)) := by
          exact
            FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
              Q
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                g q hq)
              (by
                simpa [Q] using
                  forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                    g q hq)
        have hδeq : δ₁ = δ₂ := by
          apply hFreshQ.eq_of_star_eq
          · simpa [Q, Aout, starOf, δ₁] using
              forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
                g q hq hγ₁R
          · simpa [Q, Aout, starOf, δ₂] using
              forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
                g q hq hγ₂R
          · simpa [Q, Aout, starOf, δ₁, δ₂,
              forestComponentMixedBoundarySplitStarOf_right g q hq hγ₁R,
              forestComponentMixedBoundarySplitStarOf_right g q hq hγ₂R] using hstar
        have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
              q.1.2
        have hV :
            ∀ η ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
              ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
          intro η hη v hv
          dsimp [Aout]
          exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
            q.1.1 q.2 hDisjA hη hv
        have hinj :=
          admissibleSubgraphRetarget_injective_of_not_mem
            Aout starOf
            (forestComponentChoiceRightSubgraph q.1.1 q.2)
            (fun η hη =>
              forestComponentMixedBoundaryRightRetarget_edge_le g q hq η hη)
            hV
        have hSubtype :
            (⟨γ₁, hγ₁R⟩ :
              {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
                γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements}) =
            ⟨γ₂, hγ₂R⟩ := by
          apply hinj
          simpa [Aout, starOf, δ₁, δ₂] using hδeq
        exact congrArg Subtype.val hSubtype

private theorem forestComponentMixedBoundary_splitStar_starVertices_eq_union
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    q.1.1.starVertices (forestComponentMixedBoundarySplitStarOf g q hq) =
      (forestComponentChoiceLeftSubgraph q.1.1 q.2).starVertices
          (forestComponentMixedBoundarySplitStarOf g q hq) ∪
        (forestComponentChoiceRightSubgraph q.1.1 q.2).starVertices
          (forestComponentMixedBoundarySplitStarOf g q hq) := by
  ext v
  constructor
  · intro hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγ, rfl⟩
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ hγ with
      hγL | hγR
    · exact Finset.mem_union_left _
        (AdmissibleSubgraph.mem_starVertices.mpr ⟨γ, hγL, rfl⟩)
    · exact Finset.mem_union_right _
        (AdmissibleSubgraph.mem_starVertices.mpr ⟨γ, hγR, rfl⟩)
  · intro hv
    rw [AdmissibleSubgraph.mem_starVertices]
    rcases Finset.mem_union.mp hv with hvL | hvR
    · rw [AdmissibleSubgraph.mem_starVertices] at hvL
      rcases hvL with ⟨γ, hγL, rfl⟩
      exact ⟨γ, forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hγL,
        rfl⟩
    · rw [AdmissibleSubgraph.mem_starVertices] at hvR
      rcases hvR with ⟨γ, hγR, rfl⟩
      exact ⟨γ, forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 hγR,
        rfl⟩

private theorem forestComponentMixedBoundary_left_splitStar_starVertices_eq_outer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).starVertices
        (forestComponentMixedBoundarySplitStarOf g q hq) =
      (forestComponentChoiceLeftSubgraph q.1.1 q.2).starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2) := by
  ext v
  constructor <;> intro hv
  · rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγL, rfl⟩
    rw [forestComponentMixedBoundarySplitStarOf_left g q hq hγL]
    exact AdmissibleSubgraph.mem_starVertices.mpr ⟨γ, hγL, rfl⟩
  · rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγL, rfl⟩
    rw [← forestComponentMixedBoundarySplitStarOf_left g q hq hγL]
    exact AdmissibleSubgraph.mem_starVertices.mpr ⟨γ, hγL, rfl⟩

private theorem forestComponentMixedBoundary_right_splitStar_starVertices_eq_actualRight
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceRightSubgraph q.1.1 q.2).starVertices
        (forestComponentMixedBoundarySplitStarOf g q hq) =
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq).starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)) := by
  ext v
  constructor
  · intro hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγR, rfl⟩
    let δ :=
      admissibleSubgraphRetargetSubgraph
        (forestComponentMixedBoundaryOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2)
        γ
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR)
    rw [forestComponentMixedBoundarySplitStarOf_right g q hq hγR]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨δ, by
        simpa [δ] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
            g q hq hγR, rfl⟩
  · intro hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨δ, hδ, rfl⟩
    rcases
        forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_exists
          g q hq hδ with
      ⟨γ, rfl⟩
    rw [← forestComponentMixedBoundarySplitStarOf_right g q hq γ.2]
    exact AdmissibleSubgraph.mem_starVertices.mpr ⟨γ.1, γ.2, rfl⟩

private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).vertices =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).vertices := by
  classical
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  have hV :
      ∀ η ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
        ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
    intro η hη v hv
    dsimp [Aout]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hη hv
  ext v
  constructor
  · intro hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ⟨δ, hδ, hvδ⟩
    rcases
        forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_exists
          g q hq hδ with
      ⟨γ, rfl⟩
    have hVeq :=
      admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        Aout starOf γ.1
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1 γ.2)
        (hV γ.1 γ.2)
    exact AdmissibleSubgraph.mem_vertices.mpr ⟨γ.1, γ.2, by
      exact hVeq ▸ hvδ⟩
  · intro hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ⟨γ, hγ, hvγ⟩
    let δ :=
      admissibleSubgraphRetargetSubgraph
        Aout starOf γ
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγ)
    have hVeq :
        δ.vertices = γ.vertices := by
      simpa [δ] using
        admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
          Aout starOf γ
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγ)
          (hV γ hγ)
    exact AdmissibleSubgraph.mem_vertices.mpr ⟨δ, by
      simpa [δ] using
        forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
          g q hq hγ, by
      simpa [hVeq] using hvγ⟩

private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_internalEdges_eq_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).internalEdges =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges := by
  classical
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  have hV :
      ∀ η ∈ R.elements, ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
    intro η hη v hv
    dsimp [Aout, R]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hη hv
  have hinj :=
    admissibleSubgraphRetarget_injective_of_not_mem
      Aout starOf R
      (fun η hη =>
        forestComponentMixedBoundaryRightRetarget_edge_le g q hq η (by
          simpa [R] using hη))
      hV
  unfold AdmissibleSubgraph.internalEdges
  change
    (∑ δ ∈
      (R.elements.attach.image fun γ =>
        admissibleSubgraphRetargetSubgraph
          Aout starOf γ.1
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1
            (by simpa [R] using γ.2))),
      δ.internalEdges) =
    ∑ γ ∈ R.elements, γ.internalEdges
  rw [Finset.sum_image]
  · trans ∑ γ ∈ R.elements.attach, γ.1.internalEdges
    · apply Finset.sum_congr rfl
      intro γ _hγ
      exact admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
        Aout starOf γ.1
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1
          (by simpa [R] using γ.2))
        (hV γ.1 γ.2)
    · rw [Finset.sum_attach]
  · intro γ₁ _ γ₂ _ hEq
    exact hinj hEq

private theorem forestComponentMixedBoundary_right_internalEdges_outerRetarget_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges.map
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)) =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges := by
  classical
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  have hV :
      ∀ η ∈ R.elements, ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
    intro η hη v hv
    dsimp [Aout, R]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hη hv
  unfold AdmissibleSubgraph.internalEdges
  change (Multiset.mapAddMonoidHom (Aout.retargetEdge starOf))
      (∑ γ ∈ R.elements, γ.internalEdges) =
    ∑ γ ∈ R.elements, γ.internalEdges
  rw [map_sum (Multiset.mapAddMonoidHom (Aout.retargetEdge starOf))]
  apply Finset.sum_congr rfl
  intro γ hγ
  exact admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
    Aout starOf γ
    (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ (by
      simpa [R] using hγ))
    (hV γ hγ)

/-- The original right-factor contraction graph for a component-choice branch. -/
private noncomputable def forestComponentChoiceOriginalRightContractGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) : FeynmanGraph :=
  FeynmanGraph.admissibleForestContractGraphWithStars
    (repG g).toFeynmanGraph q.1.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph q.1.1 q.1.2)

/-- The actual quotient-side final right contraction graph in the genuine
component-forest branch. -/
private noncomputable def forestComponentForestChoiceActualRightContractGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq) :
    FeynmanGraph :=
  FeynmanGraph.admissibleForestContractGraphWithStars
    (forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq))
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))
      (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
      (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
        g q hq
        (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
          g q hq C)))

/-- The split-star assignment for the genuine-forest actual right
contraction.  Left components keep the outer-splice stars, right components
use their retargeted quotient-side survivor stars, and genuine forest
components use the quotient-remnant star of `γ / B`. -/
private noncomputable def forestComponentForestChoiceSplitStarOf
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    FeynmanSubgraph (repG g).toFeynmanGraph → VertexId :=
  fun γ =>
    let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let outerStar :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    let Q := forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq)
    let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical
      g q hq
    let rightStar :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        Q Aact
        (by
          simpa [Q, Aact] using
            forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
              g q hq
              (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
                g q hq C))
    if hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements then
      outerStar γ
    else if hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements then
      rightStar
        (admissibleSubgraphRetargetSubgraph
          Aout outerStar γ
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR))
    else if hγA : γ ∈ q.1.1.elements then
      match q.2 ⟨γ, hγA⟩ (Finset.mem_attach q.1.1.elements ⟨γ, hγA⟩) with
      | forestCoproductChoice.forest _B =>
          rightStar
            (admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γ)
      | forestCoproductChoice.left => q.1.1.componentFreshStar γ
      | forestCoproductChoice.right => q.1.1.componentFreshStar γ
    else
      q.1.1.componentFreshStar γ

@[simp] private theorem forestComponentForestChoiceSplitStarOf_left
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γ =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2 γ := by
  unfold forestComponentForestChoiceSplitStarOf
  rw [dif_pos hγL]

@[simp] private theorem forestComponentForestChoiceSplitStarOf_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γ =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq))
        (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq)
        (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
          g q hq
          (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
            g q hq C))
        (admissibleSubgraphRetargetSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR)) := by
  have hnotL :
      γ ∉ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements :=
    forestComponentChoiceRightSubgraph_not_mem_left q.1.1 q.2 hγR
  unfold forestComponentForestChoiceSplitStarOf
  rw [dif_neg hnotL, dif_pos hγR]

@[simp] private theorem forestComponentForestChoiceSplitStarOf_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    forestComponentForestChoiceSplitStarOf g q hq C γ.1 =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq))
        (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq)
        (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
          g q hq
          (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
            g q hq C))
        (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1) := by
  have hnotL :
      γ.1 ∉ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements := by
    intro hγL
    rw [forestComponentChoiceLeftSubgraph_elements] at hγL
    rcases Finset.mem_filter.mp hγL with ⟨_hγA, hLeft⟩
    unfold forestComponentChoiceIsLeft at hLeft
    rw [dif_pos γ.2] at hLeft
    rw [hB] at hLeft
    cases hLeft
  have hnotR :
      γ.1 ∉ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements := by
    intro hγR
    rw [forestComponentChoiceRightSubgraph_elements] at hγR
    rcases Finset.mem_filter.mp hγR with ⟨_hγA, hRight⟩
    unfold forestComponentChoiceIsRight at hRight
    rw [dif_pos γ.2] at hRight
    rw [hB] at hRight
    cases hRight
  unfold forestComponentForestChoiceSplitStarOf
  rw [dif_neg hnotL, dif_neg hnotR, dif_pos γ.2]
  cases hChoice :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) with
  | left =>
      rw [hChoice] at hB
      cases hB
  | right =>
      rw [hChoice] at hB
      cases hB
  | forest B' =>
      rfl

/-- Any outer-splice component star is visible as a vertex of the actual
outer quotient graph. -/
private theorem forestComponentForestChoice_outer_star_mem_outer_quotient_vertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {δ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hδ : δ ∈ (forestComponentForestChoiceOuterIndex g q hq).1.elements) :
    FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2 δ ∈
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)).vertices := by
  change
    (forestComponentForestChoiceOuterIndex g q hq).1.componentFreshStar δ ∈
      ((forestComponentForestChoiceOuterIndex g q hq).1.contractWithStars
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)).vertices
  rw [AdmissibleSubgraph.contractWithStars_vertices]
  refine Finset.mem_union.mpr (Or.inr ?_)
  rw [AdmissibleSubgraph.mem_starVertices]
  exact ⟨δ, hδ, rfl⟩

private theorem forestComponentForestChoice_outer_star_ge_original_freshVertex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (δ : FeynmanSubgraph (repG g).toFeynmanGraph) :
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2 δ := by
  change
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      (forestComponentForestChoiceOuterIndex g q hq).1.componentFreshStar δ
  exact freshVertex_le_componentFreshStar
    (forestComponentForestChoiceOuterIndex g q hq).1 δ

private theorem forestComponentForestChoice_actualRightStar_ge_original_freshVertex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) :
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq))
        (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq)
        (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
          g q hq
          (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
            g q hq C))
        δ := by
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical
    g q hq
  have hAoutNonempty : Aout.IsNonempty := by
    simpa [Aout] using
      properDisjointAdmissibleDivergentSubgraphs_isNonempty
        (forestComponentForestChoiceOuterIndex g q hq).2
  rcases hAoutNonempty with ⟨δ₀, hδ₀⟩
  have hOuterMem :
      outerStar δ₀ ∈ Q.vertices := by
    simpa [Q, outerStar, Aout] using
      forestComponentForestChoice_outer_star_mem_outer_quotient_vertices
        g q hq hδ₀
  have hOuterGe :
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        outerStar δ₀ := by
    simpa [outerStar] using
      forestComponentForestChoice_outer_star_ge_original_freshVertex
        g q hq δ₀
  have hOuterLtQ :
      outerStar δ₀ < FeynmanGraph.freshVertex Q.vertices :=
    lt_freshVertex_of_mem hOuterMem
  have hQle :
      FeynmanGraph.freshVertex Q.vertices ≤ Aact.componentFreshStar δ := by
    simpa [Q, Aact] using freshVertex_le_componentFreshStar Aact δ
  change
    FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
      Aact.componentFreshStar δ
  exact Nat.le_trans hOuterGe
    (Nat.le_trans (Nat.le_of_lt hOuterLtQ) hQle)

/-- Left-selected genuine components receive fresh original-ambient stars
from the outer splice. -/
private theorem forestComponentForestChoiceSplitStarOf_left_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γ ∉
      (repG g).toFeynmanGraph.vertices := by
  have hFresh :
      (forestComponentForestChoiceOuterIndex g q hq).1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  rw [forestComponentForestChoiceSplitStarOf_left g q hq C hγL]
  have hγOuter :
      γ ∈ (forestComponentForestChoiceOuterIndex g q hq).1.elements := by
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_left
      (forestComponentChoicePromotedForestComponents q.1.1 q.2) hγL
  exact hFresh.fresh hγOuter

private theorem forestComponentForestChoiceSplitStarOf_right_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γ ∉
      (repG g).toFeynmanGraph.vertices := by
  let δ :=
    admissibleSubgraphRetargetSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR)
  have hOrigLe :
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        forestComponentForestChoiceSplitStarOf g q hq C γ := by
    rw [forestComponentForestChoiceSplitStarOf_right g q hq C hγR]
    simpa [δ] using
      forestComponentForestChoice_actualRightStar_ge_original_freshVertex
        g q hq C δ
  exact not_mem_of_freshVertex_le hOrigLe

private theorem forestComponentForestChoiceSplitStarOf_forest_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    forestComponentForestChoiceSplitStarOf g q hq C γ.1 ∉
      (repG g).toFeynmanGraph.vertices := by
  let δ :=
    admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ.1
  have hOrigLe :
      FeynmanGraph.freshVertex (repG g).toFeynmanGraph.vertices ≤
        forestComponentForestChoiceSplitStarOf g q hq C γ.1 := by
    rw [forestComponentForestChoiceSplitStarOf_forest g q hq C γ hB]
    simpa [δ] using
      forestComponentForestChoice_actualRightStar_ge_original_freshVertex
        g q hq C δ
  exact not_mem_of_freshVertex_le hOrigLe

omit [ForestComponentForestChoiceRepQuotientComplementPositiveModel] in
/-- Every original component in the genuine-forest branch is either selected
on the left, selected on the right, or supplies a genuine component forest. -/
private theorem forestComponentForestChoice_choice_left_or_right_or_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (_hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ q.1.1.elements) :
    γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∨
      γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements ∨
      ∃ B : AdmissibleSubgraph
        (repG (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγ))).toFeynmanGraph,
        q.2 ⟨γ, hγ⟩ (Finset.mem_attach q.1.1.elements ⟨γ, hγ⟩) =
          forestCoproductChoice.forest B := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest
      (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγ))
      (q.2 ⟨γ, hγ⟩ (Finset.mem_attach q.1.1.elements ⟨γ, hγ⟩)) with
    hLeft | hRightOrForest
  · exact Or.inl (by
      rw [forestComponentChoiceLeftSubgraph_elements]
      refine Finset.mem_filter.mpr ⟨hγ, ?_⟩
      unfold forestComponentChoiceIsLeft
      rw [dif_pos hγ]
      exact hLeft)
  · rcases hRightOrForest with hRight | hForest
    · exact Or.inr (Or.inl (by
        rw [forestComponentChoiceRightSubgraph_elements]
        refine Finset.mem_filter.mpr ⟨hγ, ?_⟩
        unfold forestComponentChoiceIsRight
        rw [dif_pos hγ]
        exact hRight))
    · rcases hForest with ⟨B, hB⟩
      exact Or.inr (Or.inr ⟨B, hB⟩)

private theorem forestComponentForestChoiceSplitStarOf_point_fresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ q.1.1.elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γ ∉
      (repG g).toFeynmanGraph.vertices := by
  rcases forestComponentForestChoice_choice_left_or_right_or_forest
      g q hq hγ with hγL | hγR | hγF
  · exact forestComponentForestChoiceSplitStarOf_left_fresh g q hq C hγL
  · exact forestComponentForestChoiceSplitStarOf_right_fresh g q hq C hγR
  · rcases hγF with ⟨B, hB⟩
    exact forestComponentForestChoiceSplitStarOf_forest_fresh
      g q hq C ⟨γ, hγ⟩ hB

omit [ForestComponentForestChoiceRepQuotientComplementPositiveModel] in
/-- Left-selected original components are components of the genuine outer
splice. -/
private theorem forestComponentForestChoiceOuterIndex_mem_of_left
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements) :
    γ ∈ (forestComponentForestChoiceOuterIndex g q hq).1.elements := by
  rw [forestComponentForestChoiceOuterIndex_val,
    forestComponentForestChoiceOuterSubgraph_elements]
  exact Finset.mem_union_left
    (forestComponentChoicePromotedForestComponents q.1.1 q.2) hγL

/-- A right-selected survivor component belongs to the full genuine actual
quotient forest. -/
private theorem forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR) ∈
      (forestComponentForestChoiceActualQuotientSubgraphCanonical
        g q hq).elements := by
  rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
  unfold forestComponentForestChoiceActualQuotientComponents
  exact Finset.mem_union_left _
    (forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_of_right
      g q hq hγR)

/-- A selected remnant component belongs to the full genuine actual quotient
forest. -/
private theorem forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    admissibleSubgraphQuotientRemainderSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ.1 ∈
      (forestComponentForestChoiceActualQuotientSubgraphCanonical
        g q hq).elements := by
  rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
  unfold forestComponentForestChoiceActualQuotientComponents
  exact Finset.mem_union_right _
    (forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq γ hB)

/-- Remaining freshness payload for the concrete genuine split-star
assignment: pointwise freshness is canonical, so only injectivity of the
chosen stars over the original component carrier remains. -/
private structure forestComponentForestChoiceSplitStarInjectivityPayload
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  inj :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γ₁, γ₁ ∈ q.1.1.elements →
      ∀ γ₂, γ₂ ∈ q.1.1.elements →
        forestComponentForestChoiceSplitStarOf g q hq C γ₁ =
          forestComponentForestChoiceSplitStarOf g q hq C γ₂ →
        γ₁ = γ₂

private theorem forestComponentForestChoiceSplitStarOf_isFresh_of_injective
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentForestChoiceSplitStarInjectivityPayload) :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
        q.1.1.IsFreshStarAssignment
          (forestComponentForestChoiceSplitStarOf g q hq C) := by
  intro g q hq C
  constructor
  · intro γ hγ
    exact forestComponentForestChoiceSplitStarOf_point_fresh g q hq C hγ
  · intro γ₁ hγ₁ γ₂ hγ₂ hstar
    exact T.inj g q hq C γ₁ hγ₁ γ₂ hγ₂ hstar

/-- Branchwise form of genuine split-star injectivity.  The nine possible
left/right/forest combinations are the final finite case split before the
freshness field closes. -/
private structure forestComponentForestChoiceSplitStarBranchInjectivityPayload
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  left_left :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γ₁, γ₁ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements →
      ∀ γ₂, γ₂ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements →
        forestComponentForestChoiceSplitStarOf g q hq C γ₁ =
          forestComponentForestChoiceSplitStarOf g q hq C γ₂ →
        γ₁ = γ₂
  right_right :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γ₁, γ₁ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements →
      ∀ γ₂, γ₂ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements →
        forestComponentForestChoiceSplitStarOf g q hq C γ₁ =
          forestComponentForestChoiceSplitStarOf g q hq C γ₂ →
        γ₁ = γ₂
  forest_forest :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γ₁ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ q.1.1.elements},
      ∀ B₁ : AdmissibleSubgraph
        (repG (γ₁.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ₁.2))).toFeynmanGraph,
      ∀ hB₁ : q.2 γ₁ (Finset.mem_attach q.1.1.elements γ₁) =
          forestCoproductChoice.forest B₁,
      ∀ γ₂ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ q.1.1.elements},
      ∀ B₂ : AdmissibleSubgraph
        (repG (γ₂.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ₂.2))).toFeynmanGraph,
      ∀ hB₂ : q.2 γ₂ (Finset.mem_attach q.1.1.elements γ₂) =
          forestCoproductChoice.forest B₂,
        forestComponentForestChoiceSplitStarOf g q hq C γ₁.1 =
          forestComponentForestChoiceSplitStarOf g q hq C γ₂.1 →
        γ₁.1 = γ₂.1
  left_right :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γL, γL ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements →
      ∀ γR, γR ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements →
        forestComponentForestChoiceSplitStarOf g q hq C γL ≠
          forestComponentForestChoiceSplitStarOf g q hq C γR
  left_forest :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γL, γL ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements →
      ∀ γF : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γF.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γF.2))).toFeynmanGraph,
      ∀ hB : q.2 γF (Finset.mem_attach q.1.1.elements γF) =
          forestCoproductChoice.forest B,
        forestComponentForestChoiceSplitStarOf g q hq C γL ≠
          forestComponentForestChoiceSplitStarOf g q hq C γF.1
  right_forest :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
      ∀ γR, γR ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements →
      ∀ γF : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γF.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γF.2))).toFeynmanGraph,
      ∀ hB : q.2 γF (Finset.mem_attach q.1.1.elements γF) =
          forestCoproductChoice.forest B,
        forestComponentForestChoiceSplitStarOf g q hq C γR ≠
          forestComponentForestChoiceSplitStarOf g q hq C γF.1

private theorem forestComponentForestChoiceSplitStarInjectivityOfBranches
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentForestChoiceSplitStarBranchInjectivityPayload) :
    forestComponentForestChoiceSplitStarInjectivityPayload where
  inj := by
    intro g q hq C γ₁ hγ₁ γ₂ hγ₂ hstar
    rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hγ₁ with hγ₁L | hγ₁R | hγ₁F
    · rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hγ₂ with hγ₂L | hγ₂R | hγ₂F
      · exact T.left_left g q hq C γ₁ hγ₁L γ₂ hγ₂L hstar
      · exact False.elim ((T.left_right g q hq C γ₁ hγ₁L γ₂ hγ₂R) hstar)
      · rcases hγ₂F with ⟨B₂, hB₂⟩
        exact False.elim
          ((T.left_forest g q hq C γ₁ hγ₁L ⟨γ₂, hγ₂⟩ B₂ hB₂) hstar)
    · rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hγ₂ with hγ₂L | hγ₂R | hγ₂F
      · exact False.elim ((T.left_right g q hq C γ₂ hγ₂L γ₁ hγ₁R) hstar.symm)
      · exact T.right_right g q hq C γ₁ hγ₁R γ₂ hγ₂R hstar
      · rcases hγ₂F with ⟨B₂, hB₂⟩
        exact False.elim
          ((T.right_forest g q hq C γ₁ hγ₁R ⟨γ₂, hγ₂⟩ B₂ hB₂) hstar)
    · rcases hγ₁F with ⟨B₁, hB₁⟩
      rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hγ₂ with hγ₂L | hγ₂R | hγ₂F
      · exact False.elim
          ((T.left_forest g q hq C γ₂ hγ₂L ⟨γ₁, hγ₁⟩ B₁ hB₁) hstar.symm)
      · exact False.elim
          ((T.right_forest g q hq C γ₂ hγ₂R ⟨γ₁, hγ₁⟩ B₁ hB₁) hstar.symm)
      · rcases hγ₂F with ⟨B₂, hB₂⟩
        exact T.forest_forest g q hq C ⟨γ₁, hγ₁⟩ B₁ hB₁
          ⟨γ₂, hγ₂⟩ B₂ hB₂ hstar

private theorem forestComponentForestChoiceSplitStarBranch_left_left
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁L : γ₁ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements)
    (hγ₂L : γ₂ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements)
    (hstar :
      forestComponentForestChoiceSplitStarOf g q hq C γ₁ =
        forestComponentForestChoiceSplitStarOf g q hq C γ₂) :
    γ₁ = γ₂ := by
  have hFreshOuter :
      (forestComponentForestChoiceOuterIndex g q hq).1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  apply hFreshOuter.eq_of_star_eq
  · exact forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγ₁L
  · exact forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγ₂L
  · simpa [forestComponentForestChoiceSplitStarOf_left g q hq C hγ₁L,
      forestComponentForestChoiceSplitStarOf_left g q hq C hγ₂L] using hstar

private theorem forestComponentForestChoiceSplitStarBranch_left_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γL γR : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γL ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements)
    (hγR : γR ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    forestComponentForestChoiceSplitStarOf g q hq C γL ≠
      forestComponentForestChoiceSplitStarOf g q hq C γR := by
  intro hstar
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let δR :=
    admissibleSubgraphRetargetSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γR
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)
  have hLeftMem :
      forestComponentForestChoiceSplitStarOf g q hq C γL ∈ Q.vertices := by
    rw [forestComponentForestChoiceSplitStarOf_left g q hq C hγL]
    exact forestComponentForestChoice_outer_star_mem_outer_quotient_vertices
      g q hq (forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγL)
  have hFreshQ :
      Aact.IsFreshStarAssignment rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hRightFresh :
      forestComponentForestChoiceSplitStarOf g q hq C γR ∉ Q.vertices := by
    rw [forestComponentForestChoiceSplitStarOf_right g q hq C hγR]
    exact hFreshQ.fresh (by
      simpa [Q, Aact, rightStar, δR] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
          g q hq hγR)
  exact hRightFresh (by simpa [hstar] using hLeftMem)

private theorem forestComponentForestChoiceSplitStarBranch_left_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γL : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγL : γL ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements)
    (γF : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γF.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γF.2))).toFeynmanGraph}
    (hB : q.2 γF (Finset.mem_attach q.1.1.elements γF) =
      forestCoproductChoice.forest B) :
    forestComponentForestChoiceSplitStarOf g q hq C γL ≠
      forestComponentForestChoiceSplitStarOf g q hq C γF.1 := by
  intro hstar
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let δF :=
    admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γF.1
  have hLeftMem :
      forestComponentForestChoiceSplitStarOf g q hq C γL ∈ Q.vertices := by
    rw [forestComponentForestChoiceSplitStarOf_left g q hq C hγL]
    exact forestComponentForestChoice_outer_star_mem_outer_quotient_vertices
      g q hq (forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγL)
  have hFreshQ :
      Aact.IsFreshStarAssignment rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hForestFresh :
      forestComponentForestChoiceSplitStarOf g q hq C γF.1 ∉ Q.vertices := by
    rw [forestComponentForestChoiceSplitStarOf_forest g q hq C γF hB]
    exact hFreshQ.fresh (by
      simpa [Q, Aact, rightStar, δF] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
          g q hq γF hB)
  exact hForestFresh (by simpa [hstar] using hLeftMem)

private theorem forestComponentForestChoiceSplitStarBranch_right_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁R : γ₁ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements)
    (hγ₂R : γ₂ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements)
    (hstar :
      forestComponentForestChoiceSplitStarOf g q hq C γ₁ =
        forestComponentForestChoiceSplitStarOf g q hq C γ₂) :
    γ₁ = γ₂ := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let δ₁ :=
    admissibleSubgraphRetargetSubgraph Aout outerStar γ₁
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₁ hγ₁R)
  let δ₂ :=
    admissibleSubgraphRetargetSubgraph Aout outerStar γ₂
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γ₂ hγ₂R)
  have hFreshQ : Aact.IsFreshStarAssignment rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hδeq : δ₁ = δ₂ := by
    apply hFreshQ.eq_of_star_eq
    · simpa [Q, Aact, δ₁] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
          g q hq hγ₁R
    · simpa [Q, Aact, δ₂] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
          g q hq hγ₂R
    · simpa [Q, Aact, rightStar, Aout, outerStar, δ₁, δ₂,
        forestComponentForestChoiceSplitStarOf_right g q hq C hγ₁R,
        forestComponentForestChoiceSplitStarOf_right g q hq C hγ₂R] using hstar
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV :
      ∀ η ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
        ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
    intro η hη v hv
    simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q.1.1 q.2 hDisjA hη hv
  have hinj :=
    admissibleSubgraphRetarget_injective_of_not_mem
      Aout outerStar (forestComponentChoiceRightSubgraph q.1.1 q.2)
      (fun η hη =>
        forestComponentForestChoiceRightRetarget_edge_le g q hq η hη)
      hV
  have hSubtype :
      (⟨γ₁, hγ₁R⟩ :
        {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements}) =
      ⟨γ₂, hγ₂R⟩ := by
    apply hinj
    simpa [Aout, outerStar, δ₁, δ₂] using hδeq
  exact congrArg Subtype.val hSubtype

private theorem forestComponentForestChoiceSplitStarBranch_right_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {γR : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γR ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements)
    (γF : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γF.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γF.2))).toFeynmanGraph}
    (hB : q.2 γF (Finset.mem_attach q.1.1.elements γF) =
      forestCoproductChoice.forest B) :
    forestComponentForestChoiceSplitStarOf g q hq C γR ≠
      forestComponentForestChoiceSplitStarOf g q hq C γF.1 := by
  intro hstar
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let δR :=
    admissibleSubgraphRetargetSubgraph Aout outerStar γR
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)
  let δF :=
    admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γF.1
  have hFreshQ : Aact.IsFreshStarAssignment rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hδeq : δR = δF := by
    apply hFreshQ.eq_of_star_eq
    · simpa [Q, Aact, δR] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
          g q hq hγR
    · simpa [Q, Aact, δF] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
          g q hq γF hB
    · simpa [Q, Aact, rightStar, Aout, outerStar, δR, δF,
        forestComponentForestChoiceSplitStarOf_right g q hq C hγR,
        forestComponentForestChoiceSplitStarOf_forest g q hq C γF hB] using hstar
  have hδRmem :
      δR ∈ (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
        g q hq).elements := by
    simpa [δR, Aout, outerStar] using
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_of_right
        g q hq hγR
  have hδFmem :
      δF ∈ forestComponentForestChoiceRemnantComponents g q hq := by
    simpa [δF, Aout, outerStar] using
      forestComponentForestChoiceRemnantComponents_mem_of_forest
        g q hq γF hB
  have hSelfDisj : δR.Disjoint δR := by
    simpa [hδeq] using
      forestComponentForestChoiceRightRemnant_disjoint g q hq
        δR hδRmem δF hδFmem
  have hPos :
      0 < δR.internalEdges.card :=
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents
      g q hq δR hδRmem
  rcases Multiset.exists_mem_of_ne_zero (Multiset.card_pos.mp hPos) with
    ⟨e, he⟩
  have hsupp := δR.edges_supported e he
  simp [FeynmanEdge.SupportedOn] at hsupp
  exact (Finset.disjoint_left.mp hSelfDisj hsupp.1) hsupp.1

private theorem forestComponentForestChoiceSplitStarBranch_forest_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (γ₁ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B₁ : AdmissibleSubgraph
      (repG (γ₁.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γ₁.2))).toFeynmanGraph}
    (hB₁ : q.2 γ₁ (Finset.mem_attach q.1.1.elements γ₁) =
      forestCoproductChoice.forest B₁)
    (γ₂ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B₂ : AdmissibleSubgraph
      (repG (γ₂.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γ₂.2))).toFeynmanGraph}
    (hB₂ : q.2 γ₂ (Finset.mem_attach q.1.1.elements γ₂) =
      forestCoproductChoice.forest B₂)
    (hstar :
      forestComponentForestChoiceSplitStarOf g q hq C γ₁.1 =
        forestComponentForestChoiceSplitStarOf g q hq C γ₂.1) :
    γ₁.1 = γ₂.1 := by
  classical
  by_contra hne
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let δ₁ := admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γ₁.1
  let δ₂ := admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γ₂.1
  have hFreshQ : Aact.IsFreshStarAssignment rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hδeq : δ₁ = δ₂ := by
    apply hFreshQ.eq_of_star_eq
    · simpa [Q, Aact, δ₁] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
          g q hq γ₁ hB₁
    · simpa [Q, Aact, δ₂] using
        forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
          g q hq γ₂ hB₂
    · simpa [Q, Aact, rightStar, Aout, outerStar, δ₁, δ₂,
        forestComponentForestChoiceSplitStarOf_forest g q hq C γ₁ hB₁,
        forestComponentForestChoiceSplitStarOf_forest g q hq C γ₂ hB₂] using hstar
  have hδ₁mem : δ₁ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
    simpa [δ₁, Aout, outerStar] using
      forestComponentForestChoiceRemnantComponents_mem_of_forest
        g q hq γ₁ hB₁
  have hδ₂mem : δ₂ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
    simpa [δ₂, Aout, outerStar] using
      forestComponentForestChoiceRemnantComponents_mem_of_forest
        g q hq γ₂ hB₂
  have hSelfDisj : δ₁.Disjoint δ₁ := by
    have hDisj :
        δ₁.Disjoint δ₂ := by
      simpa [δ₁, δ₂, Aout, outerStar] using
        forestComponentForestChoiceRemnantComponents_disjoint_of_source_ne
          g q hq γ₁ γ₂ hB₁ hB₂ hne
    simpa [hδeq] using hDisj
  have hPos : 0 < δ₁.internalEdges.card := C.positive δ₁ hδ₁mem
  rcases Multiset.exists_mem_of_ne_zero (Multiset.card_pos.mp hPos) with
    ⟨e, he⟩
  have hsupp := δ₁.edges_supported e he
  simp [FeynmanEdge.SupportedOn] at hsupp
  exact (Finset.disjoint_left.mp hSelfDisj hsupp.1) hsupp.1

private theorem forestComponentForestChoiceSplitStarBranchInjectivityCanonical
    [IsDivergencePreservedByAdmissibleForestContract] :
    forestComponentForestChoiceSplitStarBranchInjectivityPayload where
  left_left := by
    intro g q hq C γ₁ hγ₁ γ₂ hγ₂ hstar
    exact forestComponentForestChoiceSplitStarBranch_left_left
      g q hq C hγ₁ hγ₂ hstar
  right_right := by
    intro g q hq C γ₁ hγ₁ γ₂ hγ₂ hstar
    exact forestComponentForestChoiceSplitStarBranch_right_right
      g q hq C hγ₁ hγ₂ hstar
  forest_forest := by
    intro g q hq C γ₁ B₁ hB₁ γ₂ B₂ hB₂ hstar
    exact forestComponentForestChoiceSplitStarBranch_forest_forest
      g q hq C γ₁ hB₁ γ₂ hB₂ hstar
  left_right := by
    intro g q hq C γL hγL γR hγR
    exact forestComponentForestChoiceSplitStarBranch_left_right
      g q hq C hγL hγR
  left_forest := by
    intro g q hq C γL hγL γF B hB
    exact forestComponentForestChoiceSplitStarBranch_left_forest
      g q hq C hγL γF hB
  right_forest := by
    intro g q hq C γR hγR γF B hB
    exact forestComponentForestChoiceSplitStarBranch_right_forest
      g q hq C hγR γF hB

/-- The original-side stars contributed by genuine component-forest choices
under the final split-star assignment.  This is the source-side mirror of the
actual quotient remnant carrier. -/
private noncomputable def
    forestComponentForestChoiceForestSplitStarVertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    Finset VertexId :=
  q.1.1.elements.attach.biUnion fun γ =>
    match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
    | forestCoproductChoice.left => ∅
    | forestCoproductChoice.right => ∅
    | forestCoproductChoice.forest _B =>
        {forestComponentForestChoiceSplitStarOf g q hq C γ.1}

private theorem
    forestComponentForestChoiceForestSplitStarVertices_mem_of_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
      γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
