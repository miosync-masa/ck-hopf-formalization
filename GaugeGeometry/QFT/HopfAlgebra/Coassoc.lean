/-- Sprint F2-Track-B-1b-2: retarget-subgraph injectivity on A.elements.
For ő≥‚āĀ, ő≥‚āā ‚ąą A.elements, equality of `admissibleSubgraphRetargetSubgraph`
implies ő≥‚āĀ = ő≥‚āā.  Proof: extract vertex-set equality ‚Üí for any v ‚ąą ő≥‚āĀ.vertices,
its retarget = starOf ő≥‚āĀ is also in ő≥‚āā.vertices.image retargetVertex, giving
some v‚āā ‚ąą ő≥‚āā.vertices with retargetVertex v‚āā = starOf ő≥‚āĀ = starOf ő≥‚āā; then
star injectivity (B-1b-1) closes. -/
private theorem admissibleSubgraphRetargetSubgraph_inj_on_elements
    {G : FeynmanGraph}
    {A : AdmissibleSubgraph G}
    (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
    {ő≥‚āĀ ő≥‚āā : FeynmanSubgraph G}
    (hő≥‚āĀ : ő≥‚āĀ ‚ąą A.elements)
    (hő≥‚āā : ő≥‚āā ‚ąą A.elements)
    (hEdges‚āĀ : ő≥‚āĀ.internalEdges ‚Č§ A.complementEdges)
    (hEdges‚āā : ő≥‚āā.internalEdges ‚Č§ A.complementEdges)
    (hRetarget :
      admissibleSubgraphRetargetSubgraph A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) ő≥‚āĀ hEdges‚āĀ =
      admissibleSubgraphRetargetSubgraph A
        (FeynmanGraph.admissibleForestCanonicalStarOf G A hA) ő≥‚āā hEdges‚āā) :
    ő≥‚āĀ = ő≥‚āā := by
  classical
  have hDisj : A.IsPairwiseDisjoint :=
    G.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hNE : A.HasNonemptyComponents :=
    G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents hA
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf G A hA with hstarOfDef
  have hVerts : ő≥‚āĀ.vertices.image (A.retargetVertex starOf) =
      ő≥‚āā.vertices.image (A.retargetVertex starOf) := by
    have := congrArg FeynmanSubgraph.vertices hRetarget
    simpa using this
  -- ő≥‚āĀ is nonempty: pick v‚āĀ ‚ąą ő≥‚āĀ.vertices
  have hő≥‚āĀcard : 0 < ő≥‚āĀ.vertices.card := by
    have hne := hNE ő≥‚āĀ hő≥‚āĀ
    unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hne
    exact hne
  obtain ‚ü®v‚āĀ, hv‚āĀ‚ü© := Finset.card_pos.mp hő≥‚āĀcard
  -- retargetVertex v‚āĀ = starOf ő≥‚āĀ
  have hRetV‚āĀ : A.retargetVertex starOf v‚āĀ = starOf ő≥‚āĀ :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj starOf hő≥‚āĀ hv‚āĀ
  -- starOf ő≥‚āĀ ‚ąą ő≥‚āā.vertices.image retargetVertex
  have hStarMem : starOf ő≥‚āĀ ‚ąą ő≥‚āā.vertices.image (A.retargetVertex starOf) := by
    rw [‚Üź hVerts, ‚Üź hRetV‚āĀ]
    exact Finset.mem_image_of_mem _ hv‚āĀ
  -- Extract v‚āā ‚ąą ő≥‚āā.vertices with retargetVertex v‚āā = starOf ő≥‚āĀ
  obtain ‚ü®v‚āā, hv‚āā, hRetV‚āā‚ü© := Finset.mem_image.mp hStarMem
  -- retargetVertex v‚āā = starOf ő≥‚āā
  have hRetV‚āā' : A.retargetVertex starOf v‚āā = starOf ő≥‚āā :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj starOf hő≥‚āā hv‚āā
  -- Combine
  have hStarEq : starOf ő≥‚āĀ = starOf ő≥‚āā := hRetV‚āā.symm.trans hRetV‚āā'
  exact admissibleForestCanonicalStarOf_injOn_elements A hA hő≥‚āĀ hő≥‚āā hStarEq

