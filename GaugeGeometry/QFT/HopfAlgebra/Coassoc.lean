/-- Source partition transport (Sprint F1o-1): if two component-choice
functions `p‚āĀ`, `p‚āā` produce the same outer subgraph, then for any outer
component `őī` they yield the same source `ő≥ ‚ąą A.elements`.  This is the
foundation for `slotAt_eq_of_outer_eq` and ultimately for outer-injectivity.

Both source partitions cover the same nonempty `őī` with vertices contained
in `ő≥ŠĶĘ.vertices`; `hA.eq_of_mem_vertices` then forces `ő≥‚āĀ = ő≥‚āā`. -/
private theorem forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (őī : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements}) :
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p‚āĀ hA őī).1 =
    (forestComponentForestChoiceOuterSubgraph_sourcePartition A p‚āā hA
      ‚ü®őī.1, by rw [‚Üź hEq]; exact őī.2‚ü©).1 := by
  classical
  -- (a) sp‚āĀ: őī.vertices ‚äÜ sp‚āĀ.vertices, sp‚āĀ.1 ‚ąą A.elements
  have hSub‚āĀ : őī.1.vertices ‚äÜ
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p‚āĀ hA őī).1.vertices :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p‚āĀ hA őī
  have hMem‚āĀ :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p‚āĀ hA őī).1 ‚ąą A.elements :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_mem A p‚āĀ hA őī
  -- (b) sp‚āā: same shape, with őī transported across hEq
  let őī‚āā : {őī : FeynmanSubgraph G //
      őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements} :=
    ‚ü®őī.1, by rw [‚Üź hEq]; exact őī.2‚ü©
  have hSub‚āā : őī.1.vertices ‚äÜ
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p‚āā hA őī‚āā).1.vertices :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_vertices_subset
      A p‚āā hA őī‚āā
  have hMem‚āā :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition
        A p‚āā hA őī‚āā).1 ‚ąą A.elements :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_mem A p‚āā hA őī‚āā
  -- (c) őī.1 nonempty (via hCompOuter on the p‚āĀ side)
  have hőīNE : őī.1.IsNonempty := hCompOuter őī.1 őī.2
  rcases Finset.card_pos.mp hőīNE with ‚ü®v, hvőī‚ü©
  -- (d) hA + common vertex v ‚áí sp‚āĀ.1 = sp‚āā.1
  exact hA.eq_of_mem_vertices hMem‚āĀ hMem‚āā (hSub‚āĀ hvőī) (hSub‚āā hvőī)

/-- slotAt membership transport (Sprint F1o-2a): under outer equality,
őī ‚ąą slotAt p‚āĀ ő≥ ‚ÜĒ (őī transported) ‚ąą slotAt p‚āā ő≥.  Foundation for the upcoming
observedChoice transport.  Uses `_mem_slotAt_iff` on both sides + F1o-1's
sourcePartition equality.  Stated at iff level to avoid Finset equality
across distinct subtype carriers. -/
private theorem forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (őī : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements}) :
    őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ ‚ÜĒ
      (‚ü®őī.1, by rw [‚Üź hEq]; exact őī.2‚ü© :
        {őī : FeynmanSubgraph G //
          őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements})
        ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ := by
  classical
  -- Bridge sp‚āĀ ‚ÜĒ sp‚āā via F1o-1
  have hSPeq :
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p‚āĀ hA őī).1 =
      (forestComponentForestChoiceOuterSubgraph_sourcePartition A p‚āā hA
        ‚ü®őī.1, by rw [‚Üź hEq]; exact őī.2‚ü©).1 :=
    forestComponentForestChoiceOuterSubgraph_sourcePartition_eq_of_outer_eq
      (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter őī
  -- Apply mem_slotAt_iff on both sides and chain through hSPeq
  rw [forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff
        A p‚āĀ hA ő≥ őī,
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff
        A p‚āā hA ő≥ ‚ü®őī.1, by rw [‚Üź hEq]; exact őī.2‚ü©]
  exact ‚ü®fun h => hSPeq.symm.trans h, fun h => hSPeq.trans h‚ü©

/-- slotAt empty transport (Sprint F1o-2b): under outer equality, the
emptiness of `slotAt ő≥` is preserved.  Iff form to keep both directions
symmetric; uses F1o-2a's membership iff. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_empty_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements}) :
    forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ = ‚ąÖ ‚ÜĒ
      forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ = ‚ąÖ := by
  classical
  -- p‚āā side outer nonempty components, transported via hEq.
  have hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents := by
    rw [‚Üź hEq]; exact hCompOuter
  refine ‚ü®fun h‚āĀ => ?_, fun h‚āā => ?_‚ü©
  ¬∑ refine Finset.eq_empty_iff_forall_notMem.mpr ?_
    intro őī‚āā hőī‚āā
    let őī‚āĀ : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements} :=
      ‚ü®őī‚āā.1, by rw [hEq]; exact őī‚āā.2‚ü©
    have hőī‚āĀ : őī‚āĀ ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter ő≥ őī‚āĀ).mpr (by simpa using hőī‚āā))
    rw [h‚āĀ] at hőī‚āĀ
    exact (Finset.notMem_empty őī‚āĀ) hőī‚āĀ
  ¬∑ refine Finset.eq_empty_iff_forall_notMem.mpr ?_
    intro őī‚āĀ hőī‚āĀ
    have hőī‚āā :
        (‚ü®őī‚āĀ.1, by rw [‚Üź hEq]; exact őī‚āĀ.2‚ü© :
          {őī : FeynmanSubgraph G //
            őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements}) ‚ąą
            forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter ő≥ őī‚āĀ).mp hőī‚āĀ)
    rw [h‚āā] at hőī‚āā
    exact (Finset.notMem_empty _) hőī‚āā

/-- slotAt self-exists transport (Sprint F1o-2c): under outer equality, the
existence of a self-element őī (with `őī.1 = ő≥.1`) in `slotAt ő≥` is
preserved.  Iff form via F1o-2a's membership iff. -/
private theorem forestComponentForestChoiceOuterSubgraph_slotAt_self_exists_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hA : A.IsPairwiseDisjoint)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements}) :
    (‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥,
        őī.1 = ő≥.1) ‚ÜĒ
      (‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥,
        őī.1 = ő≥.1) := by
  classical
  refine ‚ü®?_, ?_‚ü©
  ¬∑ rintro ‚ü®őī‚āĀ, hőī‚āĀSlot, hőī‚āĀEq‚ü©
    let őī‚āā : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements} :=
      ‚ü®őī‚āĀ.1, by rw [‚Üź hEq]; exact őī‚āĀ.2‚ü©
    have hiff :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter ő≥ őī‚āĀ
    refine ‚ü®őī‚āā, hiff.mp hőī‚āĀSlot, ?_‚ü©
    simpa [őī‚āā] using hőī‚āĀEq
  ¬∑ rintro ‚ü®őī‚āā, hőī‚āāSlot, hőī‚āāEq‚ü©
    let őī‚āĀ : {őī : FeynmanSubgraph G //
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements} :=
      ‚ü®őī‚āā.1, by rw [hEq]; exact őī‚āā.2‚ü©
    have hiff :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter ő≥ őī‚āĀ
    refine ‚ü®őī‚āĀ, hiff.mpr (by simpa [őī‚āĀ] using hőī‚āāSlot), ?_‚ü©
    simpa [őī‚āĀ] using hőī‚āāEq

/-- Strong reverse direction (Sprint F1l-4c): under `hp ‚ąą core`, a self
őī ‚ąą slotAt ő≥ forces `p ő≥ = .left` outright.  Forest case is now closed via
F1k (slot ‚äÜ promoted) + F1n-2e (promoted component ‚Č† source). -/
private theorem forestComponentForestChoiceOuterSubgraph_pő≥_eq_left_of_slotAt_self_strong
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hCompOuter :
      (forestComponentForestChoiceOuterSubgraph A p hA).HasNonemptyComponents)
    (hSelf :
      ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p hA ő≥,
        őī.1 = ő≥.1) :
    p ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left := by
  classical
  rcases hSelf with ‚ü®őī, hőīSlot, hőīEq‚ü©
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p ő≥ (Finset.mem_attach A.elements ő≥)) with hLeft | hRight | ‚ü®B, hForest‚ü©
  ¬∑ exact hLeft
  ¬∑ -- right case ruled out by F1l-4a
    exact absurd hRight
