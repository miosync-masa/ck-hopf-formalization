/-- Sprint F2i-3q-4l-1-defs: outer "Left" components — those `η ∈ A_final.elements`
not absorbed by any forest-type δ.  These are the components destined for the
`.left` choice on the v3 source subgraph. -/
private noncomputable def forestQuotientForestSigmaForestCoverLeftComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  r.1.1.1.elements.filter
    (fun η => η ∉ forestQuotientForestSigmaForestCoverAllPromotedComponents g r)

/-- Sprint F2i-3q-4l-1-defs: membership for `AllPromotedComponents`. -/
private theorem forestQuotientForestSigmaForestCoverAllPromotedComponents_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {η : FeynmanSubgraph (repG g).toFeynmanGraph} :
