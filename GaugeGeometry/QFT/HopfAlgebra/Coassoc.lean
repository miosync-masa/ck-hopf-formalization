/-! ### Track B-forest-final-1 ‚ÄĒ star-touching separation of `Right` from `Remnant`

The quotient-side forest `ActualQuotientComponents = Right.elements ‚ą™ RemnantComponents`
is a vertex-disjoint union, but to *extract* the `Remnant` part from a quotient
equality we need an intrinsic predicate separating the two.  The separator is
**"the component contains a canonical star of the spliced outer forest"**:
- a `Remnant` component is `ő≥` contracted by its promoted children, so it
  contains their stars (Target 2), while
- a `Right` survivor avoids the outer carrier entirely, so its retarget is the
  identity and its vertices stay in the ambient graph ‚ÄĒ never a (fresh) star
  (Target 1).
The genuine-forest index forces every `.forest B` choice to have `B` a *proper*
(nonempty, positive-edge) forest, so a promoted child always exists; this is why
Target 2 holds (and is exactly where an empty-`B` forest choice would have broken
separation ‚ÄĒ the index excludes it via `0 < B.internalEdges.card`). -/
private def forestComponentForestChoiceTouchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (őī : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) : Prop :=
  ‚ąÉ ő∑ ‚ąą (forestComponentForestChoiceOuterIndex g q hq).1.elements,
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
      ő∑ ‚ąą őī.vertices

/-- **Target 1.**  A right-selected survivor component (in the quotient) does
*not* touch any canonical outer star: its retarget is the identity (it avoids the
outer carrier), so its vertices stay in the ambient graph, while the stars are
fresh. -/
private theorem forestComponentForestChoiceRight_not_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    {őī : FeynmanSubgraph (forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq))}
    (hőī : őī ‚ąą (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
      g q hq).elements) :
    ¬¨ forestComponentForestChoiceTouchesOuterStar g q hq őī := by
  classical
  rintro ‚ü®ő∑, hő∑Outer, hStarMem‚ü©
  rcases forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
      g q hq hőī with ‚ü®ő≥R, rfl‚ü©
  rcases ő≥R with ‚ü®ő≥R, hő≥R‚ü©
  set Aout := (forestComponentForestChoiceOuterIndex g q hq).1 with hAoutDef
  set starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2 with hStarOfDef
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hRightVertices :
      (admissibleSubgraphRetargetSubgraph Aout starOf ő≥R
        (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥R hő≥R)).vertices =
        ő≥R.vertices := by
    refine admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      Aout starOf ő≥R
      (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥R hő≥R) ?_
    intro v hv
    simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q.1.1 q.2 hDisjA hő≥R hv
  have hFresh : Aout.IsFreshStarAssignment starOf := by
    dsimp [Aout, starOf]
    exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hStar' :
      starOf ő∑ ‚ąą
        (admissibleSubgraphRetargetSubgraph Aout starOf ő≥R
          (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥R hő≥R)).vertices := by
    simpa [Aout, starOf] using hStarMem
  rw [hRightVertices] at hStar'
  exact hFresh.fresh hő∑Outer (ő≥R.vertices_subset hStar')

/-- **Target 2.**  A remnant component (in the quotient) touches a canonical outer
star: it is `ő≥` contracted by its proper (nonempty) promoted forest `B`, so a
promoted child `ő∑ ‚äÜ ő≥` exists in the outer carrier, and `starOf ő∑` lands in the
remnant by `admissibleSubgraph_star_mem_remainder_vertices_iff_intersects`. -/
private theorem forestComponentForestChoiceRemnant_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    {őī : FeynmanSubgraph (forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq))}
    (hőī : őī ‚ąą forestComponentForestChoiceRemnantComponents g q hq) :
    forestComponentForestChoiceTouchesOuterStar g q hq őī := by
  classical
  rcases forestComponentForestChoiceRemnantComponents_mem_exists g q hq hőī with
    ‚ü®ő≥F, B, hB, rfl‚ü©
  have hpCore : q.2 ‚ąą forestComponentCoreChoiceIndex q.1.1 := by
    have hpForest : q.2 ‚ąą forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    exact (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hPromoteProper :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem hpCore ő≥F hB
  have hProperData :=
    ((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      hPromoteProper
  have hPromoteNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥F.1
        (q.1.1.isConnectedDivergent_of_mem ő≥F.2) B).elements.Nonempty :=
    (((repG g).toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs _).mp
      hProperData.1).2
  obtain ‚ü®ő∑, hő∑Promote‚ü© := hPromoteNE
  have hő∑NE : ő∑.IsNonempty := hProperData.2.1 ő∑ hő∑Promote
  obtain ‚ü®v, hvő∑‚ü© := Finset.card_pos.mp hő∑NE
  have hő∑PromotedComp :
      ő∑ ‚ąą forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
    forestComponentChoicePromotedForestComponents_mem_of_forest q.1.1 q.2 ő≥F hB hő∑Promote
  have hő∑Outer : ő∑ ‚ąą (forestComponentForestChoiceOuterIndex g q hq).1.elements := by
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union.mpr (Or.inr hő∑PromotedComp)
  have hvő≥F : v ‚ąą ő≥F.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő≥F.1 (q.1.1.isConnectedDivergent_of_mem ő≥F.2) B hő∑Promote hvő∑
  refine ‚ü®ő∑, hő∑Outer, ?_‚ü©
  exact (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
    (forestComponentForestChoiceOuterIndex g q hq).1
    (forestComponentForestChoiceOuterIndex g q hq).2
    ő≥F.1 hő∑Outer).mpr ‚ü®v, hvő∑, hvő≥F‚ü©

/-- Selected component-forest quotient remnants are mutually compatible after
retargeting through the spliced outer forest. -/
private theorem forestComponentForestChoiceRemnantComponents_disjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    ‚ąÄ őī‚āĀ, őī‚āĀ ‚ąą forestComponentForestChoiceRemnantComponents g q hq ‚Üí
      ‚ąÄ őī‚āā, őī‚āā ‚ąą forestComponentForestChoiceRemnantComponents g q hq ‚Üí
        őī‚āĀ ‚Č† őī‚āā ‚Üí őī‚āĀ.Disjoint őī‚āā := by
  classical
  intro őī‚āĀ hőī‚āĀ őī‚āā hőī‚āā hne
  rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hőī‚āĀ with
    ‚ü®ő≥‚āĀ, B‚āĀ, hB‚āĀ, rfl‚ü©
  rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hőī‚āā with
    ‚ü®ő≥‚āā, B‚āā, hB‚āā, rfl‚ü©
  by_cases hő≥ : ő≥‚āĀ.1 = ő≥‚āā.1
  ¬∑ have hő≥sub : ő≥‚āĀ = ő≥‚āā := Subtype.ext hő≥
    subst ő≥‚āā
    exact False.elim (hne rfl)
  ¬∑
    let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let starOf :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    have hDisjA : q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
    have hFresh : Aout.IsFreshStarAssignment starOf := by
