      exact Finset.disjoint_left.mp hRdisj hv2
        (AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő≥‚āĀ, hL1, hv1‚ü©)
  ¬∑ rcases Finset.mem_union.mp hő≥‚āā with hL2 | hR2
    ¬∑ -- R vs L: symmetric
      have hRdisj :=
        forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
          g r hNotForest ő≥‚āĀ hR1
      refine Finset.disjoint_left.mpr fun v hv1 hv2 => ?_
      exact Finset.disjoint_left.mp hRdisj hv1
        (AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő≥‚āā, hL2, hv2‚ü©)
    ¬∑ -- R vs R: lift transport from actualQuotient.IsPairwiseDisjoint
      unfold forestQuotientForestSigmaMixedLiftedRightComponents at hR1 hR2
      rcases Finset.mem_image.mp hR1 with ‚ü®‚ü®őī‚āĀ, hőī‚āĀ‚ü©, _, hEq‚āĀ‚ü©
      rcases Finset.mem_image.mp hR2 with ‚ü®‚ü®őī‚āā, hőī‚āā‚ü©, _, hEq‚āā‚ü©
      have hőīne : őī‚āĀ ‚Č† őī‚āā := by
        intro h; apply hne; rw [‚Üź hEq‚āĀ, ‚Üź hEq‚āā]; subst h; rfl
      have hőīDisj := hActualIPD hőī‚āĀ hőī‚āā hőīne
      rw [‚Üź hEq‚āĀ, ‚Üź hEq‚āā]
