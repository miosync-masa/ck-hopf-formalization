/-- Sprint F2i-3g helper: an ambient endpoint whose retarget lies in δ-vertex
belongs to the recovered source vertices.  Two cases: (i) ambient endpoint
∉ A.vertices — retarget is identity, endpoint equals δ-side, and is
non-star (because ambient G.vertices is disjoint from fresh star
vertices); F2i-3a `_nonstar_mem` applies.  (ii) ambient endpoint
∈ A.vertices — `componentAt` returns η ∈ A.elements with endpoint ∈
η.vertices, retarget collapses to `starOf η ∈ δ.vertices`; F2i-3a
`_eta_subset` applies. -/
private theorem forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {v : VertexId} (hvG : v ∈ (repG g).toFeynmanGraph.vertices)
    {v' : VertexId}
    (hRet :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v = v')
    (hv'δ : v' ∈ δ.vertices) :
    v ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  classical
  by_cases hvA : v ∈ r.1.1.1.vertices
  · -- v ∈ A.vertices: componentAt v gives η ∈ A.elements with v ∈ η.vertices.
    set η := r.1.1.1.componentAt hvA with hηDef
    have hηA : η ∈ r.1.1.1.elements := r.1.1.1.componentAt_mem hvA
    have hvη : v ∈ η.vertices := r.1.1.1.componentAt_vertex_mem hvA
    have hRetη :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v =
          FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η := by
      rw [AdmissibleSubgraph.retargetVertex, r.1.1.1.componentAt?_of_mem hvA]
    have hStarEq : FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η = v' :=
      hRetη.symm.trans hRet
    have hStarη : FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices := by
      rw [hStarEq]; exact hv'δ
    exact (forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hηA hStarη) hvη
  · -- v ∉ A.vertices: retarget is identity, v ∈ G.vertices ∉ A.starVertices (fresh).
    have hRetId := AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) hvA
    have hvEq : v = v' := hRetId.symm.trans hRet
    have hFresh := FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
    have hvNotStar : v ∉ r.1.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) := fun hStar =>
      hFresh.star_not_mem_vertices hStar hvG
    have hvδ : v ∈ δ.vertices := hvEq.symm ▸ hv'δ
    exact forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem
      g r hvδ hvNotStar

/-- Sprint F2i-3g: every δ-edge has at least one ambient preimage with
endpoints in the recovered source vertices.  Multiset existence; no
uniqueness, no global construction yet. -/
private theorem forestQuotientForestSigmaForestCover_edgePreimage_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e' : FeynmanEdge} (he' : e' ∈ δ.internalEdges) :
    ∃ e : FeynmanEdge,
      e ∈ (repG g).toFeynmanGraph.internalEdges ∧
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e = e' ∧
      e.source ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
      e.target ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  classical
  have he'Q : e' ∈ (forestOuterActualQuotientGraph g r.1.1).internalEdges :=
    Multiset.mem_of_le δ.internalEdges_le he'
  unfold forestOuterActualQuotientGraph at he'Q
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges] at he'Q
  rcases Multiset.mem_map.mp he'Q with ⟨e, heC, hRet⟩
  have heG : e ∈ (repG g).toFeynmanGraph.internalEdges :=
    AdmissibleSubgraph.mem_ambientInternalEdges_of_mem_complementEdges _ heC
  have heSupp := δ.edges_supported e' he'
  have hRetSrc :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.source = e'.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRetTgt :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.target = e'.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have heGsupp := FeynmanGraph.wellFormed_internal (repG_wellFormed g) heG
  refine ⟨e, heG, hRet, ?_, ?_⟩
  · exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r δ heGsupp.1 hRetSrc heSupp.1
  · exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r δ heGsupp.2 hRetTgt heSupp.2

/-- Sprint F2i-3h: chosen ambient preimage edge for a single δ-edge.
Wraps `Classical.choose` over F2i-3g's existence statement. -/
private noncomputable def forestQuotientForestSigmaForestCoverEdgePreimageOf
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (e' : {e' : FeynmanEdge // e' ∈ δ.internalEdges}) :
    FeynmanEdge :=
  Classical.choose
    (forestQuotientForestSigmaForestCover_edgePreimage_exists g r δ e'.2)

/-- Sprint F2i-3h spec 1: chosen preimage is in ambient internal edges. -/
private theorem forestQuotientForestSigmaForestCoverEdgePreimageOf_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (e' : {e' : FeynmanEdge // e' ∈ δ.internalEdges}) :
    forestQuotientForestSigmaForestCoverEdgePreimageOf g r δ e' ∈
      (repG g).toFeynmanGraph.internalEdges :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCover_edgePreimage_exists g r δ e'.2)).1

/-- Sprint F2i-3h spec 2: chosen preimage retargets back to the δ-edge. -/
private theorem forestQuotientForestSigmaForestCoverEdgePreimageOf_retarget
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (e' : {e' : FeynmanEdge // e' ∈ δ.internalEdges}) :
    r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverEdgePreimageOf g r δ e') =
      e'.1 :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCover_edgePreimage_exists g r δ e'.2)).2.1

/-- Sprint F2i-3h spec 3: chosen preimage endpoints lie in source vertices. -/
private theorem forestQuotientForestSigmaForestCoverEdgePreimageOf_endpoints
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (e' : {e' : FeynmanEdge // e' ∈ δ.internalEdges}) :
    (forestQuotientForestSigmaForestCoverEdgePreimageOf g r δ e').source ∈
