/-- Sprint F2i-3o-2g helper: if two multisets are `Multiset.Disjoint`, then
subtraction by one leaves the other unchanged.  Pure count calculation. -/
private theorem Multiset.sub_eq_self_of_disjoint
    {őĪ : Type*} [DecidableEq őĪ] {s t : Multiset őĪ}
    (h : Disjoint s t) :
    s - t = s := by
  ext x
  by_cases hx : x ‚ąą s
  ¬∑ have hxt : x ‚ąČ t := (Multiset.disjoint_left.mp h) hx
    have ht0 : Multiset.count x t = 0 := Multiset.count_eq_zero_of_notMem hxt
    rw [Multiset.count_sub, ht0, Nat.sub_zero]
  ¬∑ have hs0 : Multiset.count x s = 0 := Multiset.count_eq_zero_of_notMem hx
    rw [Multiset.count_sub, hs0, Nat.zero_sub]

