      _ =
          (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges +
            (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
              g q hq).internalEdges := by
            rw [forestComponentForestChoiceActualRightQuotientSubgraphCanonical_internalEdges_eq_right]
      _ =
          (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges.map f +
            (∑ γ ∈ q.1.1.elements.attach,
              match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  (γ.1.internalEdges - Aout.internalEdges).map f) := by
            rw [hRem]
            rw [forestComponentForestChoice_right_internalEdges_outerRetarget_eq]
      _ =
          (q.1.1.internalEdges - Aout.internalEdges).map f := by
            rw [hSourceMap, hSourceRemap]

