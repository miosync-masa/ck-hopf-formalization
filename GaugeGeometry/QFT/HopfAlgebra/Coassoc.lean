private theorem forestComponentForestChoiceSplitStarOf_isFresh_of_injective
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentForestChoiceSplitStarInjectivityPayload) :
    ‚ąÄ g q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      ‚ąÄ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
        q.1.1.IsFreshStarAssignment
          (forestComponentForestChoiceSplitStarOf g q hq C) := by
  intro g q hq C
  constructor
  ¬∑ intro ő≥ hő≥
    exact forestComponentForestChoiceSplitStarOf_point_fresh g q hq C hő≥
  ¬∑ intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hstar
    exact T.inj g q hq C ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hstar

