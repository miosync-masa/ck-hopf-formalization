private theorem
    forestComponentForestChoiceActualQuotientInternalEdgesModelOfSourceSplit
    [IsDivergencePreservedByAdmissibleForestContract]
    (S : forestComponentForestChoiceSourceInternalEdgesSplitModel) :
    forestComponentForestChoiceActualQuotientInternalEdgesModel where
  internalEdges := by
    intro g q hq
    classical
    let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let outerStar :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph Aout
        (forestComponentForestChoiceOuterIndex g q hq).2
    let f := Aout.retargetEdge outerStar
    have hRem :
        (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
          g q hq).internalEdges =
          ∑ γ ∈ q.1.1.elements.attach,
            match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                (γ.1.internalEdges - Aout.internalEdges).map f := by
      rw [forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical_internalEdges_eq_sum_forChoice]
      apply Finset.sum_congr rfl
      intro γ _hγ
      cases hChoice : q.2 γ (Finset.mem_attach q.1.1.elements γ) with
      | left =>
          simp [forestComponentForestChoiceRemnantComponentsForChoice, hChoice]
      | right =>
          simp [forestComponentForestChoiceRemnantComponentsForChoice, hChoice]
      | forest B =>
          let rem :
              FeynmanSubgraph
                (forestOuterActualQuotientGraph g
                  (forestComponentForestChoiceOuterIndex g q hq)) :=
            admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γ.1
          rw [show
            forestComponentForestChoiceRemnantComponentsForChoice g q hq γ
                (Finset.mem_attach q.1.1.elements γ) =
              ({rem} :
                Finset (FeynmanSubgraph
                  (forestOuterActualQuotientGraph g
                    (forestComponentForestChoiceOuterIndex g q hq)))) by
              simp [forestComponentForestChoiceRemnantComponentsForChoice,
                hChoice, rem, Aout, outerStar]
              rfl]
          change (∑ δ ∈ ({rem} :
              Finset (FeynmanSubgraph
                (forestOuterActualQuotientGraph g
                  (forestComponentForestChoiceOuterIndex g q hq)))),
              δ.internalEdges) = rem.internalEdges
          rw [Finset.sum_eq_single rem]
          · intro δ hδ hne
            exact False.elim (hne (Finset.mem_singleton.mp hδ))
          · intro hrem
            exact False.elim (hrem (Finset.mem_singleton_self rem))
    have hSourceMap :
        (q.1.1.internalEdges - Aout.internalEdges).map f =
          (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges.map f +
            (∑ γ ∈ q.1.1.elements.attach,
              match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  γ.1.internalEdges - Aout.internalEdges).map f := by
      rw [S.internalEdges g q hq]
      rw [Multiset.map_add]
    have hSourceRemap :
        (∑ γ ∈ q.1.1.elements.attach,
              match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  γ.1.internalEdges - Aout.internalEdges).map f =
          ∑ γ ∈ q.1.1.elements.attach,
            match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                (γ.1.internalEdges - Aout.internalEdges).map f := by
      change
        (Multiset.mapAddMonoidHom f)
            (∑ γ ∈ q.1.1.elements.attach,
              match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
              | forestCoproductChoice.left => 0
              | forestCoproductChoice.right => 0
              | forestCoproductChoice.forest _B =>
                  γ.1.internalEdges - Aout.internalEdges) =
          ∑ γ ∈ q.1.1.elements.attach,
            match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
            | forestCoproductChoice.left => 0
            | forestCoproductChoice.right => 0
            | forestCoproductChoice.forest _B =>
                (γ.1.internalEdges - Aout.internalEdges).map f
      rw [map_sum (Multiset.mapAddMonoidHom f)]
      apply Finset.sum_congr rfl
      intro γ _hγ
      cases q.2 γ (Finset.mem_attach q.1.1.elements γ) <;> rfl
    calc
      (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq).internalEdges =
          (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
            g q hq).internalEdges +
            (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
              g q hq).internalEdges := by
            exact forestComponentForestChoiceActualQuotientSubgraphCanonical_internalEdges_eq_right_add_remnant
