/-- A genuine-forest quotient properness certificate places the branch target
of `ŌÜ` in the RHS quotient-forest finite carrier. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceActualQuotientProperCertificate g q hq) :
    forestComponentForestChoiceToQuotientForestSigma g q hq ‚ąą
      forestQuotientForestSigmaIndex g := by
  classical
  unfold forestQuotientForestSigmaIndex
  apply Finset.mem_sigma.mpr
  refine ‚ü®?_, ?_‚ü©
  ¬∑ apply Finset.mem_filter.mpr
    refine ‚ü®Finset.mem_attach _ _, ?_‚ü©
    have hpForest :
        q.2 ‚ąą forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    have hpCore :
        q.2 ‚ąą forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
    have hAcomp : 0 < q.1.1.complementEdges.card :=
      (Finset.mem_filter.mp (Finset.mem_sigma.mp hq).1).2
    have hDisj :
        q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          q.1.2
    exact admissibleSubgraph_complementEdges_card_pos_of_internalEdges_le
      (forestComponentForestChoiceOuterSubgraph_internalEdges_le_original
        q.1.1 q.2 hpCore hDisj)
      hAcomp
  ¬∑ change forestComponentForestChoiceRepQuotientSubgraphCanonical
        g q hq ‚ąą
        ((forestOuterQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq)
        ).properDisjointAdmissibleDivergentSubgraphs).filter
          (fun A => 0 < A.complementEdges.card)
    exact Finset.mem_filter.mpr ‚ü®
      forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint
        g q hq C,
      ForestComponentForestChoiceRepQuotientComplementPositiveModel.positive
        g q hq‚ü©

/-- The genuine-forest branch target of `ŌÜ` lands in the RHS finite carrier
once the exact remaining remnant positivity payload is supplied. -/
