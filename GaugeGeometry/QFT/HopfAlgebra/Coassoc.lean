          forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī
          ‚Č§ r.1.1.1.complementEdges +
              forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī :=
        add_le_add
          (forestQuotientForestSigmaForestCoverExactInternalEdges_le_complementEdges
            g r őī)
          (le_refl _)
      _ ‚Č§ r.1.1.1.complementEdges + r.1.1.1.internalEdges :=
        add_le_add (le_refl _)
          (forestQuotientForestSigmaForestCoverPromotedInternalEdges_le_outer g r őī)
      _ = (repG g).toFeynmanGraph.internalEdges := by
        unfold AdmissibleSubgraph.complementEdges
        exact Multiset.sub_add_cancel hAIle
  externalLegs_le :=
    forestQuotientForestSigmaForestCoverExactExternalLegs_le g r őī
  edges_supported := by
    intro e he
    rcases Multiset.mem_add.mp he with heE | heP
    ¬∑ exact forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints
        g r őī heE
    ¬∑ exact forestQuotientForestSigmaForestCoverPromotedInternalEdges_endpoints
        g r őī heP
  legs_supported := by
    intro ‚Ąď h‚Ąď
    exact forestQuotientForestSigmaForestCoverExactExternalLegs_attached g r őī h‚Ąď

