  have hδCD : δ.IsConnectedDivergent :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem hδmem
  -- `d := retarget e` is a δ-edge; δ is 1PI so `δ∖d` is connected.
