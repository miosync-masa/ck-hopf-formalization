/-- Witness form of source-side remnant positivity: for every genuine component
forest choice, exhibit one internal edge that survives outside the outer splice. -/
private structure forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) : Type where
  edge :
    ‚ąÄ ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph //
        ő≥ ‚ąą q.1.1.elements},
      ‚ąÄ B : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph,
        q.2 ő≥ (Finset.mem_attach q.1.1.elements ő≥) =
          forestCoproductChoice.forest B ‚Üí
