          simpa [forestComponentSplitChoiceSigmaIndex, hp] using hmem
        refine ‚ü®q, hq, ?_‚ü©
        rw [hp, forestComponentSplitPhi_inl_of_mem g q hq] at hright
        exact hright
    | inr q =>
        right
        have hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g := by
          simpa [forestComponentSplitChoiceSigmaIndex, hp] using hmem
        refine ‚ü®q, hq, ?_‚ü©
        rw [hp, forestComponentSplitPhi_inr_of_mem g q hq] at hright
        exact hright

/-- A concrete inverse construction supplies same-branch injectivity and
cross-branch separation for the branch targets. -/
private def
    forestComponentSplitPhiBranchInjectivitySeparationOfInverseConstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiInverseConstruction g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    have hq‚āĀSplit :
        Sum.inl q‚āĀ ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āĀ
    have hq‚āāSplit :
        Sum.inl q‚āā ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
    have h‚āĀ := X.left_inv (Sum.inl q‚āĀ) hq‚āĀSplit
    have h‚āā := X.left_inv (Sum.inl q‚āā) hq‚āāSplit
    rw [forestComponentSplitPhi_inl_of_mem g q‚āĀ hq‚āĀ] at h‚āĀ
    rw [forestComponentSplitPhi_inl_of_mem g q‚āā hq‚āā] at h‚āā
    apply Sum.inl.inj
    calc
      Sum.inl q‚āĀ = X.inv (forestComponentForestChoiceToQuotientForestSigma g q‚āĀ hq‚āĀ) :=
        h‚āĀ.symm
      _ = X.inv (forestComponentForestChoiceToQuotientForestSigma g q‚āā hq‚āā) := by
        rw [hŌÜ]
      _ = Sum.inl q‚āā := h‚āā
  mixed_inj := by
    intro q‚āĀ hq‚āĀ q‚āā hq‚āā hŌÜ
    have hq‚āĀSplit :
        Sum.inr q‚āĀ ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āĀ
    have hq‚āāSplit :
        Sum.inr q‚āā ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq‚āā
    have h‚āĀ := X.left_inv (Sum.inr q‚āĀ) hq‚āĀSplit
    have h‚āā := X.left_inv (Sum.inr q‚āā) hq‚āāSplit
    rw [forestComponentSplitPhi_inr_of_mem g q‚āĀ hq‚āĀ] at h‚āĀ
    rw [forestComponentSplitPhi_inr_of_mem g q‚āā hq‚āā] at h‚āā
    apply Sum.inr.inj
    calc
      Sum.inr q‚āĀ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g q‚āĀ hq‚āĀ) :=
        h‚āĀ.symm
      _ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g q‚āā hq‚āā) := by
        rw [hŌÜ]
      _ = Sum.inr q‚āā := h‚āā
  cross := by
    intro qF hF qM hM hŌÜ
    have hFSplit :
        Sum.inl qF ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hF
    have hMSplit :
        Sum.inr qM ‚ąą forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hM
    have hFInv := X.left_inv (Sum.inl qF) hFSplit
    have hMInv := X.left_inv (Sum.inr qM) hMSplit
    rw [forestComponentSplitPhi_inl_of_mem g qF hF] at hFInv
    rw [forestComponentSplitPhi_inr_of_mem g qM hM] at hMInv
    have hsum : Sum.inl qF = Sum.inr qM := by
      calc
        Sum.inl qF =
            X.inv (forestComponentForestChoiceToQuotientForestSigma g qF hF) :=
          hFInv.symm
        _ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g qM hM) := by
          rw [hŌÜ]
        _ = Sum.inr qM := hMInv
    cases hsum

/-- A concrete inverse construction supplies the RHS branch cover. -/
