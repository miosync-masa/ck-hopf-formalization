    (fun ő∑ => ő∑.internalEdges)

/-- Sprint F2i-3o-2d main: an exact preimage edge can never lie inside the
non-promoted internal edges.  Proof: if `e ‚ąą NonPromotedInternalEdges`, then
some non-promoted `ő∑ ‚ąč e` exists with `starOf ő∑ ‚ąČ őī.vertices`.  But by
`ExactInternalEdges_map`, the retarget of `e` lies in `őī.internalEdges`, so
its source `= retargetVertex e.source = starOf ő∑` (pairwise-disjoint retarget)
must lie in `őī.vertices` (by `őī.edges_supported`).  Contradiction. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_not_mem_nonPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (heE : e ‚ąą forestQuotientForestSigmaForestCoverExactInternalEdges g r őī) :
    e ‚ąČ forestQuotientForestSigmaForestCoverNonPromotedInternalEdges g r őī := by
  classical
  intro heNP
  unfold forestQuotientForestSigmaForestCoverNonPromotedInternalEdges at heNP
  rcases Multiset.mem_sum.mp heNP with ‚ü®ő∑, hő∑Non, heő∑‚ü©
  rw [forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff]
    at hő∑Non
  obtain ‚ü®hő∑A, hStarNotIn‚ü© := hő∑Non
  have hSupp : e.source ‚ąą ő∑.vertices ‚ąß e.target ‚ąą ő∑.vertices :=
    ő∑.edges_supported e heő∑
  have hDisj : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hRet :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.source =
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hDisj _ hő∑A hSupp.1
  have hMap :=
    forestQuotientForestSigmaForestCoverExactInternalEdges_map g r őī
  have hfe :
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e ‚ąą őī.internalEdges := by
    rw [‚Üź hMap]
    exact Multiset.mem_map_of_mem _ heE
  have hSrcInőī :
      (r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e).source ‚ąą őī.vertices :=
    (őī.edges_supported _ hfe).1
  rw [AdmissibleSubgraph.retargetEdge_source, hRet] at hSrcInőī
  exact hStarNotIn hSrcInőī

/-- Sprint F2i-3o-2d': promoted ‚ą™ non-promoted components recover the full
outer forest `A.elements`.  Each ő∑ ‚ąą A.elements lies in exactly one side
depending on whether `starOf ő∑ ‚ąą őī.vertices`. -/
private theorem forestQuotientForestSigmaForestCover_promoted_union_nonPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverPromotedComponents g r őī ‚ą™
      forestQuotientForestSigmaForestCoverNonPromotedComponents g r őī =
      r.1.1.1.elements := by
  classical
  ext ő∑
  constructor
  ¬∑ intro h
    rcases Finset.mem_union.mp h with hP | hNP
    ¬∑ exact (forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r őī).mp hP |>.1
    ¬∑ exact (forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
        g r őī).mp hNP |>.1
  ¬∑ intro hő∑
    by_cases hStar :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices
    ¬∑ exact Finset.mem_union_left _
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
          g r őī).mpr ‚ü®hő∑, hStar‚ü©)
    ¬∑ exact Finset.mem_union_right _
        ((forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff
          g r őī).mpr ‚ü®hő∑, hStar‚ü©)

/-- Sprint F2i-3o-2d': promoted and non-promoted components are disjoint as
finsets of forest elements.  The predicates `starOf ő∑ ‚ąą őī.vertices` and
`starOf ő∑ ‚ąČ őī.vertices` are mutually exclusive. -/
private theorem forestQuotientForestSigmaForestCover_promoted_disjoint_nonPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Disjoint
      (forestQuotientForestSigmaForestCoverPromotedComponents g r őī)
      (forestQuotientForestSigmaForestCoverNonPromotedComponents g r őī) := by
  classical
  rw [Finset.disjoint_left]
  intro ő∑ hP hNP
  rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff] at hP
  rw [forestQuotientForestSigmaForestCover_mem_nonPromotedComponents_iff] at hNP
  exact hNP.2 hP.2

/-- Sprint F2i-3o-2d' optional: convenience symmetric form of the union
identity, expressing `A.elements` as the partition. -/
private theorem forestQuotientForestSigmaForestCover_elements_eq_promoted_union_nonPromoted
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    r.1.1.1.elements =
      forestQuotientForestSigmaForestCoverPromotedComponents g r őī ‚ą™
        forestQuotientForestSigmaForestCoverNonPromotedComponents g r őī :=
  (forestQuotientForestSigmaForestCover_promoted_union_nonPromotedComponents
    g r őī).symm

