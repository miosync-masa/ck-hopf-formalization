/-- Sprint F2i-3q-4l-actual-4m-step2-right-generic: q-independent
`ActualRightQuotient` equality.  Forest analog of mixed F2h-6b Step 2
([Coassoc.lean:15335]).  Given generic q with outer-index match + right-
subgraph match (= RightCandidate_v3), the actual right quotient subgraph
transported via `hOuter` recovers `RightActualSubgraph` (no-star part of D).
Replaces mixed's `_all_noStar_of_not_isForestByStar` (which only applies in
mixed case) with per-element no-star extraction via `RightComponents_mem`. -/
private theorem forestComponentForestChoiceActualRightQuotientSubgraph_eq_of_outer_v3
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter : forestComponentForestChoiceOuterIndex g q hq = r.1.1)
    (hRight :
      forestComponentChoiceRightSubgraph q.1.1 q.2 =
        forestQuotientForestSigmaForestCoverRightCandidate_v3 g r) :
    hOuter ▸
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q hq
      = forestQuotientForestSigmaForestCoverRightActualSubgraph g r := by
  classical
  obtain ⟨⟨A, D⟩, hr⟩ := r
  cases hOuter
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  apply Finset.ext
  intro δ
  constructor
  · -- Forward
    intro hδLHS
    rcases Finset.mem_image.mp hδLHS with ⟨γ, _, hRetγ⟩
    obtain ⟨γ_val, γ_mem_orig⟩ := γ
    have γ_mem_lifted : γ_val ∈
        forestQuotientForestSigmaForestCoverLiftedRightComponents
          g ⟨⟨_, D⟩, hr⟩ := by
      rw [← forestQuotientForestSigmaForestCoverRightCandidate_v3_elements
        g ⟨⟨_, D⟩, hr⟩, ← hRight]
      exact γ_mem_orig
    rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
      g ⟨⟨_, D⟩, hr⟩ γ_mem_lifted with ⟨δ₀, hδ₀Right, hNoStarδ₀, hLiftEq⟩
    subst hLiftEq
    have hRetEq :=
      forestOuterActualQuotientNoStarComponentLift_retarget_eq
        g (forestComponentForestChoiceOuterIndex g q hq) δ₀ hNoStarδ₀
        (forestComponentForestChoiceRightRetarget_edge_le g q hq _ γ_mem_orig)
    have hδEqδ₀ : δ = δ₀ := hRetγ.symm.trans hRetEq
    rw [hδEqδ₀]
    exact hδ₀Right
  · -- Backward
    intro hδRHS
    have hδInRC :
        δ ∈ forestQuotientForestSigmaForestCoverRightComponents
          g ⟨⟨_, D⟩, hr⟩ := hδRHS
    have hδRightMem :=
      (forestQuotientForestSigmaForestCoverRightComponents_mem g ⟨⟨_, D⟩, hr⟩).mp hδInRC
    have hNoStarδ := hδRightMem.2
    set lifted := forestOuterActualQuotientNoStarComponentLift g
      (forestComponentForestChoiceOuterIndex g q hq) δ hNoStarδ with hLiftedDef
    have hLiftedRight :
        lifted ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents
          g ⟨⟨_, D⟩, hr⟩ := by
      unfold forestQuotientForestSigmaForestCoverLiftedRightComponents
      exact Finset.mem_image.mpr ⟨⟨δ, hδInRC⟩, Finset.mem_attach _ _, rfl⟩
    have hLiftedInRightSubgraph : lifted ∈
        (forestComponentChoiceRightSubgraph q.1.1 q.2).elements := by
      rw [hRight, forestQuotientForestSigmaForestCoverRightCandidate_v3_elements]
      exact hLiftedRight
    refine Finset.mem_image.mpr
      ⟨⟨lifted, hLiftedInRightSubgraph⟩, Finset.mem_attach _ _, ?_⟩
    exact forestOuterActualQuotientNoStarComponentLift_retarget_eq
      g (forestComponentForestChoiceOuterIndex g q hq) δ hNoStarδ _

/-- Sprint F2i-3q-4f-1: vertex-disjointness between lifted right-type and
lifted forest-type components — **axiom-free**.  The key invariants:
- `δ_R.V` is in `G.V \ A_final.V` (no-star),
- `Plus(δ_F).V` non-star part = `δ_F.V \ stars` ⊆ `δ_F.V`,
- `Plus(δ_F).V` promoted part = `⋃ η.V` for `η ∈ A_final.elements` ⊆ `A_final.V`.

The "promoted" branch directly contradicts `v ∉ A_final.V`; the "non-star"
branch uses `D.IsPairwiseDisjoint` (chained from `r.2`'s `forestCoproduct
ProperForestIndex` membership via `mapPermAdmissibleSubgraphPreimage`
and `properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint`). -/
private theorem forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForest_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γR γF : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hR : γR ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
    (hF : γF ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    Disjoint γR.vertices γF.vertices := by
  classical
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hR with ⟨δR, hδRRight, hNoStar, hEqR⟩
  rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    g r hF with ⟨δF, hδFForest, hEqF⟩
  rw [← hEqR, ← hEqF]
  rw [forestOuterActualQuotientNoStarComponentLift_vertices,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices]
  rw [Finset.disjoint_left]
  intro v hvR hvF
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hvF
  rcases Finset.mem_union.mp hvF with hLeft | hRight
  · -- non-star branch: v ∈ δF.V, use D.IsPairwiseDisjoint
    rcases Finset.mem_sdiff.mp hLeft with ⟨hvδF, _⟩
    have hδR_D :
        δR ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
      ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδRRight).1
    have hδF_D :
        δF ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδFForest).1
    have hδne : δR ≠ δF := by
      intro hδ
      have hCrossDisj :=
        forestQuotientForestSigmaForestCover_right_disjoint_forestComponents g r
      rw [Finset.disjoint_left] at hCrossDisj
      exact hCrossDisj hδRRight (hδ ▸ hδFForest)
    have hR2Proper :
        r.1.2 ∈ (forestOuterQuotientGraph g r.1.1
          ).properDisjointAdmissibleDivergentSubgraphs := by
      have hSigma := Finset.mem_sigma.mp r.2
      exact ((mem_forestCoproductProperForestIndex _ _).mp hSigma.2).1
    have hDProper :
        forestQuotientForestSigmaActualQuotientSubgraph g r.1 ∈
          (forestOuterActualQuotientGraph g r.1.1
            ).properDisjointAdmissibleDivergentSubgraphs := by
      unfold forestQuotientForestSigmaActualQuotientSubgraph
      exact mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
        (forestOuterActualToRepPerm_spec g r.1.1) hR2Proper
    have hDPairwise :
        (forestQuotientForestSigmaActualQuotientSubgraph
          g r.1).IsPairwiseDisjoint :=
      (forestOuterActualQuotientGraph g r.1.1
        ).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hDProper
    exact Finset.disjoint_left.mp (hDPairwise hδR_D hδF_D hδne) hvR hvδF
  · -- promoted branch: v ∈ η.V ⊆ A_final.V, contradicts noStar
    rcases Finset.mem_biUnion.mp hRight with ⟨η, hηA, hvIf⟩
    by_cases hStar :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δF.vertices
    · simp only [hStar, if_true] at hvIf
      have hvA : v ∈ r.1.1.1.vertices :=
        AdmissibleSubgraph.mem_vertices.mpr ⟨η, hηA, hvIf⟩
      have hvNotA :=
        (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
          g r.1.1 hNoStar hvR).2
      exact hvNotA hvA
    · simp only [hStar, if_false] at hvIf
      exact (Finset.notMem_empty v hvIf).elim

/-- Sprint F2i-3q-4f-2: Right-Forest NOD wrapper.  Vertex disjointness
(F2i-3q-4f-1) lifts trivially to `NestedOrDisjoint` via `Or.inr`. -/
private theorem forestQuotientForestSigmaForestCover_liftedRight_liftedForest_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γR γF : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hR : γR ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
    (hF : γF ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    γR.NestedOrDisjoint γF :=
