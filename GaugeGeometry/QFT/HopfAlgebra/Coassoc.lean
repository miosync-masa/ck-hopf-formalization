    (forestOuterActualQuotientGraph g
      (forestComponentMixedBoundaryOuterIndex g q hq))
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq)
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (forestOuterActualQuotientGraph g
        (forestComponentMixedBoundaryOuterIndex g q hq))
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq)
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
        g q hq))

private theorem forestComponentMixedBoundary_splitStar_vertices_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightContractGraph g q hq).vertices =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentMixedBoundarySplitStarOf g q hq)).vertices := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let A := q.1.1
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  let splitStar := forestComponentMixedBoundarySplitStarOf g q hq
  have hQvertices :
      Q.vertices = (G₀.vertices \ L.vertices) ∪ L.starVertices outerStar := by
    simp [Q, G₀, forestOuterActualQuotientGraph, L, Aout, outerStar,
      forestComponentMixedBoundaryOuterIndex_val,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices]
  have hAactVertices : Aact.vertices = R.vertices := by
    simpa [Aact, R] using
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hAvertices : A.vertices = L.vertices ∪ R.vertices := by
    simpa [A, L, R] using
      (forestComponentMixedBoundary_left_union_right_vertices g q hq).symm
  have hSplitStars :
      A.starVertices splitStar =
        L.starVertices splitStar ∪ R.starVertices splitStar := by
    simpa [A, L, R, splitStar] using
      forestComponentMixedBoundary_splitStar_starVertices_eq_union g q hq
  have hLeftStars :
      L.starVertices splitStar = L.starVertices outerStar := by
    simpa [L, Aout, outerStar, splitStar] using
      forestComponentMixedBoundary_left_splitStar_starVertices_eq_outer g q hq
  have hRightStars :
      R.starVertices splitStar = Aact.starVertices rightStar := by
    simpa [R, Aact, Q, rightStar, splitStar] using
      forestComponentMixedBoundary_right_splitStar_starVertices_eq_actualRight
        g q hq
  have hLStarFresh :
      ∀ {v}, v ∈ L.starVertices outerStar → v ∉ G₀.vertices := by
    intro v hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγL, rfl⟩
    have hFresh :
        Aout.IsFreshStarAssignment outerStar := by
      simpa [G₀, Aout, outerStar] using
        FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2
    exact hFresh.fresh (by
      simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using hγL)
  have hRsubsetG : R.vertices ⊆ G₀.vertices := by
    intro v hv
    simpa [G₀, R] using R.vertices_subset hv
  simp only [forestComponentMixedBoundaryActualRightContractGraph,
    FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices]
  ext v
  constructor
  · intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStarR
    · rcases Finset.mem_sdiff.mp hvDiff with ⟨hvQ, hvNotAct⟩
      rw [hQvertices] at hvQ
      rcases Finset.mem_union.mp hvQ with hvGnotL | hvLStar
      · rcases Finset.mem_sdiff.mp hvGnotL with ⟨hvG, hvNotL⟩
        refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ⟨hvG, ?_⟩
        rw [hAvertices, Finset.mem_union]
        exact fun hLR => hLR.elim hvNotL (fun hvR =>
          hvNotAct (by exact hAactVertices.symm ▸ hvR))
      · refine Finset.mem_union_right _ ?_
        rw [hSplitStars, hLeftStars]
        exact Finset.mem_union_left _ hvLStar
    · refine Finset.mem_union_right _ ?_
      rw [hSplitStars, hRightStars]
      exact Finset.mem_union_right _ hvStarR
  · intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStar
    · rcases Finset.mem_sdiff.mp hvDiff with ⟨hvG, hvNotA⟩
      refine Finset.mem_union_left _ ?_
      refine Finset.mem_sdiff.mpr ⟨?_, ?_⟩
      · rw [hQvertices]
        refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ⟨hvG, ?_⟩
        intro hvL
        exact hvNotA (by
          rw [hAvertices, Finset.mem_union]
          exact Or.inl hvL)
      · intro hvAct
        exact hvNotA (by
          rw [hAvertices, Finset.mem_union]
          exact Or.inr (by exact hAactVertices ▸ hvAct))
    · rw [hSplitStars, hLeftStars, hRightStars] at hvStar
      rcases Finset.mem_union.mp hvStar with hvLStar | hvRStar
      · refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ⟨?_, ?_⟩
        · rw [hQvertices]
          exact Finset.mem_union_right _ hvLStar
        · intro hvAct
          exact hLStarFresh hvLStar (hRsubsetG (by
            exact hAactVertices ▸ hvAct))
      · exact Finset.mem_union_right _ hvRStar

private theorem forestComponentMixedBoundary_twoStep_retargetVertex_eq_splitStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (v : VertexId) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          v) =
      q.1.1.retargetVertex
        (forestComponentMixedBoundarySplitStarOf g q hq) v := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let A := q.1.1
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  let splitStar := forestComponentMixedBoundarySplitStarOf g q hq
  have hADisj : A.IsPairwiseDisjoint :=
    G₀.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by simpa [G₀, A] using q.1.2)
  have hAoutDisj : Aout.IsPairwiseDisjoint := by
    simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using
      forestComponentChoiceLeftSubgraph_isPairwiseDisjoint q.1.1 q.2 hADisj
  have hAactDisj : Aact.IsPairwiseDisjoint :=
    Q.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  have hAoutVertices : Aout.vertices = L.vertices := by
    simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val]
  have hAactVertices : Aact.vertices = R.vertices := by
    simpa [Aact, R] using
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hAvertices : A.vertices = L.vertices ∪ R.vertices := by
    simpa [A, L, R] using
      (forestComponentMixedBoundary_left_union_right_vertices g q hq).symm
  by_cases hvA : v ∈ A.vertices
  · let γ := A.componentAt hvA
    have hγA : γ ∈ A.elements := A.componentAt_mem hvA
    have hvγ : v ∈ γ.vertices := A.componentAt_vertex_mem hvA
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq γ hγA with
      hγL | hγR
    · have hγAout : γ ∈ Aout.elements := by
        simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using hγL
      have hOuter :
          Aout.retargetVertex outerStar v = outerStar γ := by
        exact AdmissibleSubgraph.retargetVertex_of_mem_component
          hAoutDisj outerStar hγAout hvγ
      have hFreshOuter :
          Aout.IsFreshStarAssignment outerStar := by
        simpa [G₀, Aout, outerStar] using
          FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2
      have hOuterNotAct : outerStar γ ∉ Aact.vertices := by
        intro hvAct
        have hvR : outerStar γ ∈ R.vertices := by
          exact hAactVertices ▸ hvAct
        exact hFreshOuter.fresh hγAout (R.vertices_subset hvR)
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar (outerStar γ) := by rw [hOuter]
        _ = outerStar γ := by
          exact AdmissibleSubgraph.retargetVertex_of_not_mem
            Aact rightStar hOuterNotAct
        _ = splitStar γ := by
          simpa [outerStar, splitStar] using
            (forestComponentMixedBoundarySplitStarOf_left
              g q hq hγL).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hγA hvγ]
    · have hNotAout : v ∉ Aout.vertices := by
        intro hvOut
        have hvL : v ∈ L.vertices := by
          exact hAoutVertices ▸ hvOut
        exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
          q.1.1 q.2 hADisj hγR hvγ hvL
      have hOuter : Aout.retargetVertex outerStar v = v :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hNotAout
      let δ :=
        admissibleSubgraphRetargetSubgraph
          Aout outerStar γ
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ hγR)
      have hδ : δ ∈ Aact.elements := by
        simpa [Aout, outerStar, Aact, δ] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
            g q hq hγR
      have hvδ : v ∈ δ.vertices := by
        change v ∈ γ.vertices.image (Aout.retargetVertex outerStar)
        exact Finset.mem_image.mpr ⟨v, hvγ, hOuter⟩
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar v := by rw [hOuter]
        _ = rightStar δ := by
          exact AdmissibleSubgraph.retargetVertex_of_mem_component
            hAactDisj rightStar hδ hvδ
        _ = splitStar γ := by
          simpa [Aout, outerStar, Q, Aact, rightStar, splitStar, δ] using
            (forestComponentMixedBoundarySplitStarOf_right
              g q hq hγR).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hγA hvγ]
  · have hNotAout : v ∉ Aout.vertices := by
      intro hvOut
      apply hvA
      rw [hAvertices]
      exact Finset.mem_union_left _ (by exact hAoutVertices ▸ hvOut)
    have hNotAct : v ∉ Aact.vertices := by
      intro hvAct
      apply hvA
      rw [hAvertices]
      exact Finset.mem_union_right _ (by exact hAactVertices ▸ hvAct)
    have hOuter : Aout.retargetVertex outerStar v = v :=
      AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hNotAout
    calc
      Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
          = Aact.retargetVertex rightStar v := by rw [hOuter]
      _ = v := by
        exact AdmissibleSubgraph.retargetVertex_of_not_mem
          Aact rightStar hNotAct
      _ = A.retargetVertex splitStar v := by
        rw [AdmissibleSubgraph.retargetVertex_of_not_mem A splitStar hvA]

private theorem forestComponentMixedBoundary_twoStep_retargetExternalLeg_eq_splitStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (ℓ : ExternalLeg) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          ℓ) =
      q.1.1.retargetExternalLeg
        (forestComponentMixedBoundarySplitStarOf g q hq) ℓ := by
  apply ExternalLeg.mk.injEq _ _ _ _ |>.mpr
  exact ⟨
    forestComponentMixedBoundary_twoStep_retargetVertex_eq_splitStar
      g q hq ℓ.attachedTo,
    rfl⟩

private theorem forestComponentMixedBoundary_twoStep_retargetEdge_eq_splitStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (e : FeynmanEdge) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          e) =
      q.1.1.retargetEdge
        (forestComponentMixedBoundarySplitStarOf g q hq) e := by
  apply FeynmanEdge.mk.injEq _ _ _ _ _ _ |>.mpr
  exact ⟨
    forestComponentMixedBoundary_twoStep_retargetVertex_eq_splitStar
      g q hq e.source,
    forestComponentMixedBoundary_twoStep_retargetVertex_eq_splitStar
      g q hq e.target,
    rfl⟩

private theorem forestComponentMixedBoundary_splitStar_externalLegs_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightContractGraph g q hq).externalLegs =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentMixedBoundarySplitStarOf g q hq)).externalLegs := by
  classical
  simp only [forestComponentMixedBoundaryActualRightContractGraph,
    forestOuterActualQuotientGraph,
    FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_externalLegs]
  rw [Multiset.map_map]
  refine Multiset.map_congr rfl ?_
  intro ℓ _hℓ
  exact forestComponentMixedBoundary_twoStep_retargetExternalLeg_eq_splitStar
    g q hq ℓ

private theorem forestComponentMixedBoundary_splitStar_internalEdges_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightContractGraph g q hq).internalEdges =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentMixedBoundarySplitStarOf g q hq)).internalEdges := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let A := q.1.1
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  let splitStar := forestComponentMixedBoundarySplitStarOf g q hq
  have hRle : R.internalEdges ≤ L.complementEdges := by
    simpa [L, R] using
      forestComponentMixedBoundary_right_internalEdges_le_left_complement
        g q hq
  have hRmap :
      R.internalEdges.map (Aout.retargetEdge outerStar) =
        R.internalEdges := by
    simpa [Aout, outerStar, R] using
      forestComponentMixedBoundary_right_internalEdges_outerRetarget_eq
        g q hq
  have hAactI : Aact.internalEdges = R.internalEdges := by
    simpa [Aact, R] using
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_internalEdges_eq_right
        g q hq
  have hSplit :
      A.internalEdges = L.internalEdges + R.internalEdges := by
    simpa [A, L, R] using
      forestComponentMixedBoundary_left_union_right_internalEdges g q hq
  have hQinternal :
      Q.internalEdges =
        (G₀.internalEdges - L.internalEdges).map (Aout.retargetEdge outerStar) := by
    simp [Q, G₀, L, Aout, outerStar, forestOuterActualQuotientGraph,
      forestComponentMixedBoundaryOuterIndex_val,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges,
      AdmissibleSubgraph.complementEdges]
  have hAactComplement :
      Aact.complementEdges =
        ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
          (Aout.retargetEdge outerStar) := by
    unfold AdmissibleSubgraph.complementEdges
    calc
      Q.internalEdges - Aact.internalEdges
          = (G₀.internalEdges - L.internalEdges).map
              (Aout.retargetEdge outerStar) - R.internalEdges := by
            rw [hQinternal, hAactI]
      _ = (G₀.internalEdges - L.internalEdges).map
              (Aout.retargetEdge outerStar) -
            R.internalEdges.map (Aout.retargetEdge outerStar) := by
            rw [hRmap]
      _ = ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
              (Aout.retargetEdge outerStar) := by
            exact (multiset_map_sub_of_le (Aout.retargetEdge outerStar)
              (by simpa [L] using hRle)).symm
  have hComplementSource :
      (G₀.internalEdges - L.internalEdges) - R.internalEdges =
        G₀.internalEdges - A.internalEdges := by
    rw [hSplit, Multiset.sub_add_eq_sub_sub]
  simp only [forestComponentMixedBoundaryActualRightContractGraph,
    FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges]
  calc
    Aact.complementEdges.map (Aact.retargetEdge rightStar)
        =
      (((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
          (Aout.retargetEdge outerStar)).map (Aact.retargetEdge rightStar) := by
        rw [hAactComplement]
    _ =
      ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
        ((Aact.retargetEdge rightStar) ∘ (Aout.retargetEdge outerStar)) := by
        rw [Multiset.map_map]
    _ =
      ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
        (A.retargetEdge splitStar) := by
        refine Multiset.map_congr rfl ?_
        intro e _he
        exact forestComponentMixedBoundary_twoStep_retargetEdge_eq_splitStar
          g q hq e
    _ = (G₀.internalEdges - A.internalEdges).map (A.retargetEdge splitStar) := by
        rw [hComplementSource]
    _ = A.complementEdges.map (A.retargetEdge splitStar) := by
        unfold AdmissibleSubgraph.complementEdges
        simp [G₀]

/-- Mixed-boundary literal split-star payload, separated from the genuine
forest branch so the last graph model can be attacked branchwise. -/
private structure forestComponentMixedBoundarySplitStarModelPayload
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  fresh :
    ∀ g q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      q.1.1.IsFreshStarAssignment
        (forestComponentMixedBoundarySplitStarOf g q hq)
  graph_eq :
    ∀ g q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      forestComponentMixedBoundaryActualRightContractGraph g q hq =
        FeynmanGraph.admissibleForestContractGraphWithStars
          (repG g).toFeynmanGraph q.1.1
          (forestComponentMixedBoundarySplitStarOf g q hq)

/-- Genuine-forest literal split-star payload, kept independent from the
mixed-boundary construction. -/
private structure forestComponentForestChoiceSplitStarModelPayload
    [IsDivergencePreservedByAdmissibleForestContract] : Prop where
  model :
    ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
        g q hq,
        ∃ starOf : FeynmanSubgraph (repG g).toFeynmanGraph → VertexId,
          q.1.1.IsFreshStarAssignment starOf ∧
          forestComponentForestChoiceActualRightContractGraph g q hq C =
            FeynmanGraph.admissibleForestContractGraphWithStars
              (repG g).toFeynmanGraph q.1.1 starOf

private theorem forestComponentMixedBoundarySplitStarModelPayloadOfGraphEq
    [IsDivergencePreservedByAdmissibleForestContract]
    (H :
      ∀ g q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryActualRightContractGraph g q hq =
          FeynmanGraph.admissibleForestContractGraphWithStars
            (repG g).toFeynmanGraph q.1.1
            (forestComponentMixedBoundarySplitStarOf g q hq)) :
    forestComponentMixedBoundarySplitStarModelPayload where
  fresh := forestComponentMixedBoundarySplitStarOf_isFresh
  graph_eq := H

