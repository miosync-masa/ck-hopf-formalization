    apply FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr
    exact ‚ü®hV, hI, hE‚ü©
  have hFlip := graph_eq_mapPerm_inv_of_eq_mapPerm _ _ ŌĄ hOrig
  exact (FeynmanGraph.toClass_eq_iff _ _).mpr ‚ü®ŌĄ‚ĀĽ¬Ļ, hFlip‚ü©

/-- **G-9b: the forest-branch right factor, CANONICAL** (facade-free).  Composing the canonical
graph-class equality (`h58BridgeForestRightActualClassCanonical`) with the gen‚Üígraph reduction
(G-9a).  This discharges the resolved `right` datum with no facade. -/
theorem h58BridgeForestRightHopfHCanonical
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (q : h58BridgeForestChoiceSigma g) (hq : q ‚ąą h58BridgeForestChoiceIndex g) :
    h58BridgeForestRightHopfH g q =
      h58BridgeForestRightHopfHQuotient g
        (h58BridgeForestChoiceOuterIndex g q hq)
        (h58BridgeForestChoiceRepQuotient g q hq)
        (h58BridgeForestChoiceRepQuotientMem g q hq
          (h58BridgeForestChoiceRemnantCertificateCanonical g q hq)) :=
  h58BridgeForestRightHopfHEqOfActualRightClass g q hq
    (h58BridgeForestRightActualClassCanonical g q hq)

/-! ### G-12b-2 ‚ÄĒ `splitPhi` at a forest left choice = the actual‚Üírep transport of its actual quotient

The cover dictionary square needs `h58BridgeSplitPhi g (Sum.inl i)` expressed as the actual‚Üírep
transport (`h58BridgeActualQuotientToSigma`) of the forest choice's *actual* quotient subgraph ‚ÄĒ so
it matches `canonicalFlatImageOf` of the lift of that actual quotient.  Both sides reduce to
`‚ü®OuterIndex, forestOuterActualToRep (ActualQuotientCanonical)‚ü©` definitionally (the rep quotient IS
that transport). -/

/-- Public alias: the actual quotient-side forest of a forest choice (over the ACTUAL quotient
graph), whose actual‚Üírep transport is the representative quotient `h58BridgeForestChoiceRepQuotient`. -/
noncomputable def h58BridgeForestSplitActualQuotient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (q : h58BridgeForestChoiceSigma g) (hq : q ‚ąą h58BridgeForestChoiceIndex g) :
    AdmissibleSubgraph (h58BridgeOuterActualQuotientGraph g (h58BridgeForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq

/-- **G-12b-2: `splitPhi (Sum.inl q)` = actual‚Üírep transport of the actual quotient.**  The forest
left-branch image of `ŌÜ` equals `h58BridgeActualQuotientToSigma` applied to the forest choice's
actual quotient subgraph ‚ÄĒ definitionally (the representative quotient is exactly that transport),
modulo the `dif_pos` `ŌÜ`-on-`inl` alignment. -/
theorem h58BridgeForestSplitPhiInl_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (q : h58BridgeForestChoiceSigma g) (hq : q ‚ąą h58BridgeForestChoiceIndex g) :
    h58BridgeSplitPhi g (Sum.inl q) =
      h58BridgeActualQuotientToSigma g (h58BridgeForestChoiceOuterIndex g q hq)
        (h58BridgeForestSplitActualQuotient g q hq) := by
  rw [show h58BridgeSplitPhi g (Sum.inl q) =
      forestComponentForestChoiceToQuotientForestSigma g q hq from
      forestComponentSplitPhi_inl_of_mem g q hq]
  rfl

end PathW

