/-- Sprint F2i-3q-model-4a-6-helper-3: `B_candidate.internalEdges.card =
PromotedInternalEdges.card`.  Chain:
1. `B_candidate.internalEdges = ∑ ζ ∈ B_candidate.elements, ζ.internalEdges`.
2. Card-of-sum = sum-of-cards (via `Finset.induction_on` + `Multiset.card_add`).
3. `B_candidate.elements = (PC.attach).image _BElementMap` → `Finset.sum_image`
   with helper-2 (`_BElementMap_injective`).
4. Per-η: `(_BElementMap η hη).internalEdges.card = η.internalEdges.card`
   (Target 2 + `mapPerm_internalEdges` + `Multiset.card_map` + `toFG_internalEdges`).
5. `Finset.sum_attach` unwraps. -/
private theorem forestQuotientForestSigmaForestCover_BCandidate_internalEdges_card_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    [ForestQuotientForestSigmaForestCoverBElementMapAdmissibleModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    (forestQuotientForestSigmaForestCover_BCandidate
        g r hForestCD hγ).internalEdges.card =
      (forestQuotientForestSigmaForestCoverPromotedInternalEdges g r
        (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ)).card := by
  classical
  set δ := forestQuotientForestSigmaForestCover_liftedForestSource g r hγ
  show (∑ ζ ∈ (forestQuotientForestSigmaForestCover_BCandidate
      g r hForestCD hγ).elements, ζ.internalEdges).card = _
  rw [show ∀ (s : Finset (FeynmanSubgraph _)),
        (∑ ζ ∈ s, ζ.internalEdges).card = ∑ ζ ∈ s, ζ.internalEdges.card from by
      intro s
      induction s using Finset.induction_on with
      | empty => simp
      | insert _ _ hni ih => simp [Finset.sum_insert hni, Multiset.card_add, ih]]
  rw [forestQuotientForestSigmaForestCover_BCandidate_elements]
  rw [Finset.sum_image (fun a _ b _ hEq =>
    Subtype.ext (forestQuotientForestSigmaForestCover_BElementMap_injective
      g r hForestCD hγ a.2 b.2 hEq))]
  rw [Finset.sum_congr rfl
    (fun a _ => show (forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ a.1 a.2).internalEdges.card = a.1.internalEdges.card by
      have h := forestQuotientForestSigmaForestCover_BElementMap_toFeynmanGraph_eq
        g r hForestCD hγ a.1 a.2
      have hIE : (forestQuotientForestSigmaForestCover_BElementMap
            g r hForestCD hγ a.1 a.2).internalEdges =
          a.1.internalEdges.map (FeynmanEdge.map
            (feynmanSubgraphToHopfGenRepPerm γ
              (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
                g r hForestCD hγ))) :=
        congrArg FeynmanGraph.internalEdges h
      rw [hIE, Multiset.card_map])]
  rw [Finset.sum_attach
    (forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
    (fun η => η.internalEdges.card)]
  unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges
  induction (forestQuotientForestSigmaForestCoverPromotedComponents g r δ) using
    Finset.induction_on with
  | empty => simp
  | insert _ _ hni ih =>
    rw [Finset.sum_insert hni, Finset.sum_insert hni, Multiset.card_add, ih]

/-- Sprint F2i-3q-model-4a-6-helper-4: `0 < δ.internalEdges.card` for
δ = `_liftedForestSource γ hγ`.  δ ∈ `ForestComponents` ⊆
`actualQuotientSubgraph.elements`.  `actualQuotientSubgraph =
mapPermAdmissibleSubgraphPreimage hπ r.1.2`; r.1.2 ∈
`forestCoproductProperForestIndex` → properDisjoint →
`HasPositiveInternalEdgesComponents`; perm-preimage preserves
internalEdges.card. -/
private theorem forestQuotientForestSigmaForestCover_liftedForestSource_internalEdges_card_pos
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    0 < (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ).internalEdges.card := by
  classical
  have hδForest := forestQuotientForestSigmaForestCover_liftedForestSource_mem g r hγ
  have hδAct : forestQuotientForestSigmaForestCover_liftedForestSource g r hγ ∈
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem
      g r).mp hδForest).1
  unfold forestQuotientForestSigmaActualQuotientSubgraph at hδAct
  unfold mapPermAdmissibleSubgraphPreimage at hδAct
  rw [mapPermAdmissibleSubgraph_elements] at hδAct
  rcases Finset.mem_image.mp hδAct with ⟨η', hη', hEq⟩
  -- η' ∈ r.1.2.elements ⇒ η'.internalEdges.card > 0 from properDisjoint
  have hr2 : r.1.2 ∈
      forestCoproductProperForestIndex (forestOuterQuotientHopfGen g r.1.1) := by
    have hMem := r.2
    unfold forestQuotientForestSigmaIndex at hMem
    exact (Finset.mem_sigma.mp hMem).2
  have hr2Proper : r.1.2 ∈
      (repG (forestOuterQuotientHopfGen g r.1.1)).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    ((mem_forestCoproductProperForestIndex _ _).mp hr2).1
  have hη'pos : 0 < η'.internalEdges.card :=
    (repG (forestOuterQuotientHopfGen g r.1.1)).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      hr2Proper η' hη'
  rw [← hEq, mapPermSubgraph_internalEdges_card]
  exact hη'pos

/-- Sprint F2i-3q-model-4a-6: `0 < B_candidate.complementEdges.card`.
Algebraic cancellation:
  complementEdges.card = ambient.card - B_candidate.card
                       = (Exact.card + Promoted.card) - Promoted.card
                       = Exact.card = δ.internalEdges.card > 0. -/
private theorem forestQuotientForestSigmaForestCover_BCandidate_complementEdges_card_pos
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    [ForestQuotientForestSigmaForestCoverBElementMapAdmissibleModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    0 < (forestQuotientForestSigmaForestCover_BCandidate
      g r hForestCD hγ).complementEdges.card := by
  classical
  set δ := forestQuotientForestSigmaForestCover_liftedForestSource g r hγ with hδdef
  set π := feynmanSubgraphToHopfGenRepPerm γ
    (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
      g r hForestCD hγ) with hπdef
  -- ambient.internalEdges.card = γ.internalEdges.card
  have hAmbientCard :
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ))).toFeynmanGraph.internalEdges.card =
      γ.toFeynmanGraph.internalEdges.card := by
    rw [feynmanSubgraphToHopfGenRepPerm_spec γ
      (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
        g r hForestCD hγ)]
    show (γ.toFeynmanGraph.mapPerm π).internalEdges.card = _
    rw [FeynmanGraph.mapPerm_internalEdges, Multiset.card_map]
  -- γ.internalEdges = Exact + Promoted (via γ = Plus δ)
  have hPlusEq :
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ = γ :=
    forestQuotientForestSigmaForestCover_liftedForestSource_plus_eq g r hγ
  have hγCardAdd : γ.toFeynmanGraph.internalEdges.card =
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).card +
      (forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ).card := by
    rw [show γ.toFeynmanGraph.internalEdges =
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ from by
      rw [← hPlusEq]; rfl]
    exact Multiset.card_add _ _
  -- B_candidate.internalEdges ≤ ambient.internalEdges
  have hLe : (forestQuotientForestSigmaForestCover_BCandidate
        g r hForestCD hγ).internalEdges ≤
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ))).toFeynmanGraph.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise _
      (forestQuotientForestSigmaForestCover_BCandidate_isPairwiseDisjoint
        g r hForestCD hγ)
  -- complementEdges.card = ambient.card - B.card
  have hCompCard : (forestQuotientForestSigmaForestCover_BCandidate
        g r hForestCD hγ).complementEdges.card =
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ))).toFeynmanGraph.internalEdges.card -
      (forestQuotientForestSigmaForestCover_BCandidate
        g r hForestCD hγ).internalEdges.card := by
    show ((repG _).toFeynmanGraph.internalEdges - _).card = _
    exact Multiset.card_sub hLe
  -- Exact.card = δ.internalEdges.card (via ExactInternalEdges_map + card_map)
  have hExactCard : (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).card =
      δ.internalEdges.card := by
    have hMap := forestQuotientForestSigmaForestCoverExactInternalEdges_map g r δ
    have := congrArg Multiset.card hMap
    simp only [Multiset.card_map] at this
    exact this
  -- δ.internalEdges.card > 0
  have hδpos : 0 < δ.internalEdges.card :=
    forestQuotientForestSigmaForestCover_liftedForestSource_internalEdges_card_pos
      g r hγ
  -- Combine: complementEdges.card = (Exact.card + Promoted.card) - Promoted.card = Exact.card
  have hBCard :
      (forestQuotientForestSigmaForestCover_BCandidate
        g r hForestCD hγ).internalEdges.card =
      (forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ).card :=
    forestQuotientForestSigmaForestCover_BCandidate_internalEdges_card_eq
      g r hForestCD hγ
  have hStep : (forestQuotientForestSigmaForestCover_BCandidate
      g r hForestCD hγ).complementEdges.card =
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).card := by
    rw [hCompCard, hAmbientCard, hγCardAdd, hBCard]
    omega
  rw [hStep, hExactCard]
  exact hδpos

