      A.internalEdges - Aout.internalEdges ≤
        G₀.internalEdges - Aout.internalEdges := by
    rw [Multiset.le_iff_count]
    intro e
    rw [Multiset.count_sub, Multiset.count_sub]
    have hcount := Multiset.count_le_of_le e hA_le_G
    omega
  have hSubSub :
      (G₀.internalEdges - Aout.internalEdges) -
