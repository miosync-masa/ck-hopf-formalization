        q‚āā.1.1 q‚āā.2 hPD‚āā hő≥ hv)
    hActualRight

/-- **Track B-forest-final-4c ‚ÄĒ ForestParents equality.**  From a genuine-forest
`toQuotient` equality, the forest-chosen parent carriers agree.  Chain: outer
equality (`fst`) ‚Üí actual-quotient `eqRec` (final-3) ‚Üí component-carrier `eqRec`
‚Üí `RemnantComponents` `eqRec` (positive star-touch filter) ‚Üí `ForestParents`
equality (cross-`q` recovery through the insertion-uniqueness model).  This is
the *only* genuine-forest branch step that consumes
`ForestGraphInsertionUniquenessModel`. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_forestParents_eq_of_eq
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q‚āĀ q‚āā : forestComponentChoiceSigma g}
    (hq‚āĀ : q‚āĀ ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hq‚āā : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q‚āĀ hq‚āĀ =
      forestComponentForestChoiceToQuotientForestSigma g q‚āā hq‚āā) :
    forestComponentForestChoiceForestParents g q‚āĀ =
      forestComponentForestChoiceForestParents g q‚āā := by
  classical
  have hOuter :
      forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ =
      forestComponentForestChoiceOuterIndex g q‚āā hq‚āā := congrArg Sigma.fst hEq
  have hActual :=
    forestComponentForestChoiceToQuotientForestSigma_actualQuotient_eqRec_of_eq
      hq‚āĀ hq‚āā hOuter hEq
  have hComp :=
