/-- Canonical mapPerm-preimage field relabeling for a well-formed source
ambient graph, using the finite star-alignment permutation. -/
private theorem admissibleForestContractCanonicalPreimage_fieldRelabeling_of_wellFormed
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (hG‚āĀwf : G‚āĀ.WellFormed)
    (A : AdmissibleSubgraph G‚āā)
    (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs) :
    ‚ąÉ ŌĄ : Equiv.Perm VertexId,
      (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
        (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).vertices =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
          (mapPermAdmissibleSubgraphPreimage hŌÄ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hŌÄ hA))).mapPerm ŌĄ).vertices ‚ąß
      (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
        (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).internalEdges =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
          (mapPermAdmissibleSubgraphPreimage hŌÄ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hŌÄ hA))).mapPerm ŌĄ).internalEdges ‚ąß
      (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
        (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).externalLegs =
        ((FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
          (mapPermAdmissibleSubgraphPreimage hŌÄ A)
          (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
              hŌÄ hA))).mapPerm ŌĄ).externalLegs := by
  rcases admissibleForestContractCanonicalPreimage_starPermutation hŌÄ A hA with
    ‚ü®ŌĄ, hŌĄV, hŌĄStar‚ü©
  refine ‚ü®ŌĄ, ?_, ?_, ?_‚ü©
  ¬∑ exact admissibleForestContractCanonicalPreimage_vertices_eq_of_starPermutation
      hŌÄ A hA hŌĄV hŌĄStar
  ¬∑ exact admissibleForestContractCanonicalPreimage_internalEdges_eq_of_starPermutation
      hŌÄ hG‚āĀwf A hA hŌĄV hŌĄStar
  ¬∑ exact admissibleForestContractCanonicalPreimage_externalLegs_eq_of_starPermutation
      hŌÄ hG‚āĀwf A hA hŌĄV hŌĄStar

/-- Well-formed canonical mapPerm-preimage class invariance. -/
private theorem admissibleForestContractCanonicalPreimageClass_of_wellFormed
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (hG‚āĀwf : G‚āĀ.WellFormed)
