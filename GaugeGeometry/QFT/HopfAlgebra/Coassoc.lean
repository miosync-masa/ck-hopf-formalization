/-- Sprint F2i-3q-4l-actual-4m-step2-remnant-generic: q-independent Remnant
equality.  Given a generic `q` whose outer index matches `r.1.1` and whose
`IsForest`-set matches `LiftedForestComponents g r`, the Remnant transported
via `hOuter` recovers `ForestComponents g r`.  Proof: destructure `r` to free
`r.1.1` as `A`, `cases hOuter` to align types (q-independent so no circularity),
then `Finset.ext` + `_remainder_eq` (F2i-3o-2i) bridge each Remnant element to
its underlying δ ∈ ForestComponents via Plus injectivity. -/
private theorem forestComponentForestChoiceRemnantComponents_eq_forestComponents_of_outer
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter : forestComponentForestChoiceOuterIndex g q hq = r.1.1)
    (hForestSet :
      ∀ γ : FeynmanSubgraph (repG g).toFeynmanGraph,
        forestComponentChoiceIsForest q.1.1 q.2 γ ↔
          γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    hOuter ▸ forestComponentForestChoiceRemnantComponents g q hq =
      forestQuotientForestSigmaForestCoverForestComponents g r := by
  classical
  obtain ⟨⟨A, D⟩, hr⟩ := r
  cases hOuter
  apply Finset.ext
  intro δ
  constructor
  · -- Forward: δ ∈ Remnant → δ ∈ ForestComponents.
    intro hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists g q hq hδ
      with ⟨γ, B, hChoice, hδEq⟩
    have hIsForest : forestComponentChoiceIsForest q.1.1 q.2 γ.1 :=
      forestComponentChoiceIsForest_of_eq γ.2 hChoice
    have hγLF :
        γ.1 ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents
          g ⟨⟨_, D⟩, hr⟩ :=
      (hForestSet γ.1).mp hIsForest
    rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
      g ⟨⟨_, D⟩, hr⟩ hγLF with ⟨δ', hδ', hPlusEq⟩
    rw [hδEq, ← hPlusEq]
    exact (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
      g ⟨⟨_, D⟩, hr⟩ δ').symm ▸ hδ'
  · -- Backward: δ ∈ ForestComponents → δ ∈ Remnant.
    intro hδ
    set γ := forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
      g ⟨⟨_, D⟩, hr⟩ δ with hγDef
    have hγLF :
        γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents
          g ⟨⟨_, D⟩, hr⟩ := by
      unfold forestQuotientForestSigmaForestCoverLiftedForestComponents
      exact Finset.mem_image.mpr ⟨⟨δ, hδ⟩, Finset.mem_attach _ _, rfl⟩
    have hIsForest := (hForestSet γ).mpr hγLF
    rcases forestComponentChoiceIsForest_exists hIsForest with ⟨hγMem, B, hChoice⟩
    have hRemEq :
        admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ = δ := by
      rw [hγDef]
      exact forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
        g ⟨⟨_, D⟩, hr⟩ δ
    rw [← hRemEq]
    exact forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq
      ⟨γ, hγMem⟩ hChoice

