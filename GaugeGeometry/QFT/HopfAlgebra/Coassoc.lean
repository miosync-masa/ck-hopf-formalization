    (forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForest_vertices
      g r hR hF)

/-- Sprint F2i-3q-4f-3: Forest-Right NOD wrapper (symmetric form). -/
private theorem forestQuotientForestSigmaForestCover_liftedForest_liftedRight_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γF γR : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hF : γF ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (hR : γR ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r) :
    γF.NestedOrDisjoint γR :=
  Or.inr
    (forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForest_vertices
      g r hR hF).symm

/-- Sprint F2i-3q-4l-1c: a `LeftComponents` element `η` has vertices disjoint
from any `LiftedForestComponents` element `γF = Plus(δF)`.  `η ∉ AllPromoted`
specialises to `η ∉ PromotedComponents δF` for the specific δF underlying γF;
unfolds to `starOf η ∉ δF.vertices`, then F2i-3q-4l-1b gives the disjoint. -/
private theorem forestQuotientForestSigmaForestCover_leftComponents_disjoint_liftedForestComponents_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {η γF : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverLeftComponents g r)
    (hγF : γF ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    Disjoint η.vertices γF.vertices := by
  rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    g r hγF with ⟨δF, hδF, hEqF⟩
  rcases (forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hη
    with ⟨hηA, hηNotAllPromoted⟩
  have hηNotPromotedδF :
      η ∉ forestQuotientForestSigmaForestCoverPromotedComponents g r δF := by
    intro h
    exact hηNotAllPromoted
      ((forestQuotientForestSigmaForestCoverAllPromotedComponents_mem g r).mpr
        ⟨δF, hδF, h⟩)
  have hStarNotIn :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∉ δF.vertices := by
    intro hStar
    exact hηNotPromotedδF
      ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r δF).mpr ⟨hηA, hStar⟩)
  rw [← hEqF, forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices]
  exact forestQuotientForestSigmaForestCoverSourceVertices_disjoint_nonPromoted_vertices
    g r hηA hStarNotIn

/-- Sprint F2i-3q-4l-1d: a `LeftComponents` element `η` has vertices disjoint
from any `LiftedRightComponents` element `γR = no-star lift of some δR ∈
RightComponents`.  `η ⊆ A_final.vertices`; the no-star lift's vertices equal
`δR.vertices`, every vertex of which lies in `G.vertices \ A_final.vertices`
(F2g-0 per-vertex via F2i-3q-4l-1a). -/
private theorem forestQuotientForestSigmaForestCover_left_disjoint_liftedRight_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {η γR : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverLeftComponents g r)
    (hR : γR ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r) :
    Disjoint η.vertices γR.vertices := by
  classical
  have hηA :=
    ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hη).1
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hR with ⟨δR, _hδR, hNoStar, hEq⟩
  rw [← hEq, forestOuterActualQuotientNoStarComponentLift_vertices,
    Finset.disjoint_left]
  intro v hvη hvδ
  have hvNotStar :
      v ∉ r.1.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    fun hvStar => (Finset.disjoint_left.mp hNoStar hvδ) hvStar
  have hvNotA :=
    forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
      g r hvδ hvNotStar
  exact hvNotA (AdmissibleSubgraph.mem_vertices.mpr ⟨η, hηA, hvη⟩)

/-- **Track forest_cd-3a (foundational) — support reachability is monotone under
internal-edge inclusion.**  More internal edges can only add support adjacencies,
so reachability transfers along `H.internalEdges ≤ G.internalEdges`.  This is the
workhorse for lifting connectivity of the promoted children and the exact part
into the spliced `SourceSubgraphExactPlus`. -/
private theorem supportReachable_mono_of_internalEdges_le
    {H G : FeynmanGraph} (hle : H.internalEdges ≤ G.internalEdges)
    {u v : VertexId} (h : H.SupportReachable u v) :
    G.SupportReachable u v := by
  refine SimpleGraph.Reachable.mono ?_ h
  intro a b hab
  obtain ⟨hne, e, heH, hend⟩ := hab
  exact ⟨hne, e, Multiset.mem_of_le hle heH, hend⟩

/-- **Track forest_cd-3a (Helper 1) — within-promoted-child reachability.**  Each
promoted child `η` is a connected `A`-component, and its internal edges sit
inside the spliced `SourceSubgraphExactPlus` (promoted half), so any two of its
vertices are support-reachable in the splice. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
    {u v : VertexId} (hu : u ∈ η.vertices) (hv : v ∈ η.vertices) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportReachable
      u v := by
  have hηA : η ∈ r.1.1.1.elements :=
    ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hη).1
  have hηconn : η.toFeynmanGraph.IsSupportConnected :=
    (r.1.1.1.isConnectedDivergent_of_mem hηA).1
  have hreach : η.toFeynmanGraph.SupportReachable u v := hηconn hu hv
  have hle :
      η.internalEdges ≤
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    refine le_trans
      (Finset.single_le_sum (fun i _ => Multiset.zero_le _) hη)
      (Multiset.le_add_left _ _)
  exact supportReachable_mono_of_internalEdges_le hle hreach

/-- **Track forest_cd-3a (Helper 2a) — source-vertex retarget classification.**
Each source vertex is either a non-star vertex fixed by `retargetVertex`, or a
vertex of some promoted child `η` sent to `starOf η`. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {z : VertexId}
    (hz : z ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ) :
    (r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) z = z) ∨
      (∃ η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ,
        z ∈ η.vertices ∧
          r.1.1.1.retargetVertex
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) z =
            FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η) := by
  classical
  have hApd : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hz
  rcases Finset.mem_union.mp hz with hns | hpr
  · rcases Finset.mem_sdiff.mp hns with ⟨hzδ, hzns⟩
    exact Or.inl (AdmissibleSubgraph.retargetVertex_of_not_mem _ _
      (forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
        g r hzδ hzns))
  · rcases Finset.mem_biUnion.mp hpr with ⟨η, hηA, hzB⟩
    by_cases hs :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices
    · simp only [hs, if_true] at hzB
      exact Or.inr ⟨η,
        (forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mpr
          ⟨hηA, hs⟩,
        hzB,
        AdmissibleSubgraph.retargetVertex_of_mem_component hApd _ hηA hzB⟩
    · simp only [hs, if_false] at hzB
      exact (Finset.notMem_empty z hzB).elim

/-- **Track forest_cd-3a (Helper 2b) — same-retarget gluing.**  Two source
vertices with equal `retargetVertex` image are support-reachable in the splice:
either they coincide (both non-star), or they lie in the same promoted child
(equal stars ⇒ equal components by freshness), where Helper 1 connects them. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {x y : VertexId}
    (hx : x ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hy : y ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hret :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) y) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportReachable
      x y := by
  classical
  have hFresh : r.1.1.1.IsFreshStarAssignment
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hx with
    hx0 | ⟨ηx, hηx, hxηx, hxret⟩
  · rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hy with
      hy0 | ⟨ηy, hηy, hyηy, hyret⟩
    · rw [show x = y from hx0.symm.trans (hret.trans hy0)]
      exact FeynmanGraph.SupportReachable.refl _ _
    · exfalso
      have hηyA : ηy ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηy).1
      have hxstar : x = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηy := hx0.symm.trans (hret.trans hyret)
      exact hFresh.fresh hηyA
        (hxstar ▸ forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ hx)
  · rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hy with
      hy0 | ⟨ηy, hηy, hyηy, hyret⟩
    · exfalso
      have hηxA : ηx ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηx).1
      have hystar : y = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηx :=
        hy0.symm.trans (hret.symm.trans hxret)
      exact hFresh.fresh hηxA
        (hystar ▸ forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ hy)
    · have hηxA : ηx ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηx).1
      have hηyA : ηy ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηy).1
      have hstar :
          FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηx =
            FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηy :=
        hxret.symm.trans (hret.trans hyret)
      have hηeq : ηx = ηy := hFresh.eq_of_star_eq hηxA hηyA hstar
      subst hηeq
      exact forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable
        g r δ hηx hxηx hyηy

/-- **Track forest_cd-3a (edge-step lift).**  A single support-adjacency step
`c —δ— b` in the quotient lifts: from any source preimage `wc` of `c`, there is a
source preimage `wb` of `b` reachable from `wc` in the splice.  The `δ`-edge has
an exact source preimage `eE` (`ExactInternalEdges_map`); `eE` is a `Plus` edge
joining its endpoints, and the same-retarget gluing (Helper 2b) connects `wc`/`wb`
to `eE`'s endpoints. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_edgeStep
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {c b : VertexId}
    (hadj : δ.toFeynmanGraph.SupportAdj c b)
    {wc : VertexId}
    (hwc : wc ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hwcc :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) wc = c) :
    ∃ wb, wb ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) wb = b ∧
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportReachable
        wc wb := by
  classical
  obtain ⟨hcb, eδ, heδ, hend⟩ := hadj
  have heδ' : eδ ∈
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    rw [forestQuotientForestSigmaForestCoverExactInternalEdges_map]; exact heδ
  obtain ⟨eE, heE, hmap⟩ := Multiset.mem_map.mp heδ'
  obtain ⟨hsE, htE⟩ :=
    forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints g r δ heE
  have hrs :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = eδ.source := by
    rw [← hmap]; rfl
  have hrt :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = eδ.target := by
    rw [← hmap]; rfl
  have heEPlus : eE ∈
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    exact Multiset.mem_add.mpr (Or.inl heE)
  have plusAdj : eE.source ≠ eE.target →
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportReachable
        eE.source eE.target :=
    fun hne => SimpleGraph.Adj.reachable
      (show (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportAdj
          eE.source eE.target from ⟨hne, eE, heEPlus, Or.inl ⟨rfl, rfl⟩⟩)
  rcases hend with ⟨hsc, htb⟩ | ⟨hsb, htc⟩
  · have hsEc :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = c := hrs.trans hsc
    have htEb :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = b := hrt.trans htb
    have hne : eE.source ≠ eE.target := fun h =>
      hcb (hsEc.symm.trans ((congrArg _ h).trans htEb))
    exact ⟨eE.target, htE, htEb,
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
        g r δ hwc hsE (hwcc.trans hsEc.symm)).trans (plusAdj hne)⟩
  · have hsEb :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = b := hrs.trans hsb
    have htEc :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = c := hrt.trans htc
    have hne : eE.source ≠ eE.target := fun h =>
      hcb (htEc.symm.trans ((congrArg _ h.symm).trans hsEb))
    exact ⟨eE.source, hsE, hsEb,
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
        g r δ hwc htE (hwcc.trans htEc.symm)).trans (plusAdj hne).symm⟩

/-- **Track forest_cd-3a (path lift).**  A full quotient support-reachability path
`a —δ—* b` lifts: from any source preimage `u` of `a`, there is a source preimage
`w` of `b` reachable from `u` in the splice.  Induction on the reflexive-transitive
support path, edge-step per adjacency. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_reachable_lift
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {a b u : VertexId}
    (hu : u ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hua :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) u = a)
    (hab : δ.toFeynmanGraph.SupportReachable a b) :
    ∃ w, w ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) w = b ∧
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.SupportReachable
        u w := by
  have hrtg : Relation.ReflTransGen δ.toFeynmanGraph.SupportAdj a b :=
    (SimpleGraph.reachable_iff_reflTransGen _ _).1 hab
  clear hab
  induction hrtg with
  | refl => exact ⟨u, hu, hua, FeynmanGraph.SupportReachable.refl _ _⟩
  | tail _hac hcb IH =>
      obtain ⟨wc, hwc, hwcc, hreach⟩ := IH
      obtain ⟨wb, hwb, hwbb, hstepR⟩ :=
        forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_edgeStep
          g r δ hcb hwc hwcc
      exact ⟨wb, hwb, hwbb, hreach.trans hstepR⟩

/-- **Track forest_cd-3a (Connected).**  `SourceSubgraphExactPlus` is support
connected: any two source vertices retarget into the connected quotient component
`δ`, whose path lifts back (path lift) and whose endpoints glue (Helper 2b). -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_isConnected
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).IsConnected := by
  classical
  have hδconn : δ.toFeynmanGraph.IsSupportConnected :=
    ((forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ).1).1
  have hrem :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r δ
  intro u v hu hv
  have hretu :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) u ∈ δ.vertices := by
    rw [← hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨u, hu, rfl⟩
  have hretv :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v ∈ δ.vertices := by
    rw [← hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨v, hv, rfl⟩
  obtain ⟨w, hw, hwv, huw⟩ :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_reachable_lift
      g r δ hu rfl (hδconn hretu hretv)
  exact huw.trans
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
      g r δ hw hv hwv)

/-- **Track forest_cd-onePI (Helper 1, target-graph generalized).**  Helper 1
(`_promotedComponent_reachable`) relativized to any graph `K` whose internal
edges contain the promoted half: two vertices of a promoted child `η` are
support-reachable in `K`.  Used with `K = Plus.eraseInternalEdge e` (erasing an
Exact edge keeps every Promoted edge), so the within-child gluing survives the
bridge erasure. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable_in
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
    {K : FeynmanGraph}
    (hKle : forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤ K.internalEdges)
    {u v : VertexId} (hu : u ∈ η.vertices) (hv : v ∈ η.vertices) :
    K.SupportReachable u v := by
  have hηA : η ∈ r.1.1.1.elements :=
    ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hη).1
  have hηconn : η.toFeynmanGraph.IsSupportConnected :=
    (r.1.1.1.isConnectedDivergent_of_mem hηA).1
  have hreach : η.toFeynmanGraph.SupportReachable u v := hηconn hu hv
  have hle : η.internalEdges ≤ K.internalEdges :=
    le_trans (Finset.single_le_sum (fun i _ => Multiset.zero_le _) hη) hKle
  exact supportReachable_mono_of_internalEdges_le hle hreach

/-- **Track forest_cd-onePI (Helper 2b, target-graph generalized).**  Helper 2b
(`_sameRetarget_reachable`) relativized to any graph `K` whose internal edges
contain the promoted half: two source vertices with equal `retargetVertex` image
are support-reachable in `K`.  The classification (Helper 2a) and freshness
arguments are graph-independent; only the within-child step uses `K`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable_in
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {K : FeynmanGraph}
    (hKle : forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤ K.internalEdges)
    {x y : VertexId}
    (hx : x ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hy : y ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ)
    (hret :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) y) :
    K.SupportReachable x y := by
  classical
  have hFresh : r.1.1.1.IsFreshStarAssignment
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hx with
    hx0 | ⟨ηx, hηx, hxηx, hxret⟩
  · rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hy with
      hy0 | ⟨ηy, hηy, hyηy, hyret⟩
    · rw [show x = y from hx0.symm.trans (hret.trans hy0)]
      exact FeynmanGraph.SupportReachable.refl _ _
    · exfalso
      have hηyA : ηy ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηy).1
      have hxstar : x = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηy := hx0.symm.trans (hret.trans hyret)
      exact hFresh.fresh hηyA
        (hxstar ▸ forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ hx)
  · rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r δ hy with
      hy0 | ⟨ηy, hηy, hyηy, hyret⟩
    · exfalso
      have hηxA : ηx ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηx).1
      have hystar : y = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηx :=
        hy0.symm.trans (hret.symm.trans hxret)
      exact hFresh.fresh hηxA
        (hystar ▸ forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ hy)
    · have hηxA : ηx ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηx).1
      have hηyA : ηy ∈ r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r δ).mp hηy).1
      have hstar :
          FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηx =
            FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ηy :=
        hxret.symm.trans (hret.trans hyret)
      have hηeq : ηx = ηy := hFresh.eq_of_star_eq hηxA hηyA hstar
      subst hηeq
      exact forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable_in
        g r δ hηx hKle hxηx hyηy

/-- **Track forest_cd-onePI-1b (edge-step avoiding an Exact edge).**  The
erase-aware analogue of `_edgeStep`: a support-adjacency `c —(δ∖d)— b` in the
quotient with the chosen Exact edge `e` (whose retarget is `d`) removed lifts to
reachability in `Plus.eraseInternalEdge e`.  Key fact:
`(Exact.erase e).map retarget = δ.internalEdges.erase d` (`Multiset.map_erase_of_mem`,
