/-- The chosen representative of `ő≥.toHopfGen` is isomorphic to
`ő≥.toFeynmanGraph`, with source orientation suited for `mapPermSubgraph`. -/
private theorem feynmanSubgraphToHopfGen_rep_isIso
    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent) :
    ő≥.toFeynmanGraph.IsIso (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph := by
  have hRepClass :
      (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph.toClass =
        ő≥.toFeynmanGraph.toClass := by
    rw [repG_toClass, FeynmanSubgraph.toHopfGen_val]
  exact (FeynmanGraph.toClass_eq_iff
    ő≥.toFeynmanGraph (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph).mp
    hRepClass.symm

/-- Fixed permutation from a component graph to the selected representative of
