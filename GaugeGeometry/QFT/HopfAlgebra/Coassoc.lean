/-- Sprint F2i-3q-4l-1-defs: membership for `LeftComponents`. -/
private theorem forestQuotientForestSigmaForestCoverLeftComponents_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {η : FeynmanSubgraph (repG g).toFeynmanGraph} :
    η ∈ forestQuotientForestSigmaForestCoverLeftComponents g r ↔
      η ∈ r.1.1.1.elements ∧
        η ∉ forestQuotientForestSigmaForestCoverAllPromotedComponents g r := by
  unfold forestQuotientForestSigmaForestCoverLeftComponents
  exact Finset.mem_filter

/-- Sprint F2i-3q-4l-actual-partition: `LeftComponents ∪ AllPromoted` recovers
`r.1.1.1.elements`.  Forward via `LeftComponents_mem.1` and
`AllPromoted_mem → PromotedComponents_mem → ∈ r.1.1.1.elements`.  Reverse via
`by_cases` on `AllPromoted` membership. -/
private theorem forestQuotientForestSigmaForestCover_left_union_allPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    forestQuotientForestSigmaForestCoverLeftComponents g r ∪
      forestQuotientForestSigmaForestCoverAllPromotedComponents g r =
        r.1.1.1.elements := by
  classical
  ext η
  constructor
  · intro h
    rcases Finset.mem_union.mp h with hL | hP
    · exact ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hL).1
    · rcases (forestQuotientForestSigmaForestCoverAllPromotedComponents_mem g r).mp hP
        with ⟨δ, _hδ, hηδ⟩
      exact ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r δ).mp hηδ).1
  · intro hηA
    by_cases hP : η ∈ forestQuotientForestSigmaForestCoverAllPromotedComponents g r
    · exact Finset.mem_union_right _ hP
    · exact Finset.mem_union_left _
        ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mpr ⟨hηA, hP⟩)

/-- Sprint F2i-3q-4l-actual-partition: `LeftComponents` and `AllPromoted` are
Finset-disjoint.  Direct from `LeftComponents_mem.2` (the filter excludes
`AllPromoted`). -/
private theorem forestQuotientForestSigmaForestCover_left_disjoint_allPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Disjoint
      (forestQuotientForestSigmaForestCoverLeftComponents g r)
      (forestQuotientForestSigmaForestCoverAllPromotedComponents g r) := by
  classical
  rw [Finset.disjoint_left]
  intro η hL hP
  exact ((forestQuotientForestSigmaForestCoverLeftComponents_mem g r).mp hL).2 hP

/-- Sprint F2i-3q-4a: union recovers `D.elements`. -/
private theorem forestQuotientForestSigmaForestCover_right_union_forestComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    forestQuotientForestSigmaForestCoverRightComponents g r ∪
      forestQuotientForestSigmaForestCoverForestComponents g r =
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements := by
  classical
  ext δ
  constructor
  · intro h
    rcases Finset.mem_union.mp h with hR | hF
    · exact ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hR).1
    · exact ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hF).1
  · intro hδ
    by_cases hDisj :
        Disjoint δ.vertices
          (r.1.1.1.starVertices
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2))
    · exact Finset.mem_union_left _
        ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mpr
          ⟨hδ, hDisj⟩)
    · exact Finset.mem_union_right _
        ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mpr
          ⟨hδ, hDisj⟩)

/-- Sprint F2i-3q-4a: right-type and forest-type components are Finset-disjoint. -/
private theorem forestQuotientForestSigmaForestCover_right_disjoint_forestComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Disjoint
      (forestQuotientForestSigmaForestCoverRightComponents g r)
      (forestQuotientForestSigmaForestCoverForestComponents g r) := by
  classical
  rw [Finset.disjoint_left]
  intro δ hR hF
  have hDisj :=
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hR).2
  have hNot :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hF).2
  exact hNot hDisj

/-- Sprint F2i-3q-4b: ambient lifts of right-type components, reusing the
existing F2g no-star lift (which only needs `Disjoint δ.V A_final.starVertices`,
exactly the `RightComponents` filter predicate). -/
private noncomputable def forestQuotientForestSigmaForestCoverLiftedRightComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaForestCoverRightComponents g r).attach.image
    (fun δ =>
      forestOuterActualQuotientNoStarComponentLift
        g r.1.1 δ.1
        ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp δ.2).2)

/-- Sprint F2i-3q-4b: every lifted right-type γ arises from a right-type δ
with its associated no-star disjointness witness. -/
private theorem forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r) :
    ∃ δ ∈ forestQuotientForestSigmaForestCoverRightComponents g r,
      ∃ hNoStar :
        Disjoint δ.vertices
          (r.1.1.1.starVertices
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)),
        forestOuterActualQuotientNoStarComponentLift g r.1.1 δ hNoStar = γ := by
  unfold forestQuotientForestSigmaForestCoverLiftedRightComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨δ, _hδAttach, hEq⟩
  refine ⟨δ.1, δ.2,
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp δ.2).2,
    hEq⟩

/-- Sprint F2i-3q-4b': CD for lifted right components — **axiom-free**.
Right components have `Disjoint δ.V A_final.starVertices`, so the existing F2g
`forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent` applies
without any extra `hSourceCD` hypothesis.  Contrast with Plus's
F2i-3p-2a where CD requires explicit `hSourceCD`. -/
private theorem forestQuotientForestSigmaForestCoverLiftedRightComponents_cd
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r) :
    γ.IsConnectedDivergent := by
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hγ with ⟨δ, hδRight, hNoStar, hEq⟩
  rw [← hEq]
  have hδActual :
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδRight).1
  have hδCD : δ.IsConnectedDivergent :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem
      hδActual
  exact forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent
    g r.1.1 δ hNoStar hδCD

/-- Sprint F2i-3q-4c: ambient lifts of forest-type components via the Plus
construction.  Reconnects today's F2i-3o-2 Plus machinery to the forest
preimage's forest-choice path.  Each forest-type δ_F is lifted to
`Plus(δ_F)`, which by F2i-3q-2g recovers the source γ_F's vertices exactly. -/
private noncomputable def forestQuotientForestSigmaForestCoverLiftedForestComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaForestCoverForestComponents g r).attach.image
    (fun δ =>
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ.1)

/-- Sprint F2i-3q-4c: every lifted forest-type γ arises from some
forest-type δ via the Plus construction. -/
private theorem forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    ∃ δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ = γ := by
  unfold forestQuotientForestSigmaForestCoverLiftedForestComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨δ, _hδAttach, hEq⟩
  exact ⟨δ.1, δ.2, hEq⟩

/-- Sprint F2i-3q-4c optional: forest-lift remainder wrapper.  Direct
specialization of F2i-3o-2i `_remainder_eq` to forest-type δ. -/
private theorem forestQuotientForestSigmaForestCoverLiftedForestComponents_remainder_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (_hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r) :
    admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)
