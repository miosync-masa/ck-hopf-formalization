/-- Sprint F2i-3q-4d: CD bottleneck reduction for lifted forest-type
components.  Reduces the CD obligation to an explicit per-`δ_F` hypothesis,
same plumbing as F2i-3p-2a (Plus over all of D) — no new typeclass, no
axiom, no `sorry`.  Contrast with F2i-3q-4b' (right side) which is
axiom-free because no-star lift preserves CD via existing F2g theorem. -/
private theorem forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    γ.IsConnectedDivergent := by
  rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    g r hγ with ⟨δ, hδ, hEq⟩
  rw [← hEq]
  exact hForestCD δ hδ

/-- Sprint F2i-3q-4d' (refactored by F2i-3q-4i-1): NOD bottleneck reduction
for lifted forest-type components.  Now takes a **vertex-disjointness**
hypothesis (strengthened from NOD) to support the upcoming A_source v2
`IsPairwiseDisjoint` proof; NOD is derived via `Or.inr`. -/
private theorem forestQuotientForestSigmaForestCoverLiftedForestComponents_nestedOrDisjoint_of_source_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices)
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ :
      γ₁ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (hγ₂ :
      γ₂ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (hne : γ₁ ≠ γ₂) :
    γ₁.NestedOrDisjoint γ₂ := by
  rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    g r hγ₁ with ⟨δ₁, hδ₁, hEq₁⟩
  rcases forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists
    g r hγ₂ with ⟨δ₂, hδ₂, hEq₂⟩
  have hδne : δ₁ ≠ δ₂ := by
    intro hδ
    apply hne
    rw [← hEq₁, ← hEq₂, hδ]
  rw [← hEq₁, ← hEq₂]
  exact Or.inr (hForestDisjoint δ₁ hδ₁ δ₂ hδ₂ hδne)

/-- Sprint F2i-3q-4e: right-right NOD for lifted right-type components —
**axiom-free**.  Direct transcription of mixed cover's
`forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint` ([L14219]),
using `RightComponents_mem` to bridge filter membership to `D.elements`,
then leveraging no-star lift carrier simp lemmas for transport. -/
private theorem forestQuotientForestSigmaForestCoverLiftedRightComponents_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ :
      γ₁ ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
    (hγ₂ :
      γ₂ ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
    (hne : γ₁ ≠ γ₂) :
    γ₁.NestedOrDisjoint γ₂ := by
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hγ₁ with ⟨δ₁, hδ₁Right, _hNoStar₁, hEq₁⟩
  rcases forestQuotientForestSigmaForestCoverLiftedRightComponents_mem_exists
    g r hγ₂ with ⟨δ₂, hδ₂Right, _hNoStar₂, hEq₂⟩
  have hδ₁D :
      δ₁ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδ₁Right).1
  have hδ₂D :
      δ₂ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδ₂Right).1
  have hδne : δ₁ ≠ δ₂ := by
    intro hδ
    apply hne
    rw [← hEq₁, ← hEq₂]
    subst hδ
    rfl
  have hδNOD : δ₁.NestedOrDisjoint δ₂ :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).forest.nestedOrDisjoint
      hδ₁D hδ₂D hδne
  rw [← hEq₁, ← hEq₂]
  rcases hδNOD with hN | hD
  · refine Or.inl ?_
    rcases hN with hN | hN
    · exact Or.inl ⟨hN.1, hN.2.1, hN.2.2⟩
    · exact Or.inr ⟨hN.1, hN.2.1, hN.2.2⟩
  · exact Or.inr hD

/-- Sprint F2i-3q-4l-actual-4m-step2-right-defs: ambient-side lifted right
candidate, packaged as `AdmissibleSubgraph`.  Forest analog of mixed
`MixedCoverRightCandidate` ([Coassoc.lean:14605]).  CD/NOD axiom-free. -/
private noncomputable def forestQuotientForestSigmaForestCoverRightCandidate_v3
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
