          |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
            (forestComponentForestChoiceOuterIndex g q hq).2
      have hRet :
          Aout.retargetVertex outerStar u =
            outerStar (Aout.componentAt huOut) :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hAoutDisj outerStar (Aout.componentAt_mem huOut)
          (Aout.componentAt_vertex_mem huOut)
      have hStarEq :
          outerStar (Aout.componentAt huOut) = outerStar ő≥L :=
        hRet.symm.trans huv
      have hCompEq : Aout.componentAt huOut = ő≥L :=
        hFreshOuter.eq_of_star_eq (Aout.componentAt_mem huOut) hő≥Lout hStarEq
      have hDisjA : q.1.1.IsPairwiseDisjoint :=
        (repG g).toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
      have hSubset :
          (Aout.componentAt huOut).vertices ‚äÜ ő≥F.1.vertices := by
        simpa [Aout] using
          forestComponentForestChoiceOuterSubgraph_componentAt_vertices_subset_source
            q.1.1 q.2 hDisjA ő≥F hB huő≥F (by
              simpa [Aout] using huOut)
      have huL : u ‚ąą ő≥L.vertices := by
        simpa [hCompEq] using Aout.componentAt_vertex_mem huOut
      have hő≥LA : ő≥L ‚ąą q.1.1.elements :=
        forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hő≥L
      have hne : ő≥L ‚Č† ő≥F.1 := by
        intro hEq
        have hő≥FLeft :
            ő≥F.1 ‚ąą (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements := by
          simpa [hEq] using hő≥L
        rw [forestComponentChoiceLeftSubgraph_elements] at hő≥FLeft
        rcases Finset.mem_filter.mp hő≥FLeft with ‚ü®_hő≥A, hLeft‚ü©
        unfold forestComponentChoiceIsLeft at hLeft
