explicitly (`B` field) along with two proof fields:
- `mem`: each `B γ hγ` lives in `properForestIndex` (old `ForestBWitness`).
- `promotes`: each `B γ hγ`, after rep-transform + ambient promote, recovers
  the canonical `PromotedComponents` set for some δ ∈ `ForestComponents` with
  `γ = Plus δ`.

Required for F2i-3q-4l outer index equality, where the specific `B` used by
`ChoiceFn_v3_promoted` must coincide with the canonical one (the existential
form would force `Classical.choose` on two distinct existentials, breaking
the identification of the chosen witness). -/
private structure forestQuotientForestSigmaForestCoverForestBPromotesWitness
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent) where
  B :
    ∀ (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
      (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r),
      AdmissibleSubgraph
        (repG (γ.toHopfGen
          (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
            g r hForestCD hγ))).toFeynmanGraph
  mem :
    ∀ (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
      (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r),
      B γ hγ ∈ forestCoproductProperForestIndex
        (γ.toHopfGen
          (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
            g r hForestCD hγ))
  promotes :
    ∀ (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
      (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r),
      ∃ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        ∃ _hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r,
        γ = forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ ∧
        (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ
          (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
            g r hForestCD hγ) (B γ hγ)).elements =
          forestQuotientForestSigmaForestCoverPromotedComponents g r δ

/-- Sprint F2i-3q-4l-actual-hyp-fix: projection — the Skolem-form witness gives
the old `ForestBWitness` by bundling `B γ hγ` with `mem γ hγ` as an
existential. -/
private theorem forestQuotientForestSigmaForestCoverForestBPromotesWitness_to_ForestBWitness
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hBP : forestQuotientForestSigmaForestCoverForestBPromotesWitness g r hForestCD) :
    forestQuotientForestSigmaForestCoverForestBWitness g r hForestCD :=
  fun γ hγ => ⟨hBP.B γ hγ, hBP.mem γ hγ⟩

/-- Sprint F2i-3q-4l-actual-hyp-fix-accessors: canonical `B_γ` extraction.
Parallels old `forestQuotientForestSigmaForestCoverForestB`, but takes the
Skolem-form `hBP` and returns the `B` field directly (no `Classical.choose`,
so the identity is structural). -/
private noncomputable def forestQuotientForestSigmaForestCoverForestB_canonical
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hBP : forestQuotientForestSigmaForestCoverForestBPromotesWitness g r hForestCD)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    AdmissibleSubgraph
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ))).toFeynmanGraph :=
  hBP.B γ hγ

/-- Sprint F2i-3q-4l-actual-hyp-fix-accessors: `B_canonical ∈ properForestIndex`. -/
private theorem forestQuotientForestSigmaForestCoverForestB_canonical_mem
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hBP : forestQuotientForestSigmaForestCoverForestBPromotesWitness g r hForestCD)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    forestQuotientForestSigmaForestCoverForestB_canonical g r hForestCD hBP γ hγ ∈
      forestCoproductProperForestIndex
        (γ.toHopfGen
          (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
            g r hForestCD hγ)) :=
  hBP.mem γ hγ

/-- Sprint F2i-3q-4l-actual-hyp-fix-accessors: `B_canonical` promotes back to
`PromotedComponents g r δ` for some δ ∈ `ForestComponents` with γ = Plus δ. -/
private theorem forestQuotientForestSigmaForestCoverForestB_canonical_promotes
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hBP : forestQuotientForestSigmaForestCoverForestBPromotesWitness g r hForestCD)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    ∃ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
      ∃ _hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r,
      γ = forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ ∧
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ)
        (forestQuotientForestSigmaForestCoverForestB_canonical
          g r hForestCD hBP γ hγ)).elements =
        forestQuotientForestSigmaForestCoverPromotedComponents g r δ :=
  hBP.promotes γ hγ

/-- Sprint F2i-3q-4l-actual-hyp-fix-choicefn: `ChoiceFn` variant driven by
the Skolem-form `hBP` witness.  Identical 3-way dispatch as `ChoiceFn_v3`,
but uses `ForestB_canonical` (= `hBP.B`) instead of the existential
`Classical.choose` extraction, so that downstream `promote_eq` is structurally
available. -/
private noncomputable def forestQuotientForestSigmaForestCoverChoiceFn_v3_promoted
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices)
    (hBP : forestQuotientForestSigmaForestCoverForestBPromotesWitness g r hForestCD) :
    forestComponentChoiceFn
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint) :=
  fun γ _ =>
    if _hL : γ.1 ∈ forestQuotientForestSigmaForestCoverLeftComponents g r then
      forestCoproductChoice.left
    else if _hR :
        γ.1 ∈ forestQuotientForestSigmaForestCoverLiftedRightComponents g r then
      forestCoproductChoice.right
    else
      forestCoproductChoice.forest
        (forestQuotientForestSigmaForestCoverForestB_canonical
          g r hForestCD hBP γ.1
          (by
            have hγUnion :
                γ.1 ∈ forestQuotientForestSigmaForestCoverSourceElements_v3 g r := by
              simpa [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_elements]
                using γ.2
            rcases (forestQuotientForestSigmaForestCoverSourceElements_v3_mem g r).mp hγUnion
              with hL' | hRF
            · exact (_hL hL').elim
            · rcases hRF with hR' | hF
              · exact (_hR hR').elim
              · exact hF))

/-- Sprint F2i-3q-4h-1: `Classical.choose` extraction of the witness `B_γ`. -/
