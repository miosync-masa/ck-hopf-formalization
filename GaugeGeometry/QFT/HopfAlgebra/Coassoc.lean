    (forestQuotientForestSigmaForestCoverEdgePreimageOf g r δ e').target ∈
        forestQuotientForestSigmaForestCoverSourceVertices g r δ :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCover_edgePreimage_exists g r δ e'.2)).2.2

/-- Sprint F2i-3h: aggregated multiset of chosen preimage edges, one per
δ-edge (with multiplicity preserved through `attach.map`). -/
private noncomputable def forestQuotientForestSigmaForestCoverChosenInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
