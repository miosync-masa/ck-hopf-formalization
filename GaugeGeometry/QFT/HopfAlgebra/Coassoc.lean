        g r őī,
      Multiset.sub_add_eq_sub_sub,
      Multiset.add_sub_cancel_right]
  exact Multiset.sub_eq_self_of_disjoint
    (forestQuotientForestSigmaForestCoverExactInternalEdges_disjoint_nonPromotedInternalEdges
      g r őī)

/-- Sprint F2i-3o-2g main: the Plus version's quotient-remainder internal
