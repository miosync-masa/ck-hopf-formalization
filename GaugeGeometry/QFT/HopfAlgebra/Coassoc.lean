  ¬∑ -- forest case ruled out by F1k + F1n-2e
    have hőīProm :=
      forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
        A p hA ő≥ hCompOuter hForest őī hőīSlot
    have hne :=
      forestComponentChoicePromotedForestComponents_ne_source
        hp ő≥ hForest hőīProm
    exact absurd hőīEq hne

/-- Per-ő≥ choice equality (Sprint F1o-3, partial): under outer equality and
both `p_i ‚ąą core`, the left and right outcomes of `p‚āĀ ő≥` are matched by
`p‚āā ő≥`.  The forest outcome requires identifying `B‚āĀ = B‚āā`, which depends
on a promoted-carrier injectivity lemma not yet available; it is gated on
the per-ő≥ `hForestMatch` hypothesis. -/
private theorem forestComponentForestChoiceOuterSubgraph_choice_at_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    (hForestMatch :
      ‚ąÄ {B‚āĀ : AdmissibleSubgraph
            (repG (ő≥.1.toHopfGen
              (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph},
        p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) =
            forestCoproductChoice.forest B‚āĀ ‚Üí
        ‚ąÄ {B‚āā : AdmissibleSubgraph
            (repG (ő≥.1.toHopfGen
              (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph},
        p‚āā ő≥ (Finset.mem_attach A.elements ő≥) =
            forestCoproductChoice.forest B‚āā ‚Üí
        (forestCoproductChoice.forest B‚āĀ :
            forestCoproductChoice
              (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))) =
          forestCoproductChoice.forest B‚āā) :
    p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) =
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) := by
  classical
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥)) with hL‚āĀ | hR‚āĀ | ‚ü®B‚āĀ, hF‚āĀ‚ü©
  ¬∑ -- left: p‚āĀ ő≥ = .left
    have hSelf‚āĀ :
        ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥,
            őī.1 = ő≥.1 := by
      rcases forestComponentForestChoiceOuterSubgraph_mem_slotAt_self_of_left
          A p‚āĀ hA ő≥ hCompNE hL‚āĀ with ‚ü®őī, hőīEq, hőīSlot‚ü©
      exact ‚ü®őī, hőīSlot, hőīEq‚ü©
    have hSelf‚āā :
        ‚ąÉ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥,
            őī.1 = ő≥.1 :=
      (forestComponentForestChoiceOuterSubgraph_slotAt_self_exists_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥).mp hSelf‚āĀ
    have hL‚āā :
        p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.left :=
      forestComponentForestChoiceOuterSubgraph_pő≥_eq_left_of_slotAt_self_strong
        hp‚āā hA ő≥ hCompOuter‚āā hSelf‚āā
    rw [hL‚āĀ, hL‚āā]
  ¬∑ -- right: p‚āĀ ő≥ = .right
    have hEmpty‚āĀ :
        forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ = ‚ąÖ :=
      forestComponentForestChoiceOuterSubgraph_slotAt_eq_empty_of_right
        A p‚āĀ hA ő≥ hCompOuter‚āĀ hR‚āĀ
    have hEmpty‚āā :
        forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ = ‚ąÖ :=
      (forestComponentForestChoiceOuterSubgraph_slotAt_empty_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥).mp hEmpty‚āĀ
    have hR‚āā :
        p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.right :=
      forestComponentForestChoiceOuterSubgraph_pő≥_eq_right_of_slotAt_empty_strong
        hp‚āā hA ő≥ hCompNE hEmpty‚āā
    rw [hR‚āĀ, hR‚āā]
  ¬∑ -- forest: p‚āĀ ő≥ = .forest B‚āĀ; derive p‚āā ő≥ = .forest B‚āā via slot-shape
    -- transport, then identify .forest B‚āĀ = .forest B‚āā via `hForestMatch`.
    have hNonempty‚āĀ :
        (forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥).Nonempty :=
      forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
        (A := A) (p := p‚āĀ) hp‚āĀ hA ő≥ hF‚āĀ
    have hNonempty‚āā :
        (forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥).Nonempty := by
      rcases hNonempty‚āĀ with ‚ü®őī‚āĀ, hőī‚āĀ‚ü©
      refine ‚ü®‚ü®őī‚āĀ.1, by rw [‚Üź hEq]; exact őī‚āĀ.2‚ü©, ?_‚ü©
      exact (forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥ őī‚āĀ).mp hőī‚āĀ
    have hNoSelf‚āā :
        ‚ąÄ őī ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥,
            őī.1 ‚Č† ő≥.1 := by
      intro őī‚āā hőī‚āāSlot hőī‚āāEq
      let őī‚āĀ : {őī : FeynmanSubgraph G //
          őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements} :=
        ‚ü®őī‚āā.1, by rw [hEq]; exact őī‚āā.2‚ü©
      have hőī‚āĀSlot :
          őī‚āĀ ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ :=
        ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
          (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥ őī‚āĀ).mpr
          (by simpa using hőī‚āāSlot))
      have hőī‚āĀProm :=
        forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
          A p‚āĀ hA ő≥ hCompOuter‚āĀ hF‚āĀ őī‚āĀ hőī‚āĀSlot
      have hne :=
        forestComponentChoicePromotedForestComponents_ne_source
          hp‚āĀ ő≥ hF‚āĀ hőī‚āĀProm
      exact hne (by simpa [őī‚āĀ] using hőī‚āāEq)
    rcases forestComponentForestChoiceOuterSubgraph_pő≥_is_forest_of_slotAt_no_self
      (A := A) (p := p‚āā) hA ő≥ hCompNE hCompOuter‚āā hNonempty‚āā hNoSelf‚āā
      with ‚ü®B‚āā, hF‚āā‚ü©
    rw [hF‚āĀ, hF‚āā]
    exact hForestMatch hF‚āĀ hF‚āā

/-- Outer-injectivity skeleton (Sprint F1o-4): under `hp_i ‚ąą core` and outer
equality, the two component-choice functions agree, **modulo** a forest-case
B-identification hypothesis `hForestMatchAll`.  The proof is purely a
`funext` + F1o-3 application; the B-identification work is concentrated in
`hForestMatchAll`, which a future sprint will discharge canonically. -/
private theorem forestComponentForestChoiceOuterSubgraph_inj_of_forest_match
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (hForestMatchAll :
      ‚ąÄ ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements},
        ‚ąÄ {B‚āĀ : AdmissibleSubgraph
              (repG (ő≥.1.toHopfGen
                (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph},
          p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) =
              forestCoproductChoice.forest B‚āĀ ‚Üí
          ‚ąÄ {B‚āā : AdmissibleSubgraph
              (repG (ő≥.1.toHopfGen
                (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph},
          p‚āā ő≥ (Finset.mem_attach A.elements ő≥) =
              forestCoproductChoice.forest B‚āā ‚Üí
          (forestCoproductChoice.forest B‚āĀ :
              forestCoproductChoice
                (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))) =
            forestCoproductChoice.forest B‚āā) :
    p‚āĀ = p‚āā := by
  funext ő≥ hő≥
  -- p_i ő≥ hő≥ = p_i ő≥ (Finset.mem_attach _ _) by proof-irrelevance
  -- F1o-3 returns the equality in the (Finset.mem_attach _ _) form.
  exact forestComponentForestChoiceOuterSubgraph_choice_at_eq_of_outer_eq
    (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā)
    hp‚āĀ hp‚āā hA hCompNE hCompOuter‚āĀ hCompOuter‚āā hEq ő≥
    (hForestMatchAll ő≥)

/-- Promoted carrier membership transport (Sprint F1p-1): under outer
equality and `p_i ő≥ = .forest B_i`, the promoted carriers of B‚āĀ and B‚āā
contain the same őī.  The shared slot/sourcePartition machinery from F1g/F1h
+ F1o-2a does the transport.  Foundation for the `B_i` identification. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_mem_iff_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B‚āĀ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    {B‚āā : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest‚āĀ :
      p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āĀ)
    (hForest‚āā :
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āā)
    (őī : FeynmanSubgraph G) :
    őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
      (A.isConnectedDivergent_of_mem ő≥.2) B‚āĀ).elements ‚ÜĒ
    őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
      (A.isConnectedDivergent_of_mem ő≥.2) B‚āā).elements := by
  classical
  -- Helper: őī ‚ąą promoted ő≥ BŠĶĘ in p_i ‚áí őī ‚ąą slot p_i ő≥
  -- (uses hForest_i + sourcePartition uniqueness via hCompOuter_i)
  -- Transport to the other side via F1o-2a, then apply F1k.
  -- We package this as a one-direction helper and apply both ways.
  -- Forward: B‚āĀ ‚Üí B‚āā.
  refine ‚ü®fun hőīB‚āĀ => ?_, fun hőīB‚āā => ?_‚ü©
  ¬∑ -- (1) őī.1 ‚ąą promoted A p‚āĀ via _mem_of_forest
    have hőīProm‚āĀ :
        őī ‚ąą forestComponentChoicePromotedForestComponents A p‚āĀ :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        A p‚āĀ ő≥ hForest‚āĀ hőīB‚āĀ
    -- (2) őī ‚ąą outer p‚āĀ via union-right
    have hőīOuter‚āĀ :
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact Finset.mem_union_right _ hőīProm‚āĀ
    -- (3) őī.vertices ‚äÜ ő≥.1.vertices
    have hőīSub : őī.vertices ‚äÜ ő≥.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) B‚āĀ hőīB‚āĀ
    -- (4) őī.IsNonempty via hCompOuter‚āĀ
    have hőīNE : őī.IsNonempty := hCompOuter‚āĀ őī hőīOuter‚āĀ
    -- (5) sourcePartition őī = ő≥ on the p‚āĀ side via uniqueness
    let őīsub‚āĀ : {ő∑ : FeynmanSubgraph G //
        ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements} :=
      ‚ü®őī, hőīOuter‚āĀ‚ü©
    have hsp‚āĀ :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition
          A p‚āĀ hA őīsub‚āĀ).1 = ő≥.1 := by
      have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
        A p‚āĀ hA őīsub‚āĀ hőīNE ő≥.2 hőīSub
      exact this.symm
    -- (6) őīsub‚āĀ ‚ąą slot p‚āĀ ő≥
    have hőīSlot‚āĀ :
        őīsub‚āĀ ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
        A p‚āĀ hA hsp‚āĀ
    -- (7) Transport to slot p‚āā ő≥ via F1o-2a
    have hőīSlot‚āā :
        (‚ü®őīsub‚āĀ.1, by rw [‚Üź hEq]; exact őīsub‚āĀ.2‚ü© :
          {ő∑ : FeynmanSubgraph G //
            ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements}) ‚ąą
            forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥ őīsub‚āĀ).mp hőīSlot‚āĀ)
    -- (8) F1k on the p‚āā side gives őī ‚ąą promoted ő≥ B‚āā
    exact forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      A p‚āā hA ő≥ hCompOuter‚āā hForest‚āā _ hőīSlot‚āā
  ¬∑ -- Reverse direction: symmetric, with hEq.symm.
    have hőīProm‚āā :
        őī ‚ąą forestComponentChoicePromotedForestComponents A p‚āā :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        A p‚āā ő≥ hForest‚āā hőīB‚āā
    have hőīOuter‚āā :
        őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact Finset.mem_union_right _ hőīProm‚āā
    have hőīSub : őī.vertices ‚äÜ ő≥.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) B‚āā hőīB‚āā
    have hőīNE : őī.IsNonempty := hCompOuter‚āā őī hőīOuter‚āā
    let őīsub‚āā : {ő∑ : FeynmanSubgraph G //
        ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āā hA).elements} :=
      ‚ü®őī, hőīOuter‚āā‚ü©
    have hsp‚āā :
        (forestComponentForestChoiceOuterSubgraph_sourcePartition
          A p‚āā hA őīsub‚āā).1 = ő≥.1 := by
      have := forestComponentForestChoiceOuterSubgraph_sourcePartition_unique
        A p‚āā hA őīsub‚āā hőīNE ő≥.2 hőīSub
      exact this.symm
    have hőīSlot‚āā :
        őīsub‚āā ‚ąą forestComponentForestChoiceOuterSubgraph_slotAt A p‚āā hA ő≥ :=
      forestComponentForestChoiceOuterSubgraph_mem_slotAt_of_sourcePartition_eq
        A p‚āā hA hsp‚āā
    have hőīSlot‚āĀ :
        (‚ü®őīsub‚āā.1, by rw [hEq]; exact őīsub‚āā.2‚ü© :
          {ő∑ : FeynmanSubgraph G //
            ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).elements}) ‚ąą
            forestComponentForestChoiceOuterSubgraph_slotAt A p‚āĀ hA ő≥ :=
      ((forestComponentForestChoiceOuterSubgraph_mem_slotAt_iff_of_outer_eq
        (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hA hEq hCompOuter‚āĀ ő≥
        ‚ü®őīsub‚āā.1, by rw [hEq]; exact őīsub‚āā.2‚ü©).mpr (by simpa using hőīSlot‚āā))
    exact forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      A p‚āĀ hA ő≥ hCompOuter‚āĀ hForest‚āĀ _ hőīSlot‚āĀ

/-- Promoted-carrier elements equality (Sprint F1p-2): F1p-1's membership iff
lifted to a Finset.elements equation via `Finset.ext`.  Foundation step for
the upcoming admissible-subgraph and B-equality lemmas. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_elements_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B‚āĀ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    {B‚āā : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest‚āĀ :
      p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āĀ)
    (hForest‚āā :
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āā) :
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B‚āĀ).elements =
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B‚āā).elements := by
  ext őī
  exact forestComponentForestChoiceOuterSubgraph_promoted_mem_iff_of_outer_eq
    (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā) hp‚āĀ hp‚āā hA
    hCompOuter‚āĀ hCompOuter‚āā hEq ő≥ hForest‚āĀ hForest‚āā őī

/-- Promoted carrier equality (Sprint F1p-3): F1p-2's elements equality
lifted through `Forest.ext` and `AdmissibleSubgraph.ext` to a full
admissible-subgraph equation.  Foundation for the upcoming B-equality
identification. -/
private theorem forestComponentForestChoiceOuterSubgraph_promoted_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B‚āĀ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    {B‚āā : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest‚āĀ :
      p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āĀ)
    (hForest‚āā :
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āā) :
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B‚āĀ =
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (A.isConnectedDivergent_of_mem ő≥.2) B‚āā := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  simpa [AdmissibleSubgraph.elements] using
    forestComponentForestChoiceOuterSubgraph_promoted_elements_eq_of_outer_eq
      (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā)
      hp‚āĀ hp‚āā hA hCompOuter‚āĀ hCompOuter‚āā hEq ő≥ hForest‚āĀ hForest‚āā

/-- `feynmanSubgraphPromoteAdmissibleSubgraph` injectivity (Sprint F1p-4a):
two admissible subgraphs of `ő≥_outer.toFeynmanGraph` whose ambient promotions
agree must be equal.  Proof goes through elements equality + Finset.image
injectivity (using `feynmanSubgraphPromote_injective`) + AdmissibleSubgraph
extensionality. -/
private theorem feynmanSubgraphPromoteAdmissibleSubgraph_injective
    {G : FeynmanGraph} {ő≥_outer : FeynmanSubgraph G}
    {B‚āĀ B‚āā : AdmissibleSubgraph ő≥_outer.toFeynmanGraph}
    (h :
      feynmanSubgraphPromoteAdmissibleSubgraph (ő≥_outer := ő≥_outer) B‚āĀ =
      feynmanSubgraphPromoteAdmissibleSubgraph (ő≥_outer := ő≥_outer) B‚āā) :
    B‚āĀ = B‚āā := by
  classical
  -- Step 1: extract elements equality from the outer promoted equality.
  have hElemsOuter :
      (feynmanSubgraphPromoteAdmissibleSubgraph (ő≥_outer := ő≥_outer) B‚āĀ).elements =
      (feynmanSubgraphPromoteAdmissibleSubgraph (ő≥_outer := ő≥_outer) B‚āā).elements :=
    congrArg AdmissibleSubgraph.elements h
  -- Step 2: rewrite via the @[simp] lemma to expose the image expression.
  rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements,
      feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hElemsOuter
  -- Step 3: rewrite attach.image (fun ő≥ => promote ő≥.1) =
  --   (attach.image Subtype.val).image promote = elements.image promote.
  have hAttach‚āĀ :
      B‚āĀ.elements.attach.image (fun ő≥ : {x // x ‚ąą B‚āĀ.elements} =>
          feynmanSubgraphPromote (ő≥_outer := ő≥_outer) ő≥.1) =
        B‚āĀ.elements.image (feynmanSubgraphPromote (ő≥_outer := ő≥_outer)) := by
    rw [show (fun ő≥ : {x // x ‚ąą B‚āĀ.elements} =>
          feynmanSubgraphPromote (ő≥_outer := ő≥_outer) ő≥.1) =
        (feynmanSubgraphPromote (ő≥_outer := ő≥_outer)) ‚ąė Subtype.val from rfl,
      ‚Üź Finset.image_image, B‚āĀ.elements.attach_image_val]
  have hAttach‚āā :
      B‚āā.elements.attach.image (fun ő≥ : {x // x ‚ąą B‚āā.elements} =>
          feynmanSubgraphPromote (ő≥_outer := ő≥_outer) ő≥.1) =
        B‚āā.elements.image (feynmanSubgraphPromote (ő≥_outer := ő≥_outer)) := by
    rw [show (fun ő≥ : {x // x ‚ąą B‚āā.elements} =>
          feynmanSubgraphPromote (ő≥_outer := ő≥_outer) ő≥.1) =
        (feynmanSubgraphPromote (ő≥_outer := ő≥_outer)) ‚ąė Subtype.val from rfl,
      ‚Üź Finset.image_image, B‚āā.elements.attach_image_val]
  rw [hAttach‚āĀ, hAttach‚āā] at hElemsOuter
  -- Step 4: Finset.image_injective on `feynmanSubgraphPromote_injective`.
  have hElemsInner : B‚āĀ.elements = B‚āā.elements :=
    Finset.image_injective feynmanSubgraphPromote_injective hElemsOuter
  -- Step 5: Forest.ext + AdmissibleSubgraph.ext lifts to B‚āĀ = B‚āā.
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  exact hElemsInner

/-- `mapPermAdmissibleSubgraphPreimage` injectivity (Sprint F1p-4b): the
inverse-direction transport along a permutation is injective.  Proof uses
the round-trip identity `preimage h‚āĀ ‚ąė preimage hŌÄ = id` derived from the
definition `preimage hŌÄ A = mapPermAdmissibleSubgraph h‚āĀ A` and applying
`mapPermAdmissibleSubgraphPreimage_mapPerm_eq` along `h‚āĀ`. -/
private theorem mapPermAdmissibleSubgraphPreimage_injective
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) :
    Function.Injective (mapPermAdmissibleSubgraphPreimage hŌÄ) := by
  intro A‚āĀ A‚āā hAB
  -- preimage hŌÄ A := mapPermAdmissibleSubgraph h‚āĀ A where h‚āĀ : G‚āĀ = G‚āā.mapPerm ŌÄ‚ĀĽ¬Ļ
  have h‚āĀ : G‚āĀ = G‚āā.mapPerm ŌÄ‚ĀĽ¬Ļ := by
    subst hŌÄ
    rw [‚Üź FeynmanGraph.mapPerm_mul]
    simp
  -- Apply round-trip preimage_mapPerm_eq h‚āĀ A_i: roundtrip lands back at A_i.
  have hRT‚āĀ :
      mapPermAdmissibleSubgraphPreimage h‚āĀ
          (mapPermAdmissibleSubgraph h‚āĀ A‚āĀ) = A‚āĀ :=
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq h‚āĀ A‚āĀ
  have hRT‚āā :
      mapPermAdmissibleSubgraphPreimage h‚āĀ
          (mapPermAdmissibleSubgraph h‚āĀ A‚āā) = A‚āā :=
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq h‚āĀ A‚āā
  -- preimage hŌÄ A_i = mapPermAdmissibleSubgraph h‚āĀ A_i (definitional).
  have hDef‚āĀ :
      mapPermAdmissibleSubgraphPreimage hŌÄ A‚āĀ =
        mapPermAdmissibleSubgraph h‚āĀ A‚āĀ := rfl
  have hDef‚āā :
      mapPermAdmissibleSubgraphPreimage hŌÄ A‚āā =
        mapPermAdmissibleSubgraph h‚āĀ A‚āā := rfl
  -- From hAB and the def equations, mapPermAdmissibleSubgraph h‚āĀ A‚āĀ = h‚āĀ A‚āā.
  have hMapEq :
      mapPermAdmissibleSubgraph h‚āĀ A‚āĀ = mapPermAdmissibleSubgraph h‚āĀ A‚āā := by
    rw [‚Üź hDef‚āĀ, ‚Üź hDef‚āā]; exact hAB
  -- Apply preimage h‚āĀ to both sides and use hRT to recover A‚āĀ = A‚āā.
  calc A‚āĀ
      = mapPermAdmissibleSubgraphPreimage h‚āĀ
          (mapPermAdmissibleSubgraph h‚āĀ A‚āĀ) := hRT‚āĀ.symm
    _ = mapPermAdmissibleSubgraphPreimage h‚āĀ
          (mapPermAdmissibleSubgraph h‚āĀ A‚āā) := by rw [hMapEq]
    _ = A‚āā := hRT‚āā

/-- `feynmanSubgraphRepForestPromoteAdmissibleSubgraph` injectivity
(Sprint F1p-4c): the composition of representative-component transport
and ambient promotion is injective in `B`.  Combines F1p-4a (outer
promote injective) with F1p-4b (perm-preimage injective). -/
private theorem feynmanSubgraphRepForestPromoteAdmissibleSubgraph_injective
    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent) :
    Function.Injective
      (fun B : AdmissibleSubgraph
          (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph =>
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥ hő≥ B) := by
  intro B‚āĀ B‚āā h
  -- Step 1: outer promote injective ‚áí RepToComponent equality.
  have hRep :
      feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B‚āĀ =
        feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B‚āā :=
    feynmanSubgraphPromoteAdmissibleSubgraph_injective h
  -- Step 2: RepToComponent := mapPermAdmissibleSubgraphPreimage,
  -- so apply F1p-4b on the spec permutation.
  exact mapPermAdmissibleSubgraphPreimage_injective
    (feynmanSubgraphToHopfGenRepPerm_spec ő≥ hő≥) hRep

/-- B identification (Sprint F1p-5): under outer equality and `p_i ő≥ = .forest B_i`,
the witnesses `B_i` are equal.  Pure composition of F1p-3 (promoted carrier
equality) and F1p-4c (promoted carrier injectivity in `B`). -/
private theorem forestComponentForestChoiceOuterSubgraph_B_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B‚āĀ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    {B‚āā : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest‚āĀ :
      p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āĀ)
    (hForest‚āā :
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āā) :
    B‚āĀ = B‚āā := by
  have hPromEq :=
    forestComponentForestChoiceOuterSubgraph_promoted_eq_of_outer_eq
      (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā)
      hp‚āĀ hp‚āā hA hCompOuter‚āĀ hCompOuter‚āā hEq ő≥ hForest‚āĀ hForest‚āā
  exact
    (feynmanSubgraphRepForestPromoteAdmissibleSubgraph_injective
      ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2)) hPromEq

/-- Forest constructor equality (Sprint F1p-6): F1p-5's B equality wrapped
through `forestCoproductChoice.forest` so it matches the
`hForestMatchAll` shape required by F1o-4. -/
private theorem forestComponentForestChoiceOuterSubgraph_forestChoice_eq_of_outer_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B‚āĀ : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    {B‚āā : AdmissibleSubgraph
        (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hForest‚āĀ :
      p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āĀ)
    (hForest‚āā :
      p‚āā ő≥ (Finset.mem_attach A.elements ő≥) = forestCoproductChoice.forest B‚āā) :
    (forestCoproductChoice.forest B‚āĀ :
        forestCoproductChoice
          (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))) =
      forestCoproductChoice.forest B‚āā :=
  congrArg forestCoproductChoice.forest
    (forestComponentForestChoiceOuterSubgraph_B_eq_of_outer_eq
      (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā)
      hp‚āĀ hp‚āā hA hCompOuter‚āĀ hCompOuter‚āā hEq ő≥ hForest‚āĀ hForest‚āā)

/-- Outer-subgraph injectivity (Sprint F1p-7): unconditional outer-equality
implies `p‚āĀ = p‚āā` in the core component-choice carrier.  The
`hForestMatchAll` gate from F1o-4 is now discharged by the canonical
F1p-6 lemma, completing the F1 forest-branch injectivity. -/
private theorem forestComponentForestChoiceOuterSubgraph_inj
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentCoreChoiceIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint)
    (hCompNE : A.HasNonemptyComponents)
    (hCompOuter‚āĀ :
      (forestComponentForestChoiceOuterSubgraph A p‚āĀ hA).HasNonemptyComponents)
    (hCompOuter‚āā :
      (forestComponentForestChoiceOuterSubgraph A p‚āā hA).HasNonemptyComponents)
    (hEq :
      forestComponentForestChoiceOuterSubgraph A p‚āĀ hA =
      forestComponentForestChoiceOuterSubgraph A p‚āā hA) :
    p‚āĀ = p‚āā :=
  forestComponentForestChoiceOuterSubgraph_inj_of_forest_match
    hp‚āĀ hp‚āā hA hCompNE hCompOuter‚āĀ hCompOuter‚āā hEq
    (fun ő≥ {_B‚āĀ} hForest‚āĀ {_B‚āā} hForest‚āā =>
      forestComponentForestChoiceOuterSubgraph_forestChoice_eq_of_outer_eq
        (A := A) (p‚āĀ := p‚āĀ) (p‚āā := p‚āā)
        hp‚āĀ hp‚āā hA hCompOuter‚āĀ hCompOuter‚āā hEq ő≥ hForest‚āĀ hForest‚āā)

/-- Mixed-boundary outer injectivity (Sprint F1r): in the mixed-boundary
regime (`hp_i` rules out forest choices), `LeftSubgraph` equality forces
`p‚āĀ = p‚āā`.  No forest machinery used; this routes through `Finset.filter`
ext + the binary `.left`/`.right` case split. -/
private theorem forestComponentChoiceLeftSubgraph_inj_of_mixed_boundary
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p‚āĀ p‚āā : forestComponentChoiceFn A}
    (hp‚āĀ : p‚āĀ ‚ąą forestComponentMixedBoundaryChoiceCoreIndex A)
    (hp‚āā : p‚āā ‚ąą forestComponentMixedBoundaryChoiceCoreIndex A)
    (hLeftEq :
      forestComponentChoiceLeftSubgraph A p‚āĀ =
      forestComponentChoiceLeftSubgraph A p‚āā) :
    p‚āĀ = p‚āā := by
  classical
  -- Step 1: extract element-level filter equality.
  have hElems :
      A.elements.filter (forestComponentChoiceIsLeft A p‚āĀ) =
      A.elements.filter (forestComponentChoiceIsLeft A p‚āā) := by
    have := congrArg AdmissibleSubgraph.elements hLeftEq
    simpa [forestComponentChoiceLeftSubgraph_elements] using this
  -- Step 2: extract noForest from mixed-boundary index membership.
  have hNoForest‚āĀ : ¬¨ forestComponentChoiceHasForest A p‚āĀ := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp‚āĀ
    exact (Finset.mem_filter.mp hp‚āĀ).2
  have hNoForest‚āā : ¬¨ forestComponentChoiceHasForest A p‚āā := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp‚āā
    exact (Finset.mem_filter.mp hp‚āā).2
  -- Step 3: pointwise equality via the filter ext.
  funext ő≥ hő≥
  have hő≥Mem : ő≥.1 ‚ąą A.elements := ő≥.2
  -- Membership in the filtered set is iff IsLeft holds.
  have hMem‚āĀ :
      ő≥.1 ‚ąą A.elements.filter (forestComponentChoiceIsLeft A p‚āĀ) ‚ÜĒ
      forestComponentChoiceIsLeft A p‚āĀ ő≥.1 :=
    ‚ü®fun h => (Finset.mem_filter.mp h).2,
     fun h => Finset.mem_filter.mpr ‚ü®hő≥Mem, h‚ü©‚ü©
  have hMem‚āā :
      ő≥.1 ‚ąą A.elements.filter (forestComponentChoiceIsLeft A p‚āā) ‚ÜĒ
      forestComponentChoiceIsLeft A p‚āā ő≥.1 :=
    ‚ü®fun h => (Finset.mem_filter.mp h).2,
     fun h => Finset.mem_filter.mpr ‚ü®hő≥Mem, h‚ü©‚ü©
  -- IsLeft‚āĀ ‚ÜĒ IsLeft‚āā via hElems.
  have hIff : forestComponentChoiceIsLeft A p‚āĀ ő≥.1 ‚ÜĒ
              forestComponentChoiceIsLeft A p‚āā ő≥.1 := by
    rw [‚Üź hMem‚āĀ, ‚Üź hMem‚āā, hElems]
  -- Unfold IsLeft to expose `p_i ő≥ ... = .left`.
  unfold forestComponentChoiceIsLeft at hIff
  rw [dif_pos ő≥.2, dif_pos ő≥.2] at hIff
  -- Step 4: 3-way case split on `p_i ő≥`, ruling out forest by hNoForest_i.
  rcases forestCoproductChoice_eq_left_or_right_or_forest _
      (p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥)) with hL‚āĀ | hR‚āĀ | ‚ü®B‚āĀ, hF‚āĀ‚ü©
  ¬∑ -- p‚āĀ ő≥ = .left ‚áí p‚āā ő≥ = .left (via hIff).
    have hL‚āā := hIff.mp hL‚āĀ
    rw [hL‚āĀ, hL‚āā]
  ¬∑ -- p‚āĀ ő≥ = .right ‚áí p‚āā ő≥ ‚Č† .left, so p‚āā ő≥ ‚ąą {.right, .forest _}.
    -- Use hNoForest‚āā to rule out forest, leaving p‚āā ő≥ = .right.
    have hNotL‚āĀ : p‚āĀ ő≥ (Finset.mem_attach A.elements ő≥) ‚Č† forestCoproductChoice.left := by
      rw [hR‚āĀ]; intro h; cases h
    have hNotL‚āā : p‚āā ő≥ (Finset.mem_attach A.elements ő≥) ‚Č† forestCoproductChoice.left :=
      fun h => hNotL‚āĀ (hIff.mpr h)
    rcases forestCoproductChoice_eq_left_or_right_or_forest _
        (p‚āā ő≥ (Finset.mem_attach A.elements ő≥)) with hL‚āā | hR‚āā | ‚ü®B‚āā, hF‚āā‚ü©
    ¬∑ exact absurd hL‚āā hNotL‚āā
    ¬∑ rw [hR‚āĀ, hR‚āā]
    ¬∑ exact absurd ‚ü®ő≥, B‚āā, hF‚āā‚ü© hNoForest‚āā
  ¬∑ -- forest case ruled out by hNoForest‚āĀ.
    exact absurd ‚ü®ő≥, B‚āĀ, hF‚āĀ‚ü© hNoForest‚āĀ

/-- Mixed-boundary core injectivity (Sprint F1r-2a): given that the outer
admissible component `q.1` is equal across `q‚āĀ` and `q‚āā`, equality of the
`MixedOuterIndex` values forces `q‚āĀ = q‚āā`.  The `q‚āĀ.1 = q‚āā.1` hypothesis
is the natural side-condition which a downstream `ToQuotientForestSigma`
wrapper will discharge from RHS sigma equality. -/
private theorem forestComponentMixedBoundaryOuterIndex_inj_of_q1_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q‚āĀ q‚āā : forestComponentChoiceSigma g}
    (hq‚āĀ : q‚āĀ ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq‚āā : q‚āā ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hQ1 : q‚āĀ.1 = q‚āā.1)
    (hOuter :
      forestComponentMixedBoundaryOuterIndex g q‚āĀ hq‚āĀ =
      forestComponentMixedBoundaryOuterIndex g q‚āā hq‚āā) :
    q‚āĀ = q‚āā := by
  classical
  -- Step 1: extract LeftSubgraph equality from hOuter via Subtype.val.
  have hLeftEq :
      forestComponentChoiceLeftSubgraph q‚āĀ.1.1 q‚āĀ.2 =
      forestComponentChoiceLeftSubgraph q‚āā.1.1 q‚āā.2 := by
    have := congrArg Subtype.val hOuter
    simpa [forestComponentMixedBoundaryOuterIndex_val] using this
  -- Step 2: mixed-boundary core memberships for both p_i.
  have hpCore‚āĀ :
      q‚āĀ.2 ‚ąą forestComponentMixedBoundaryChoiceCoreIndex q‚āĀ.1.1 :=
    (Finset.mem_sigma.mp hq‚āĀ).2
  have hpCore‚āā :
      q‚āā.2 ‚ąą forestComponentMixedBoundaryChoiceCoreIndex q‚āā.1.1 :=
    (Finset.mem_sigma.mp hq‚āā).2
  -- Step 3: subst hQ1 to align the choice-fn types, then apply F1r.
  refine Sigma.ext hQ1 ?_
  rcases q‚āĀ with ‚ü®A‚āĀ, p‚āĀ‚ü©
  rcases q‚āā with ‚ü®A‚āā, p‚āā‚ü©
  cases hQ1
  -- After cases, A‚āĀ = A‚āā. Goal: HEq p‚āĀ p‚āā.
  refine heq_of_eq ?_
  exact forestComponentChoiceLeftSubgraph_inj_of_mixed_boundary
    hpCore‚āĀ hpCore‚āā hLeftEq

/-- Mixed-boundary sigma injectivity (Sprint F1r-2b): `MixedOuterIndex`
equality + `q‚āĀ.1 = q‚āā.1` ‚áí `q‚āĀ = q‚āā`.  Same conclusion as F1r-2a but
expressed as a thin re-export aimed at downstream `ToQuotientForestSigma`
wrappers; `q‚āĀ.1 = q‚āā.1` is supplied externally because the
`MixedOuterIndex.1 = LeftSubgraph` value alone does not pin down the
outer admissible subgraph.  Cross/cover sites that index per `q.1` will
discharge it naturally. -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_inj_of_q1_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q‚āĀ q‚āā : forestComponentChoiceSigma g}
    (hq‚āĀ : q‚āĀ ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq‚āā : q‚āā ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hQ1 : q‚āĀ.1 = q‚āā.1)
    (hOuter :
      forestComponentMixedBoundaryOuterIndex g q‚āĀ hq‚āĀ =
      forestComponentMixedBoundaryOuterIndex g q‚āā hq‚āā) :
    q‚āĀ = q‚āā :=
  forestComponentMixedBoundaryOuterIndex_inj_of_q1_eq hq‚āĀ hq‚āā hQ1 hOuter

/-- Forest-vs-mixed cross disjointness, same outer-A case (Sprint F1s-1):
under `qF.1 = qM.1` (same outer admissible subgraph), the forest-branch
outer-subgraph cannot equal the mixed-boundary outer-subgraph.  Uses F1l-2
(forest ‚áí slot nonempty), F1k (slot ‚äÜ promoted), F1n-2e (promoted ‚Č† source),
plus pairwise-disjoint vertex argument on the shared outer A. -/
private theorem forestComponentForestChoice_mixedBoundary_cross_same_outer_false
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {qF qM : forestComponentChoiceSigma g}
    (hqF : qF ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hqM : qM ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hSame : qF.1 = qM.1)
    (hCompOuterF :
      (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2
        (((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          qF.1.2)).HasNonemptyComponents)
    (hOuterEq :
      (forestComponentForestChoiceOuterIndex g qF hqF).1 =
      (forestComponentMixedBoundaryOuterIndex g qM hqM).1) :
    False := by
  classical
  -- Set up shared notation.
  have hAprop : qF.1.1 ‚ąą
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := qF.1.2
  have hA : qF.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hAprop
  -- (1) Forest core: ‚ąÉ ő≥ ‚ąą A.elements, ‚ąÉ B, qF.2 ő≥ = .forest B.
  have hpForest :
      qF.2 ‚ąą forestComponentForestChoiceCoreIndex qF.1.1 :=
    (Finset.mem_sigma.mp hqF).2
  have hpCore : qF.2 ‚ąą forestComponentCoreChoiceIndex qF.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  rcases (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
    with ‚ü®ő≥, B, hPő≥‚ü©
  -- (2) F1l-2: slot p_F ő≥ has a witness őī.
  have hSlotNE :
      (forestComponentForestChoiceOuterSubgraph_slotAt qF.1.1 qF.2 hA ő≥).Nonempty :=
    forestComponentForestChoiceOuterSubgraph_slotAt_nonempty_of_forest
      (A := qF.1.1) (p := qF.2) hpCore hA ő≥ hPő≥
  rcases hSlotNE with ‚ü®őī, hőīSlot‚ü©
  -- (3) F1k: őī.1 ‚ąą promoted ő≥ B.
  have hőīProm :
      őī.1 ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
        (qF.1.1.isConnectedDivergent_of_mem ő≥.2) B).elements :=
    forestComponentForestChoiceOuterSubgraph_slotAt_classify_forest_shared
      qF.1.1 qF.2 hA ő≥ hCompOuterF hPő≥ őī hőīSlot
  -- (4) őī.1 ‚ąą outer p_F (already known via őī.2).
  have hőīOuterF :
      őī.1 ‚ąą (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2 hA).elements :=
    őī.2
  -- (5) hOuterEq + simp ‚áí őī.1 ‚ąą mixed outer.elements = LeftSubgraph_M.elements.
  have hőīMixed : őī.1 ‚ąą (forestComponentChoiceLeftSubgraph qM.1.1 qM.2).elements := by
    have hMem :
        őī.1 ‚ąą (forestComponentMixedBoundaryOuterIndex g qM hqM).1.elements := by
      rw [‚Üź hOuterEq]; exact hőīOuterF
    simpa [forestComponentMixedBoundaryOuterIndex_val] using hMem
  -- (6) őī.1 ‚ąą qM.1.1.elements via filter subset.
  have hőīAM : őī.1 ‚ąą qM.1.1.elements := by
    rw [forestComponentChoiceLeftSubgraph_elements] at hőīMixed
    exact (Finset.mem_filter.mp hőīMixed).1
  -- Use the `qM.1.1`-side pairwise-disjoint to avoid transporting `őī` through
  -- a `qF.1.1 = qM.1.1` rewrite (which triggers motive failure on őī's type).
  have hAM : qM.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      qM.1.2
  -- (7) F1n-2e: őī.1 ‚Č† ő≥.1.
  have hNeSource :
      őī.1 ‚Č† ő≥.1 :=
    forestComponentChoicePromotedForestComponents_ne_source
      hpCore ő≥ hPő≥ hőīProm
  -- (8) őī.1.vertices ‚äÜ ő≥.1.vertices via promoted vertex_subset.
  have hSub : őī.1.vertices ‚äÜ ő≥.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő≥.1 (qF.1.1.isConnectedDivergent_of_mem ő≥.2) B hőīProm
  -- ő≥.1 ‚ąą qM.1.1.elements via hSame (membership transport via congrArg).
  have hő≥M : ő≥.1 ‚ąą qM.1.1.elements := by
    have hSameVal : qF.1.1 = qM.1.1 := congrArg Subtype.val hSame
    exact hSameVal ‚Ėł ő≥.2
  -- (9) őī.1.IsNonempty via hCompOuterF.
  have hőīNE : őī.1.IsNonempty := hCompOuterF őī.1 hőīOuterF
  rcases Finset.card_pos.mp hőīNE with ‚ü®v, hv‚ü©
  -- (10) hAM.eq_of_mem_vertices on the qM.1.1 side ‚áí őī.1 = ő≥.1.
  have hőīEqő≥ : őī.1 = ő≥.1 :=
    hAM.eq_of_mem_vertices hőīAM hő≥M hv (hSub hv)
  exact hNeSource hőīEqő≥

private theorem forestComponentChoiceRight_internalEdges_le_forestOuter_complement
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {ő≥ : FeynmanSubgraph G}
    (hő≥R : ő≥ ‚ąą (forestComponentChoiceRightSubgraph A p).elements) :
    ő≥.internalEdges ‚Č§
      (forestComponentForestChoiceOuterSubgraph A p hA).complementEdges := by
  refine feynmanSubgraph_internalEdges_le_admissible_complementEdges_of_not_mem
    (forestComponentForestChoiceOuterSubgraph A p hA) ő≥ ?_
  intro e heő≥ heOuter
  rcases AdmissibleSubgraph.mem_internalEdges.mp heOuter with
    ‚ü®őī, hőīOuter, heőī‚ü©
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hőīOuter
  have hsuppő≥ := ő≥.edges_supported e heő≥
  have hsuppőī := őī.edges_supported e heőī
  simp [FeynmanEdge.SupportedOn] at hsuppő≥ hsuppőī
  rcases Finset.mem_union.mp hőīOuter with hőīL | hőīF
  ¬∑ have hdisj := forestComponentChoiceRightLeft_disjoint A p hA hő≥R hőīL
    exact (Finset.disjoint_left.mp hdisj hsuppő≥.1) hsuppőī.1
  ¬∑ have hdisj := forestComponentChoiceRight_promotedForestComponent_disjoint
      A p hA hő≥R hőīF
    exact (Finset.disjoint_left.mp hdisj hsuppő≥.1) hsuppőī.1

/-- A right-selected original component is disjoint from the source component
of any genuine forest choice. -/
private theorem forestComponentChoiceRight_forestChoiceSource_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {ő≥R : FeynmanSubgraph G}
    (hő≥R : ő≥R ‚ąą (forestComponentChoiceRightSubgraph A p).elements)
    (ő≥F : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥F.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥F.2))).toFeynmanGraph}
    (hB :
      p ő≥F (Finset.mem_attach A.elements ő≥F) =
        forestCoproductChoice.forest B) :
    ő≥R.Disjoint ő≥F.1 := by
  classical
  have hő≥RA : ő≥R ‚ąą A.elements :=
    forestComponentChoiceRightSubgraph_elements_subset A p hő≥R
  by_cases hEq : ő≥R = ő≥F.1
  ¬∑ subst ő≥R
    rw [forestComponentChoiceRightSubgraph_elements] at hő≥R
    rcases Finset.mem_filter.mp hő≥R with ‚ü®_hő≥FA, hRight‚ü©
    unfold forestComponentChoiceIsRight at hRight
    rw [dif_pos ő≥F.2] at hRight
    rw [hB] at hRight
    cases hRight
  ¬∑ exact hA hő≥RA ő≥F.2 hEq

/-- Transport an actual quotient-side admissible forest to the chosen
representative quotient graph. -/
private noncomputable def forestOuterActualToRepAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  mapPermAdmissibleSubgraph (forestOuterActualToRepPerm_spec g A) B

/-- The actual quotient graph by an outer admissible forest is well-formed. -/
private theorem forestOuterActualQuotientGraph_wellFormed
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g) :
    (forestOuterActualQuotientGraph g A).WellFormed := by
  unfold forestOuterActualQuotientGraph
  exact A.1.contractWithStars_wellFormed
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    (repG_wellFormed g)

/-- Representative transport for quotient-side right-factor contractions:
contracting an actual quotient-side forest, then passing to graph class,
agrees with contracting its transported representative quotient forest. -/
private theorem forestOuterActualToRep_rightContractClass
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A))
    (hB : B ‚ąą (forestOuterActualQuotientGraph g A
      ).properDisjointAdmissibleDivergentSubgraphs) :
    (FeynmanGraph.admissibleForestContractGraphWithStars
      (forestOuterActualQuotientGraph g A) B
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterActualQuotientGraph g A) B hB)).toClass =
    (FeynmanGraph.admissibleForestContractGraphWithStars
      (forestOuterQuotientGraph g A)
      (forestOuterActualToRepAdmissibleSubgraph g A B)
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (forestOuterQuotientGraph g A)
        (forestOuterActualToRepAdmissibleSubgraph g A B)
        (mapPermAdmissibleSubgraph_mem_properDisjoint
          (forestOuterActualToRepPerm_spec g A) hB))).toClass := by
  simpa [forestOuterActualToRepAdmissibleSubgraph] using
    admissibleForestContractMapPermClass_of_wellFormed
      (forestOuterActualToRepPerm_spec g A)
      (forestOuterActualQuotientGraph_wellFormed g A) B hB

/-- Proper quotient-side forest membership survives the actual-to-representative
transport. -/
private theorem forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    {B : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)}
    (hB : B ‚ąą
      (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterActualToRepAdmissibleSubgraph g A B ‚ąą
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  mapPermAdmissibleSubgraph_mem_properDisjoint
    (forestOuterActualToRepPerm_spec g A) hB

/-- Compose actual quotient retargeting with transport to the chosen `repG`
representative quotient graph. -/
private noncomputable def forestOuterRepRetargetAdmissibleSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hEdges : ‚ąÄ ő≥ ‚ąą B.elements, ő≥.internalEdges ‚Č§ A.1.complementEdges)
    (hCD : ‚ąÄ ő≥ hő≥,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥ (hEdges ő≥ hő≥)).IsConnectedDivergent)
    (hCompat : ‚ąÄ ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥‚āĀ (hEdges ő≥‚āĀ hő≥‚āĀ)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥‚āā (hEdges ő≥‚āā hő≥‚āā))) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  forestOuterActualToRepAdmissibleSubgraph g A
    (forestOuterActualRetargetAdmissibleSubgraph g A B
      hEdges hCD hCompat)

/-- Properness in the actual quotient is enough to place the retargeted forest
in the representative quotient finite carrier. -/
private theorem forestOuterRepRetargetAdmissibleSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (hEdges : ‚ąÄ ő≥ ‚ąą B.elements, ő≥.internalEdges ‚Č§ A.1.complementEdges)
    (hCD : ‚ąÄ ő≥ hő≥,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥ (hEdges ő≥ hő≥)).IsConnectedDivergent)
    (hCompat : ‚ąÄ ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā,
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥‚āĀ (hEdges ő≥‚āĀ hő≥‚āĀ)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        ő≥‚āā (hEdges ő≥‚āā hő≥‚āā)))
    (hProper :
      forestOuterActualRetargetAdmissibleSubgraph g A B
        hEdges hCD hCompat ‚ąą
        (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterRepRetargetAdmissibleSubgraph g A B
      hEdges hCD hCompat ‚ąą
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint g A hProper

/-- Certificate that an ambient source forest survives as an admissible forest
in the actual quotient by an attached outer forest.  This is used for
right-selected components that are disjoint from the chosen outer carrier;
genuine component forest choices are promoted into the ambient outer carrier
before quotienting. -/
private structure forestOuterActualRetargetCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph) : Type where
  edge_le : ‚ąÄ ő≥ ‚ąą B.elements, ő≥.internalEdges ‚Č§ A.1.complementEdges
  cd : ‚ąÄ ő≥ hő≥,
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      ő≥ (edge_le ő≥ hő≥)).IsConnectedDivergent
  compat : ‚ąÄ ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā,
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      ő≥‚āĀ (edge_le ő≥‚āĀ hő≥‚āĀ)).NestedOrDisjoint
    (admissibleSubgraphRetargetSubgraph A.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph A.1 A.2)
      ő≥‚āā (edge_le ő≥‚āā hő≥‚āā))

/-- Actual quotient-side forest built from a retarget certificate. -/
private noncomputable def forestOuterActualRetargetAdmissibleSubgraphOfCert
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g A) :=
  forestOuterActualRetargetAdmissibleSubgraph g A B
    C.edge_le C.cd C.compat

/-- Representative quotient-side forest built from a retarget certificate. -/
private noncomputable def forestOuterRepRetargetAdmissibleSubgraphOfCert
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B) :
    AdmissibleSubgraph (forestOuterQuotientGraph g A) :=
  forestOuterRepRetargetAdmissibleSubgraph g A B
    C.edge_le C.cd C.compat

/-- Properness of a certificate-built actual retargeted forest, when the
source forest is proper and untouched by the outer carrier. -/
private theorem forestOuterActualRetargetAdmissibleSubgraphOfCert_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hB :
      B ‚ąą (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    (hV : ‚ąÄ ő≥ ‚ąą B.elements, ‚ąÄ v ‚ąą ő≥.vertices, v ‚ąČ A.1.vertices) :
    forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C ‚ąą
      (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  admissibleSubgraphRetarget_mem_properDisjoint_of_not_mem
    A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    B C.edge_le C.cd C.compat hB hV

/-- Properness survives the representative transport for certificate-built
retargeted forests. -/
private theorem forestOuterRepRetargetAdmissibleSubgraphOfCert_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hB :
      forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C ‚ąą
        (forestOuterActualQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs) :
    forestOuterRepRetargetAdmissibleSubgraphOfCert g A B C ‚ąą
      (forestOuterQuotientGraph g A).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint g A hB

/-- Certificate-built actual quotient retargeting preserves the Hopf product
when every source component is untouched by the outer carrier. -/
private theorem forestOuterActualRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hV : ‚ąÄ ő≥ ‚ąą B.elements, ‚ąÄ v ‚ąą ő≥.vertices, v ‚ąČ A.1.vertices) :
    (forestOuterActualRetargetAdmissibleSubgraphOfCert g A B C).toHopfH =
      B.toHopfH := by
  unfold forestOuterActualRetargetAdmissibleSubgraphOfCert
    forestOuterActualRetargetAdmissibleSubgraph
  exact admissibleSubgraphRetarget_toHopfH_eq_of_not_mem
    A.1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2)
    B C.edge_le C.cd C.compat hV

/-- Certificate-built representative quotient retargeting preserves the Hopf
product when every source component is untouched by the outer carrier. -/
private theorem forestOuterRepRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (C : forestOuterActualRetargetCertificate g A B)
    (hV : ‚ąÄ ő≥ ‚ąą B.elements, ‚ąÄ v ‚ąą ő≥.vertices, v ‚ąČ A.1.vertices) :
    (forestOuterRepRetargetAdmissibleSubgraphOfCert g A B C).toHopfH =
      B.toHopfH := by
  unfold forestOuterRepRetargetAdmissibleSubgraphOfCert
    forestOuterRepRetargetAdmissibleSubgraph
    forestOuterActualToRepAdmissibleSubgraph
  rw [mapPermAdmissibleSubgraph_toHopfH]
  exact forestOuterActualRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
    g A B C hV

/-- Certificate type for carrying the genuine-forest-regime right-selected
survivors into the quotient by the spliced outer forest. -/
private abbrev forestComponentForestChoiceRightRetargetCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) : Type :=
  forestOuterActualRetargetCertificate g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentChoiceRightSubgraph q.1.1 q.2)

/-- The edge-survival field for the canonical genuine-forest right-retarget
certificate. -/
private theorem forestComponentForestChoiceRightRetarget_edge_le
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    ‚ąÄ ő≥ ‚ąą (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
      ő≥.internalEdges ‚Č§
        (forestComponentForestChoiceOuterIndex g q hq).1.complementEdges := by
  intro ő≥ hő≥
  rw [forestComponentForestChoiceOuterIndex_val]
  exact forestComponentChoiceRight_internalEdges_le_forestOuter_complement
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2)
    hő≥

/-- Connected-divergence for each right-selected survivor after retargeting
through the spliced quotient. -/
private theorem forestComponentForestChoiceRightRetarget_cd
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    ‚ąÄ ő≥ hő≥,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        ő≥
        (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥ hő≥)).IsConnectedDivergent := by
  intro ő≥ hő≥
  let hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV :
      ‚ąÄ v ‚ąą ő≥.vertices,
        v ‚ąČ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hő≥ hv
  have hGraphEq :=
    admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      ő≥
      (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥ hő≥)
      hV
  exact feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq hGraphEq
    ((forestComponentChoiceRightSubgraph q.1.1 q.2).isConnectedDivergent_of_mem hő≥)

/-- Zimmermann compatibility for right-selected survivors after retargeting
through the spliced quotient. -/
private theorem forestComponentForestChoiceRightRetarget_compat
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    ‚ąÄ ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā,
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        ő≥‚āĀ
        (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥‚āĀ hő≥‚āĀ)).NestedOrDisjoint
      (admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        ő≥‚āā
        (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥‚āā hő≥‚āā)) := by
  intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā
  let hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV‚āĀ :
      ‚ąÄ v ‚ąą ő≥‚āĀ.vertices,
        v ‚ąČ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hő≥‚āĀ hv
  have hV‚āā :
      ‚ąÄ v ‚ąą ő≥‚āā.vertices,
        v ‚ąČ (forestComponentForestChoiceOuterIndex g q hq).1.vertices := by
    intro v hv
    rw [forestComponentForestChoiceOuterIndex_val]
    exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
      q.1.1 q.2 hDisj hő≥‚āā hv
  have hCompat : ő≥‚āĀ.NestedOrDisjoint ő≥‚āā := by
    by_cases hEq : ő≥‚āĀ = ő≥‚āā
    ¬∑ subst ő≥‚āā
      exact Or.inl (Or.inl (FeynmanSubgraph.le_refl' ő≥‚āĀ))
    ¬∑ exact (forestComponentChoiceRightSubgraph q.1.1 q.2).forest.nestedOrDisjoint
        hő≥‚āĀ hő≥‚āā hEq
  exact admissibleSubgraphRetargetSubgraph_nestedOrDisjoint_of_not_mem
    (forestComponentForestChoiceOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2)
    ő≥‚āĀ ő≥‚āā
    (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥‚āĀ hő≥‚āĀ)
    (forestComponentForestChoiceRightRetarget_edge_le g q hq ő≥‚āā hő≥‚āā)
    hV‚āĀ hV‚āā hCompat

/-- Canonical certificate carrying genuine-forest-regime right-selected
