    rcases forestComponentMixedBoundary_choice_left_or_right g q hq ő≥ hő≥ with
      hő≥L | hő≥R
    ¬∑ exact Finset.mem_union_left _
        (AdmissibleSubgraph.mem_starVertices.mpr ‚ü®ő≥, hő≥L, rfl‚ü©)
    ¬∑ exact Finset.mem_union_right _
        (AdmissibleSubgraph.mem_starVertices.mpr ‚ü®ő≥, hő≥R, rfl‚ü©)
  ¬∑ intro hv
    rw [AdmissibleSubgraph.mem_starVertices]
    rcases Finset.mem_union.mp hv with hvL | hvR
    ¬∑ rw [AdmissibleSubgraph.mem_starVertices] at hvL
      rcases hvL with ‚ü®ő≥, hő≥L, rfl‚ü©
