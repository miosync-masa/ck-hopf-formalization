    rcases T.forest_field_relabel g q hq C with ⟨τ, hV, hI, hE⟩
    exact ⟨τ, FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr ⟨hV, hI, hE⟩⟩
  mixed_relabel := by
    intro g q hq
    rcases T.mixed_field_relabel g q hq with ⟨τ, hV, hI, hE⟩
