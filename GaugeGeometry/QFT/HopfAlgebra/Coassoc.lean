  exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2)
    hő≥ hv

/-- A mixed-boundary right-factor class equality can be proved on the actual
quotient graph and then transported to the chosen quotient representative. -/
private theorem forestComponentMixedBoundary_rightContractClass_of_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hActual :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (forestOuterActualQuotientGraph g
          (forestComponentMixedBoundaryOuterIndex g q hq))
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))).toClass) :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG (forestOuterQuotientHopfGen g
          (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
        (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
          g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG (forestOuterQuotientHopfGen g
            (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))).toClass := by
  calc
    (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (forestOuterActualQuotientGraph g
              (forestComponentMixedBoundaryOuterIndex g q hq))
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
              g q hq)
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
              g q hq))).toClass := hActual
    _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (forestOuterQuotientHopfGen g
            (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (forestOuterQuotientHopfGen g
              (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
              g q hq)
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
              g q hq))).toClass := by
          simpa [forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical,
            forestComponentMixedBoundaryRepRightQuotientSubgraph,
            forestOuterQuotientGraph] using
            forestOuterActualToRep_rightContractClass g
              (forestComponentMixedBoundaryOuterIndex g q hq)
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                g q hq)
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                g q hq)

/-- Mixed-boundary component product factored through the final representative
