into the spliced `SourceSubgraphExactPlus`. -/
private theorem supportReachable_mono_of_internalEdges_le
    {H G : FeynmanGraph} (hle : H.internalEdges ‚Č§ G.internalEdges)
    {u v : VertexId} (h : H.SupportReachable u v) :
    G.SupportReachable u v := by
  refine SimpleGraph.Reachable.mono ?_ h
  intro a b hab
  obtain ‚ü®hne, e, heH, hend‚ü© := hab
  exact ‚ü®hne, e, Multiset.mem_of_le hle heH, hend‚ü©

/-- **Track forest_cd-3a (Helper 1) ‚ÄĒ within-promoted-child reachability.**  Each
promoted child `ő∑` is a connected `A`-component, and its internal edges sit
inside the spliced `SourceSubgraphExactPlus` (promoted half), so any two of its
vertices are support-reachable in the splice. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ő∑ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő∑ : ő∑ ‚ąą forestQuotientForestSigmaForestCoverPromotedComponents g r őī)
    {u v : VertexId} (hu : u ‚ąą ő∑.vertices) (hv : v ‚ąą ő∑.vertices) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportReachable
      u v := by
  have hő∑A : ő∑ ‚ąą r.1.1.1.elements :=
    ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑).1
  have hő∑conn : ő∑.toFeynmanGraph.IsSupportConnected :=
    (r.1.1.1.isConnectedDivergent_of_mem hő∑A).1
  have hreach : ő∑.toFeynmanGraph.SupportReachable u v := hő∑conn hu hv
  have hle :
      ő∑.internalEdges ‚Č§
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).internalEdges := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    refine le_trans
      (Finset.single_le_sum (fun i _ => Multiset.zero_le _) hő∑)
      (Multiset.le_add_left _ _)
  exact supportReachable_mono_of_internalEdges_le hle hreach

/-- **Track forest_cd-3a (Helper 2a) ‚ÄĒ source-vertex retarget classification.**
Each source vertex is either a non-star vertex fixed by `retargetVertex`, or a
vertex of some promoted child `ő∑` sent to `starOf ő∑`. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {z : VertexId}
    (hz : z ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī) :
    (r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) z = z) ‚ą®
      (‚ąÉ ő∑ ‚ąą forestQuotientForestSigmaForestCoverPromotedComponents g r őī,
        z ‚ąą ő∑.vertices ‚ąß
          r.1.1.1.retargetVertex
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) z =
            FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑) := by
  classical
  have hApd : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hz
  rcases Finset.mem_union.mp hz with hns | hpr
  ¬∑ rcases Finset.mem_sdiff.mp hns with ‚ü®hzőī, hzns‚ü©
    exact Or.inl (AdmissibleSubgraph.retargetVertex_of_not_mem _ _
      (forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
        g r hzőī hzns))
  ¬∑ rcases Finset.mem_biUnion.mp hpr with ‚ü®ő∑, hő∑A, hzB‚ü©
    by_cases hs :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices
    ¬∑ simp only [hs, if_true] at hzB
      exact Or.inr ‚ü®ő∑,
        (forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mpr
          ‚ü®hő∑A, hs‚ü©,
        hzB,
        AdmissibleSubgraph.retargetVertex_of_mem_component hApd _ hő∑A hzB‚ü©
    ¬∑ simp only [hs, if_false] at hzB
      exact (Finset.notMem_empty z hzB).elim

/-- **Track forest_cd-3a (Helper 2b) ‚ÄĒ same-retarget gluing.**  Two source
vertices with equal `retargetVertex` image are support-reachable in the splice:
either they coincide (both non-star), or they lie in the same promoted child
(equal stars ‚áí equal components by freshness), where Helper 1 connects them. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {x y : VertexId}
    (hx : x ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hy : y ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hret :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) y) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportReachable
      x y := by
  classical
  have hFresh : r.1.1.1.IsFreshStarAssignment
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r őī hx with
    hx0 | ‚ü®ő∑x, hő∑x, hxő∑x, hxret‚ü©
  ¬∑ rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r őī hy with
      hy0 | ‚ü®ő∑y, hő∑y, hyő∑y, hyret‚ü©
    ¬∑ rw [show x = y from hx0.symm.trans (hret.trans hy0)]
      exact FeynmanGraph.SupportReachable.refl _ _
    ¬∑ exfalso
      have hő∑yA : ő∑y ‚ąą r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑y).1
      have hxstar : x = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑y := hx0.symm.trans (hret.trans hyret)
      exact hFresh.fresh hő∑yA
        (hxstar ‚Ėł forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r őī hx)
  ¬∑ rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r őī hy with
      hy0 | ‚ü®ő∑y, hő∑y, hyő∑y, hyret‚ü©
    ¬∑ exfalso
      have hő∑xA : ő∑x ‚ąą r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑x).1
      have hystar : y = FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑x :=
        hy0.symm.trans (hret.symm.trans hxret)
      exact hFresh.fresh hő∑xA
        (hystar ‚Ėł forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r őī hy)
    ¬∑ have hő∑xA : ő∑x ‚ąą r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑x).1
      have hő∑yA : ő∑y ‚ąą r.1.1.1.elements :=
        ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑y).1
      have hstar :
          FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑x =
            FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑y :=
        hxret.symm.trans (hret.trans hyret)
      have hő∑eq : ő∑x = ő∑y := hFresh.eq_of_star_eq hő∑xA hő∑yA hstar
      subst hő∑eq
      exact forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable
        g r őī hő∑x hxő∑x hyő∑y

/-- **Track forest_cd-3a (edge-step lift).**  A single support-adjacency step
`c ‚ÄĒőī‚ÄĒ b` in the quotient lifts: from any source preimage `wc` of `c`, there is a
source preimage `wb` of `b` reachable from `wc` in the splice.  The `őī`-edge has
an exact source preimage `eE` (`ExactInternalEdges_map`); `eE` is a `Plus` edge
joining its endpoints, and the same-retarget gluing (Helper 2b) connects `wc`/`wb`
to `eE`'s endpoints. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_edgeStep
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {c b : VertexId}
    (hadj : őī.toFeynmanGraph.SupportAdj c b)
    {wc : VertexId}
    (hwc : wc ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hwcc :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) wc = c) :
    ‚ąÉ wb, wb ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī ‚ąß
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) wb = b ‚ąß
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportReachable
        wc wb := by
  classical
  obtain ‚ü®hcb, eőī, heőī, hend‚ü© := hadj
  have heőī' : eőī ‚ąą
      (forestQuotientForestSigmaForestCoverExactInternalEdges g r őī).map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    rw [forestQuotientForestSigmaForestCoverExactInternalEdges_map]; exact heőī
  obtain ‚ü®eE, heE, hmap‚ü© := Multiset.mem_map.mp heőī'
  obtain ‚ü®hsE, htE‚ü© :=
    forestQuotientForestSigmaForestCoverExactInternalEdges_endpoints g r őī heE
  have hrs :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = eőī.source := by
    rw [‚Üź hmap]; rfl
  have hrt :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = eőī.target := by
    rw [‚Üź hmap]; rfl
  have heEPlus : eE ‚ąą
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).internalEdges := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    exact Multiset.mem_add.mpr (Or.inl heE)
  have plusAdj : eE.source ‚Č† eE.target ‚Üí
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportReachable
        eE.source eE.target :=
    fun hne => SimpleGraph.Adj.reachable
      (show (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportAdj
          eE.source eE.target from ‚ü®hne, eE, heEPlus, Or.inl ‚ü®rfl, rfl‚ü©‚ü©)
  rcases hend with ‚ü®hsc, htb‚ü© | ‚ü®hsb, htc‚ü©
  ¬∑ have hsEc :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = c := hrs.trans hsc
    have htEb :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = b := hrt.trans htb
    have hne : eE.source ‚Č† eE.target := fun h =>
      hcb (hsEc.symm.trans ((congrArg _ h).trans htEb))
    exact ‚ü®eE.target, htE, htEb,
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
        g r őī hwc hsE (hwcc.trans hsEc.symm)).trans (plusAdj hne)‚ü©
  ¬∑ have hsEb :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = b := hrs.trans hsb
    have htEc :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = c := hrt.trans htc
    have hne : eE.source ‚Č† eE.target := fun h =>
      hcb (htEc.symm.trans ((congrArg _ h.symm).trans hsEb))
    exact ‚ü®eE.source, hsE, hsEb,
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
        g r őī hwc htE (hwcc.trans htEc.symm)).trans (plusAdj hne).symm‚ü©

/-- **Track forest_cd-3a (path lift).**  A full quotient support-reachability path
`a ‚ÄĒőī‚ÄĒ* b` lifts: from any source preimage `u` of `a`, there is a source preimage
`w` of `b` reachable from `u` in the splice.  Induction on the reflexive-transitive
support path, edge-step per adjacency. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_reachable_lift
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {a b u : VertexId}
    (hu : u ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hua :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) u = a)
    (hab : őī.toFeynmanGraph.SupportReachable a b) :
    ‚ąÉ w, w ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī ‚ąß
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) w = b ‚ąß
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).toFeynmanGraph.SupportReachable
        u w := by
  have hrtg : Relation.ReflTransGen őī.toFeynmanGraph.SupportAdj a b :=
    (SimpleGraph.reachable_iff_reflTransGen _ _).1 hab
  clear hab
  induction hrtg with
  | refl => exact ‚ü®u, hu, hua, FeynmanGraph.SupportReachable.refl _ _‚ü©
  | tail _hac hcb IH =>
      obtain ‚ü®wc, hwc, hwcc, hreach‚ü© := IH
      obtain ‚ü®wb, hwb, hwbb, hstepR‚ü© :=
        forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_edgeStep
          g r őī hcb hwc hwcc
      exact ‚ü®wb, hwb, hwbb, hreach.trans hstepR‚ü©

/-- **Track forest_cd-3a (Connected).**  `SourceSubgraphExactPlus` is support
connected: any two source vertices retarget into the connected quotient component
`őī`, whose path lifts back (path lift) and whose endpoints glue (Helper 2b). -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_isConnected
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hőī : őī ‚ąą forestQuotientForestSigmaForestCoverForestComponents g r) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).IsConnected := by
  classical
  have hőīconn : őī.toFeynmanGraph.IsSupportConnected :=
    ((forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hőī).1).1
  have hrem :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r őī
  intro u v hu hv
  have hretu :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) u ‚ąą őī.vertices := by
    rw [‚Üź hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ‚ü®u, hu, rfl‚ü©
  have hretv :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v ‚ąą őī.vertices := by
    rw [‚Üź hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ‚ü®v, hv, rfl‚ü©
  obtain ‚ü®w, hw, hwv, huw‚ü© :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_reachable_lift
      g r őī hu rfl (hőīconn hretu hretv)
  exact huw.trans
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable
      g r őī hw hv hwv)

/-- **Track forest_cd-onePI (Helper 1, target-graph generalized).**  Helper 1
(`_promotedComponent_reachable`) relativized to any graph `K` whose internal
edges contain the promoted half: two vertices of a promoted child `ő∑` are
support-reachable in `K`.  Used with `K = Plus.eraseInternalEdge e` (erasing an
Exact edge keeps every Promoted edge), so the within-child gluing survives the
bridge erasure. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_promotedComponent_reachable_in
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ő∑ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő∑ : ő∑ ‚ąą forestQuotientForestSigmaForestCoverPromotedComponents g r őī)
    {K : FeynmanGraph}
    (hKle : forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī ‚Č§ K.internalEdges)
    {u v : VertexId} (hu : u ‚ąą ő∑.vertices) (hv : v ‚ąą ő∑.vertices) :
    K.SupportReachable u v := by
  have hő∑A : ő∑ ‚ąą r.1.1.1.elements :=
    ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff g r őī).mp hő∑).1
  have hő∑conn : ő∑.toFeynmanGraph.IsSupportConnected :=
    (r.1.1.1.isConnectedDivergent_of_mem hő∑A).1
  have hreach : ő∑.toFeynmanGraph.SupportReachable u v := hő∑conn hu hv
  have hle : ő∑.internalEdges ‚Č§ K.internalEdges :=
    le_trans (Finset.single_le_sum (fun i _ => Multiset.zero_le _) hő∑) hKle
  exact supportReachable_mono_of_internalEdges_le hle hreach

/-- **Track forest_cd-onePI (Helper 2b, target-graph generalized).**  Helper 2b
(`_sameRetarget_reachable`) relativized to any graph `K` whose internal edges
contain the promoted half: two source vertices with equal `retargetVertex` image
are support-reachable in `K`.  The classification (Helper 2a) and freshness
arguments are graph-independent; only the within-child step uses `K`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable_in
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {K : FeynmanGraph}
    (hKle : forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī ‚Č§ K.internalEdges)
    {x y : VertexId}
    (hx : x ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hy : y ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hret :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) y) :
    K.SupportReachable x y := by
  classical
  have hFresh : r.1.1.1.IsFreshStarAssignment
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r őī hx with
    hx0 | ‚ü®ő∑x, hő∑x, hxő∑x, hxret‚ü©
  ¬∑ rcases forestQuotientForestSigmaForestCoverSourceVertices_retarget_classify g r őī hy with
      hy0 | ‚ü®ő∑y, hő∑y, hyő∑y, hyret‚ü©
    ¬∑ rw [show x = y from hx0.symm.trans (hret.trans hy0)]
