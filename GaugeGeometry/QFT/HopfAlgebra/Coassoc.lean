/-- Literal vertex-carrier equality for the selected remnant graph
identification. -/
private theorem forestComponentForestChoiceRemnantGraph_vertices_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph // ő≥ ‚ąą q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hB :
      q.2 ő≥ (Finset.mem_attach q.1.1.elements ő≥) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq ő≥).vertices =
      (forestComponentForestChoiceComponentRemnantGraph g q hq ő≥ B).vertices := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
    (q.1.1.isConnectedDivergent_of_mem ő≥.2) B
  let innerStar := forestComponentForestChoiceComponentRemnantStarOf g q hq ő≥ B
  have hBcProper :
      Bc ‚ąą ő≥.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
    simpa [Bc] using
      forestComponentForestChoiceComponentRemnant_mem_properDisjoint
        g q hq ő≥ hB
  have hDisjBc : Bc.IsPairwiseDisjoint := by
    simpa [Bc] using
      ő≥.1.toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          hBcProper
  rw [forestComponentForestChoiceRetargetedRemnantGraph_vertices,
    forestComponentForestChoiceComponentRemnantGraph_vertices]
  ext v
  constructor
  ¬∑ intro hv
    rcases Finset.mem_image.mp hv with ‚ü®u, huő≥, huv‚ü©
    have hret :
        Aout.retargetVertex outerStar u = Bc.retargetVertex innerStar u := by
      simpa [Aout, outerStar, Bc, innerStar] using
        forestComponentForestChoice_retargetVertex_eq_componentRemnant
          g q hq ő≥ hB huő≥
    have huvB : Bc.retargetVertex innerStar u = v := hret.symm.trans huv
    by_cases huBc : u ‚ąą Bc.vertices
    ¬∑ rcases AdmissibleSubgraph.mem_vertices.mp huBc with ‚ü®ő∑, hő∑, huő∑‚ü©
      have hRetB :
          Bc.retargetVertex innerStar u = innerStar ő∑ :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hDisjBc innerStar hő∑ huő∑
      rw [Finset.mem_union]
      right
      rw [AdmissibleSubgraph.mem_starVertices]
      exact ‚ü®ő∑, hő∑, hRetB.symm.trans huvB‚ü©
    ¬∑ have hRetB : Bc.retargetVertex innerStar u = u :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Bc innerStar huBc
      have huvEq : u = v := by
        rw [hRetB] at huvB
        exact huvB
      rw [Finset.mem_union]
      left
      rw [‚Üź huvEq]
      exact Finset.mem_sdiff.mpr ‚ü®by simpa using huő≥, huBc‚ü©
  ¬∑ intro hv
    rw [Finset.mem_union] at hv
    rcases hv with hvRest | hvStar
    ¬∑ rcases Finset.mem_sdiff.mp hvRest with ‚ü®hvő≥Graph, hvBc‚ü©
      have hvő≥ : v ‚ąą ő≥.1.vertices := by
        simpa using hvő≥Graph
      refine Finset.mem_image.mpr ‚ü®v, hvő≥, ?_‚ü©
      have hret :
          Aout.retargetVertex outerStar v = Bc.retargetVertex innerStar v := by
        simpa [Aout, outerStar, Bc, innerStar] using
          forestComponentForestChoice_retargetVertex_eq_componentRemnant
            g q hq ő≥ hB hvő≥
      have hRetB : Bc.retargetVertex innerStar v = v :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Bc innerStar hvBc
      exact hret.trans hRetB
    ¬∑ rw [AdmissibleSubgraph.mem_starVertices] at hvStar
      rcases hvStar with ‚ü®ő∑, hő∑, hő∑Star‚ü©
      have hő∑Nonempty : ő∑.IsNonempty :=
        ő≥.1.toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
            hBcProper ő∑ hő∑
      unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hő∑Nonempty
      rcases Finset.card_pos.mp hő∑Nonempty with ‚ü®u, huő∑‚ü©
      have huő≥ : u ‚ąą ő≥.1.vertices := by
        simpa using ő∑.vertices_subset huő∑
      refine Finset.mem_image.mpr ‚ü®u, huő≥, ?_‚ü©
      have hret :
          Aout.retargetVertex outerStar u = Bc.retargetVertex innerStar u := by
        simpa [Aout, outerStar, Bc, innerStar] using
          forestComponentForestChoice_retargetVertex_eq_componentRemnant
            g q hq ő≥ hB huő≥
      have hRetB :
          Bc.retargetVertex innerStar u = innerStar ő∑ :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hDisjBc innerStar hő∑ huő∑
      exact hret.trans (hRetB.trans hő∑Star)

