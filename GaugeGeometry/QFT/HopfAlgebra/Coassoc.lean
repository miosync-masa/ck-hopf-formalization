    (hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r) :
    0 < (forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ).card := by
  classical
  have hForestProp :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ).2
  rw [Finset.not_disjoint_iff] at hForestProp
  rcases hForestProp with ⟨v, hvδ, hvStar⟩
  rcases AdmissibleSubgraph.mem_starVertices.mp hvStar with ⟨η, hηA, hStarEq⟩
  have hηPromoted :
      η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ := by
    rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff]
    refine ⟨hηA, ?_⟩
    rw [hStarEq]; exact hvδ
  have hAhasPositive :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      r.1.1.2
  have hηIcard : 0 < η.internalEdges.card := hAhasPositive η hηA
  rcases Multiset.card_pos_iff_exists_mem.mp hηIcard with ⟨e, heη⟩
  have hePromoted :
      e ∈ forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ := by
    unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges
    exact Multiset.mem_sum.mpr ⟨η, hηPromoted, heη⟩
  exact Multiset.card_pos_iff_exists_mem.mpr ⟨e, hePromoted⟩

