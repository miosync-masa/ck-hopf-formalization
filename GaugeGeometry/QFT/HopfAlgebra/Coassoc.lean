        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestOuterActualRetargetAdmissibleSubgraphOfCert g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentChoiceRightSubgraph q.1.1 q.2) C

/-- Representative quotient-side right-selected survivor forest in the
genuine-forest regime. -/
