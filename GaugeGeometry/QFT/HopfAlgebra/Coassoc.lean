    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A‚āĀ A‚āā : forestOuterProperIndex g} (hA : A‚āĀ = A‚āā)
    {R‚āĀ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A‚āĀ))}
    {R‚āā : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A‚āā))}
