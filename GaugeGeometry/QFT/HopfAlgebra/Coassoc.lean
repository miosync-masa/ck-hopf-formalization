    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ő∑ : FeynmanSubgraph (repG g).toFeynmanGraph} :
    ő∑ ‚ąą forestQuotientForestSigmaForestCoverNonPromotedComponents g r őī ‚ÜĒ
      ő∑ ‚ąą r.1.1.1.elements ‚ąß
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąČ őī.vertices := by
  unfold forestQuotientForestSigmaForestCoverNonPromotedComponents
