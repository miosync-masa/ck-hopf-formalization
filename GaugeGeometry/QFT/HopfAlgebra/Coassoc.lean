private theorem forestComponentForestChoiceToQuotientForestSigma_inj_of_q1_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q‚āĀ q‚āā : forestComponentChoiceSigma g}
    (hq‚āĀ : q‚āĀ ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hq‚āā : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hq1 : q‚āĀ.1 = q‚āā.1)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ =
      forestComponentForestChoiceOuterIndex g q‚āā hq‚āā) :
    q‚āĀ = q‚āā := by
  classical
  have hA‚āĀ : q‚āĀ.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āĀ.1.2
  have hA‚āā : q‚āā.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āā.1.2
  have hpCore‚āĀ : q‚āĀ.2 ‚ąą forestComponentCoreChoiceIndex q‚āĀ.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      (Finset.mem_sigma.mp hq‚āĀ).2).1
  have hpCore‚āā : q‚āā.2 ‚ąą forestComponentCoreChoiceIndex q‚āā.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      (Finset.mem_sigma.mp hq‚āā).2).1
  have hNE‚āĀ : q‚āĀ.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q‚āĀ.1.2).2.1
  have hNE‚āā : q‚āā.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q‚āā.1.2).2.1
  have hCO‚āĀ :
      (forestComponentForestChoiceOuterSubgraph q‚āĀ.1.1 q‚āĀ.2 hA‚āĀ).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents hpCore‚āĀ q‚āĀ.1.2 hA‚āĀ
  have hCO‚āā :
      (forestComponentForestChoiceOuterSubgraph q‚āā.1.1 q‚āā.2 hA‚āā).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents hpCore‚āā q‚āā.1.2 hA‚āā
  have hOuterSubEq :
      forestComponentForestChoiceOuterSubgraph q‚āĀ.1.1 q‚āĀ.2 hA‚āĀ =
      forestComponentForestChoiceOuterSubgraph q‚āā.1.1 q‚āā.2 hA‚āā := by
    have h := congrArg Subtype.val hOuter
    simpa [forestComponentForestChoiceOuterIndex_val] using h
  refine Sigma.ext hq1 ?_
  rcases q‚āĀ with ‚ü®A‚āĀ, p‚āĀ‚ü©
  rcases q‚āā with ‚ü®A‚āā, p‚āā‚ü©
  cases hq1
  refine heq_of_eq ?_
  exact forestComponentForestChoiceOuterSubgraph_inj
    hpCore‚āĀ hpCore‚āā hA‚āĀ hNE‚āĀ hCO‚āĀ hCO‚āā hOuterSubEq

/-- **Track B-forest-final ‚ÄĒ genuine-forest same-branch injectivity** (the
