            (q.1.1.isConnectedDivergent_of_mem γ.2) B)
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (γ.1.toHopfGen
            (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          B
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (γ.1.toHopfGen
              (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            B
            (forestComponentChoice_forest_mem_properDisjoint_of_core_mem
              (mem_forestComponentForestChoiceCoreIndex_core_hasForest
                ((Finset.mem_sigma.mp hq).2)).1
              γ hB))).toClass

/-- Canonical quotient-remnant carrier disjointness supplies the pairwise
field for the component-to-representative transport package. -/
private noncomputable def
    forestComponentForestChoiceComponentToRepContractionClassTransportOfBridge
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (T : forestComponentForestChoiceComponentToRepContractionClassBridge g) :
    forestComponentForestChoiceComponentToRepContractionClassTransport g where
  pairwise := forestComponentForestChoiceRemnantComponentsForChoice_pairwiseDisjoint g
  component_to_rep_class := T.component_to_rep_class

/-- The component-specific contraction bridge is an instance of the generic
permutation-preimage contraction transport, with the component remnant star
assignment supplying the required freshness. -/
private noncomputable def
    forestComponentForestChoiceComponentToRepContractionClassBridgeOfPreimageTransport
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : admissibleForestContractPreimageClassTransport) (g : HopfGen) :
    forestComponentForestChoiceComponentToRepContractionClassBridge g where
  component_to_rep_class := by
    intro q hq γ B hB
    let hγCD := q.1.1.isConnectedDivergent_of_mem γ.2
    let hπ := feynmanSubgraphToHopfGenRepPerm_spec γ.1 hγCD
    have hpCore :
        q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest
        ((Finset.mem_sigma.mp hq).2)).1
    have hBmem :
        B ∈ ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph
          ).properDisjointAdmissibleDivergentSubgraphs :=
      forestComponentChoice_forest_mem_properDisjoint_of_core_mem
        hpCore γ hB
    have hFresh :
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1 hγCD B
          ).IsFreshStarAssignment
            (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) := by
      simpa [hγCD] using
        forestComponentForestChoiceComponentRemnantStarOf_isFresh
          g q hq γ hB
    simpa [hγCD, hπ, feynmanSubgraphRepToComponentAdmissibleSubgraph] using
      T.preimage_contract_class hπ B hBmem
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)
        hFresh

/-- The component-to-representative bridge using the concrete finite
star-alignment and carrier transport on the well-formed component graph. -/
private noncomputable def
    forestComponentForestChoiceComponentToRepContractionClassBridgeCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentForestChoiceComponentToRepContractionClassBridge g where
  component_to_rep_class := by
    intro q hq γ B hB
    let hγCD := q.1.1.isConnectedDivergent_of_mem γ.2
    let hπ := feynmanSubgraphToHopfGenRepPerm_spec γ.1 hγCD
    let Apre := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1 hγCD B
    let starOf := forestComponentForestChoiceComponentRemnantStarOf g q hq γ B
    have hpCore :
        q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest
        ((Finset.mem_sigma.mp hq).2)).1
    have hBmem :
        B ∈ ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph
          ).properDisjointAdmissibleDivergentSubgraphs :=
      forestComponentChoice_forest_mem_properDisjoint_of_core_mem
        hpCore γ hB
    have hApre :
        Apre ∈ γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
      simpa [Apre, hγCD] using
        feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
          γ.1 hγCD hBmem
    have hFresh :
        Apre.IsFreshStarAssignment starOf := by
      simpa [Apre, starOf, hγCD] using
        forestComponentForestChoiceComponentRemnantStarOf_isFresh
          g q hq γ hB
    calc
      (FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1 hγCD B)
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)).toClass
          =
        (FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
          Apre
          (FeynmanGraph.admissibleForestCanonicalStarOf
            γ.1.toFeynmanGraph Apre hApre)).toClass := by
          simpa [Apre, starOf] using
            admissibleForestContractFreshStarClass_of_wellFormed
              γ.1.toFeynmanGraph_wellFormed Apre hApre starOf hFresh
      _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (γ.1.toHopfGen
            (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          B
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (γ.1.toHopfGen
              (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            B
            (forestComponentChoice_forest_mem_properDisjoint_of_core_mem
              (mem_forestComponentForestChoiceCoreIndex_core_hasForest
                ((Finset.mem_sigma.mp hq).2)).1
              γ hB))).toClass := by
          simpa [Apre, hγCD, hπ,
            feynmanSubgraphRepToComponentAdmissibleSubgraph] using
            admissibleForestContractCanonicalPreimageClass_of_wellFormed
              hπ γ.1.toFeynmanGraph_wellFormed B hBmem

/-- The canonical remnant graph identification reduces the component-class
payload to the remaining component-to-representative contraction class bridge. -/
private noncomputable def
    forestComponentForestChoiceRemnantComponentClassTransportOfComponentToRep
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (T : forestComponentForestChoiceComponentToRepContractionClassTransport g) :
    forestComponentForestChoiceRemnantComponentClassTransport g where
  pairwise := T.pairwise
  component_class := by
    intro q hq γ B hB
    calc
      (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1).toFeynmanGraph.toClass
          =
        (FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2) B)
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)
        ).toClass := by
          exact congrArg FeynmanGraph.toClass
            ((forestComponentForestChoiceRemnantGraphIdentificationCertificateCanonical
              g q hq).graph_eq γ B hB)
      _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (γ.1.toHopfGen
            (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          B
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (γ.1.toHopfGen
              (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            B
            (forestComponentChoice_forest_mem_properDisjoint_of_core_mem
              (mem_forestComponentForestChoiceCoreIndex_core_hasForest
                ((Finset.mem_sigma.mp hq).2)).1
              γ hB))).toClass := by
          exact T.component_to_rep_class q hq γ B hB

/-- The graph-level remnant transport payload gives the product-level remnant
transport used by the final H5.8F cut. -/
private noncomputable def
    forestComponentForestChoiceRemnantInnerProductTransportOfGraphTransport
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (T : forestComponentForestChoiceRemnantInnerProductGraphTransport g) :
    forestComponentForestChoiceRemnantInnerProductTransport g where
  remnant_product := by
    classical
    intro q hq
    rw [forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical_toHopfH_eq_actual]
    unfold AdmissibleSubgraph.toHopfH
    rw [forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical_elements]
    rw [forestComponentForestChoiceRemnantComponents_eq_biUnion_forChoice]
    rw [Finset.prod_biUnion (T.pairwise q hq)]
    apply Finset.prod_congr rfl
    intro γ _hγ
    exact (T.factor_product q hq γ).symm

/-- Canonical remnant-only product transport.  The quotient-remnant product is
now obtained by composing the canonical component-to-representative contraction
bridge with the already-proved remnant carrier disjointness and local class
identifications. -/
private noncomputable def
    forestComponentForestChoiceRemnantInnerProductTransportCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentForestChoiceRemnantInnerProductTransport g :=
  forestComponentForestChoiceRemnantInnerProductTransportOfGraphTransport g
    (forestComponentForestChoiceRemnantInnerProductGraphTransportOfComponentClass
      g
      (forestComponentForestChoiceRemnantComponentClassTransportOfComponentToRep
        g
        (forestComponentForestChoiceComponentToRepContractionClassTransportOfBridge
          g
          (forestComponentForestChoiceComponentToRepContractionClassBridgeCanonical
            g))))

/-- The full inner quotient/remnant product identity follows from the
remnant-only transport, because the right-selected survivor product is already
transported to the representative quotient carrier and the full quotient
forest product splits as right survivors times remnants. -/
private theorem
    forestComponentForestChoiceInnerProduct_eq_repQuotient_of_remnantTransport
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (T : forestComponentForestChoiceRemnantInnerProductTransport g) :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      (∏ γ ∈ q.1.1.elements.attach,
        forestComponentChoiceInnerTensorFactorOfCore q.1.1 q.2
          (mem_forestComponentForestChoiceCoreIndex_core_hasForest
            ((Finset.mem_sigma.mp hq).2)).1
          γ
          (Finset.mem_attach q.1.1.elements γ)) =
        (forestComponentForestChoiceRepQuotientSubgraphCanonical
          g q hq).toHopfH := by
  classical
  intro q hq
  let hpCore :
      q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      ((Finset.mem_sigma.mp hq).2)).1
  rw [forestComponentChoiceInnerTensorFactor_product_eq_right_mul_remnant
    q.1.1 q.2 hpCore]
  rw [T.remnant_product q hq]
  rw [← forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq
    g q hq]
  rw [forestComponentForestChoiceRepQuotientSubgraphCanonical_toHopfH_eq_right_mul_remnant
    g q hq]

/-- The abstract outer-product field follows from the explicit
left/promoted geometric product identity. -/
private theorem forestComponentForestChoice_outerProduct_of_leftPromoted
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (P : forestComponentForestChoiceOuterProductFactorization g) :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      (∏ γ ∈ q.1.1.elements.attach,
        forestComponentChoiceOuterTensorFactor q.1.1 q.2 γ
          (Finset.mem_attach q.1.1.elements γ)) =
        (forestComponentForestChoiceOuterIndex g q hq).1.toHopfH := by
  intro q hq
  rw [forestComponentChoiceOuterTensorFactor_product_eq_left_mul_promoted]
  exact P.left_mul_promoted q hq

/-- Build the genuine-forest product factorization from the explicit
outer left/promoted product identity plus the inner quotient/remnant product
identity. -/
private noncomputable def forestComponentForestChoiceProductFactorizationOfOuterInner
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (Pouter : forestComponentForestChoiceOuterProductFactorization g)
    (hInner :
      ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        (∏ γ ∈ q.1.1.elements.attach,
          forestComponentChoiceInnerTensorFactorOfCore q.1.1 q.2
            (mem_forestComponentForestChoiceCoreIndex_core_hasForest
              ((Finset.mem_sigma.mp hq).2)).1
            γ
            (Finset.mem_attach q.1.1.elements γ)) =
          (forestComponentForestChoiceRepQuotientSubgraphCanonical
            g q hq).toHopfH) :
    forestComponentForestChoiceProductFactorization g where
  outer_product :=
    forestComponentForestChoice_outerProduct_of_leftPromoted g Pouter
  inner_product := hInner

/-- Assemble the branchwise `φ` package after reducing the genuine-forest
product term to its two explicit outer/inner product identities. -/
private noncomputable def forestComponentSplitPhiBranchReindexingOfProductPayloads
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq)
    (I : forestComponentSplitPhiBranchInverseCover g)
    (P : forestComponentForestChoiceProductFactorization g)
    (hForestRight :
      ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestRightHopfH g q.1.1 q.1.2 =
          forestRightHopfH
            (forestOuterQuotientHopfGen g
              (forestComponentForestChoiceOuterIndex g q hq))
            (forestComponentForestChoiceRepQuotientSubgraphCanonical
              g q hq)
            (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
              g q hq (C q hq)))
    (hMixedRight :
      ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestRightHopfH g q.1.1 q.1.2 =
          forestRightHopfH
            (forestOuterQuotientHopfGen g
              (forestComponentMixedBoundaryOuterIndex g q hq))
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
              g q hq)
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
              g q hq)) :
    forestComponentSplitPhiBranchReindexing g :=
  forestComponentSplitPhiBranchReindexingOfRightPayloads g C I
    (forestComponentForestChoice_productTerm_eq_repQuotient_of_productFactors
      g P)
    hForestRight hMixedRight

/-- The sum of the two LHS split regimes as one flat carrier sum. -/
private theorem forestTermEComponentSplitChoicesDistributed_eq_sigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermEComponentForestChoicesDistributed g +
        forestTermEComponentMixedBoundaryChoicesDistributed g =
      ∑ q ∈ forestComponentSplitChoiceSigmaIndex g,
        forestComponentSplitChoiceSigmaTerm g q := by
  rw [forestTermEComponentForestChoicesDistributed_eq_sigma g,
    forestTermEComponentMixedBoundaryChoicesDistributed_eq_sigma g]
  unfold forestComponentSplitChoiceSigmaIndex forestComponentSplitChoiceSigmaTerm
  exact (Finset.sum_disjSum
    (forestComponentForestChoiceSigmaIndex g)
    (forestComponentMixedBoundaryChoiceSigmaIndex g)
    (forestComponentSplitChoiceSigmaTerm g)).symm

/-- A concrete finite reindexing of the split LHS flat carrier onto the explicit
RHS quotient-forest flat carrier proves the flat core identity. -/
private theorem forestComponentSplitChoices_flat_reindex_eq_quotient
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (φ : forestComponentSplitChoiceSigma g → forestQuotientForestSigma g)
    (hMap : ∀ q, q ∈ forestComponentSplitChoiceSigmaIndex g →
      φ q ∈ forestQuotientForestSigmaIndex g)
    (hInj : ∀ q₁, q₁ ∈ forestComponentSplitChoiceSigmaIndex g →
      ∀ q₂, q₂ ∈ forestComponentSplitChoiceSigmaIndex g →
        φ q₁ = φ q₂ → q₁ = q₂)
    (hSurj : ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      ∃ q, ∃ hq : q ∈ forestComponentSplitChoiceSigmaIndex g, φ q = r)
    (hTerm : ∀ q, ∀ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
      forestComponentSplitChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g (φ q)) :
    (∑ q ∈ forestComponentSplitChoiceSigmaIndex g,
        forestComponentSplitChoiceSigmaTerm g q) =
      ∑ r ∈ forestQuotientForestSigmaIndex g,
        forestQuotientForestSigmaTerm g r := by
  exact Finset.sum_bij (fun q _ => φ q)
    (fun q hq => hMap q hq)
    (fun q₁ hq₁ q₂ hq₂ hφ => hInj q₁ hq₁ q₂ hq₂ hφ)
    (fun r hr => hSurj r hr)
    (fun q hq => hTerm q hq)

/-- Final forest coassociativity cut stated directly as the pending
finite-reindexing problem. -/
private theorem coassoc_strict_forest_linear_of_component_reindex
    [IsDivergencePreservedByAdmissibleForestContract]
    (φ : ∀ g : HopfGen, forestComponentSplitChoiceSigma g → forestQuotientForestSigma g)
    (hMap : ∀ g q, q ∈ forestComponentSplitChoiceSigmaIndex g →
      φ g q ∈ forestQuotientForestSigmaIndex g)
    (hInj : ∀ g q₁, q₁ ∈ forestComponentSplitChoiceSigmaIndex g →
      ∀ q₂, q₂ ∈ forestComponentSplitChoiceSigmaIndex g →
        φ g q₁ = φ g q₂ → q₁ = q₂)
    (hSurj : ∀ g r, r ∈ forestQuotientForestSigmaIndex g →
      ∃ q, ∃ hq : q ∈ forestComponentSplitChoiceSigmaIndex g, φ g q = r)
    (hTerm : ∀ g q, ∀ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
      forestComponentSplitChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g (φ g q)) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_split_component_core
    (fun g => by
      rw [forestTermEComponentSplitChoicesDistributed_eq_sigma g,
        forestTermFQuotientForestChoicesExpanded_eq_sigma g]
      exact forestComponentSplitChoices_flat_reindex_eq_quotient g
        (φ g)
        (hMap g)
        (hInj g)
        (hSurj g)
        (hTerm g))

/-- Bundled graph-level data for the final H5.8F forest reindexing.  The
previous theorem is deliberately left unbundled for direct `Finset.sum_bij`
use; this structure is the ergonomic target for the actual quotient-forest
construction of `φ`. -/
private structure forestComponentSplitGraphReindexing
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  map : forestComponentSplitChoiceSigma g → forestQuotientForestSigma g
  map_mem : ∀ q, q ∈ forestComponentSplitChoiceSigmaIndex g →
    map q ∈ forestQuotientForestSigmaIndex g
  inj_on : ∀ q₁, q₁ ∈ forestComponentSplitChoiceSigmaIndex g →
    ∀ q₂, q₂ ∈ forestComponentSplitChoiceSigmaIndex g →
      map q₁ = map q₂ → q₁ = q₂
  surj_on : ∀ r, r ∈ forestQuotientForestSigmaIndex g →
    ∃ q, ∃ hq : q ∈ forestComponentSplitChoiceSigmaIndex g, map q = r
  term_eq : ∀ q, ∀ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
    forestComponentSplitChoiceSigmaTerm g q =
      forestQuotientForestSigmaTerm g (map q)

/-- The final graph-reindexing bundle specialized to the concrete `φ` map.
The membership field is now supplied by canonical mixed-boundary membership
plus the genuine-forest remnant-positivity certificates; the remaining fields
are the actual bijectivity and term-identification climb. -/
private noncomputable def forestComponentSplitPhiGraphReindexing
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq)
    (hInj : ∀ q₁, q₁ ∈ forestComponentSplitChoiceSigmaIndex g →
      ∀ q₂, q₂ ∈ forestComponentSplitChoiceSigmaIndex g →
        forestComponentSplitPhi g q₁ = forestComponentSplitPhi g q₂ →
          q₁ = q₂)
    (hSurj : ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      ∃ q, ∃ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
