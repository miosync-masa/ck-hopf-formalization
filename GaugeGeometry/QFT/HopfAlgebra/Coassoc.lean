/-- Sprint F2i-3o-2h-1: forward inclusion for vertices remainder equality.
The image of `SourceVertices` under `retargetVertex` is contained in
`őī.vertices`.  Two cases per the SourceVertices definition:
- non-star őī-vertex (in `őī.vertices \ A.starVertices`): comes from the
  actual quotient graph's complement side, hence outside `A.vertices`,
  so `retargetVertex` is the identity (F2g-0 pattern).
- promoted ő∑.vertex (some ő∑ ‚ąą A.elements with starOf ő∑ ‚ąą őī.vertices):
  `retargetVertex` sends it to `starOf ő∑ ‚ąą őī.vertices`. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (forestQuotientForestSigmaForestCoverSourceVertices g r őī).image
      (r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) ‚äÜ
      őī.vertices := by
  classical
  intro v hv
  rcases Finset.mem_image.mp hv with ‚ü®x, hxSrc, rfl‚ü©
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hxSrc
  rcases Finset.mem_union.mp hxSrc with hLeft | hRight
  ¬∑ -- non-star őī-vertex
    rcases Finset.mem_sdiff.mp hLeft with ‚ü®hxőī, hxNotStar‚ü©
    have hxQ : x ‚ąą (forestOuterActualQuotientGraph g r.1.1).vertices :=
      őī.vertices_subset hxőī
    unfold forestOuterActualQuotientGraph at hxQ
    simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices] at hxQ
    rcases Finset.mem_union.mp hxQ with hRest | hStar
    ¬∑ have hxNotA : x ‚ąČ r.1.1.1.vertices :=
        (Finset.mem_sdiff.mp hRest).2
      rw [AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1 _ hxNotA]
      exact hxőī
    ¬∑ exact absurd hStar hxNotStar
  ¬∑ -- promoted ő∑.vertices
    rcases Finset.mem_biUnion.mp hRight with ‚ü®ő∑, hő∑A, hxBranch‚ü©
    by_cases hStarő∑ :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices
    ¬∑ simp only [hStarő∑, if_true] at hxBranch
      have hDisj : r.1.1.1.IsPairwiseDisjoint :=
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          r.1.1.2
      rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisj _ hő∑A hxBranch]
      exact hStarő∑
    ¬∑ simp only [hStarő∑, if_false] at hxBranch
      exact (Finset.notMem_empty x hxBranch).elim

/-- Sprint F2i-3o-2h-2a: star-vertex preimage helper.  If a forest element
`ő∑ ‚ąą A.elements` has `starOf ő∑ ‚ąą őī.vertices`, then `starOf ő∑` lies in the
image of SourceVertices under retargetVertex.  Uses `A.HasNonemptyComponents`
(from `properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents`) to
extract a witness vertex `x ‚ąą ő∑.vertices`, then F2i-3a `_eta_subset` to
place it in SourceVertices, and `retargetVertex_of_mem_component` to send it
to `starOf ő∑`. -/
private theorem forestQuotientForestSigmaForestCover_starVertex_mem_image_retarget
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ő∑ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő∑A : ő∑ ‚ąą r.1.1.1.elements)
    (hStar :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices) :
    FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą
      (forestQuotientForestSigmaForestCoverSourceVertices g r őī).image
        (r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  classical
  have hCompNE : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  have hő∑NE : ő∑.IsNonempty := hCompNE ő∑ hő∑A
  rcases Finset.card_pos.mp hő∑NE with ‚ü®x, hxő∑‚ü©
  have hxSrc :
      x ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī :=
    forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hő∑A hStar hxő∑
  have hPair : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hRet :
      r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) x =
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ :=
    AdmissibleSubgraph.retargetVertex_of_mem_component hPair _ hő∑A hxő∑
  exact Finset.mem_image.mpr ‚ü®x, hxSrc, hRet‚ü©

/-- Sprint F2i-3o-2h-2b: reverse inclusion for vertices remainder equality.
`őī.vertices ‚äÜ (SourceVertices).image retargetVertex`.  Two cases:
- non-star case: `v ‚ąą G.V \ A.V`, then `v ‚ąČ starVertices` via fresh-star
  disjointness, so `v ‚ąą SourceVertices` (non-star branch) and
  `retargetVertex v = v` (F2i-3o-2h-1 mechanics).
- star case: `v = starOf ő∑` for some `ő∑ ‚ąą A.elements`; the F2i-3o-2h-2a
  helper closes this. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_supset
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    őī.vertices ‚äÜ
      (forestQuotientForestSigmaForestCoverSourceVertices g r őī).image
        (r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  classical
  intro v hvőī
  have hvQ : v ‚ąą (forestOuterActualQuotientGraph g r.1.1).vertices :=
    őī.vertices_subset hvőī
  unfold forestOuterActualQuotientGraph at hvQ
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices] at hvQ
  rcases Finset.mem_union.mp hvQ with hOutside | hStar
  ¬∑ -- non-star: v ‚ąą G.V \ A.V
    rcases Finset.mem_sdiff.mp hOutside with ‚ü®_, hvNotA‚ü©
    have hFresh :
        r.1.1.1.IsFreshStarAssignment
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
      FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
    have hvNotStar :
        v ‚ąČ r.1.1.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) :=
      Finset.disjoint_left.mp hFresh.disjoint_sdiff_starVertices hOutside
    have hvSrc :
        v ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī :=
      forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem
        g r hvőī hvNotStar
    have hRet :
        r.1.1.1.retargetVertex
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v = v :=
      AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1 _ hvNotA
    exact Finset.mem_image.mpr ‚ü®v, hvSrc, hRet‚ü©
  ¬∑ -- star case: v = starOf ő∑ for some ő∑ ‚ąą A.elements
    rcases AdmissibleSubgraph.mem_starVertices.mp hStar with ‚ü®ő∑, hő∑A, rfl‚ü©
    exact forestQuotientForestSigmaForestCover_starVertex_mem_image_retarget
      g r őī hő∑A hvőī

/-- Sprint F2i-3o-2h-3: Plus version's quotient-remainder vertices coincide
with `őī.vertices`.  Combines the F2i-3o-2h-1 forward inclusion with the
F2i-3o-2h-2b reverse inclusion via `Finset.Subset.antisymm`.  Completes the
3-carrier remainder equality (vertices ‚úď, internalEdges ‚úď, externalLegs ‚úď). -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī)).vertices
      = őī.vertices := by
  rw [admissibleSubgraphQuotientRemainderSubgraph_vertices,
      forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices]
  exact Finset.Subset.antisymm
    (forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_subset g r őī)
    (forestQuotientForestSigmaForestCoverSourceVertices_image_retarget_supset g r őī)

/-- Sprint F2i-3o-2i: the Plus version's quotient remainder is *exactly* `őī`
as a `FeynmanSubgraph` of the actual quotient graph.  Bundles the F2i-3o-2f
externalLegs, F2i-3o-2g internalEdges, and F2i-3o-2h-3 vertices equalities
into a full structural equality; the five proof fields collapse by
definitional proof irrelevance once the three carriers are pinned down.
This is the **local inverse** for forest cover source recovery: starting
from any `őī` in the actual quotient graph, the Plus source subgraph in the
ambient graph quotient-remainders back to `őī`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī)
      = őī := by
  have hV :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_vertices
      g r őī
  have hI :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_internalEdges
      g r őī
  have hE :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_externalLegs
      g r őī
  generalize hlhs :
      admissibleSubgraphQuotientRemainderSubgraph
