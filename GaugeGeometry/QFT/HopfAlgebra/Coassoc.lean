/-- Applying `mapPerm` to a subgraph and then taking the canonical preimage
along the same permutation recovers the original subgraph. -/
private theorem mapPermSubgraph_preimage_mapPerm_eq
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (ő≥ : FeynmanSubgraph G‚āĀ) :
    mapPermSubgraph_preimage hŌÄ (mapPermSubgraph hŌÄ ő≥) = ő≥ :=
  mapPermSubgraph_injective hŌÄ
    (by simpa using
      mapPermSubgraph_preimage_eq hŌÄ (mapPermSubgraph hŌÄ ő≥))

/-- Applying `mapPerm` to an admissible forest and then taking the canonical
preimage along the same permutation recovers the original admissible forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āĀ) :
    mapPermAdmissibleSubgraphPreimage hŌÄ
      (mapPermAdmissibleSubgraph hŌÄ A) = A := by
  unfold mapPermAdmissibleSubgraphPreimage
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  change
    (mapPermAdmissibleSubgraph
      (by
        subst hŌÄ
        rw [‚Üź FeynmanGraph.mapPerm_mul]
        simpa using (FeynmanGraph.mapPerm_one G‚āĀ).symm)
      (mapPermAdmissibleSubgraph hŌÄ A)).elements = A.elements
  rw [mapPermAdmissibleSubgraph_elements, mapPermAdmissibleSubgraph_elements]
  ext ő≥
  constructor
  ¬∑ intro hő≥
    rcases Finset.mem_image.mp hő≥ with ‚ü®ő≥', hő≥', hő≥'eq‚ü©
    rcases Finset.mem_image.mp hő≥' with ‚ü®őī, hőī, rfl‚ü©
    change mapPermSubgraph_preimage hŌÄ (mapPermSubgraph hŌÄ őī) = ő≥ at hő≥'eq
    have hő≥őī : ő≥ = őī :=
      hő≥'eq.symm.trans (mapPermSubgraph_preimage_mapPerm_eq hŌÄ őī)
    simpa [hő≥őī] using hőī
  ¬∑ intro hő≥
    refine Finset.mem_image.mpr ?_
    refine ‚ü®mapPermSubgraph hŌÄ ő≥, ?_, ?_‚ü©
    ¬∑ exact Finset.mem_image.mpr ‚ü®ő≥, hő≥, rfl‚ü©
    ¬∑ change mapPermSubgraph_preimage hŌÄ (mapPermSubgraph hŌÄ ő≥) = ő≥
      exact mapPermSubgraph_preimage_mapPerm_eq hŌÄ ő≥

/-- Vertex membership in a permutation preimage admissible forest is exactly
target forest membership after applying the ambient permutation. -/
private theorem mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āā)
    {v : VertexId} :
    v ‚ąą (mapPermAdmissibleSubgraphPreimage hŌÄ A).vertices ‚ÜĒ
      ŌÄ v ‚ąą A.vertices := by
  constructor
  ¬∑ intro hv
    rw [AdmissibleSubgraph.mem_vertices] at hv ‚äĘ
    rcases hv with ‚ü®őī, hőī, hvőī‚ü©
    rw [mapPermAdmissibleSubgraphPreimage_elements] at hőī
    rcases Finset.mem_image.mp hőī with ‚ü®ő≥, hő≥, rfl‚ü©
    refine ‚ü®ő≥, hő≥, ?_‚ü©
    have hV := mapPermSubgraph_preimage_vertices hŌÄ ő≥
    rw [‚Üź hV]
    rw [mapPermSubgraph_vertices]
    exact Finset.mem_image.mpr ‚ü®v, hvőī, rfl‚ü©
  ¬∑ intro hv
    rw [AdmissibleSubgraph.mem_vertices] at hv ‚äĘ
    rcases hv with ‚ü®ő≥, hő≥, hŌÄvő≥‚ü©
    refine ‚ü®mapPermSubgraph_preimage hŌÄ ő≥, ?_, ?_‚ü©
    ¬∑ rw [mapPermAdmissibleSubgraphPreimage_elements]
      exact Finset.mem_image.mpr ‚ü®ő≥, hő≥, rfl‚ü©
    ¬∑ have hV := mapPermSubgraph_preimage_vertices hŌÄ ő≥
      rw [‚Üź hV] at hŌÄvő≥
      rw [mapPermSubgraph_vertices] at hŌÄvő≥
      rcases Finset.mem_image.mp hŌÄvő≥ with ‚ü®u, hu, huv‚ü©
      have huv' : u = v := ŌÄ.injective huv
      simpa [huv'] using hu

/-- Internal-edge carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_internalEdges_map
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āā) :
    (mapPermAdmissibleSubgraphPreimage hŌÄ A).internalEdges.map
        (FeynmanEdge.map ŌÄ) =
      A.internalEdges := by
  classical
  unfold AdmissibleSubgraph.internalEdges
  change (Multiset.mapAddMonoidHom (FeynmanEdge.map ŌÄ))
      (‚ąĎ ő≥ ‚ąą (mapPermAdmissibleSubgraphPreimage hŌÄ A).elements,
        ő≥.internalEdges) =
    ‚ąĎ ő≥ ‚ąą A.elements, ő≥.internalEdges
  rw [map_sum (Multiset.mapAddMonoidHom (FeynmanEdge.map ŌÄ))]
  rw [mapPermAdmissibleSubgraphPreimage_elements]
  rw [Finset.sum_image]
  ¬∑ apply Finset.sum_congr rfl
    intro ő≥ hő≥
    rw [mapPermSubgraph_internalEdges]
    change (ő≥.internalEdges.map (FeynmanEdge.map ŌÄ‚ĀĽ¬Ļ)).map
        (FeynmanEdge.map ŌÄ) =
      ő≥.internalEdges
    rw [Multiset.map_map]
    have hcomp : (FeynmanEdge.map ŌÄ) ‚ąė (FeynmanEdge.map ŌÄ‚ĀĽ¬Ļ) = id := by
      funext e
      cases e with
      | mk src tgt sec =>
        show FeynmanEdge.map ŌÄ (FeynmanEdge.map ŌÄ‚ĀĽ¬Ļ ‚ü®src, tgt, sec‚ü©) =
          ‚ü®src, tgt, sec‚ü©
        simp [FeynmanEdge.map, ŌÄ.apply_symm_apply]
    rw [hcomp, Multiset.map_id]
  ¬∑ intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā h
    have hpre :
        mapPermSubgraph_preimage hŌÄ ő≥‚āĀ =
          mapPermSubgraph_preimage hŌÄ ő≥‚āā := by
      simpa [mapPermSubgraph_preimage] using h
    have hmap := congrArg (mapPermSubgraph hŌÄ) hpre
    simpa [mapPermSubgraph_preimage_eq hŌÄ ő≥‚āĀ,
      mapPermSubgraph_preimage_eq hŌÄ ő≥‚āā] using hmap

/-- `Multiset.map` distributes over subtraction along an injective map. -/
private theorem multiset_map_sub_of_injective {őĪ ő≤ : Type*}
    [DecidableEq őĪ] [DecidableEq ő≤] {f : őĪ ‚Üí ő≤}
    (hf : Function.Injective f) {A B : Multiset őĪ} :
    (A - B).map f = A.map f - B.map f := by
  refine Multiset.ext.mpr (fun y => ?_)
  rw [Multiset.count_sub]
  by_cases hy : y ‚ąą A.map f
  ¬∑ rcases Multiset.mem_map.mp hy with ‚ü®x, hxA, rfl‚ü©
    rw [Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_map_eq_count' _ _ hf,
        Multiset.count_sub]
  ¬∑ have hy_sub : y ‚ąČ (A - B).map f := by
      intro h
      rcases Multiset.mem_map.mp h with ‚ü®x, hx, rfl‚ü©
      have hxA : x ‚ąą A := Multiset.mem_of_le (Multiset.sub_le_self _ _) hx
      exact hy (Multiset.mem_map.mpr ‚ü®x, hxA, rfl‚ü©)
    rw [Multiset.count_eq_zero_of_notMem hy_sub,
        Multiset.count_eq_zero_of_notMem hy]
    simp

/-- `Multiset.map` distributes over subtraction whenever the subtracted multiset
is actually contained in the source.  This avoids a global injectivity
requirement for retargeting maps that intentionally collapse component
vertices. -/
private theorem multiset_map_sub_of_le {őĪ ő≤ : Type*} [DecidableEq őĪ]
    [DecidableEq ő≤] (f : őĪ ‚Üí ő≤) {A B : Multiset őĪ} (hBA : B ‚Č§ A) :
    (A - B).map f = A.map f - B.map f := by
  calc
    (A - B).map f = ((A - B).map f + B.map f) - B.map f := by
      rw [Multiset.add_sub_cancel_right]
    _ = ((A - B + B).map f) - B.map f := by
      rw [Multiset.map_add]
    _ = A.map f - B.map f := by
      rw [Multiset.sub_add_cancel hBA]

/-- Internal-edge carrier transport for an admissible forest under an ambient
permutation. -/
private theorem mapPermAdmissibleSubgraph_internalEdges
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āĀ) :
    (mapPermAdmissibleSubgraph hŌÄ A).internalEdges =
      A.internalEdges.map (FeynmanEdge.map ŌÄ) := by
  classical
  unfold AdmissibleSubgraph.internalEdges
  rw [mapPermAdmissibleSubgraph_elements]
  rw [Finset.sum_image]
  ¬∑ change
      (‚ąĎ x ‚ąą A.elements, (mapPermSubgraph hŌÄ x).internalEdges) =
        (Multiset.mapAddMonoidHom (FeynmanEdge.map ŌÄ))
          (‚ąĎ ő≥ ‚ąą A.elements, ő≥.internalEdges)
    rw [map_sum (Multiset.mapAddMonoidHom (FeynmanEdge.map ŌÄ))]
    apply Finset.sum_congr rfl
    intro ő≥ _hő≥
    exact mapPermSubgraph_internalEdges hŌÄ ő≥
  ¬∑ intro ő≥‚āĀ _ ő≥‚āā _ hő≥
    exact (mapPermSubgraph_injective hŌÄ) hő≥

/-- Complement-edge cardinality is preserved by admissible-forest permutation
transport. -/
private theorem mapPermAdmissibleSubgraph_complementEdges_card
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āĀ) :
    (mapPermAdmissibleSubgraph hŌÄ A).complementEdges.card =
      A.complementEdges.card := by
  classical
  unfold AdmissibleSubgraph.complementEdges
  rw [mapPermAdmissibleSubgraph_internalEdges hŌÄ A]
  have hG :
      G‚āā.internalEdges = G‚āĀ.internalEdges.map (FeynmanEdge.map ŌÄ) := by
    subst hŌÄ
    rfl
  rw [hG]
  rw [‚Üź multiset_map_sub_of_injective
    (FeynmanGraph.FeynmanEdge_map_injective ŌÄ)]
  rw [Multiset.card_map]

/-- Complement-edge carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_complementEdges_map
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) (A : AdmissibleSubgraph G‚āā) :
    (mapPermAdmissibleSubgraphPreimage hŌÄ A).complementEdges.map
        (FeynmanEdge.map ŌÄ) =
      A.complementEdges := by
  classical
  unfold AdmissibleSubgraph.complementEdges
  rw [multiset_map_sub_of_injective
    (FeynmanGraph.FeynmanEdge_map_injective ŌÄ)]
  rw [mapPermAdmissibleSubgraphPreimage_internalEdges_map hŌÄ A]
  have hGI : G‚āĀ.internalEdges.map (FeynmanEdge.map ŌÄ) = G‚āā.internalEdges := by
    rw [hŌÄ]
    rfl
  rw [hGI]

/-- External-leg carrier transport for a permutation-preimage admissible
forest. -/
private theorem mapPermAdmissibleSubgraphPreimage_externalLegs_map
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ) :
    G‚āĀ.externalLegs.map (ExternalLeg.map ŌÄ) = G‚āā.externalLegs := by
  rw [hŌÄ]
  rfl

/-- Generic graph-level contraction transport across a representative
permutation.  This is the remaining non-component-specific geometric fact:
contracting the permutation preimage of an admissible forest with any fresh
component-star assignment gives the same graph class as contracting the
representative forest with its canonical component stars. -/
private structure admissibleForestContractPreimageClassTransport : Prop where
  preimage_contract_class :
    ‚ąÄ {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
      (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
      (A : AdmissibleSubgraph G‚āā)
      (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G‚āĀ ‚Üí VertexId),
        (mapPermAdmissibleSubgraphPreimage hŌÄ A).IsFreshStarAssignment starOf ‚Üí
        (FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
          (mapPermAdmissibleSubgraphPreimage hŌÄ A) starOf).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
          (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).toClass

/-- Star-choice invariance for admissible forest contractions in a fixed
ambient graph. -/
private structure admissibleForestContractFreshStarClassTransport : Prop where
  fresh_star_class :
    ‚ąÄ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G ‚Üí VertexId),
        A.IsFreshStarAssignment starOf ‚Üí
        (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars G A
          (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).toClass

/-- Field-level star-renaming data for a fixed admissible forest contraction:
after applying `ŌĄ`, the contraction using `starOf` is literally the
contraction using the canonical component stars. -/
private structure admissibleForestContractFreshStarRelabeling : Prop where
  relabel :
    ‚ąÄ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G ‚Üí VertexId),
        A.IsFreshStarAssignment starOf ‚Üí
        ‚ąÉ ŌĄ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)) =
          (FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
            ).mapPerm ŌĄ

/-- Fieldwise version of fixed-forest fresh-star relabeling. -/
private structure admissibleForestContractFreshStarFieldRelabeling : Prop where
  field_relabel :
    ‚ąÄ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G ‚Üí VertexId),
        A.IsFreshStarAssignment starOf ‚Üí
        ‚ąÉ ŌĄ : Equiv.Perm VertexId,
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).vertices =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm ŌĄ).vertices ‚ąß
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).internalEdges =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm ŌĄ).internalEdges ‚ąß
          (FeynmanGraph.admissibleForestContractGraphWithStars G A
            (FeynmanGraph.admissibleForestCanonicalStarOf G A hA)).externalLegs =
            ((FeynmanGraph.admissibleForestContractGraphWithStars G A starOf
              ).mapPerm ŌĄ).externalLegs

/-- Concrete finite relabeling data for the fresh-star side: a permutation
which fixes every ambient vertex and sends each chosen fresh component star to
the canonical component star. -/
private structure admissibleForestContractFreshStarPermutationData : Prop where
  exists_perm :
    ‚ąÄ {G : FeynmanGraph}
      (A : AdmissibleSubgraph G)
      (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
      (starOf : FeynmanSubgraph G ‚Üí VertexId),
        A.IsFreshStarAssignment starOf ‚Üí
        ‚ąÉ ŌĄ : Equiv.Perm VertexId,
          (‚ąÄ v,
            (v ‚ąą G.vertices ‚ą®
              (‚ąÉ e ‚ąą A.complementEdges, e.source = v ‚ą® e.target = v) ‚ą®
              (‚ąÉ ‚Ąď ‚ąą G.externalLegs, ‚Ąď.attachedTo = v)) ‚Üí
              ŌĄ v = v) ‚ąß
          ‚ąÄ ő≥ ‚ąą A.elements,
            ŌĄ (starOf ő≥) =
              FeynmanGraph.admissibleForestCanonicalStarOf G A hA ő≥

/-- A finite partial vertex relabeling can be extended to a permutation of
`VertexId`: fix the finite set `S` and send the finite injective family
`src` to the finite injective family `dst`, provided both star families are
disjoint from `S`.  The construction is the finite-support one: extend the
partial map on the support subtype, then extend that permutation by the
identity outside the support. -/
private theorem finite_visible_star_permutation
    {őĻ : Type*} [Fintype őĻ] [DecidableEq őĻ]
    (S : Finset VertexId) (src dst : őĻ ‚Üí VertexId)
    (hsrcInj : Function.Injective src)
    (hdstInj : Function.Injective dst)
    (hsrcS : ‚ąÄ i, src i ‚ąČ S)
    (hdstS : ‚ąÄ i, dst i ‚ąČ S) :
    ‚ąÉ ŌĄ : Equiv.Perm VertexId,
      (‚ąÄ v, v ‚ąą S ‚Üí ŌĄ v = v) ‚ąß
      ‚ąÄ i, ŌĄ (src i) = dst i := by
  classical
  let srcSet : Finset VertexId := Finset.univ.image src
  let dstSet : Finset VertexId := Finset.univ.image dst
  let support : Finset VertexId := S ‚ą™ srcSet ‚ą™ dstSet
  let p : {x // x ‚ąą support} ‚Üí VertexId := fun x =>
    if h : ‚ąÉ i, src i = x.1 then dst h.choose else x.1
  let domain : Finset {x // x ‚ąą support} :=
    Finset.univ.filter (fun x : {x // x ‚ąą support} =>
      x.1 ‚ąą S ‚ą® ‚ąÉ i, src i = x.1)
  have hcard : Fintype.card {x // x ‚ąą support} = support.card :=
    Fintype.card_coe support
  have hp_subset : Finset.image p domain ‚äÜ support := by
    intro y hy
    rw [Finset.mem_image] at hy
    rcases hy with ‚ü®x, hx, rfl‚ü©
    dsimp [p]
    split
    ¬∑ rename_i hsrc
      simp [support, dstSet]
    ¬∑ exact x.2
  have hp_inj : Set.InjOn p (domain : Set {x // x ‚ąą support}) := by
    intro x hx y hy hxy
    have hx' : x.1 ‚ąą S ‚ą® ‚ąÉ i, src i = x.1 := by
      simpa [domain] using hx
    have hy' : y.1 ‚ąą S ‚ą® ‚ąÉ i, src i = y.1 := by
      simpa [domain] using hy
    rcases hx' with hxS | hxsrc
    ¬∑ rcases hy' with hyS | hysrc
      ¬∑ dsimp [p] at hxy
        have hxNotSrc : ¬¨ ‚ąÉ i, src i = x.1 := by
          rintro ‚ü®i, hi‚ü©
          exact hsrcS i (hi ‚Ėł hxS)
        have hyNotSrc : ¬¨ ‚ąÉ i, src i = y.1 := by
          rintro ‚ü®i, hi‚ü©
          exact hsrcS i (hi ‚Ėł hyS)
        simp [hxNotSrc, hyNotSrc] at hxy
        exact hxy
      ¬∑ dsimp [p] at hxy
        have hxNotSrc : ¬¨ ‚ąÉ i, src i = x.1 := by
          rintro ‚ü®i, hi‚ü©
          exact hsrcS i (hi ‚Ėł hxS)
        simp [hxNotSrc, hysrc] at hxy
        exact False.elim (hdstS hysrc.choose (hxy ‚Ėł hxS))
    ¬∑ rcases hy' with hyS | hysrc
      ¬∑ dsimp [p] at hxy
        have hyNotSrc : ¬¨ ‚ąÉ i, src i = y.1 := by
          rintro ‚ü®i, hi‚ü©
          exact hsrcS i (hi ‚Ėł hyS)
        simp [hxsrc, hyNotSrc] at hxy
        exact False.elim (hdstS hxsrc.choose (hxy.symm ‚Ėł hyS))
      ¬∑ dsimp [p] at hxy
        simp [hxsrc, hysrc] at hxy
        have hi :
            hxsrc.choose = hysrc.choose :=
          hdstInj hxy
        have hxval : x.1 = y.1 := by
          rw [‚Üź hxsrc.choose_spec, ‚Üź hysrc.choose_spec, hi]
        exact Subtype.ext hxval
  obtain ‚ü®ŌÉ, hŌÉ‚ü© :=
    Finset.exists_equiv_extend_of_card_eq hcard hp_subset hp_inj
  let ŌĄ : Equiv.Perm VertexId :=
    Equiv.Perm.extendDomain ŌÉ (Finset.equivToSet support)
  refine ‚ü®ŌĄ, ?_, ?_‚ü©
  ¬∑ intro v hvS
    have hvSupport : v ‚ąą support := by
      simp [support, hvS]
    have hvDomain : (‚ü®v, hvSupport‚ü© : {x // x ‚ąą support}) ‚ąą domain := by
      dsimp [domain]
      rw [Finset.mem_filter]
      exact ‚ü®Finset.mem_univ _, Or.inl hvS‚ü©
    have hpv : p ‚ü®v, hvSupport‚ü© = v := by
      dsimp [p]
      have hvNotSrc : ¬¨ ‚ąÉ i, src i = v := by
        rintro ‚ü®i, hi‚ü©
        exact hsrcS i (hi ‚Ėł hvS)
      simp [hvNotSrc]
    have hŌÉv : (ŌÉ ‚ü®v, hvSupport‚ü© : VertexId) = v := by
      simpa [hpv] using hŌÉ ‚ü®v, hvSupport‚ü© hvDomain
    have hŌĄ :
        ŌĄ ((Finset.equivToSet support) ‚ü®v, hvSupport‚ü©) =
          (Finset.equivToSet support) (ŌÉ ‚ü®v, hvSupport‚ü©) :=
      Equiv.Perm.extendDomain_apply_image ŌÉ
        (Finset.equivToSet support) ‚ü®v, hvSupport‚ü©
    change ŌĄ v = (ŌÉ ‚ü®v, hvSupport‚ü© : VertexId) at hŌĄ
    exact hŌĄ.trans hŌÉv
  ¬∑ intro i
    have hsrcSupport : src i ‚ąą support := by
      simp [support, srcSet]
    have hsrcDomain :
        (‚ü®src i, hsrcSupport‚ü© : {x // x ‚ąą support}) ‚ąą domain := by
      dsimp [domain]
      rw [Finset.mem_filter]
      exact ‚ü®Finset.mem_univ _, Or.inr ‚ü®i, rfl‚ü©‚ü©
    have hp_src : p ‚ü®src i, hsrcSupport‚ü© = dst i := by
      dsimp [p]
      split
      ¬∑ rename_i h
        have hi : h.choose = i :=
          hsrcInj h.choose_spec
        exact congrArg dst hi
      ¬∑ rename_i h
        exact False.elim (h ‚ü®i, rfl‚ü©)
    have hŌÉsrc : (ŌÉ ‚ü®src i, hsrcSupport‚ü© : VertexId) = dst i := by
      simpa [hp_src] using hŌÉ ‚ü®src i, hsrcSupport‚ü© hsrcDomain
    have hŌĄ :
        ŌĄ ((Finset.equivToSet support) ‚ü®src i, hsrcSupport‚ü©) =
          (Finset.equivToSet support) (ŌÉ ‚ü®src i, hsrcSupport‚ü©) :=
      Equiv.Perm.extendDomain_apply_image ŌÉ
        (Finset.equivToSet support) ‚ü®src i, hsrcSupport‚ü©
    change ŌĄ (src i) = (ŌÉ ‚ü®src i, hsrcSupport‚ü© : VertexId) at hŌĄ
    exact hŌĄ.trans hŌÉsrc

/-- Actual fresh-star permutation construction for a well-formed ambient
graph.  The finite extension lemma is applied to the component carrier, fixing
ambient vertices and sending each caller-supplied fresh star to the canonical
component star.  Well-formedness then upgrades "fix ambient vertices" to the
visible-vertex condition used by the field relabeling. -/
private theorem admissibleForestContractFreshStarPermutation_of_wellFormed
    {G : FeynmanGraph} (hGwf : G.WellFormed)
    (A : AdmissibleSubgraph G)
    (hA : A ‚ąą G.properDisjointAdmissibleDivergentSubgraphs)
    (starOf : FeynmanSubgraph G ‚Üí VertexId)
    (hFresh : A.IsFreshStarAssignment starOf) :
    ‚ąÉ ŌĄ : Equiv.Perm VertexId,
      (‚ąÄ v,
        (v ‚ąą G.vertices ‚ą®
          (‚ąÉ e ‚ąą A.complementEdges, e.source = v ‚ą® e.target = v) ‚ą®
          (‚ąÉ ‚Ąď ‚ąą G.externalLegs, ‚Ąď.attachedTo = v)) ‚Üí
          ŌĄ v = v) ‚ąß
      ‚ąÄ ő≥ ‚ąą A.elements,
        ŌĄ (starOf ő≥) =
          FeynmanGraph.admissibleForestCanonicalStarOf G A hA ő≥ := by
  classical
  let src : {ő≥ // ő≥ ‚ąą A.elements} ‚Üí VertexId := fun ő≥ => starOf ő≥.1
  let dst : {ő≥ // ő≥ ‚ąą A.elements} ‚Üí VertexId := fun ő≥ =>
    FeynmanGraph.admissibleForestCanonicalStarOf G A hA ő≥.1
  have hsrcInj : Function.Injective src := by
    intro ő≥‚āĀ ő≥‚āā h
    apply Subtype.ext
    exact hFresh.eq_of_star_eq ő≥‚āĀ.2 ő≥‚āā.2 h
  have hdstInj : Function.Injective dst := by
    intro ő≥‚āĀ ő≥‚āā h
    apply Subtype.ext
    exact AdmissibleSubgraph.componentFreshStar_eq_of_eq ő≥‚āĀ.2 (by
      simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using h)
  have hsrcS : ‚ąÄ ő≥ : {ő≥ // ő≥ ‚ąą A.elements}, src ő≥ ‚ąČ G.vertices := by
    intro ő≥
    exact hFresh.fresh ő≥.2
  have hdstS : ‚ąÄ ő≥ : {ő≥ // ő≥ ‚ąą A.elements}, dst ő≥ ‚ąČ G.vertices := by
    intro ő≥
    simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using
      A.componentFreshStar_not_mem_vertices ő≥.1
  rcases finite_visible_star_permutation G.vertices src dst
      hsrcInj hdstInj hsrcS hdstS with
    ‚ü®ŌĄ, hFixVertices, hStarSubtype‚ü©
  refine ‚ü®ŌĄ, ?_, ?_‚ü©
  ¬∑ intro v hVisible
    apply hFixVertices v
    rcases hVisible with hv | hRest
    ¬∑ exact hv
    rcases hRest with hEdge | hLeg
    ¬∑ rcases hEdge with ‚ü®e, he, hev‚ü©
      have heG : e ‚ąą G.internalEdges :=
        A.mem_ambientInternalEdges_of_mem_complementEdges he
      have hsupp := FeynmanGraph.wellFormed_internal hGwf heG
      rcases hev with rfl | rfl
      ¬∑ exact hsupp.1
      ¬∑ exact hsupp.2
    ¬∑ rcases hLeg with ‚ü®‚Ąď, h‚Ąď, h‚Ąďv‚ü©
      have hsupp := FeynmanGraph.wellFormed_external hGwf h‚Ąď
      exact h‚Ąďv ‚Ėł hsupp
  ¬∑ intro ő≥ hő≥
    simpa [src, dst] using hStarSubtype ‚ü®ő≥, hő≥‚ü©

/-- Finite star-alignment permutation for the canonical mapPerm-preimage
side.  For `hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ`, it constructs `ŌĄ = ŌÉ * ŌÄ` so that
ambient vertices are transported by `ŌÄ`, while canonical stars of the
preimage forest are sent to the canonical stars of the target forest. -/
private theorem admissibleForestContractCanonicalPreimage_starPermutation
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (A : AdmissibleSubgraph G‚āā)
    (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs) :
    let Apre := mapPermAdmissibleSubgraphPreimage hŌÄ A
    let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA
    ‚ąÉ ŌĄ : Equiv.Perm VertexId,
      (‚ąÄ v ‚ąą G‚āĀ.vertices, ŌĄ v = ŌÄ v) ‚ąß
      ‚ąÄ ő≥ ‚ąą A.elements,
        ŌĄ (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
            (mapPermSubgraph_preimage hŌÄ ő≥)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA ő≥ := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hŌÄ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA
  let pre : {ő≥ // ő≥ ‚ąą A.elements} ‚Üí FeynmanSubgraph G‚āĀ :=
    fun ő≥ => mapPermSubgraph_preimage hŌÄ ő≥.1
  let src : {ő≥ // ő≥ ‚ąą A.elements} ‚Üí VertexId := fun ő≥ =>
    ŌÄ (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
      (pre ő≥))
  let dst : {ő≥ // ő≥ ‚ąą A.elements} ‚Üí VertexId := fun ő≥ =>
    FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA ő≥.1
  have hpre_mem : ‚ąÄ ő≥ : {ő≥ // ő≥ ‚ąą A.elements}, pre ő≥ ‚ąą Apre.elements := by
    intro ő≥
    rw [mapPermAdmissibleSubgraphPreimage_elements]
    refine Finset.mem_image.mpr ?_
    exact ‚ü®ő≥.1, ő≥.2, rfl‚ü©
  have hsrcInj : Function.Injective src := by
    intro ő≥‚āĀ ő≥‚āā h
    apply Subtype.ext
    have hstar :
        FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
            (pre ő≥‚āĀ) =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
            (pre ő≥‚āā) :=
      ŌÄ.injective h
    have hpre_eq : pre ő≥‚āĀ = pre ő≥‚āā :=
      (FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        G‚āĀ Apre hApre).eq_of_star_eq (hpre_mem ő≥‚āĀ) (hpre_mem ő≥‚āā) hstar
    have hmap := congrArg (mapPermSubgraph hŌÄ) hpre_eq
    simpa [pre, mapPermSubgraph_preimage_eq hŌÄ ő≥‚āĀ.1,
      mapPermSubgraph_preimage_eq hŌÄ ő≥‚āā.1] using hmap
  have hdstInj : Function.Injective dst := by
    intro ő≥‚āĀ ő≥‚āā h
    apply Subtype.ext
    exact AdmissibleSubgraph.componentFreshStar_eq_of_eq ő≥‚āĀ.2 (by
      simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using h)
  have hsrcS : ‚ąÄ ő≥ : {ő≥ // ő≥ ‚ąą A.elements}, src ő≥ ‚ąČ G‚āā.vertices := by
    intro ő≥ hmem
    have hsource_not :
        FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
            (pre ő≥) ‚ąČ G‚āĀ.vertices := by
      simpa [FeynmanGraph.admissibleForestCanonicalStarOf] using
        Apre.componentFreshStar_not_mem_vertices (pre ő≥)
    subst hŌÄ
    rw [FeynmanGraph.mapPerm_vertices, Finset.mem_image] at hmem
    rcases hmem with ‚ü®v, hv, hvŌÄ‚ü©
    have hv_eq :
        v =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
            (pre ő≥) :=
      ŌÄ.injective hvŌÄ
    exact hsource_not (hv_eq ‚Ėł hv)
  have hdstS : ‚ąÄ ő≥ : {ő≥ // ő≥ ‚ąą A.elements}, dst ő≥ ‚ąČ G‚āā.vertices := by
    intro ő≥
    simpa [dst, FeynmanGraph.admissibleForestCanonicalStarOf] using
      A.componentFreshStar_not_mem_vertices ő≥.1
  rcases finite_visible_star_permutation G‚āā.vertices src dst
      hsrcInj hdstInj hsrcS hdstS with
    ‚ü®ŌÉ, hŌÉFix, hŌÉStar‚ü©
  refine ‚ü®ŌÉ * ŌÄ, ?_, ?_‚ü©
  ¬∑ intro v hv
    have hŌÄv : ŌÄ v ‚ąą G‚āā.vertices := by
      subst hŌÄ
      rw [FeynmanGraph.mapPerm_vertices]
      exact Finset.mem_image.mpr ‚ü®v, hv, rfl‚ü©
    simp [Equiv.Perm.mul_apply, hŌÉFix (ŌÄ v) hŌÄv]
  ¬∑ intro ő≥ hő≥
    simpa [src, dst, pre, Equiv.Perm.mul_apply] using
      hŌÉStar ‚ü®ő≥, hő≥‚ü©

/-- Vertex field transport for the canonical mapPerm-preimage contraction,
assuming the explicit star-alignment permutation data. -/
private theorem admissibleForestContractCanonicalPreimage_vertices_eq_of_starPermutation
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ ŌĄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (A : AdmissibleSubgraph G‚āā)
    (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs)
    (hŌĄV : ‚ąÄ v ‚ąą G‚āĀ.vertices, ŌĄ v = ŌÄ v)
    (hŌĄStar :
      ‚ąÄ ő≥ ‚ąą A.elements,
        ŌĄ (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA)
            (mapPermSubgraph_preimage hŌÄ ő≥)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA ő≥) :
    (FeynmanGraph.admissibleForestContractGraphWithStars G‚āā A
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA)).vertices =
    ((FeynmanGraph.admissibleForestContractGraphWithStars G‚āĀ
      (mapPermAdmissibleSubgraphPreimage hŌÄ A)
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
        (mapPermAdmissibleSubgraphPreimage hŌÄ A)
        (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
          hŌÄ hA))).mapPerm ŌĄ).vertices := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hŌÄ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices,
    FeynmanGraph.mapPerm_vertices]
  ext v
  constructor
  ¬∑ intro hv
    rw [Finset.mem_union] at hv
    rw [Finset.mem_image]
    rcases hv with hvRest | hvStar
    ¬∑ have hvG‚āā : v ‚ąą G‚āā.vertices := (Finset.mem_sdiff.mp hvRest).1
      have hvA : v ‚ąČ A.vertices := (Finset.mem_sdiff.mp hvRest).2
      have hG‚āāverts : G‚āā.vertices = G‚āĀ.vertices.image ŌÄ := by
        rw [hŌÄ]
        rfl
      rw [hG‚āāverts, Finset.mem_image] at hvG‚āā
      rcases hvG‚āā with ‚ü®u, huG‚āĀ, huv‚ü©
      refine ‚ü®u, ?_, ?_‚ü©
      ¬∑ rw [Finset.mem_union]
        left
        rw [Finset.mem_sdiff]
        refine ‚ü®huG‚āĀ, ?_‚ü©
        intro huApre
        have hŌÄuA : ŌÄ u ‚ąą A.vertices :=
          (mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
            hŌÄ A).mp huApre
        exact hvA (by simpa [huv] using hŌÄuA)
      ¬∑ exact (hŌĄV u huG‚āĀ).trans huv
    ¬∑ rw [AdmissibleSubgraph.mem_starVertices] at hvStar
      rcases hvStar with ‚ü®ő≥, hő≥, hő≥v‚ü©
      refine ‚ü®
        FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre
          (mapPermSubgraph_preimage hŌÄ ő≥), ?_, ?_‚ü©
      ¬∑ rw [Finset.mem_union]
        right
        rw [AdmissibleSubgraph.mem_starVertices]
        refine ‚ü®mapPermSubgraph_preimage hŌÄ ő≥, ?_, rfl‚ü©
        rw [mapPermAdmissibleSubgraphPreimage_elements]
        exact Finset.mem_image.mpr ‚ü®ő≥, hő≥, rfl‚ü©
      ¬∑ exact (hŌĄStar ő≥ hő≥).trans hő≥v
  ¬∑ intro hv
    rw [Finset.mem_image] at hv
    rcases hv with ‚ü®u, hu, huv‚ü©
    rw [Finset.mem_union] at hu ‚äĘ
    rcases hu with huRest | huStar
    ¬∑ left
      rw [Finset.mem_sdiff] at huRest ‚äĘ
      have hŌĄu : ŌĄ u = ŌÄ u := hŌĄV u huRest.1
      have huvŌÄ : v = ŌÄ u := by
        rw [‚Üź huv, hŌĄu]
      refine ‚ü®?_, ?_‚ü©
      ¬∑ have hG‚āāverts : G‚āā.vertices = G‚āĀ.vertices.image ŌÄ := by
          rw [hŌÄ]
          rfl
        rw [hG‚āāverts]
        exact Finset.mem_image.mpr ‚ü®u, huRest.1, huvŌÄ.symm‚ü©
      ¬∑ intro hvA
        have hŌÄuA : ŌÄ u ‚ąą A.vertices := by
          simpa [huvŌÄ] using hvA
        exact huRest.2
          ((mapPermAdmissibleSubgraphPreimage_mem_vertices_iff
            hŌÄ A).mpr hŌÄuA)
    ¬∑ right
      rw [AdmissibleSubgraph.mem_starVertices] at huStar ‚äĘ
      rcases huStar with ‚ü®őī, hőī, hőīu‚ü©
      rw [mapPermAdmissibleSubgraphPreimage_elements] at hőī
      rcases Finset.mem_image.mp hőī with ‚ü®ő≥, hő≥, rfl‚ü©
      refine ‚ü®ő≥, hő≥, ?_‚ü©
      rw [‚Üź huv, ‚Üź hőīu]
      have hstar := hŌĄStar ő≥ hő≥
      unfold mapPermSubgraph_preimage at hstar
      exact hstar.symm

/-- Pointwise retarget transport for canonical mapPerm-preimage contractions.
When `v` is an ambient vertex of `G‚āĀ`, applying the star-alignment
permutation after preimage retargeting agrees with target retargeting after
applying the ambient permutation. -/
private theorem admissibleForestContractCanonicalPreimage_retargetVertex_map
    {G‚āĀ G‚āā : FeynmanGraph} {ŌÄ ŌĄ : Equiv.Perm VertexId}
    (hŌÄ : G‚āā = G‚āĀ.mapPerm ŌÄ)
    (A : AdmissibleSubgraph G‚āā)
    (hA : A ‚ąą G‚āā.properDisjointAdmissibleDivergentSubgraphs)
    (hŌĄV : ‚ąÄ v ‚ąą G‚āĀ.vertices, ŌĄ v = ŌÄ v)
    (hŌĄStar :
      ‚ąÄ ő≥ ‚ąą A.elements,
        ŌĄ (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
            (mapPermAdmissibleSubgraphPreimage hŌÄ A)
            (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA)
            (mapPermSubgraph_preimage hŌÄ ő≥)) =
          FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA ő≥)
    {v : VertexId} (hvG‚āĀ : v ‚ąą G‚āĀ.vertices) :
    ŌĄ ((mapPermAdmissibleSubgraphPreimage hŌÄ A).retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ
          (mapPermAdmissibleSubgraphPreimage hŌÄ A)
          (mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA)) v) =
      A.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA) (ŌÄ v) := by
  classical
  let Apre := mapPermAdmissibleSubgraphPreimage hŌÄ A
  let hApre := mapPermAdmissibleSubgraphPreimage_mem_properDisjoint hŌÄ hA
  have hDisjA : A.IsPairwiseDisjoint :=
    G‚āā.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hA
  have hDisjPre : Apre.IsPairwiseDisjoint :=
    G‚āĀ.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint hApre
  by_cases hvApre : v ‚ąą Apre.vertices
  ¬∑ let őī := Apre.componentAt hvApre
    have hőī : őī ‚ąą Apre.elements := Apre.componentAt_mem hvApre
    have hvőī : v ‚ąą őī.vertices := Apre.componentAt_vertex_mem hvApre
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisjPre
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre) hőī hvőī]
    rw [mapPermAdmissibleSubgraphPreimage_elements] at hőī
    rcases Finset.mem_image.mp hőī with ‚ü®ő≥, hő≥, hőīeq‚ü©
    rw [‚Üź hőīeq] at hvőī ‚äĘ
    have hŌÄvő≥ : ŌÄ v ‚ąą ő≥.vertices := by
      have hV := mapPermSubgraph_preimage_vertices hŌÄ ő≥
      rw [‚Üź hV]
      rw [mapPermSubgraph_vertices]
      exact Finset.mem_image.mpr ‚ü®v, hvőī, rfl‚ü©
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component hDisjA
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA) hő≥ hŌÄvő≥]
    have hstar := hŌĄStar ő≥ hő≥
    unfold mapPermSubgraph_preimage at hstar
    exact hstar
  ¬∑ have hŌÄvA : ŌÄ v ‚ąČ A.vertices := by
      intro h
      exact hvApre
        ((mapPermAdmissibleSubgraphPreimage_mem_vertices_iff hŌÄ A).mpr h)
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem Apre
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āĀ Apre hApre) hvApre]
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem A
      (FeynmanGraph.admissibleForestCanonicalStarOf G‚āā A hA) hŌÄvA]
    exact hŌĄV v hvG‚āĀ

/-- Internal-edge retarget transport for canonical mapPerm-preimage
