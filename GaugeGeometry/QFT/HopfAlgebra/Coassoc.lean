      constructor
      ¬∑ intro ő≥ hő≥
        exact A.isConnectedDivergent_of_mem (hs hő≥)
      ¬∑ intro ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hne
        exact A.forest.nestedOrDisjoint (hs hő≥‚āĀ) (hs hő≥‚āā) hne)

@[simp] private theorem admissibleSubgraphOfSubelements_elements
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (s : Finset (FeynmanSubgraph G))
    (hs : s ‚äÜ A.elements) :
