/-- The strict forest-choice carrier supplies component-local complement
positivity canonically. -/
private def
    forestComponentForestChoiceComponentComplementPositiveCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq where
  positive := by
    intro ő≥ B hB
    have hpForest :
        q.2 ‚ąą forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    have hpCore :
        q.2 ‚ąą forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
    have hRepPos :
        0 < B.complementEdges.card :=
      forestComponentChoice_forest_complementEdges_positive_of_core_mem
        hpCore ő≥ hB
    have hcard :
        (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
          (q.1.1.isConnectedDivergent_of_mem ő≥.2) B
        ).complementEdges.card = B.complementEdges.card := by
      have hmap :=
        mapPermAdmissibleSubgraphPreimage_complementEdges_map
          (feynmanSubgraphToHopfGenRepPerm_spec ő≥.1
            (q.1.1.isConnectedDivergent_of_mem ő≥.2)) B
      have hcardMap := congrArg Multiset.card hmap
      simpa [feynmanSubgraphRepToComponentAdmissibleSubgraph] using hcardMap
    rw [hcard]
    exact hRepPos

/-- Component complement positivity gives positivity of the component quotient
graph because quotient internal edges are exactly the retargeted complement
edges. -/
private def
    forestComponentForestChoiceComponentRemnantPositiveCertificateOfComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq) :
    forestComponentForestChoiceComponentRemnantPositiveCertificate g q hq where
