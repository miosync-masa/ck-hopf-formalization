  let incl : HopfH ‚Üí‚āź[‚Ąö] HopfH ‚äó[‚Ąö] HopfH :=
    Algebra.TensorProduct.includeLeft
  change (‚ąŹ x ‚ąą A.elements.attach,
      incl (MvPolynomial.X (x.1.toHopfGen
        (A.isConnectedDivergent_of_mem x.2)) : HopfH)) =
    incl (‚ąŹ x ‚ąą A.elements,
      if hő≥ : x ‚ąą A.elements then
        (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hő≥)) :
          HopfH)
      else 1)
  calc
    (‚ąŹ x ‚ąą A.elements.attach,
        incl (MvPolynomial.X (x.1.toHopfGen
          (A.isConnectedDivergent_of_mem x.2)) : HopfH))
        = incl (‚ąŹ x ‚ąą A.elements.attach,
            (MvPolynomial.X (x.1.toHopfGen
              (A.isConnectedDivergent_of_mem x.2)) : HopfH)) := by
          rw [map_prod]
    _ = incl (‚ąŹ x ‚ąą A.elements,
          if hő≥ : x ‚ąą A.elements then
            (MvPolynomial.X (x.toHopfGen (A.isConnectedDivergent_of_mem hő≥)) :
              HopfH)
          else 1) := by
          congr 1
          rw [‚Üź Finset.prod_attach A.elements
            (fun x : FeynmanSubgraph G =>
              if hő≥ : x ‚ąą A.elements then
                (MvPolynomial.X (x.toHopfGen
                  (A.isConnectedDivergent_of_mem hő≥)) : HopfH)
              else 1)]
          apply Finset.prod_congr rfl
          intro x hx
          simp

