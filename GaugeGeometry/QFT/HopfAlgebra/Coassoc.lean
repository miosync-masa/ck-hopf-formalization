remainder formula.  Existing `SourceSubgraphExact` (whose `internalEdges`
is just `ExactInternalEdges`) is preserved unchanged. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices :=
    forestQuotientForestSigmaForestCoverSourceVertices g r őī
  internalEdges :=
    forestQuotientForestSigmaForestCoverExactInternalEdges g r őī +
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī
  externalLegs :=
    forestQuotientForestSigmaForestCoverExactExternalLegs g r őī
  vertices_subset :=
    forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r őī
  internalEdges_le := by
    have hAIPair : r.1.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        r.1.1.2
    have hAIle :
        r.1.1.1.internalEdges ‚Č§ (repG g).toFeynmanGraph.internalEdges :=
      admissibleSubgraph_internalEdges_le_of_pairwise r.1.1.1 hAIPair
    calc
