  have heδ' : eδ ∈
      ((forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).erase e).map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    rw [Multiset.map_erase_of_mem _ _ he,
        forestQuotientForestSigmaForestCoverExactInternalEdges_map]
    exact heδ
  obtain ⟨eE, heEerase, hmap⟩ := Multiset.mem_map.mp heδ'
  have heE : eE ∈ forestQuotientForestSigmaForestCoverExactInternalEdges g r δ :=
    Multiset.mem_of_mem_erase heEerase
