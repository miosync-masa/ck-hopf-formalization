/-- **Track B-forest-final-4c (forward).**  A forest parent of `q‚āĀ` is a forest
parent of `q‚āā`, given the `RemnantComponents` `eqRec`-equality.  The candidate
`ő≥'` (from `q‚āā`, with the same remnant) is identified with `ő≥` by the
membership-free model `parent_eq_of_remnant_eq`; the vertex hypothesis is
assembled from each `q`'s own `B-forest-2a` linked by the transport-compat
equalities (no `cases` on the computed outer equality). -/
private theorem forestComponentForestChoiceForestParents_subset_of_remnant_eqRec
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {q‚āĀ q‚āā : forestComponentChoiceSigma g}
    (hq‚āĀ : q‚āĀ ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hq‚āā : q‚āā ‚ąą forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ =
      forestComponentForestChoiceOuterIndex g q‚āā hq‚āā)
    (hRem :
      hOuter ‚Ėł forestComponentForestChoiceRemnantComponents g q‚āĀ hq‚āĀ =
        forestComponentForestChoiceRemnantComponents g q‚āā hq‚āā)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥ : ő≥ ‚ąą forestComponentForestChoiceForestParents g q‚āĀ) :
    ő≥ ‚ąą forestComponentForestChoiceForestParents g q‚āā := by
  classical
  have hő≥mem‚āĀ : ő≥ ‚ąą q‚āĀ.1.1.elements :=
    ((mem_forestComponentForestChoiceForestParents g q‚āĀ).mp hő≥).1
  have hpr‚āĀ :
      forestComponentForestChoiceParentRemnantBare g q‚āĀ hq‚āĀ ő≥ ‚ąą
        forestComponentForestChoiceRemnantComponents g q‚āĀ hq‚āĀ := by
    rw [forestComponentForestChoiceRemnantComponents_eq_image_parentRemnantBare g q‚āĀ hq‚āĀ]
    exact Finset.mem_image.mpr ‚ü®ő≥, hő≥, rfl‚ü©
  have hRemEq :
      forestComponentForestChoiceParentRemnantBare g q‚āā hq‚āā ő≥ =
        hOuter ‚Ėł forestComponentForestChoiceParentRemnantBare g q‚āĀ hq‚āĀ ő≥ :=
    (admissibleSubgraphQuotientRemainder_eqRec g hOuter ő≥).symm
  have hpr‚āāmem :
      forestComponentForestChoiceParentRemnantBare g q‚āā hq‚āā ő≥ ‚ąą
        forestComponentForestChoiceRemnantComponents g q‚āā hq‚āā := by
    have hm := mem_eqRec_forestOuterActualQuotient g hOuter hpr‚āĀ
    rw [hRem] at hm
    rw [hRemEq]
    exact hm
  rw [forestComponentForestChoiceRemnantComponents_eq_image_parentRemnantBare g q‚āā hq‚āā]
    at hpr‚āāmem
  rcases Finset.mem_image.mp hpr‚āāmem with ‚ü®ő≥', hő≥'FP, hő≥'eq‚ü©
  have hő≥'mem‚āā : ő≥' ‚ąą q‚āā.1.1.elements :=
    ((mem_forestComponentForestChoiceForestParents g q‚āā).mp hő≥'FP).1
  have hA‚āĀ : q‚āĀ.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āĀ.1.2
  have hA‚āā : q‚āā.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āā.1.2
  have hAoutPD‚āĀ :
      forestComponentForestChoiceOuterSubgraph q‚āĀ.1.1 q‚āĀ.2 hA‚āĀ ‚ąą
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q‚āĀ.1.2
      (Finset.mem_sigma.mp hq‚āĀ).2
  have hAoutPD‚āā :
      forestComponentForestChoiceOuterSubgraph q‚āā.1.1 q‚āā.2 hA‚āā ‚ąą
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q‚āā.1.2
      (Finset.mem_sigma.mp hq‚āā).2
  have hSV‚āĀ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q‚āĀ.1.1 q‚āĀ.2 hA‚āĀ hAoutPD‚āĀ hő≥mem‚āĀ
  have hSV‚āā := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q‚āā.1.1 q‚āā.2 hA‚āā hAoutPD‚āā hő≥'mem‚āā
  have hVert : ő≥'.vertices = ő≥.vertices := by
    calc ő≥'.vertices
        = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).2)
            (forestComponentForestChoiceParentRemnantBare g q‚āā hq‚āā ő≥') := hSV‚āā.symm
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).2)
            (forestComponentForestChoiceParentRemnantBare g q‚āā hq‚āā ő≥) := by rw [hő≥'eq]
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).2)
            (hOuter ‚Ėł forestComponentForestChoiceParentRemnantBare g q‚āĀ hq‚āĀ ő≥) :=
          congrArg
            (admissibleSubgraphRemainderSourceVertices
              (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
              (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
                (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
                (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).2))
            hRemEq
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ).1
              (forestComponentForestChoiceOuterIndex g q‚āĀ hq‚āĀ).2)
            (forestComponentForestChoiceParentRemnantBare g q‚āĀ hq‚āĀ ő≥) :=
          admissibleSubgraphRemainderSourceVertices_eqRec g hOuter
            (forestComponentForestChoiceParentRemnantBare g q‚āĀ hq‚āĀ ő≥)
      _ = ő≥.vertices := hSV‚āĀ
  have hő≥'ő≥ : ő≥' = ő≥ :=
    ForestGraphInsertionUniquenessModel.parent_eq_of_remnant_eq
      (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
      (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).1
        (forestComponentForestChoiceOuterIndex g q‚āā hq‚āā).2)
      hVert hő≥'eq
  rw [‚Üź hő≥'ő≥]; exact hő≥'FP

