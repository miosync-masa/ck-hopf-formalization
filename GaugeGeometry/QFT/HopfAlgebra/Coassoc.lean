/-- Genuine-forest branch transport payload for the right-selected survivor
forest: retargeting through the spliced outer forest and transporting to the
representative quotient preserve the Hopf product. -/
private theorem
    forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepRightQuotientSubgraphCanonical g q hq
      ).toHopfH =
        (forestComponentChoiceRightSubgraph q.1.1 q.2).toHopfH := by
  classical
  unfold forestComponentForestChoiceRepRightQuotientSubgraphCanonical
    forestComponentForestChoiceRepRightQuotientSubgraph
  apply forestOuterRepRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
  intro γ hγ v hv
  rw [forestComponentForestChoiceOuterIndex_val]
  exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2)
    hγ hv

/-- The representative transport for the genuine-forest right-selected
survivor forest preserves the Hopf product relative to its actual quotient
carrier. -/
private theorem
    forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepRightQuotientSubgraphCanonical g q hq
      ).toHopfH =
        (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
          g q hq).toHopfH := by
  unfold forestComponentForestChoiceRepRightQuotientSubgraphCanonical
    forestComponentForestChoiceRepRightQuotientSubgraph
    forestOuterRepRetargetAdmissibleSubgraphOfCert
    forestOuterRepRetargetAdmissibleSubgraph
    forestOuterActualToRepAdmissibleSubgraph
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical
    forestComponentForestChoiceActualRightQuotientSubgraph
    forestOuterActualRetargetAdmissibleSubgraphOfCert
  rw [mapPermAdmissibleSubgraph_toHopfH]

private theorem
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ :
      δ ∈
        (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
          g q hq).elements) :
    ∃ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements},
      δ =
        admissibleSubgraphRetargetSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γ.1 γ.2) := by
  change δ ∈
    ((forestComponentChoiceRightSubgraph q.1.1 q.2).elements.attach.image
      fun γ =>
        admissibleSubgraphRetargetSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1
          ((forestComponentForestChoiceRightRetargetCertificateCanonical
            g q hq).edge_le γ.1 γ.2)) at hδ
  rcases Finset.mem_image.mp hδ with ⟨γ, _hγ, rfl⟩
  exact ⟨γ, rfl⟩

set_option maxHeartbeats 800000

/-- A right-selected original component belongs to the canonical actual
quotient-side right-survivor forest after retargeting through the genuine
outer splice. -/
private theorem
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_of_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγR : γ ∈ (forestComponentChoiceRightSubgraph q.1.1 q.2).elements) :
    admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR) ∈
      (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
        g q hq).elements := by
  change
    admissibleSubgraphRetargetSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ
        ((forestComponentForestChoiceRightRetargetCertificateCanonical
          g q hq).edge_le γ hγR) ∈
      ((forestComponentChoiceRightSubgraph q.1.1 q.2).elements.attach.image
        fun γ =>
          admissibleSubgraphRetargetSubgraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (forestComponentForestChoiceOuterIndex g q hq).2)
            γ.1
            ((forestComponentForestChoiceRightRetargetCertificateCanonical
              g q hq).edge_le γ.1 γ.2))
  exact Finset.mem_image.mpr
    ⟨⟨γ, hγR⟩, Finset.mem_attach _ _, rfl⟩

/-- Canonical right-selected survivors remain pairwise vertex-disjoint after
retargeting through the genuine-forest outer splice. -/
private theorem
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical_isPairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
      g q hq).IsPairwiseDisjoint := by
  classical
  intro δ₁ hδ₁ δ₂ hδ₂ hne
  rcases
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
        g q hq hδ₁ with
    ⟨γ₁, rfl⟩
  rcases
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
        g q hq hδ₂ with
    ⟨γ₂, rfl⟩
  by_cases hγ : γ₁.1 = γ₂.1
  · have hγSubtype : γ₁ = γ₂ := Subtype.ext hγ
    subst γ₂
    exact False.elim (hne rfl)
  · let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let starOf :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    have hDisjA : q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
    have hSourceDisj : γ₁.1.Disjoint γ₂.1 :=
      forestComponentChoiceRightSubgraph_isPairwiseDisjoint
        q.1.1 q.2 hDisjA γ₁.2 γ₂.2 hγ
    have hV₁ :
        ∀ v ∈ γ₁.1.vertices, v ∉ Aout.vertices := by
      intro v hv
      simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
        forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
          q.1.1 q.2 hDisjA γ₁.2 hv
    have hV₂ :
        ∀ v ∈ γ₂.1.vertices, v ∉ Aout.vertices := by
      intro v hv
      simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
        forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
          q.1.1 q.2 hDisjA γ₂.2 hv
    have hVeq₁ :=
      admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        Aout starOf γ₁.1
        (forestComponentForestChoiceRightRetarget_edge_le g q hq
          γ₁.1 γ₁.2)
        hV₁
    have hVeq₂ :=
      admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        Aout starOf γ₂.1
        (forestComponentForestChoiceRightRetarget_edge_le g q hq
          γ₂.1 γ₂.2)
        hV₂
    change
      (admissibleSubgraphRetargetSubgraph Aout starOf γ₁.1
        (forestComponentForestChoiceRightRetarget_edge_le g q hq
          γ₁.1 γ₁.2)).Disjoint
      (admissibleSubgraphRetargetSubgraph Aout starOf γ₂.1
        (forestComponentForestChoiceRightRetarget_edge_le g q hq
          γ₂.1 γ₂.2))
    unfold FeynmanSubgraph.Disjoint at hSourceDisj ⊢
    rw [hVeq₁, hVeq₂]
    exact hSourceDisj

/-- Canonical right-selected survivors keep positive internal-edge carriers
after retargeting through the genuine-forest outer splice. -/
private theorem
    forestComponentForestChoiceActualRightQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
      g q hq).HasPositiveInternalEdgesComponents := by
  classical
  intro δ hδ
  rcases
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
        g q hq hδ with
    ⟨γ, rfl⟩
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hV :
      ∀ v ∈ γ.1.vertices, v ∉ Aout.vertices := by
    intro v hv
    simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q.1.1 q.2 hDisjA γ.2 hv
  have hIeq :=
    admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
      Aout starOf γ.1
      (forestComponentForestChoiceRightRetarget_edge_le g q hq
        γ.1 γ.2)
      hV
  have hSourcePos :
      0 < γ.1.internalEdges.card :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
        q.1.2 γ.1
        (forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 γ.2)
  change
    0 <
      (admissibleSubgraphRetargetSubgraph Aout starOf γ.1
        (forestComponentForestChoiceRightRetarget_edge_le g q hq
          γ.1 γ.2)).internalEdges.card
  rw [hIeq]
  exact hSourcePos

/-- Raw actual-quotient carrier of component remnants `γ / B` for every
component where the component-choice function selected a genuine forest
summand. -/
private noncomputable def forestComponentForestChoiceRemnantComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    Finset (FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) :=
  q.1.1.elements.attach.biUnion fun γ =>
    match q.2 γ (Finset.mem_attach q.1.1.elements γ) with
    | forestCoproductChoice.left => ∅
    | forestCoproductChoice.right => ∅
    | forestCoproductChoice.forest _B =>
        {admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1}

private theorem forestComponentForestChoiceRemnantComponents_mem_of_forest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    admissibleSubgraphQuotientRemainderSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ.1 ∈ forestComponentForestChoiceRemnantComponents g q hq := by
  unfold forestComponentForestChoiceRemnantComponents
  refine Finset.mem_biUnion.mpr ?_
  refine ⟨γ, Finset.mem_attach q.1.1.elements γ, ?_⟩
  simpa [hB] using (Finset.mem_singleton_self
    (admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ.1))

private theorem forestComponentForestChoiceRemnantComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ : δ ∈ forestComponentForestChoiceRemnantComponents g q hq) :
    ∃ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∃ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B ∧
        δ =
          admissibleSubgraphQuotientRemainderSubgraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
            γ.1 := by
  unfold forestComponentForestChoiceRemnantComponents at hδ
  replace hδ := Finset.mem_biUnion.mp hδ
  rcases hδ with ⟨γ, _hγ, hδγ⟩
  cases hChoice : q.2 γ (Finset.mem_attach q.1.1.elements γ) with
  | left =>
      simp [hChoice] at hδγ
  | right =>
      simp [hChoice] at hδγ
  | forest B =>
      exact ⟨γ, B, hChoice, by
        let rem :
            FeynmanSubgraph
              (forestOuterActualQuotientGraph g
                (forestComponentForestChoiceOuterIndex g q hq)) :=
          admissibleSubgraphQuotientRemainderSubgraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (forestComponentForestChoiceOuterIndex g q hq).2)
            γ.1
        have hmem :
            δ ∈ ({rem} :
              Finset (FeynmanSubgraph
                (forestOuterActualQuotientGraph g
                  (forestComponentForestChoiceOuterIndex g q hq)))) := by
          simpa only [hChoice, rem, FeynmanGraph.admissibleForestCanonicalStarOf_eq]
            using hδγ
        simpa [rem] using (Finset.mem_singleton.mp hmem)⟩

/-! ### Track B-forest-final-4a — `RemnantComponents` as an image over forest parents

The quotient remnant carrier is the `biUnion`-over-`attach` of singleton remnants
contributed by the `.forest`-chosen components.  We recast it as the *image* of
the forest-chosen parent set under the per-parent remnant map, so that
identity-uniqueness of the remnant map (the semantic model, applied later) lifts
to an injectivity of this image — recovering the forest parents. -/

/-- The forest-chosen parent components (as attached subtypes of `q.1.1.elements`). -/
private noncomputable def forestComponentForestChoiceForestParentsAttach
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    Finset {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements} := by
  classical
  exact q.1.1.elements.attach.filter
    (fun γ => ∃ B, q.2 γ (Finset.mem_attach q.1.1.elements γ) =
      forestCoproductChoice.forest B)

/-- The remnant `γ / (promoted children)` of one forest-chosen parent, in the
spliced outer quotient graph. -/
private noncomputable def forestComponentForestChoiceParentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  admissibleSubgraphQuotientRemainderSubgraph
    (forestComponentForestChoiceOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2)
    γ.1

@[simp] private theorem mem_forestComponentForestChoiceForestParentsAttach
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    γ ∈ forestComponentForestChoiceForestParentsAttach g q ↔
      ∃ B, q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B := by
  classical
  unfold forestComponentForestChoiceForestParentsAttach
  rw [Finset.mem_filter]
  exact ⟨fun h => h.2, fun h => ⟨Finset.mem_attach _ _, h⟩⟩

/-- **Track B-forest-final-4a.**  The quotient remnant carrier is the image of
the forest-chosen parents under the per-parent remnant map. -/
private theorem forestComponentForestChoiceRemnantComponents_eq_image_parentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantComponents g q hq =
      (forestComponentForestChoiceForestParentsAttach g q).image
        (forestComponentForestChoiceParentRemnant g q hq) := by
  classical
  ext δ
  constructor
  · intro hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists g q hq hδ with
      ⟨γ, B, hB, rfl⟩
    exact Finset.mem_image.mpr
      ⟨γ, (mem_forestComponentForestChoiceForestParentsAttach g q γ).mpr ⟨B, hB⟩, rfl⟩
  · intro hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, hγP, rfl⟩
    rcases (mem_forestComponentForestChoiceForestParentsAttach g q γ).mp hγP with ⟨B, hB⟩
    exact forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq γ hB

/-- **Track B-forest-final-4b — the per-parent remnant map is injective on
forest parents.**  This is the *only* place the genuine-forest branch consumes
the semantic kernel `ForestGraphInsertionUniquenessModel`: identity-uniqueness of
graph insertion.  The vertex hypothesis it needs is supplied constructively by
the remnant-source-vertices recovery (B-forest-2a), so the model is invoked in
exactly the minimal form. -/
private theorem forestComponentForestChoiceParentRemnant_injOn
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ₁ γ₂ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}}
    (hRem : forestComponentForestChoiceParentRemnant g q hq γ₁ =
            forestComponentForestChoiceParentRemnant g q hq γ₂) :
    γ₁ = γ₂ := by
  classical
  have hA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hAoutPD :
      forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA ∈
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q.1.2
      (Finset.mem_sigma.mp hq).2
  have hV₁ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q.1.1 q.2 hA hAoutPD γ₁.2
  have hV₂ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q.1.1 q.2 hA hAoutPD γ₂.2
  refine Subtype.ext
    (ForestGraphInsertionUniquenessModel.parent_eq_of_remnant_eq
      (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA)
      (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA) hAoutPD)
      ?_ hRem)
  rw [← hV₁, ← hV₂]
  exact congrArg
    (admissibleSubgraphRemainderSourceVertices
      (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA)
      (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA) hAoutPD))
    hRem

/-! #### Track B-forest-final-4c-pre — bare-`γ` forest-parent layer

`final-4a/4b` use the attached subtype `{γ // γ ∈ q.1.1.elements}`, awkward for
the eventual 3-way `q.1.1.elements = Left ∪ Right ∪ ForestParents` partition
(`Left.elements`, `Right.elements` are bare `Finset (FeynmanSubgraph (repG g))`).
Here we mirror them in bare-`γ` form so all three pieces live at the same level
and cross-`q` image-injectivity is direct. -/

/-- The forest-chosen parent components as a bare `Finset (FeynmanSubgraph …)`. -/
private noncomputable def forestComponentForestChoiceForestParents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) := by
  classical
  exact q.1.1.elements.filter (forestComponentChoiceIsForest q.1.1 q.2)

@[simp] private theorem mem_forestComponentForestChoiceForestParents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph} :
    γ ∈ forestComponentForestChoiceForestParents g q ↔
      γ ∈ q.1.1.elements ∧ forestComponentChoiceIsForest q.1.1 q.2 γ := by
  classical
  unfold forestComponentForestChoiceForestParents
  rw [Finset.mem_filter]

/-- The remnant `γ / (promoted children)` of one parent, as a bare map. -/
private noncomputable def forestComponentForestChoiceParentRemnantBare
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph) :
    FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  admissibleSubgraphQuotientRemainderSubgraph
    (forestComponentForestChoiceOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2)
    γ

/-- **Track B-forest-final-4a (bare).**  `RemnantComponents` is the image of the
bare forest-parent set under the bare remnant map. -/
private theorem forestComponentForestChoiceRemnantComponents_eq_image_parentRemnantBare
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantComponents g q hq =
      (forestComponentForestChoiceForestParents g q).image
        (forestComponentForestChoiceParentRemnantBare g q hq) := by
  classical
  ext δ
  constructor
  · intro hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists g q hq hδ with
      ⟨γ, B, hB, rfl⟩
    refine Finset.mem_image.mpr ⟨γ.1, ?_, rfl⟩
    exact (mem_forestComponentForestChoiceForestParents g q).mpr
      ⟨γ.2, forestComponentChoiceIsForest_of_eq γ.2 hB⟩
  · intro hδ
    rcases Finset.mem_image.mp hδ with ⟨γ, hγP, rfl⟩
    rcases forestComponentChoiceIsForest_exists
      ((mem_forestComponentForestChoiceForestParents g q).mp hγP).2 with ⟨hγmem, B, hB⟩
    exact forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq ⟨γ, hγmem⟩ hB

/-- **Track B-forest-final-4b (bare).**  The bare remnant map is injective on
parents (membership-explicit, ready for cross-`q` union arguments).  Sole
consumer of `ForestGraphInsertionUniquenessModel` in the genuine-forest branch. -/
private theorem forestComponentForestChoiceParentRemnantBare_injOn
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {γ₁ γ₂ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ₁ : γ₁ ∈ q.1.1.elements) (hγ₂ : γ₂ ∈ q.1.1.elements)
    (hRem : forestComponentForestChoiceParentRemnantBare g q hq γ₁ =
            forestComponentForestChoiceParentRemnantBare g q hq γ₂) :
    γ₁ = γ₂ := by
  classical
  have hA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hAoutPD :
      forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA ∈
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q.1.2
      (Finset.mem_sigma.mp hq).2
  have hV₁ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q.1.1 q.2 hA hAoutPD hγ₁
  have hV₂ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q.1.1 q.2 hA hAoutPD hγ₂
  refine ForestGraphInsertionUniquenessModel.parent_eq_of_remnant_eq
    (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA)
    (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA) hAoutPD)
    ?_ hRem
  rw [← hV₁, ← hV₂]
  exact congrArg
    (admissibleSubgraphRemainderSourceVertices
      (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA)
      (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA) hAoutPD))
    hRem

/-- **Track B-forest-final-5-pre — parent three-way partition.**  Every parent
component of `q.1.1` is selected `left`, `right`, or `forest`, so the bare
parent carrier splits as `LeftParents ∪ RightParents ∪ ForestParents`.  This is
the genuine-forest analogue of the mixed-branch two-way partition; the recovery
of `q.1.1.elements` will reassemble these three (Left/Right by the off-carrier
route, Forest by the model route). -/
private theorem forestComponentForestChoice_parents_partition
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
        (forestComponentChoiceRightSubgraph q.1.1 q.2).elements ∪
        forestComponentForestChoiceForestParents g q =
      q.1.1.elements := by
  classical
  ext γ
  simp only [Finset.mem_union, forestComponentChoiceLeftSubgraph_elements,
    forestComponentChoiceRightSubgraph_elements,
    mem_forestComponentForestChoiceForestParents, Finset.mem_filter]
  constructor
  · rintro ((⟨hγ, _⟩ | ⟨hγ, _⟩) | ⟨hγ, _⟩) <;> exact hγ
  · intro hγ
    rcases forestCoproductChoice_eq_left_or_right_or_forest
        (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγ))
        (q.2 ⟨γ, hγ⟩ (Finset.mem_attach q.1.1.elements ⟨γ, hγ⟩)) with
      hL | hR | ⟨B, hF⟩
    · exact Or.inl (Or.inl ⟨hγ, by
        unfold forestComponentChoiceIsLeft; rw [dif_pos hγ]; exact hL⟩)
    · exact Or.inl (Or.inr ⟨hγ, by
        unfold forestComponentChoiceIsRight; rw [dif_pos hγ]; exact hR⟩)
    · exact Or.inr ⟨hγ, forestComponentChoiceIsForest_of_eq hγ hF⟩

open scoped Classical in
/-- **Track B-forest-final-5b (helper, Left = outer minus inside-forest).**  Inside
the spliced outer subgraph, the `Left` parents are exactly the components NOT
contained in any forest-chosen parent: promoted children sit inside their forest
parent, while a left-selected `A`-component is proper-disjoint from every
forest-chosen `A`-component.  Stated over the bare `ForestParents` set so the
cross-`q` recovery (`leftParents_eq`) reduces to `OuterSubgraph` + `ForestParents`
equality with no transport. -/
private theorem forestComponentChoiceLeftSubgraph_elements_eq_filter_not_inside_forestParents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hA : q.1.1.IsPairwiseDisjoint)
    (hNE : q.1.1.HasNonemptyComponents) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements =
      (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA).elements.filter
        (fun δ => ¬ ∃ γ ∈ forestComponentForestChoiceForestParents g q,
          δ.vertices ⊆ γ.vertices) := by
  classical
  ext δ
  rw [Finset.mem_filter, forestComponentForestChoiceOuterSubgraph_elements]
  constructor
  · intro hδL
    refine ⟨Finset.mem_union_left _ hδL, ?_⟩
    rintro ⟨γ, hγFP, hδγ⟩
    have hδA : δ ∈ q.1.1.elements :=
      forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδL
    have hγA : γ ∈ q.1.1.elements :=
      ((mem_forestComponentForestChoiceForestParents g q).mp hγFP).1
    have hne : δ ≠ γ := by
      rintro rfl
      have h1 : forestComponentChoiceIsLeft q.1.1 q.2 δ := by
        rw [forestComponentChoiceLeftSubgraph_elements] at hδL
        exact (Finset.mem_filter.mp hδL).2
      have h2 : forestComponentChoiceIsForest q.1.1 q.2 δ :=
        ((mem_forestComponentForestChoiceForestParents g q).mp hγFP).2
      simp only [forestComponentChoiceIsLeft, dif_pos hδA] at h1
      simp only [forestComponentChoiceIsForest, dif_pos hδA] at h2
      rcases h2 with ⟨B, h2⟩
      rw [h1] at h2
      simp at h2
    obtain ⟨v, hv⟩ := Finset.card_pos.mp (hNE δ hδA)
    exact absurd (hδγ hv) (Finset.disjoint_left.mp (hA hδA hγA hne) hv)
  · rintro ⟨hδO, hδNot⟩
    rcases Finset.mem_union.mp hδO with hδL | hδP
    · exact hδL
    · exfalso
      apply hδNot
      rcases forestComponentChoicePromotedForestComponents_mem_exists q.1.1 q.2 hδP with
        ⟨γ, B, hB, hδγ⟩
      refine ⟨γ.1, (mem_forestComponentForestChoiceForestParents g q).mpr
        ⟨γ.2, forestComponentChoiceIsForest_of_eq γ.2 hB⟩, ?_⟩
      exact feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        γ.1 (q.1.1.isConnectedDivergent_of_mem γ.2) B hδγ

/-- Right-selected survivors are disjoint from selected component-forest
quotient remnants after retargeting through the spliced outer forest. -/
private theorem forestComponentForestChoiceRightRemnant_disjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ δR,
      δR ∈
        (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
          g q hq).elements →
      ∀ δM, δM ∈ forestComponentForestChoiceRemnantComponents g q hq →
        δR.Disjoint δM := by
  classical
  intro δR hδR δM hδM
  rcases
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
        g q hq hδR with
    ⟨γR, rfl⟩
  rcases γR with ⟨γR, hγR⟩
  rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hδM with
    ⟨γF, B, hB, rfl⟩
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hRightVertices :
      (admissibleSubgraphRetargetSubgraph
        Aout
        starOf γR
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)).vertices =
        γR.vertices := by
    refine admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      Aout starOf γR
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR) ?_
    intro v hv
    simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q.1.1 q.2 hDisjA hγR hv
  have hSourceDisj : γR.Disjoint γF.1 :=
    forestComponentChoiceRight_forestChoiceSource_disjoint
      q.1.1 q.2 hDisjA hγR γF hB
  unfold FeynmanSubgraph.Disjoint
  refine Finset.disjoint_left.mpr ?_
  intro v hvR hvM
  have hvR' :
      v ∈
        (admissibleSubgraphRetargetSubgraph Aout starOf γR
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)).vertices := by
    simpa [Aout, starOf] using hvR
  have hvRγ : v ∈ γR.vertices := by
    simpa [hRightVertices] using hvR'
  rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hvM
  rcases Finset.mem_image.mp hvM with ⟨u, huγF, huv⟩
  by_cases huA : u ∈ Aout.vertices
  · have hFresh :
        Aout.IsFreshStarAssignment starOf := by
      dsimp [Aout, starOf]
      exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    have hRet :
        Aout.retargetVertex starOf u = starOf (Aout.componentAt huA) := by
      rw [AdmissibleSubgraph.retargetVertex,
        AdmissibleSubgraph.componentAt?_of_mem Aout huA]
    have hvNotAmbient : v ∉ (repG g).toFeynmanGraph.vertices := by
      rw [← huv, hRet]
      exact hFresh.fresh (Aout.componentAt_mem huA)
    exact hvNotAmbient (γR.vertices_subset hvRγ)
  · have huvA : Aout.retargetVertex starOf u = v := by
      simpa [Aout, starOf] using huv
    have hRetNot : Aout.retargetVertex starOf u = u :=
      AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf huA
    have huv' : u = v := by
      rw [hRetNot] at huvA
      exact huvA
    have hvF : v ∈ γF.1.vertices := huv' ▸ huγF
    exact (Finset.disjoint_left.mp hSourceDisj hvRγ) hvF

/-- Right-selected survivors are Zimmermann-compatible with selected
component-forest quotient remnants after retargeting through the spliced
outer forest. -/
private theorem forestComponentForestChoiceRightRemnant_cross
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ δR,
      δR ∈
        (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
          g q hq).elements →
      ∀ δM, δM ∈ forestComponentForestChoiceRemnantComponents g q hq →
        δR ≠ δM → δR.NestedOrDisjoint δM := by
  intro δR hδR δM hδM _hne
  exact Or.inr
    (forestComponentForestChoiceRightRemnant_disjoint g q hq
      δR hδR δM hδM)

/-! ### Track B-forest-final-1 — star-touching separation of `Right` from `Remnant`

The quotient-side forest `ActualQuotientComponents = Right.elements ∪ RemnantComponents`
is a vertex-disjoint union, but to *extract* the `Remnant` part from a quotient
equality we need an intrinsic predicate separating the two.  The separator is
**"the component contains a canonical star of the spliced outer forest"**:
- a `Remnant` component is `γ` contracted by its promoted children, so it
  contains their stars (Target 2), while
- a `Right` survivor avoids the outer carrier entirely, so its retarget is the
  identity and its vertices stay in the ambient graph — never a (fresh) star
  (Target 1).
The genuine-forest index forces every `.forest B` choice to have `B` a *proper*
(nonempty, positive-edge) forest, so a promoted child always exists; this is why
Target 2 holds (and is exactly where an empty-`B` forest choice would have broken
separation — the index excludes it via `0 < B.internalEdges.card`). -/
private def forestComponentForestChoiceTouchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) : Prop :=
  ∃ η ∈ (forestComponentForestChoiceOuterIndex g q hq).1.elements,
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
      η ∈ δ.vertices

/-- **Target 1.**  A right-selected survivor component (in the quotient) does
*not* touch any canonical outer star: its retarget is the identity (it avoids the
outer carrier), so its vertices stay in the ambient graph, while the stars are
fresh. -/
private theorem forestComponentForestChoiceRight_not_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ : δ ∈ (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
      g q hq).elements) :
    ¬ forestComponentForestChoiceTouchesOuterStar g q hq δ := by
  classical
  rintro ⟨η, hηOuter, hStarMem⟩
  rcases forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
      g q hq hδ with ⟨γR, rfl⟩
  rcases γR with ⟨γR, hγR⟩
  set Aout := (forestComponentForestChoiceOuterIndex g q hq).1 with hAoutDef
  set starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2 with hStarOfDef
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hRightVertices :
      (admissibleSubgraphRetargetSubgraph Aout starOf γR
        (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)).vertices =
        γR.vertices := by
    refine admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      Aout starOf γR
      (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR) ?_
    intro v hv
    simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q.1.1 q.2 hDisjA hγR hv
  have hFresh : Aout.IsFreshStarAssignment starOf := by
    dsimp [Aout, starOf]
    exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hStar' :
      starOf η ∈
        (admissibleSubgraphRetargetSubgraph Aout starOf γR
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γR hγR)).vertices := by
    simpa [Aout, starOf] using hStarMem
  rw [hRightVertices] at hStar'
  exact hFresh.fresh hηOuter (γR.vertices_subset hStar')

/-- **Target 2.**  A remnant component (in the quotient) touches a canonical outer
star: it is `γ` contracted by its proper (nonempty) promoted forest `B`, so a
promoted child `η ⊆ γ` exists in the outer carrier, and `starOf η` lands in the
remnant by `admissibleSubgraph_star_mem_remainder_vertices_iff_intersects`. -/
private theorem forestComponentForestChoiceRemnant_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g
      (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ : δ ∈ forestComponentForestChoiceRemnantComponents g q hq) :
    forestComponentForestChoiceTouchesOuterStar g q hq δ := by
  classical
  rcases forestComponentForestChoiceRemnantComponents_mem_exists g q hq hδ with
    ⟨γF, B, hB, rfl⟩
  have hpCore : q.2 ∈ forestComponentCoreChoiceIndex q.1.1 := by
    have hpForest : q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    exact (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hPromoteProper :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem hpCore γF hB
  have hProperData :=
    ((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      hPromoteProper
  have hPromoteNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γF.1
        (q.1.1.isConnectedDivergent_of_mem γF.2) B).elements.Nonempty :=
    (((repG g).toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs _).mp
      hProperData.1).2
  obtain ⟨η, hηPromote⟩ := hPromoteNE
  have hηNE : η.IsNonempty := hProperData.2.1 η hηPromote
  obtain ⟨v, hvη⟩ := Finset.card_pos.mp hηNE
  have hηPromotedComp :
      η ∈ forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
    forestComponentChoicePromotedForestComponents_mem_of_forest q.1.1 q.2 γF hB hηPromote
  have hηOuter : η ∈ (forestComponentForestChoiceOuterIndex g q hq).1.elements := by
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union.mpr (Or.inr hηPromotedComp)
  have hvγF : v ∈ γF.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γF.1 (q.1.1.isConnectedDivergent_of_mem γF.2) B hηPromote hvη
  refine ⟨η, hηOuter, ?_⟩
  exact (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
    (forestComponentForestChoiceOuterIndex g q hq).1
    (forestComponentForestChoiceOuterIndex g q hq).2
    γF.1 hηOuter).mpr ⟨v, hvη, hvγF⟩

/-- Selected component-forest quotient remnants are mutually compatible after
retargeting through the spliced outer forest. -/
private theorem forestComponentForestChoiceRemnantComponents_disjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ δ₁, δ₁ ∈ forestComponentForestChoiceRemnantComponents g q hq →
      ∀ δ₂, δ₂ ∈ forestComponentForestChoiceRemnantComponents g q hq →
        δ₁ ≠ δ₂ → δ₁.Disjoint δ₂ := by
  classical
  intro δ₁ hδ₁ δ₂ hδ₂ hne
  rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hδ₁ with
    ⟨γ₁, B₁, hB₁, rfl⟩
  rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hδ₂ with
    ⟨γ₂, B₂, hB₂, rfl⟩
  by_cases hγ : γ₁.1 = γ₂.1
  · have hγsub : γ₁ = γ₂ := Subtype.ext hγ
    subst γ₂
    exact False.elim (hne rfl)
  ·
    let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
    let starOf :=
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    have hDisjA : q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
    have hFresh : Aout.IsFreshStarAssignment starOf := by
      dsimp [Aout, starOf]
      exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2
    have hSourceDisj : γ₁.1.Disjoint γ₂.1 := hDisjA γ₁.2 γ₂.2 hγ
    unfold FeynmanSubgraph.Disjoint
    refine Finset.disjoint_left.mpr ?_
    intro v hv₁ hv₂
    rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hv₁ hv₂
    rcases Finset.mem_image.mp hv₁ with ⟨u₁, hu₁γ, hu₁v⟩
    rcases Finset.mem_image.mp hv₂ with ⟨u₂, hu₂γ, hu₂v⟩
    have hu₁vA : Aout.retargetVertex starOf u₁ = v := by
      simpa [Aout, starOf] using hu₁v
    have hu₂vA : Aout.retargetVertex starOf u₂ = v := by
      simpa [Aout, starOf] using hu₂v
    by_cases hu₁A : u₁ ∈ Aout.vertices
    · by_cases hu₂A : u₂ ∈ Aout.vertices
      · have hRet₁ :
            Aout.retargetVertex starOf u₁ =
              starOf (Aout.componentAt hu₁A) := by
          rw [AdmissibleSubgraph.retargetVertex,
            AdmissibleSubgraph.componentAt?_of_mem Aout hu₁A]
        have hRet₂ :
            Aout.retargetVertex starOf u₂ =
              starOf (Aout.componentAt hu₂A) := by
          rw [AdmissibleSubgraph.retargetVertex,
            AdmissibleSubgraph.componentAt?_of_mem Aout hu₂A]
        have hStar :
            starOf (Aout.componentAt hu₁A) =
              starOf (Aout.componentAt hu₂A) := by
          rw [hRet₁] at hu₁vA
          rw [hRet₂] at hu₂vA
          exact hu₁vA.trans hu₂vA.symm
        have hComp :
            Aout.componentAt hu₁A = Aout.componentAt hu₂A :=
          hFresh.eq_of_star_eq (Aout.componentAt_mem hu₁A)
            (Aout.componentAt_mem hu₂A) hStar
        have hu₁Outer :
            u₁ ∈
              (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hDisjA).vertices := by
          simpa [Aout, forestComponentForestChoiceOuterIndex_val] using hu₁A
        have hSub₁ :
            (Aout.componentAt hu₁A).vertices ⊆ γ₁.1.vertices := by
          simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
            (forestComponentForestChoiceOuterSubgraph_componentAt_vertices_subset_source
              q.1.1 q.2 hDisjA γ₁ hB₁ hu₁γ hu₁Outer)
        have hu₂C₂ : u₂ ∈ (Aout.componentAt hu₂A).vertices :=
          Aout.componentAt_vertex_mem hu₂A
        have hu₂C₁ : u₂ ∈ (Aout.componentAt hu₁A).vertices := by
          simpa [hComp] using hu₂C₂
        have hu₂γ₁ : u₂ ∈ γ₁.1.vertices := hSub₁ hu₂C₁
        exact (Finset.disjoint_left.mp hSourceDisj hu₂γ₁) hu₂γ
      · have hRet₁ :
            Aout.retargetVertex starOf u₁ =
              starOf (Aout.componentAt hu₁A) := by
          rw [AdmissibleSubgraph.retargetVertex,
            AdmissibleSubgraph.componentAt?_of_mem Aout hu₁A]
        have hRet₂ : Aout.retargetVertex starOf u₂ = u₂ :=
          AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₂A
        rw [hRet₁] at hu₁vA
        rw [hRet₂] at hu₂vA
        have hStarEq : starOf (Aout.componentAt hu₁A) = u₂ :=
          hu₁vA.trans hu₂vA.symm
        have hu₂Ambient : u₂ ∈ (repG g).toFeynmanGraph.vertices :=
          γ₂.1.vertices_subset hu₂γ
        rw [← hStarEq] at hu₂Ambient
        exact (hFresh.fresh (Aout.componentAt_mem hu₁A)) hu₂Ambient
    · by_cases hu₂A : u₂ ∈ Aout.vertices
      · have hRet₁ : Aout.retargetVertex starOf u₁ = u₁ :=
          AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₁A
        have hRet₂ :
            Aout.retargetVertex starOf u₂ =
              starOf (Aout.componentAt hu₂A) := by
          rw [AdmissibleSubgraph.retargetVertex,
            AdmissibleSubgraph.componentAt?_of_mem Aout hu₂A]
        rw [hRet₁] at hu₁vA
        rw [hRet₂] at hu₂vA
        have hStarEq : starOf (Aout.componentAt hu₂A) = u₁ :=
          hu₂vA.trans hu₁vA.symm
        have hu₁Ambient : u₁ ∈ (repG g).toFeynmanGraph.vertices :=
          γ₁.1.vertices_subset hu₁γ
        rw [← hStarEq] at hu₁Ambient
        exact (hFresh.fresh (Aout.componentAt_mem hu₂A)) hu₁Ambient
      · have hRet₁ : Aout.retargetVertex starOf u₁ = u₁ :=
          AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₁A
        have hRet₂ : Aout.retargetVertex starOf u₂ = u₂ :=
          AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₂A
        rw [hRet₁] at hu₁vA
        rw [hRet₂] at hu₂vA
        have hu₂_eq_u₁ : u₂ = u₁ := hu₂vA.trans hu₁vA.symm
        have hu₂γ₁ : u₂ ∈ γ₁.1.vertices := hu₂_eq_u₁ ▸ hu₁γ
        exact (Finset.disjoint_left.mp hSourceDisj hu₂γ₁) hu₂γ

/-- Quotient remnants coming from distinct source components are vertex
disjoint, even before asking whether the resulting quotient subgraphs are
syntactically different. -/
private theorem forestComponentForestChoiceRemnantComponents_disjoint_of_source_ne
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ₁ γ₂ :
      {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B₁ : AdmissibleSubgraph
      (repG (γ₁.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γ₁.2))).toFeynmanGraph}
    {B₂ : AdmissibleSubgraph
      (repG (γ₂.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γ₂.2))).toFeynmanGraph}
    (hB₁ :
      q.2 γ₁ (Finset.mem_attach q.1.1.elements γ₁) =
        forestCoproductChoice.forest B₁)
    (hB₂ :
      q.2 γ₂ (Finset.mem_attach q.1.1.elements γ₂) =
        forestCoproductChoice.forest B₂)
    (hγ : γ₁.1 ≠ γ₂.1) :
    (admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ₁.1).Disjoint
    (admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ₂.1) := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hFresh : Aout.IsFreshStarAssignment starOf := by
    dsimp [Aout, starOf]
    exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hSourceDisj : γ₁.1.Disjoint γ₂.1 := hDisjA γ₁.2 γ₂.2 hγ
  unfold FeynmanSubgraph.Disjoint
  refine Finset.disjoint_left.mpr ?_
  intro v hv₁ hv₂
  rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hv₁ hv₂
  rcases Finset.mem_image.mp hv₁ with ⟨u₁, hu₁γ, hu₁v⟩
  rcases Finset.mem_image.mp hv₂ with ⟨u₂, hu₂γ, hu₂v⟩
  have hu₁vA : Aout.retargetVertex starOf u₁ = v := by
    simpa [Aout, starOf] using hu₁v
  have hu₂vA : Aout.retargetVertex starOf u₂ = v := by
    simpa [Aout, starOf] using hu₂v
  by_cases hu₁A : u₁ ∈ Aout.vertices
  · by_cases hu₂A : u₂ ∈ Aout.vertices
    · have hRet₁ :
          Aout.retargetVertex starOf u₁ =
            starOf (Aout.componentAt hu₁A) := by
        rw [AdmissibleSubgraph.retargetVertex,
          AdmissibleSubgraph.componentAt?_of_mem Aout hu₁A]
      have hRet₂ :
          Aout.retargetVertex starOf u₂ =
            starOf (Aout.componentAt hu₂A) := by
        rw [AdmissibleSubgraph.retargetVertex,
          AdmissibleSubgraph.componentAt?_of_mem Aout hu₂A]
      have hStar :
          starOf (Aout.componentAt hu₁A) =
            starOf (Aout.componentAt hu₂A) := by
        rw [hRet₁] at hu₁vA
        rw [hRet₂] at hu₂vA
        exact hu₁vA.trans hu₂vA.symm
      have hComp :
          Aout.componentAt hu₁A = Aout.componentAt hu₂A :=
        hFresh.eq_of_star_eq (Aout.componentAt_mem hu₁A)
          (Aout.componentAt_mem hu₂A) hStar
      have hu₁Outer :
          u₁ ∈
            (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hDisjA).vertices := by
        simpa [Aout, forestComponentForestChoiceOuterIndex_val] using hu₁A
      have hSub₁ :
          (Aout.componentAt hu₁A).vertices ⊆ γ₁.1.vertices := by
        simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
          (forestComponentForestChoiceOuterSubgraph_componentAt_vertices_subset_source
            q.1.1 q.2 hDisjA γ₁ hB₁ hu₁γ hu₁Outer)
      have hu₂C₂ : u₂ ∈ (Aout.componentAt hu₂A).vertices :=
        Aout.componentAt_vertex_mem hu₂A
      have hu₂C₁ : u₂ ∈ (Aout.componentAt hu₁A).vertices := by
        simpa [hComp] using hu₂C₂
      have hu₂γ₁ : u₂ ∈ γ₁.1.vertices := hSub₁ hu₂C₁
      exact (Finset.disjoint_left.mp hSourceDisj hu₂γ₁) hu₂γ
    · have hRet₁ :
          Aout.retargetVertex starOf u₁ =
            starOf (Aout.componentAt hu₁A) := by
        rw [AdmissibleSubgraph.retargetVertex,
          AdmissibleSubgraph.componentAt?_of_mem Aout hu₁A]
      have hRet₂ : Aout.retargetVertex starOf u₂ = u₂ :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₂A
      rw [hRet₁] at hu₁vA
      rw [hRet₂] at hu₂vA
      have hStarEq : starOf (Aout.componentAt hu₁A) = u₂ :=
        hu₁vA.trans hu₂vA.symm
      have hu₂Ambient : u₂ ∈ (repG g).toFeynmanGraph.vertices :=
        γ₂.1.vertices_subset hu₂γ
      rw [← hStarEq] at hu₂Ambient
      exact (hFresh.fresh (Aout.componentAt_mem hu₁A)) hu₂Ambient
  · by_cases hu₂A : u₂ ∈ Aout.vertices
    · have hRet₁ : Aout.retargetVertex starOf u₁ = u₁ :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₁A
      have hRet₂ :
          Aout.retargetVertex starOf u₂ =
            starOf (Aout.componentAt hu₂A) := by
        rw [AdmissibleSubgraph.retargetVertex,
          AdmissibleSubgraph.componentAt?_of_mem Aout hu₂A]
      rw [hRet₁] at hu₁vA
      rw [hRet₂] at hu₂vA
      have hStarEq : starOf (Aout.componentAt hu₂A) = u₁ :=
        hu₂vA.trans hu₁vA.symm
      have hu₁Ambient : u₁ ∈ (repG g).toFeynmanGraph.vertices :=
        γ₁.1.vertices_subset hu₁γ
      rw [← hStarEq] at hu₁Ambient
      exact (hFresh.fresh (Aout.componentAt_mem hu₂A)) hu₁Ambient
    · have hRet₁ : Aout.retargetVertex starOf u₁ = u₁ :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₁A
      have hRet₂ : Aout.retargetVertex starOf u₂ = u₂ :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hu₂A
      rw [hRet₁] at hu₁vA
      rw [hRet₂] at hu₂vA
      have hu₂_eq_u₁ : u₂ = u₁ := hu₂vA.trans hu₁vA.symm
      have hu₂γ₁ : u₂ ∈ γ₁.1.vertices := hu₂_eq_u₁ ▸ hu₁γ
      exact (Finset.disjoint_left.mp hSourceDisj hu₂γ₁) hu₂γ

/-- Selected component-forest quotient remnants are mutually compatible after
retargeting through the spliced outer forest. -/
private theorem forestComponentForestChoiceRemnantComponents_compat
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∀ δ₁, δ₁ ∈ forestComponentForestChoiceRemnantComponents g q hq →
      ∀ δ₂, δ₂ ∈ forestComponentForestChoiceRemnantComponents g q hq →
        δ₁ ≠ δ₂ → δ₁.NestedOrDisjoint δ₂ := by
  intro δ₁ hδ₁ δ₂ hδ₂ hne
  exact Or.inr
    (forestComponentForestChoiceRemnantComponents_disjoint g q hq
      δ₁ hδ₁ δ₂ hδ₂ hne)

/-- The component-side star assignment induced by the genuine-forest outer
splice.  A component of the selected forest inside `γ` is promoted into the
ambient graph, then assigned the canonical star of the spliced outer forest. -/
private noncomputable def forestComponentForestChoiceComponentRemnantStarOf
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph) :
    FeynmanSubgraph γ.1.toFeynmanGraph → VertexId :=
  fun η =>
    (forestComponentForestChoiceOuterIndex g q hq).1.componentFreshStar
      (feynmanSubgraphPromote (γ_outer := γ.1) η)

private theorem
    forestComponentForestChoice_componentRemnantStar_promote_mem_outer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {η : FeynmanSubgraph γ.1.toFeynmanGraph}
    (hη :
      η ∈ (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).elements) :
    feynmanSubgraphPromote (γ_outer := γ.1) η ∈
      (forestComponentForestChoiceOuterIndex g q hq).1.elements := by
  classical
  have hηPromoted :
      feynmanSubgraphPromote (γ_outer := γ.1) η ∈
        (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).elements := by
    unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph
    rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements]
    exact Finset.mem_image.mpr ⟨⟨η, hη⟩, Finset.mem_attach _ _, rfl⟩
  have hPromoted :
      feynmanSubgraphPromote (γ_outer := γ.1) η ∈
        forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
    forestComponentChoicePromotedForestComponents_mem_of_forest
      q.1.1 q.2 γ hB hηPromoted
  rw [forestComponentForestChoiceOuterIndex_val,
    forestComponentForestChoiceOuterSubgraph_elements]
  exact Finset.mem_union_right _ hPromoted

private theorem forestComponentForestChoiceComponentRemnantStarOf_isFresh
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
      (q.1.1.isConnectedDivergent_of_mem γ.2) B).IsFreshStarAssignment
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) := by
  classical
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  have hFreshOuter : Aout.IsFreshStarAssignment Aout.componentFreshStar :=
    Aout.componentFreshStar_isFreshStarAssignment
  refine ⟨?_, ?_⟩
  · intro η hη hstarγ
    have hηOuter :
        feynmanSubgraphPromote (γ_outer := γ.1) η ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η) hη
    have hstarNotAmbient :
        Aout.componentFreshStar
            (feynmanSubgraphPromote (γ_outer := γ.1) η) ∉
          (repG g).toFeynmanGraph.vertices :=
      hFreshOuter.fresh hηOuter
    exact hstarNotAmbient (γ.1.vertices_subset hstarγ)
  · intro η₁ hη₁ η₂ hη₂ hstar
    have hη₁Outer :
        feynmanSubgraphPromote (γ_outer := γ.1) η₁ ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η₁) hη₁
    have hη₂Outer :
        feynmanSubgraphPromote (γ_outer := γ.1) η₂ ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η₂) hη₂
    have hPromEq :
        feynmanSubgraphPromote (γ_outer := γ.1) η₁ =
          feynmanSubgraphPromote (γ_outer := γ.1) η₂ := by
      exact hFreshOuter.eq_of_star_eq hη₁Outer hη₂Outer hstar
    exact feynmanSubgraphPromote_injective hPromEq

/-- The transported component forest selected inside `γ` is a proper
admissible forest in the intrinsic component graph. -/
private theorem forestComponentForestChoiceComponentRemnant_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
      (q.1.1.isConnectedDivergent_of_mem γ.2) B ∈
        γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
  let hγCD := q.1.1.isConnectedDivergent_of_mem γ.2
  have hpForest : q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hpCore : q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hBRepProper :
      B ∈ ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph
        ).properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_forest_mem_properDisjoint_of_core_mem
      hpCore γ hB
  simpa [hγCD] using
    feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
      γ.1 hγCD hBRepProper

/-- The component quotient `γ / B`, using the star assignment induced by the
outer splice, is connected-divergent. -/
private theorem forestComponentForestChoiceComponentRemnantContractGraph_isConnectedDivergent
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    (FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B)
      (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)
      ).IsConnectedDivergent := by
  classical
  let hγCD := q.1.1.isConnectedDivergent_of_mem γ.2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1 hγCD B
  have hpForest : q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hpCore : q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hBRepProper :
      B ∈ ((repG (γ.1.toHopfGen hγCD)).toFeynmanGraph
        ).properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_forest_mem_properDisjoint_of_core_mem
      hpCore γ hB
  have hBcProper :
      Bc ∈ γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
    simpa [Bc, hγCD] using
      feynmanSubgraphRepToComponentAdmissibleSubgraph_mem_properDisjoint
        γ.1 hγCD hBRepProper
  have hγGraphCD : γ.1.toFeynmanGraph.IsConnectedDivergent :=
    γ.1.toFeynmanGraph_isConnectedDivergent hγCD
  have hFresh :
      Bc.IsFreshStarAssignment
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) := by
    simpa [Bc, hγCD] using
      forestComponentForestChoiceComponentRemnantStarOf_isFresh
        g q hq γ hB
  simpa [Bc, hγCD] using
    admissibleForestContractGraphWithStars_isConnectedDivergent
      γ.1.toFeynmanGraph_wellFormed
      hγGraphCD.self_isConnectedDivergent.isOnePI
      hγGraphCD
      Bc hBcProper
      (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)
      hFresh

/-- Inside a component selected by a genuine forest choice, the vertices hit by
the spliced outer forest are exactly the vertices hit by the transported
component forest. -/
private theorem
    forestComponentForestChoice_vertex_mem_outer_iff_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {u : VertexId} (huγ : u ∈ γ.1.vertices) :
    u ∈ (forestComponentForestChoiceOuterIndex g q hq).1.vertices ↔
      u ∈ (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).vertices := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  constructor
  · intro huOuter
    rcases AdmissibleSubgraph.mem_vertices.mp huOuter with
      ⟨δ, hδOuter, huδ⟩
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements] at hδOuter
    rcases Finset.mem_union.mp hδOuter with hδLeft | hδForest
    · have hδA : δ ∈ q.1.1.elements :=
        forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδLeft
      by_cases hδγ : δ = γ.1
      · subst δ
        rw [forestComponentChoiceLeftSubgraph_elements] at hδLeft
        have hLeft := (Finset.mem_filter.mp hδLeft).2
        unfold forestComponentChoiceIsLeft at hLeft
        rw [dif_pos γ.2] at hLeft
        rw [hB] at hLeft
        cases hLeft
      · have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : δ.Disjoint γ.1 := hDisjA hδA γ.2 hδγ
        exact False.elim ((Finset.disjoint_left.mp hdisj huδ) huγ)
    · rcases forestComponentChoicePromotedForestComponents_mem_exists
        q.1.1 q.2 hδForest with
        ⟨η, Bη, hBη, hδBη⟩
      have hδSubset :
          δ.vertices ⊆ η.1.vertices :=
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
          η.1 (q.1.1.isConnectedDivergent_of_mem η.2) Bη hδBη
      have huη : u ∈ η.1.vertices := hδSubset huδ
      by_cases hηγ : η.1 = γ.1
      · have hηsub : η = γ := Subtype.ext hηγ
        subst η
        have hBηEq : Bη = B := by
          apply forestCoproductChoice_forest_injective
            (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))
          rw [← hBη, ← hB]
        subst Bη
        unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hδBη
        rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hδBη
        rcases Finset.mem_image.mp hδBη with ⟨ηInner, _hηAttach, hηProm⟩
        have hηMem : ηInner.1 ∈ Bc.elements := by
          simpa [Bc] using ηInner.2
        have huηInner : u ∈ ηInner.1.vertices := by
          simpa [← hηProm] using huδ
        exact AdmissibleSubgraph.mem_vertices.mpr
          ⟨ηInner.1, hηMem, huηInner⟩
      · have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : η.1.Disjoint γ.1 := hDisjA η.2 γ.2 hηγ
        exact False.elim ((Finset.disjoint_left.mp hdisj huη) huγ)
  · intro huBc
    rcases AdmissibleSubgraph.mem_vertices.mp huBc with
      ⟨η, hη, huη⟩
    have hηOuter :
        feynmanSubgraphPromote (γ_outer := γ.1) η ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η) hη
    exact AdmissibleSubgraph.mem_vertices.mpr
      ⟨feynmanSubgraphPromote (γ_outer := γ.1) η, hηOuter, by simpa using huη⟩

/-- For an internal edge of a selected source component, being removed by the
ambient outer splice is equivalent to being removed by the transported
component forest. -/
private theorem
    forestComponentForestChoice_internalEdge_mem_outer_iff_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heγ : e ∈ γ.1.internalEdges) :
    e ∈ (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges ↔
      e ∈ (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  have hsuppγ := γ.1.edges_supported e heγ
  simp [FeynmanEdge.SupportedOn] at hsuppγ
  constructor
  · intro heOuter
    rcases AdmissibleSubgraph.mem_internalEdges.mp heOuter with
      ⟨δ, hδOuter, heδ⟩
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements] at hδOuter
    have hsuppδ := δ.edges_supported e heδ
    simp [FeynmanEdge.SupportedOn] at hsuppδ
    rcases Finset.mem_union.mp hδOuter with hδLeft | hδForest
    · have hδA : δ ∈ q.1.1.elements :=
        forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδLeft
      by_cases hδγ : δ = γ.1
      · subst δ
        rw [forestComponentChoiceLeftSubgraph_elements] at hδLeft
        have hLeft := (Finset.mem_filter.mp hδLeft).2
        unfold forestComponentChoiceIsLeft at hLeft
        rw [dif_pos γ.2] at hLeft
        rw [hB] at hLeft
        cases hLeft
      · have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : δ.Disjoint γ.1 := hDisjA hδA γ.2 hδγ
        exact False.elim ((Finset.disjoint_left.mp hdisj hsuppδ.1) hsuppγ.1)
    · rcases forestComponentChoicePromotedForestComponents_mem_exists
        q.1.1 q.2 hδForest with
        ⟨η, Bη, hBη, hδBη⟩
      have hδSubset :
          δ.vertices ⊆ η.1.vertices :=
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
          η.1 (q.1.1.isConnectedDivergent_of_mem η.2) Bη hδBη
      have hsrcη : e.source ∈ η.1.vertices := hδSubset hsuppδ.1
      by_cases hηγ : η.1 = γ.1
      · have hηsub : η = γ := Subtype.ext hηγ
        subst η
        have hBηEq : Bη = B := by
          apply forestCoproductChoice_forest_injective
            (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))
          rw [← hBη, ← hB]
        subst Bη
        unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hδBη
        rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hδBη
        rcases Finset.mem_image.mp hδBη with ⟨ηInner, _hηAttach, hηProm⟩
        have hηMem : ηInner.1 ∈ Bc.elements := by
          simpa [Bc] using ηInner.2
        have heηInner : e ∈ ηInner.1.internalEdges := by
          simpa [← hηProm] using heδ
        exact AdmissibleSubgraph.mem_internalEdges.mpr
          ⟨ηInner.1, hηMem, heηInner⟩
      · have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : η.1.Disjoint γ.1 := hDisjA η.2 γ.2 hηγ
        exact False.elim ((Finset.disjoint_left.mp hdisj hsrcη) hsuppγ.1)
  · intro heBc
    rcases AdmissibleSubgraph.mem_internalEdges.mp heBc with
      ⟨η, hη, heη⟩
    have hηOuter :
        feynmanSubgraphPromote (γ_outer := γ.1) η ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η) hη
    exact AdmissibleSubgraph.mem_internalEdges.mpr
      ⟨feynmanSubgraphPromote (γ_outer := γ.1) η, hηOuter,
        by simpa using heη⟩

/-- In the promoted genuine-forest splice, the total multiplicity of an
internal edge of the selected component is exactly the multiplicity contributed
by the transported component forest. -/
private theorem
    forestComponentForestChoice_promotedForestComponents_internalEdges_count_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (_hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heγ : e ∈ γ.1.internalEdges) :
    (∑ δ ∈ forestComponentChoicePromotedForestComponents q.1.1 q.2,
        Multiset.count e δ.internalEdges) =
      Multiset.count e
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges := by
  classical
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hsuppγ := γ.1.edges_supported e heγ
  simp [FeynmanEdge.SupportedOn] at hsuppγ
  unfold forestComponentChoicePromotedForestComponents
  rw [Finset.sum_biUnion_of_pairwise_eq_zero (M := Nat)]
  · calc
      _ = _ := by
        rw [Finset.sum_eq_single γ]
        · intro η _hη hηγ
          cases hηChoice :
              q.2 η (Finset.mem_attach q.1.1.elements η) with
          | left =>
              simp
          | right =>
              simp
          | forest Bη =>
              simp
              intro δ hδ heδ
              have hsuppδ := δ.edges_supported e heδ
              simp [FeynmanEdge.SupportedOn] at hsuppδ
              have hδSubset :
                  δ.vertices ⊆ η.1.vertices :=
                feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                  η.1 (q.1.1.isConnectedDivergent_of_mem η.2) Bη hδ
              have hηγNe : η.1 ≠ γ.1 := by
                intro hEq
                exact hηγ (Subtype.ext hEq)
              have hdisj : η.1.Disjoint γ.1 := hDisjA η.2 γ.2 hηγNe
              exact (Finset.disjoint_left.mp hdisj (hδSubset hsuppδ.1)) hsuppγ.1
        · intro hγnot
          exact False.elim (hγnot (Finset.mem_attach q.1.1.elements γ))
      _ =
        Multiset.count e
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges := by
        rw [show q.2 γ _ = q.2 γ
            (Finset.mem_attach q.1.1.elements γ) by
          congr]
        rw [hB]
        change
          (∑ δ ∈
              (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
                (q.1.1.isConnectedDivergent_of_mem γ.2) B).elements,
            Multiset.count e δ.internalEdges) =
            Multiset.count e
              (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
                (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges
        rw [← Multiset.count_sum']
        exact congrArg (Multiset.count e)
          (feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges
            γ.1 (q.1.1.isConnectedDivergent_of_mem γ.2) B)
  · intro η _hη θ _hθ hηθ δ hδ
    apply Multiset.count_eq_zero.mpr
    intro heδ
    rcases Finset.mem_inter.mp hδ with ⟨hδη, hδθ⟩
    have hsuppδ := δ.edges_supported e heδ
    simp [FeynmanEdge.SupportedOn] at hsuppδ
    cases hηChoice :
        q.2 η (Finset.mem_attach q.1.1.elements η) with
    | left =>
        simp [hηChoice] at hδη
    | right =>
        simp [hηChoice] at hδη
    | forest Bη =>
        cases hθChoice :
            q.2 θ (Finset.mem_attach q.1.1.elements θ) with
        | left =>
            simp [hθChoice] at hδθ
        | right =>
            simp [hθChoice] at hδθ
        | forest Bθ =>
            have hδSubsetη :
                δ.vertices ⊆ η.1.vertices :=
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                η.1 (q.1.1.isConnectedDivergent_of_mem η.2) Bη
                (by simpa [hηChoice] using hδη)
            have hδSubsetθ :
                δ.vertices ⊆ θ.1.vertices :=
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                θ.1 (q.1.1.isConnectedDivergent_of_mem θ.2) Bθ
                (by simpa [hθChoice] using hδθ)
            by_cases hηθVal : η.1 = θ.1
            · exact hηθ (Subtype.ext hηθVal)
            · have hdisj : η.1.Disjoint θ.1 := hDisjA η.2 θ.2 hηθVal
              exact (Finset.disjoint_left.mp hdisj
                (hδSubsetη hsuppδ.1)) (hδSubsetθ hsuppδ.1)

/-- A left-selected outer component contributes no multiplicity to an internal
edge of a component whose choice is a genuine forest. -/
private theorem
    forestComponentForestChoice_leftSubgraph_internalEdges_count_eq_zero_of_component
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (_hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heγ : e ∈ γ.1.internalEdges) :
    Multiset.count e (forestComponentChoiceLeftSubgraph q.1.1 q.2).internalEdges = 0 := by
  classical
  apply Multiset.count_eq_zero.mpr
  intro heLeft
  rcases AdmissibleSubgraph.mem_internalEdges.mp heLeft with ⟨δ, hδLeft, heδ⟩
  have hδA : δ ∈ q.1.1.elements :=
    forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδLeft
  by_cases hδγ : δ = γ.1
  · subst δ
    rw [forestComponentChoiceLeftSubgraph_elements] at hδLeft
    have hLeft := (Finset.mem_filter.mp hδLeft).2
    unfold forestComponentChoiceIsLeft at hLeft
    rw [dif_pos γ.2] at hLeft
    rw [hB] at hLeft
    cases hLeft
  · have hsuppδ := δ.edges_supported e heδ
    have hsuppγ := γ.1.edges_supported e heγ
    simp [FeynmanEdge.SupportedOn] at hsuppδ hsuppγ
    have hDisjA : q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
    have hdisj : δ.Disjoint γ.1 := hDisjA hδA γ.2 hδγ
    exact (Finset.disjoint_left.mp hdisj hsuppδ.1) hsuppγ.1

/-- The left-selected carrier and the promoted genuine-forest carrier are
disjoint as finite component carriers. -/
private theorem forestComponentForestChoice_left_promotedForestComponents_disjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g) :
    Disjoint (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements
      (forestComponentChoicePromotedForestComponents q.1.1 q.2) := by
  classical
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  rw [Finset.disjoint_left]
  intro δ hδLeft hδPromoted
  have hδDisj : δ.Disjoint δ :=
    forestComponentChoiceLeft_promotedForestComponent_disjoint
      q.1.1 q.2 hDisjA hδLeft hδPromoted
  have hδA : δ ∈ q.1.1.elements :=
    forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδLeft
  have hδNonempty : δ.IsNonempty :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
        q.1.2 δ hδA
  unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hδNonempty
  rcases Finset.card_pos.mp hδNonempty with ⟨v, hv⟩
  exact (Finset.disjoint_left.mp hδDisj hv) hv

/-- The spliced genuine-forest outer carrier has exactly the product of the
left-selected original components and the promoted forest components. -/
private theorem forestComponentForestChoiceOuterIndex_toHopfH_eq_left_mul_promotedComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceOuterIndex g q hq).1.toHopfH =
      (forestComponentChoiceLeftSubgraph q.1.1 q.2).toHopfH *
        forestComponentChoicePromotedComponentsHopfProduct q.1.1 q.2 := by
  classical
  rw [forestComponentForestChoiceOuterIndex_val]
  unfold AdmissibleSubgraph.toHopfH
  rw [forestComponentForestChoiceOuterSubgraph_elements]
  rw [Finset.prod_union
    (forestComponentForestChoice_left_promotedForestComponents_disjoint g q)]
  unfold forestComponentChoicePromotedComponentsHopfProduct
  congr 1
  · apply Finset.prod_congr rfl
    intro δ hδ
    unfold AdmissibleSubgraph.componentToHopfH gen
    have hδOuterUnion :
        δ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
          forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
      Finset.mem_union_left _ hδ
    have hδOuter :
        δ ∈ (forestComponentForestChoiceOuterSubgraph q.1.1 q.2
          ((repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
              q.1.2)).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact hδOuterUnion
    rw [dif_pos hδOuter, dif_pos hδ]
  · apply Finset.prod_congr rfl
    intro δ hδ
    unfold AdmissibleSubgraph.componentToHopfH gen
    have hδOuterUnion :
        δ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
          forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
      Finset.mem_union_right _ hδ
    have hδOuter :
        δ ∈ (forestComponentForestChoiceOuterSubgraph q.1.1 q.2
          ((repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
              q.1.2)).elements := by
      rw [forestComponentForestChoiceOuterSubgraph_elements]
      exact hδOuterUnion
    rw [dif_pos hδOuter, dif_pos hδ]

/-- For an internal edge of the selected component, the full outer splice has
exactly the multiplicity supplied by the transported component forest. -/
private theorem forestComponentForestChoice_outer_internalEdges_count_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heγ : e ∈ γ.1.internalEdges) :
    Multiset.count e (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges =
      Multiset.count e
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges := by
  classical
  have hLeft0 :=
    forestComponentForestChoice_leftSubgraph_internalEdges_count_eq_zero_of_component
      g q hq γ hB heγ
  have hPromoted :=
    forestComponentForestChoice_promotedForestComponents_internalEdges_count_eq_componentRemnant
      g q hq γ hB heγ
  have hLeftPromoted :
      Disjoint (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements
        (forestComponentChoicePromotedForestComponents q.1.1 q.2) :=
    forestComponentForestChoice_left_promotedForestComponents_disjoint g q
  rw [forestComponentForestChoiceOuterIndex_val]
  unfold AdmissibleSubgraph.internalEdges
  rw [forestComponentForestChoiceOuterSubgraph_elements]
  rw [Finset.sum_union hLeftPromoted]
  rw [Multiset.count_add]
  have hLeft0' :
      Multiset.count e
          (∑ δ ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements,
            δ.internalEdges) = 0 := by
    simpa [AdmissibleSubgraph.internalEdges] using hLeft0
  have hPromoted' :
      Multiset.count e
          (∑ δ ∈ forestComponentChoicePromotedForestComponents q.1.1 q.2,
            δ.internalEdges) =
        Multiset.count e
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2) B).internalEdges := by
    rw [Multiset.count_sum']
    exact hPromoted
  have hPromoted'' :
      Multiset.count e
          (∑ δ ∈ forestComponentChoicePromotedForestComponents q.1.1 q.2,
            δ.internalEdges) =
        Multiset.count e
          (∑ δ ∈
            (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
              (q.1.1.isConnectedDivergent_of_mem γ.2) B).elements,
            δ.internalEdges) := by
    simpa [AdmissibleSubgraph.internalEdges] using hPromoted'
  rw [hLeft0', hPromoted'']
  simp

/-- On the vertices of a component selected by a genuine forest choice, the
ambient outer-splice retargeting agrees literally with the component-quotient
retargeting. -/
private theorem
    forestComponentForestChoice_retargetVertex_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {u : VertexId} (huγ : u ∈ γ.1.vertices) :
    (forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2) u =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).retargetVertex
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) u := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  let innerStar := forestComponentForestChoiceComponentRemnantStarOf g q hq γ B
  have hDisjOuter : Aout.IsPairwiseDisjoint := by
    simpa [Aout] using
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          (forestComponentForestChoiceOuterIndex g q hq).2
  have hBcProper :
      Bc ∈ γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
    simpa [Bc] using
      forestComponentForestChoiceComponentRemnant_mem_properDisjoint
        g q hq γ hB
  have hDisjBc : Bc.IsPairwiseDisjoint := by
    simpa [Bc] using
      γ.1.toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          hBcProper
  by_cases huBc : u ∈ Bc.vertices
  · rcases AdmissibleSubgraph.mem_vertices.mp huBc with ⟨η, hη, huη⟩
    have hηOuter : feynmanSubgraphPromote (γ_outer := γ.1) η ∈ Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq γ hB (η := η) hη
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component
        hDisjOuter outerStar hηOuter (by simpa using huη)]
    rw [AdmissibleSubgraph.retargetVertex_of_mem_component
        hDisjBc innerStar hη huη]
    simp [outerStar, innerStar,
      forestComponentForestChoiceComponentRemnantStarOf]
  · have huOuter : u ∉ Aout.vertices := by
      intro huA
      exact huBc
        ((forestComponentForestChoice_vertex_mem_outer_iff_componentRemnant
          g q hq γ hB huγ).mp (by simpa [Aout] using huA))
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar huOuter]
    rw [AdmissibleSubgraph.retargetVertex_of_not_mem Bc innerStar huBc]

/-- On internal edges of a selected source component, the ambient outer-splice
edge retargeting agrees literally with component-quotient edge retargeting. -/
private theorem
    forestComponentForestChoice_retargetEdge_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heγ : e ∈ γ.1.internalEdges) :
    (forestComponentForestChoiceOuterIndex g q hq).1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2) e =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).retargetEdge
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) e := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  let innerStar := forestComponentForestChoiceComponentRemnantStarOf g q hq γ B
  have hsupp := γ.1.edges_supported e heγ
  simp [FeynmanEdge.SupportedOn] at hsupp
  have hsrc :
      Aout.retargetVertex outerStar e.source =
        Bc.retargetVertex innerStar e.source := by
    simpa [Aout, outerStar, Bc, innerStar] using
      forestComponentForestChoice_retargetVertex_eq_componentRemnant
        g q hq γ hB hsupp.1
  have htgt :
      Aout.retargetVertex outerStar e.target =
        Bc.retargetVertex innerStar e.target := by
    simpa [Aout, outerStar, Bc, innerStar] using
      forestComponentForestChoice_retargetVertex_eq_componentRemnant
        g q hq γ hB hsupp.2
  cases e
  apply FeynmanEdge.mk.injEq _ _ _ _ _ _ |>.mpr
  exact ⟨by simpa [Aout, outerStar, Bc, innerStar] using hsrc,
    by simpa [Aout, outerStar, Bc, innerStar] using htgt, rfl⟩

/-- On external legs of a selected source component, the ambient outer-splice
leg retargeting agrees literally with component-quotient leg retargeting. -/
private theorem
    forestComponentForestChoice_retargetExternalLeg_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B)
    {ℓ : ExternalLeg} (hℓγ : ℓ ∈ γ.1.externalLegs) :
    (forestComponentForestChoiceOuterIndex g q hq).1.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2) ℓ =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).retargetExternalLeg
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) ℓ := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  let innerStar := forestComponentForestChoiceComponentRemnantStarOf g q hq γ B
  have hsupp := γ.1.legs_supported ℓ hℓγ
  simp [ExternalLeg.SupportedOn] at hsupp
  have hatt :
      Aout.retargetVertex outerStar ℓ.attachedTo =
        Bc.retargetVertex innerStar ℓ.attachedTo := by
    simpa [Aout, outerStar, Bc, innerStar] using
      forestComponentForestChoice_retargetVertex_eq_componentRemnant
        g q hq γ hB hsupp
  cases ℓ
  apply ExternalLeg.mk.injEq _ _ _ _ |>.mpr
  exact ⟨by simpa [Aout, outerStar, Bc, innerStar] using hatt, rfl⟩

set_option maxHeartbeats 800000

/-- Certificate for turning the raw selected-component remnant carrier into
an admissible quotient-side forest.  The hard fields are exactly the remaining
graph-level identification of each remnant with the component quotient
`γ / B`, plus compatibility between those remnants. -/
private structure forestComponentForestChoiceRemnantCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  cd : ∀ δ ∈ forestComponentForestChoiceRemnantComponents g q hq,
    δ.IsConnectedDivergent
  compat : ∀ δ₁, δ₁ ∈ forestComponentForestChoiceRemnantComponents g q hq →
    ∀ δ₂, δ₂ ∈ forestComponentForestChoiceRemnantComponents g q hq →
      δ₁ ≠ δ₂ → δ₁.NestedOrDisjoint δ₂

/-- Once each selected component remnant has been identified as a connected
divergent graph, compatibility is already supplied by the outer-splice
retargeting geometry. -/
private structure forestComponentForestChoiceRemnantCDCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  cd : ∀ δ ∈ forestComponentForestChoiceRemnantComponents g q hq,
    δ.IsConnectedDivergent

/-- The remaining graph-level payload for the remnant CD field: each raw
retargeted remnant must be literally the component quotient `γ / B`, with the
component-star assignment induced by the spliced outer forest. -/
private structure forestComponentForestChoiceRemnantGraphIdentificationCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  graph_eq :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          γ.1).toFeynmanGraph =
        FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2) B)
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)

/-- The raw retargeted remnant graph on the quotient side. -/
private noncomputable def forestComponentForestChoiceRetargetedRemnantGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    FeynmanGraph :=
  (admissibleSubgraphQuotientRemainderSubgraph
    (forestComponentForestChoiceOuterIndex g q hq).1
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2)
    γ.1).toFeynmanGraph

/-- The component quotient graph `γ / B` with the star assignment induced by
the spliced outer forest. -/
private noncomputable def forestComponentForestChoiceComponentRemnantGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph) :
    FeynmanGraph :=
  FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
    (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
      (q.1.1.isConnectedDivergent_of_mem γ.2) B)
    (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)

@[simp] private theorem forestComponentForestChoiceRetargetedRemnantGraph_vertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).vertices =
      γ.1.vertices.image
        ((forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)) := rfl

@[simp] private theorem forestComponentForestChoiceRetargetedRemnantGraph_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).internalEdges =
      (γ.1.internalEdges - (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges).map
        ((forestComponentForestChoiceOuterIndex g q hq).1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)) := rfl

@[simp] private theorem forestComponentForestChoiceRetargetedRemnantGraph_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements}) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).externalLegs =
      γ.1.externalLegs.map
        ((forestComponentForestChoiceOuterIndex g q hq).1.retargetExternalLeg
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)) := rfl

@[simp] private theorem forestComponentForestChoiceComponentRemnantGraph_vertices
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph) :
    (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).vertices =
      (γ.1.toFeynmanGraph.vertices \
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).vertices) ∪
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).starVertices
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B) := rfl

@[simp] private theorem forestComponentForestChoiceComponentRemnantGraph_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph) :
    (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).internalEdges =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).complementEdges.map
        ((feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).retargetEdge
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)) := rfl

@[simp] private theorem forestComponentForestChoiceComponentRemnantGraph_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph) :
    (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).externalLegs =
      γ.1.toFeynmanGraph.externalLegs.map
        ((feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).retargetExternalLeg
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)) := rfl

/-- Literal vertex-carrier equality for the selected remnant graph
identification. -/
private theorem forestComponentForestChoiceRemnantGraph_vertices_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).vertices =
      (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).vertices := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
    (q.1.1.isConnectedDivergent_of_mem γ.2) B
  let innerStar := forestComponentForestChoiceComponentRemnantStarOf g q hq γ B
  have hBcProper :
      Bc ∈ γ.1.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
    simpa [Bc] using
      forestComponentForestChoiceComponentRemnant_mem_properDisjoint
        g q hq γ hB
  have hDisjBc : Bc.IsPairwiseDisjoint := by
    simpa [Bc] using
      γ.1.toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          hBcProper
  rw [forestComponentForestChoiceRetargetedRemnantGraph_vertices,
    forestComponentForestChoiceComponentRemnantGraph_vertices]
  ext v
  constructor
  · intro hv
    rcases Finset.mem_image.mp hv with ⟨u, huγ, huv⟩
    have hret :
        Aout.retargetVertex outerStar u = Bc.retargetVertex innerStar u := by
      simpa [Aout, outerStar, Bc, innerStar] using
        forestComponentForestChoice_retargetVertex_eq_componentRemnant
          g q hq γ hB huγ
    have huvB : Bc.retargetVertex innerStar u = v := hret.symm.trans huv
    by_cases huBc : u ∈ Bc.vertices
    · rcases AdmissibleSubgraph.mem_vertices.mp huBc with ⟨η, hη, huη⟩
      have hRetB :
          Bc.retargetVertex innerStar u = innerStar η :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hDisjBc innerStar hη huη
      rw [Finset.mem_union]
      right
      rw [AdmissibleSubgraph.mem_starVertices]
      exact ⟨η, hη, hRetB.symm.trans huvB⟩
    · have hRetB : Bc.retargetVertex innerStar u = u :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Bc innerStar huBc
      have huvEq : u = v := by
        rw [hRetB] at huvB
        exact huvB
      rw [Finset.mem_union]
      left
      rw [← huvEq]
      exact Finset.mem_sdiff.mpr ⟨by simpa using huγ, huBc⟩
  · intro hv
    rw [Finset.mem_union] at hv
    rcases hv with hvRest | hvStar
    · rcases Finset.mem_sdiff.mp hvRest with ⟨hvγGraph, hvBc⟩
      have hvγ : v ∈ γ.1.vertices := by
        simpa using hvγGraph
      refine Finset.mem_image.mpr ⟨v, hvγ, ?_⟩
      have hret :
          Aout.retargetVertex outerStar v = Bc.retargetVertex innerStar v := by
        simpa [Aout, outerStar, Bc, innerStar] using
          forestComponentForestChoice_retargetVertex_eq_componentRemnant
            g q hq γ hB hvγ
      have hRetB : Bc.retargetVertex innerStar v = v :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Bc innerStar hvBc
      exact hret.trans hRetB
    · rw [AdmissibleSubgraph.mem_starVertices] at hvStar
      rcases hvStar with ⟨η, hη, hηStar⟩
      have hηNonempty : η.IsNonempty :=
        γ.1.toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
            hBcProper η hη
      unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hηNonempty
      rcases Finset.card_pos.mp hηNonempty with ⟨u, huη⟩
      have huγ : u ∈ γ.1.vertices := by
        simpa using η.vertices_subset huη
      refine Finset.mem_image.mpr ⟨u, huγ, ?_⟩
      have hret :
          Aout.retargetVertex outerStar u = Bc.retargetVertex innerStar u := by
        simpa [Aout, outerStar, Bc, innerStar] using
          forestComponentForestChoice_retargetVertex_eq_componentRemnant
            g q hq γ hB huγ
      have hRetB :
          Bc.retargetVertex innerStar u = innerStar η :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hDisjBc innerStar hη huη
      exact hret.trans (hRetB.trans hηStar)

/-- The source multiset of internal edges left by the outer splice on `γ` is
literally the complement-edge multiset of the transported component forest. -/
private theorem
    forestComponentForestChoice_gamma_internalEdges_sub_outer_eq_componentRemnant_complementEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    γ.1.internalEdges - (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges =
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).complementEdges := by
  classical
  refine Multiset.ext.mpr ?_
  intro e
  rw [AdmissibleSubgraph.complementEdges, FeynmanSubgraph.toFeynmanGraph_internalEdges]
  rw [Multiset.count_sub, Multiset.count_sub]
  by_cases heγ : e ∈ γ.1.internalEdges
  · have hcount :=
      forestComponentForestChoice_outer_internalEdges_count_eq_componentRemnant
        g q hq γ hB heγ
    rw [hcount]
  · have hγ0 : Multiset.count e γ.1.internalEdges = 0 :=
      Multiset.count_eq_zero.mpr heγ
    rw [hγ0]
    simp

/-- Literal internal-edge equality for the selected remnant graph
identification. -/
private theorem forestComponentForestChoiceRemnantGraph_internalEdges_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).internalEdges =
      (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).internalEdges := by
  rw [forestComponentForestChoiceRetargetedRemnantGraph_internalEdges,
    forestComponentForestChoiceComponentRemnantGraph_internalEdges]
  rw [forestComponentForestChoice_gamma_internalEdges_sub_outer_eq_componentRemnant_complementEdges
    g q hq γ hB]
  refine Multiset.map_congr rfl ?_
  intro e he
  have heγ : e ∈ γ.1.internalEdges := by
    have heAmbient :=
      (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B)
        |>.mem_ambientInternalEdges_of_mem_complementEdges he
    simpa using heAmbient
  simpa using
    forestComponentForestChoice_retargetEdge_eq_componentRemnant
      g q hq γ hB heγ

/-- Literal external-leg equality for the selected remnant graph
identification. -/
private theorem forestComponentForestChoiceRemnantGraph_externalLegs_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph}
    (hB :
      q.2 γ (Finset.mem_attach q.1.1.elements γ) =
        forestCoproductChoice.forest B) :
    (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).externalLegs =
      (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).externalLegs := by
  rw [forestComponentForestChoiceRetargetedRemnantGraph_externalLegs,
    forestComponentForestChoiceComponentRemnantGraph_externalLegs]
  refine Multiset.map_congr rfl ?_
  intro ℓ hℓ
  simpa using
    forestComponentForestChoice_retargetExternalLeg_eq_componentRemnant
      g q hq γ hB hℓ

/-- Fieldwise version of the final remnant graph identification.  This is the
literal vertices/internal-edges/external-legs target split out for the final
graph equality proof. -/
private structure
    forestComponentForestChoiceRemnantGraphFieldIdentificationCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  vertices_eq :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).vertices =
          (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).vertices
  internalEdges_eq :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).internalEdges =
          (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).internalEdges
  externalLegs_eq :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        (forestComponentForestChoiceRetargetedRemnantGraph g q hq γ).externalLegs =
          (forestComponentForestChoiceComponentRemnantGraph g q hq γ B).externalLegs

/-- Fieldwise literal equality supplies the graph-level remnant identification. -/
private noncomputable def
    forestComponentForestChoiceRemnantGraphIdentificationCertificateOfFields
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantGraphFieldIdentificationCertificate
      g q hq) :
    forestComponentForestChoiceRemnantGraphIdentificationCertificate g q hq where
  graph_eq := by
    intro γ B hB
    apply FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr
    exact ⟨C.vertices_eq γ B hB, C.internalEdges_eq γ B hB,
      C.externalLegs_eq γ B hB⟩

/-- Canonical fieldwise identification of every selected retargeted remnant
with its component quotient. -/
private noncomputable def
    forestComponentForestChoiceRemnantGraphFieldIdentificationCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantGraphFieldIdentificationCertificate
      g q hq where
  vertices_eq := by
    intro γ B hB
    exact forestComponentForestChoiceRemnantGraph_vertices_eq g q hq γ hB
  internalEdges_eq := by
    intro γ B hB
    exact forestComponentForestChoiceRemnantGraph_internalEdges_eq g q hq γ hB
  externalLegs_eq := by
    intro γ B hB
    exact forestComponentForestChoiceRemnantGraph_externalLegs_eq g q hq γ hB

/-- Canonical graph-level identification of every selected retargeted remnant
with its component quotient. -/
private noncomputable def
    forestComponentForestChoiceRemnantGraphIdentificationCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantGraphIdentificationCertificate g q hq :=
  forestComponentForestChoiceRemnantGraphIdentificationCertificateOfFields
    g q hq
    (forestComponentForestChoiceRemnantGraphFieldIdentificationCertificateCanonical
      g q hq)

/-- A graph-level identification of every selected remnant with its component
quotient supplies the remaining connected-divergent field. -/
private noncomputable def
    forestComponentForestChoiceRemnantCDCertificateOfGraphIdentification
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantGraphIdentificationCertificate
      g q hq) :
    forestComponentForestChoiceRemnantCDCertificate g q hq where
  cd := by
    intro δ hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists
        g q hq hδ with
      ⟨γ, B, hB, rfl⟩
    let Q :=
      FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B)
        (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)
    have hQCD : Q.IsConnectedDivergent := by
      simpa [Q] using
        forestComponentForestChoiceComponentRemnantContractGraph_isConnectedDivergent
          g q hq γ hB
    exact feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq
      (γ₁ := FeynmanSubgraph.self Q hQCD.wellFormed)
      (γ₂ := admissibleSubgraphQuotientRemainderSubgraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterIndex g q hq).1
          (forestComponentForestChoiceOuterIndex g q hq).2)
        γ.1)
      (by simpa [Q] using C.graph_eq γ B hB)
      hQCD.self_isConnectedDivergent

/-- Build the full remnant forest certificate from the remaining graph-level
connected-divergent identification. -/
private noncomputable def forestComponentForestChoiceRemnantCertificateOfCD
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantCDCertificate g q hq) :
    forestComponentForestChoiceRemnantCertificate g q hq where
  cd := C.cd
  compat := forestComponentForestChoiceRemnantComponents_compat g q hq

/-- Build the full remnant forest certificate from the graph-level remnant
identification. -/
private noncomputable def
    forestComponentForestChoiceRemnantCertificateOfGraphIdentification
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantGraphIdentificationCertificate
      g q hq) :
    forestComponentForestChoiceRemnantCertificate g q hq :=
  forestComponentForestChoiceRemnantCertificateOfCD g q hq
    (forestComponentForestChoiceRemnantCDCertificateOfGraphIdentification
      g q hq C)

/-- Canonical full remnant certificate obtained from the literal graph-level
identification. -/
private noncomputable def forestComponentForestChoiceRemnantCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantCertificate g q hq :=
  forestComponentForestChoiceRemnantCertificateOfGraphIdentification
    g q hq
    (forestComponentForestChoiceRemnantGraphIdentificationCertificateCanonical
      g q hq)

/-- Actual quotient-side forest made of all selected component remnants
`γ / B`. -/
private noncomputable def forestComponentForestChoiceActualRemnantQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantCertificate g q hq) :
    AdmissibleSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  AdmissibleSubgraph.ofElements
    (forestComponentForestChoiceRemnantComponents g q hq)
    ⟨C.cd, C.compat⟩

/-- Representative quotient-side forest made of all selected component
remnants `γ / B`. -/
private noncomputable def forestComponentForestChoiceRepRemnantQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantCertificate g q hq) :
    AdmissibleSubgraph
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestOuterActualToRepAdmissibleSubgraph g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentForestChoiceActualRemnantQuotientSubgraph g q hq C)

/-- Canonical actual quotient-side forest made only of selected component
remnants. -/
private noncomputable def forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    AdmissibleSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceActualRemnantQuotientSubgraph g q hq
    (forestComponentForestChoiceRemnantCertificateCanonical g q hq)

@[simp] private theorem
    forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical_elements
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
      g q hq).elements =
        forestComponentForestChoiceRemnantComponents g q hq := rfl

/-- Canonical representative quotient-side forest made only of selected
component remnants. -/
private noncomputable def forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    AdmissibleSubgraph
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceRepRemnantQuotientSubgraph g q hq
    (forestComponentForestChoiceRemnantCertificateCanonical g q hq)

/-- Transporting the genuine-forest remnant-only quotient forest from the
actual quotient graph to its representative preserves the Hopf product. -/
private theorem
    forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical_toHopfH_eq_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical
      g q hq).toHopfH =
        (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
          g q hq).toHopfH := by
  unfold forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical
    forestComponentForestChoiceRepRemnantQuotientSubgraph
    forestOuterActualToRepAdmissibleSubgraph
    forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
    forestComponentForestChoiceActualRemnantQuotientSubgraph
  rw [mapPermAdmissibleSubgraph_toHopfH]

/-- The combined actual quotient-side carrier paired with a genuine-forest
outer splice: right-selected survivors plus quotient remnants of selected
component forests. -/
private noncomputable def forestComponentForestChoiceActualQuotientComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    Finset (FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) :=
  (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
    g q hq).elements ∪
    forestComponentForestChoiceRemnantComponents g q hq

/-- **Track B-forest-final-2 — `Remnant` is the star-touching part of the
quotient forest.**  Inside `ActualQuotientComponents = Right ∪ Remnant`, the
remnant components are exactly those touching a canonical outer star (Targets
1 & 2).  This is the intrinsic separator that lets a quotient-forest equality be
projected onto a `Remnant`-equality — the constructive core of the genuine-forest
`q.1` recovery, isolating the only semantic obstruction in
`ForestGraphInsertionUniquenessModel`. -/
private theorem forestComponentForestChoiceRemnantComponents_eq_filter_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) {δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ : δ ∈ forestComponentForestChoiceActualQuotientComponents g q hq) :
    forestComponentForestChoiceTouchesOuterStar g q hq δ ↔
      δ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
  classical
  unfold forestComponentForestChoiceActualQuotientComponents at hδ
  rcases Finset.mem_union.mp hδ with hR | hM
  · constructor
    · intro hP
      exact absurd hP
        (forestComponentForestChoiceRight_not_touchesOuterStar g q hq hR)
    · intro hM
      exact forestComponentForestChoiceRemnant_touchesOuterStar g q hq hM
  · exact ⟨fun _ => hM, fun _ =>
      forestComponentForestChoiceRemnant_touchesOuterStar g q hq hM⟩

/-- **Track B-forest-final-5a (helper A).**  Dual of final-2: inside the quotient
component carrier, the `Right` survivors are exactly the components that do *not*
touch a canonical outer star.  iff form (no `DecidablePred` in the statement);
projects `ActualRight` out of `ActualQuotientComponents`. -/
private theorem forestComponentForestChoiceActualRight_mem_iff_not_touchesOuterStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) {δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))}
    (hδ : δ ∈ forestComponentForestChoiceActualQuotientComponents g q hq) :
    δ ∈ (forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q hq).elements ↔
      ¬ forestComponentForestChoiceTouchesOuterStar g q hq δ := by
  classical
  unfold forestComponentForestChoiceActualQuotientComponents at hδ
  constructor
  · intro hR
    exact forestComponentForestChoiceRight_not_touchesOuterStar g q hq hR
  · intro hNot
    rcases Finset.mem_union.mp hδ with hR | hM
    · exact hR
    · exact absurd (forestComponentForestChoiceRemnant_touchesOuterStar g q hq hM) hNot

/-! ### Track B-forest-final-5a — raw star-touch predicate (index-free)

The `q`-tied `forestComponentForestChoiceTouchesOuterStar` bakes in
`OuterIndex g q hq`, blocking `cases hOuter` on the *computed* outer equality.
The raw form takes the outer index `A` as a free variable, so the eventual
filter-transport helper can `cases hA` on a *free* binder. -/
private def forestComponentForestChoiceTouchesOuterStarRaw
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A)) : Prop :=
  ∃ η ∈ A.1.elements,
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2 η ∈ δ.vertices

/-- The `q`-tied predicate is the raw predicate at `OuterIndex g q hq` (`rfl`). -/
private theorem forestComponentForestChoiceTouchesOuterStar_eq_raw
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (δ : FeynmanSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq))) :
    forestComponentForestChoiceTouchesOuterStar g q hq δ =
      forestComponentForestChoiceTouchesOuterStarRaw g
        (forestComponentForestChoiceOuterIndex g q hq) δ := rfl

open scoped Classical in
/-- **Track B-forest-final-5a (helper A, raw filter form).**  `ActualRight` is
the `¬ touchesStarRaw` slice of the quotient component carrier. -/
private theorem forestComponentForestChoiceActualRightComponents_eq_filter_not_touchesOuterStarRaw
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q hq).elements =
      (forestComponentForestChoiceActualQuotientComponents g q hq).filter
        (fun δ => ¬ forestComponentForestChoiceTouchesOuterStarRaw g
          (forestComponentForestChoiceOuterIndex g q hq) δ) := by
  classical
  ext δ
  rw [Finset.mem_filter]
  constructor
  · intro hδR
    refine ⟨?_, ?_⟩
    · unfold forestComponentForestChoiceActualQuotientComponents
      exact Finset.mem_union_left _ hδR
    · exact forestComponentForestChoiceRight_not_touchesOuterStar g q hq hδR
  · rintro ⟨hδC, hδNot⟩
    exact (forestComponentForestChoiceActualRight_mem_iff_not_touchesOuterStar
      g q hq hδC).mpr hδNot

open scoped Classical in
/-- **Track B-forest-final-5a (helper, free-index filter transport).**  A
component-carrier `eqRec`-equality (free outer index) descends to the
`¬ touchesStarRaw` slices.  `cases hA` is legal — `A₁ A₂` are free variables. -/
private theorem finset_filter_not_touchesOuterStarRaw_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {S₁ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₁))}
    {S₂ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₂))}
    (hS : hA ▸ S₁ = S₂) :
    hA ▸ S₁.filter
        (fun δ => ¬ forestComponentForestChoiceTouchesOuterStarRaw g A₁ δ) =
      S₂.filter
        (fun δ => ¬ forestComponentForestChoiceTouchesOuterStarRaw g A₂ δ) := by
  cases hA
  exact congrArg
    (fun S => S.filter
      (fun δ => ¬ forestComponentForestChoiceTouchesOuterStarRaw g A₁ δ)) hS

/-- An `elements` `eqRec`-equality (free outer index) lifts to the subgraph by
`AdmissibleSubgraph.ext`.  `cases hA` is legal — `A₁ A₂` are free. -/
private theorem admissibleSubgraph_eqRec_of_elements_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {B₁ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₁)}
    {B₂ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₂)}
    (h : hA ▸ B₁.elements = B₂.elements) : hA ▸ B₁ = B₂ := by
  cases hA
  exact AdmissibleSubgraph.ext (Forest.ext h)

/-- **Track B-forest-final-5a (helper, `ActualRight` eqRec).**  From a quotient
component-carrier `eqRec`-equality, recover the `ActualRight` subgraph
`eqRec`-equality, via the `¬ touchesStarRaw` filter characterization. -/
private theorem forestComponentForestChoiceActualRight_eqRec_of_components_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (hComp :
      hOuter ▸ forestComponentForestChoiceActualQuotientComponents g q₁ hq₁ =
        forestComponentForestChoiceActualQuotientComponents g q₂ hq₂) :
    hOuter ▸
        forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q₁ hq₁ =
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q₂ hq₂ := by
  classical
  refine admissibleSubgraph_eqRec_of_elements_eqRec g hOuter ?_
  rw [forestComponentForestChoiceActualRightComponents_eq_filter_not_touchesOuterStarRaw
        g q₁ hq₁,
      forestComponentForestChoiceActualRightComponents_eq_filter_not_touchesOuterStarRaw
        g q₂ hq₂]
  exact finset_filter_not_touchesOuterStarRaw_eqRec g hOuter hComp

open scoped Classical in
/-- **Track B-forest-final-4c (helper, positive raw filter transport).**  Dual of
the `Right` (negative) filter transport: the `touchesStarRaw` slice. -/
private theorem finset_filter_touchesOuterStarRaw_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {S₁ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₁))}
    {S₂ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₂))}
    (hS : hA ▸ S₁ = S₂) :
    hA ▸ S₁.filter
        (fun δ => forestComponentForestChoiceTouchesOuterStarRaw g A₁ δ) =
      S₂.filter
        (fun δ => forestComponentForestChoiceTouchesOuterStarRaw g A₂ δ) := by
  cases hA
  exact congrArg
    (fun S => S.filter
      (fun δ => forestComponentForestChoiceTouchesOuterStarRaw g A₁ δ)) hS

open scoped Classical in
/-- **Track B-forest-final-4c (helper, Remnant raw filter form).**  `Remnant` is
the `touchesStarRaw` slice of the quotient component carrier (dual of
helper A). -/
private theorem forestComponentForestChoiceRemnantComponents_eq_filter_touchesOuterStarRaw
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceRemnantComponents g q hq =
      (forestComponentForestChoiceActualQuotientComponents g q hq).filter
        (fun δ => forestComponentForestChoiceTouchesOuterStarRaw g
          (forestComponentForestChoiceOuterIndex g q hq) δ) := by
  classical
  ext δ
  rw [Finset.mem_filter]
  constructor
  · intro hδRem
    refine ⟨?_, ?_⟩
    · unfold forestComponentForestChoiceActualQuotientComponents
      exact Finset.mem_union_right _ hδRem
    · exact forestComponentForestChoiceRemnant_touchesOuterStar g q hq hδRem
  · rintro ⟨hδC, hδTouch⟩
    exact (forestComponentForestChoiceRemnantComponents_eq_filter_touchesOuterStar
      g q hq hδC).mp hδTouch

/-- **Track B-forest-final-4c (helper, RemnantComponents eqRec).**  From a
quotient component-carrier `eqRec`-equality, recover the `RemnantComponents`
`eqRec`-equality, via the positive `touchesStarRaw` filter characterization. -/
private theorem forestComponentForestChoiceRemnantComponents_eq_of_components_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (hComp :
      hOuter ▸ forestComponentForestChoiceActualQuotientComponents g q₁ hq₁ =
        forestComponentForestChoiceActualQuotientComponents g q₂ hq₂) :
    hOuter ▸ forestComponentForestChoiceRemnantComponents g q₁ hq₁ =
      forestComponentForestChoiceRemnantComponents g q₂ hq₂ := by
  classical
  rw [forestComponentForestChoiceRemnantComponents_eq_filter_touchesOuterStarRaw
        g q₁ hq₁,
      forestComponentForestChoiceRemnantComponents_eq_filter_touchesOuterStarRaw
        g q₂ hq₂]
  exact finset_filter_touchesOuterStarRaw_eqRec g hOuter hComp

/-! #### Track B-forest-final-4c — free-index transport-compat helpers

The cross-`q` `ForestParents` recovery (below) compares a parent `γ` taken from
`q₁` against a candidate `γ'` from `q₂` whose remnant agrees.  The membership-free
model `parent_eq_of_remnant_eq` closes it once `γ.vertices = γ'.vertices`, and
each vertex set is recovered by its *own* `q`'s `B-forest-2a`
(`remnant_sourceVertices_eq_parent_vertices`, membership-restricted) — linked
across `q₁/q₂` by these `cases hA`-on-free-index transport equalities. -/

/-- Remnant map commutes with outer-index transport (free index). -/
private theorem admissibleSubgraphQuotientRemainder_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph) :
    hA ▸ admissibleSubgraphQuotientRemainderSubgraph A₁.1
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph A₁.1 A₁.2)
        γ =
      admissibleSubgraphQuotientRemainderSubgraph A₂.1
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph A₂.1 A₂.2)
        γ := by
  cases hA; rfl

/-- Remainder source-vertices commute with outer-index transport (free index). -/
private theorem admissibleSubgraphRemainderSourceVertices_eqRec
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A₁)) :
    admissibleSubgraphRemainderSourceVertices A₂.1
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph A₂.1 A₂.2)
        (hA ▸ δ) =
      admissibleSubgraphRemainderSourceVertices A₁.1
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph A₁.1 A₁.2)
        δ := by
  cases hA; rfl

/-- Membership transports along outer-index transport (free index). -/
private theorem mem_eqRec_forestOuterActualQuotient
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {S : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₁))}
    {a : FeynmanSubgraph (forestOuterActualQuotientGraph g A₁)} (h : a ∈ S) :
    hA ▸ a ∈ hA ▸ S := by
  cases hA; exact h

/-- **Track B-forest-final-4c (forward).**  A forest parent of `q₁` is a forest
parent of `q₂`, given the `RemnantComponents` `eqRec`-equality.  The candidate
`γ'` (from `q₂`, with the same remnant) is identified with `γ` by the
membership-free model `parent_eq_of_remnant_eq`; the vertex hypothesis is
assembled from each `q`'s own `B-forest-2a` linked by the transport-compat
equalities (no `cases` on the computed outer equality). -/
private theorem forestComponentForestChoiceForestParents_subset_of_remnant_eqRec
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (hRem :
      hOuter ▸ forestComponentForestChoiceRemnantComponents g q₁ hq₁ =
        forestComponentForestChoiceRemnantComponents g q₂ hq₂)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestComponentForestChoiceForestParents g q₁) :
    γ ∈ forestComponentForestChoiceForestParents g q₂ := by
  classical
  have hγmem₁ : γ ∈ q₁.1.1.elements :=
    ((mem_forestComponentForestChoiceForestParents g q₁).mp hγ).1
  have hpr₁ :
      forestComponentForestChoiceParentRemnantBare g q₁ hq₁ γ ∈
        forestComponentForestChoiceRemnantComponents g q₁ hq₁ := by
    rw [forestComponentForestChoiceRemnantComponents_eq_image_parentRemnantBare g q₁ hq₁]
    exact Finset.mem_image.mpr ⟨γ, hγ, rfl⟩
  have hRemEq :
      forestComponentForestChoiceParentRemnantBare g q₂ hq₂ γ =
        hOuter ▸ forestComponentForestChoiceParentRemnantBare g q₁ hq₁ γ :=
    (admissibleSubgraphQuotientRemainder_eqRec g hOuter γ).symm
  have hpr₂mem :
      forestComponentForestChoiceParentRemnantBare g q₂ hq₂ γ ∈
        forestComponentForestChoiceRemnantComponents g q₂ hq₂ := by
    have hm := mem_eqRec_forestOuterActualQuotient g hOuter hpr₁
    rw [hRem] at hm
    rw [hRemEq]
    exact hm
  rw [forestComponentForestChoiceRemnantComponents_eq_image_parentRemnantBare g q₂ hq₂]
    at hpr₂mem
  rcases Finset.mem_image.mp hpr₂mem with ⟨γ', hγ'FP, hγ'eq⟩
  have hγ'mem₂ : γ' ∈ q₂.1.1.elements :=
    ((mem_forestComponentForestChoiceForestParents g q₂).mp hγ'FP).1
  have hA₁ : q₁.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₁.1.2
  have hA₂ : q₂.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₂.1.2
  have hAoutPD₁ :
      forestComponentForestChoiceOuterSubgraph q₁.1.1 q₁.2 hA₁ ∈
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q₁.1.2
      (Finset.mem_sigma.mp hq₁).2
  have hAoutPD₂ :
      forestComponentForestChoiceOuterSubgraph q₂.1.1 q₂.2 hA₂ ∈
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q₂.1.2
      (Finset.mem_sigma.mp hq₂).2
  have hSV₁ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q₁.1.1 q₁.2 hA₁ hAoutPD₁ hγmem₁
  have hSV₂ := forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    g q₂.1.1 q₂.2 hA₂ hAoutPD₂ hγ'mem₂
  have hVert : γ'.vertices = γ.vertices := by
    calc γ'.vertices
        = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).2)
            (forestComponentForestChoiceParentRemnantBare g q₂ hq₂ γ') := hSV₂.symm
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).2)
            (forestComponentForestChoiceParentRemnantBare g q₂ hq₂ γ) := by rw [hγ'eq]
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).2)
            (hOuter ▸ forestComponentForestChoiceParentRemnantBare g q₁ hq₁ γ) :=
          congrArg
            (admissibleSubgraphRemainderSourceVertices
              (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
              (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
                (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
                (forestComponentForestChoiceOuterIndex g q₂ hq₂).2))
            hRemEq
      _ = admissibleSubgraphRemainderSourceVertices
            (forestComponentForestChoiceOuterIndex g q₁ hq₁).1
            (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q₁ hq₁).1
              (forestComponentForestChoiceOuterIndex g q₁ hq₁).2)
            (forestComponentForestChoiceParentRemnantBare g q₁ hq₁ γ) :=
          admissibleSubgraphRemainderSourceVertices_eqRec g hOuter
            (forestComponentForestChoiceParentRemnantBare g q₁ hq₁ γ)
      _ = γ.vertices := hSV₁
  have hγ'γ : γ' = γ :=
    ForestGraphInsertionUniquenessModel.parent_eq_of_remnant_eq
      (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
      (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q₂ hq₂).1
        (forestComponentForestChoiceOuterIndex g q₂ hq₂).2)
      hVert hγ'eq
  rw [← hγ'γ]; exact hγ'FP

/-- Symmetrize an outer-index `eqRec`-equality of remnant carriers (free index). -/
private theorem forestComponentForestChoiceRemnantComponents_eqRec_symm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {R₁ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₁))}
    {R₂ : Finset (FeynmanSubgraph (forestOuterActualQuotientGraph g A₂))}
    (h : hA ▸ R₁ = R₂) : hA.symm ▸ R₂ = R₁ := by
  cases hA; exact h.symm

/-- **Track B-forest-final-4c (ForestParents eqRec).**  Forest-parent sets agree
given the `RemnantComponents` `eqRec`-equality, by the forward subset both ways
(reverse via the symmetrized transport). -/
private theorem forestComponentForestChoiceForestParents_eq_of_remnant_eqRec
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (hRem :
      hOuter ▸ forestComponentForestChoiceRemnantComponents g q₁ hq₁ =
        forestComponentForestChoiceRemnantComponents g q₂ hq₂) :
    forestComponentForestChoiceForestParents g q₁ =
      forestComponentForestChoiceForestParents g q₂ := by
  apply Finset.ext
  intro γ
  constructor
  · intro hγ
    exact forestComponentForestChoiceForestParents_subset_of_remnant_eqRec
      g hq₁ hq₂ hOuter hRem hγ
  · intro hγ
    exact forestComponentForestChoiceForestParents_subset_of_remnant_eqRec
      g hq₂ hq₁ hOuter.symm
      (forestComponentForestChoiceRemnantComponents_eqRec_symm g hOuter hRem) hγ

/-- Certificate for the full quotient-side forest paired with the
genuine-forest outer splice.  The remaining hard graph work is the remnant
identification and its compatibility with the already-retargeted
right-selected survivors. -/
private structure forestComponentForestChoiceQuotientCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  remnant : forestComponentForestChoiceRemnantCertificate g q hq
  cross : ∀ δR,
    δR ∈
      (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
        g q hq).elements →
    ∀ δM, δM ∈ forestComponentForestChoiceRemnantComponents g q hq →
      δR ≠ δM → δR.NestedOrDisjoint δM

/-- Once the selected component remnants themselves form an admissible forest,
the right-remnant cross compatibility is canonical. -/
private noncomputable def forestComponentForestChoiceQuotientCertificateOfRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantCertificate g q hq) :
    forestComponentForestChoiceQuotientCertificate g q hq where
  remnant := C
  cross := forestComponentForestChoiceRightRemnant_cross g q hq

/-- Canonical full quotient-side certificate for the genuine-forest component
choice regime. -/
private noncomputable def forestComponentForestChoiceQuotientCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceQuotientCertificate g q hq :=
  forestComponentForestChoiceQuotientCertificateOfRemnant g q hq
    (forestComponentForestChoiceRemnantCertificateCanonical g q hq)

/-- Actual quotient-side forest paired with the genuine-forest outer splice. -/
private noncomputable def forestComponentForestChoiceActualQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceQuotientCertificate g q hq) :
    AdmissibleSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  AdmissibleSubgraph.ofElements
    (forestComponentForestChoiceActualQuotientComponents g q hq)
    (by
      constructor
      · intro δ hδ
        unfold forestComponentForestChoiceActualQuotientComponents at hδ
        rcases Finset.mem_union.mp hδ with hR | hM
        · exact
            (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
              g q hq).isConnectedDivergent_of_mem hR
        · exact C.remnant.cd δ hM
      · intro δ₁ hδ₁ δ₂ hδ₂ hne
        unfold forestComponentForestChoiceActualQuotientComponents at hδ₁ hδ₂
        rcases Finset.mem_union.mp hδ₁ with h₁R | h₁M
        · rcases Finset.mem_union.mp hδ₂ with h₂R | h₂M
          · exact
              (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
                g q hq).forest.nestedOrDisjoint h₁R h₂R hne
          · exact C.cross δ₁ h₁R δ₂ h₂M hne
        · rcases Finset.mem_union.mp hδ₂ with h₂R | h₂M
          · exact (C.cross δ₂ h₂R δ₁ h₁M
              (by
                intro h
                exact hne h.symm)).symm
          · exact C.remnant.compat δ₁ h₁M δ₂ h₂M hne)

/-- Representative quotient-side forest paired with the genuine-forest outer
splice. -/
private noncomputable def forestComponentForestChoiceRepQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceQuotientCertificate g q hq) :
    AdmissibleSubgraph
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestOuterActualToRepAdmissibleSubgraph g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentForestChoiceActualQuotientSubgraph g q hq C)

/-- Canonical actual quotient-side forest paired with the genuine-forest outer
splice. -/
private noncomputable def forestComponentForestChoiceActualQuotientSubgraphCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    AdmissibleSubgraph
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceActualQuotientSubgraph g q hq
    (forestComponentForestChoiceQuotientCertificateCanonical g q hq)

@[simp] private theorem
    forestComponentForestChoiceActualQuotientSubgraphCanonical_elements
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq).elements =
      forestComponentForestChoiceActualQuotientComponents g q hq := rfl

/-- The canonical actual genuine-forest quotient product splits into the
right-selected survivor product and the selected-remnant product. -/
private theorem
    forestComponentForestChoiceActualQuotientSubgraphCanonical_toHopfH_eq_right_mul_remnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq).toHopfH =
      (forestComponentForestChoiceActualRightQuotientSubgraphCanonical
        g q hq).toHopfH *
        (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
          g q hq).toHopfH := by
  classical
  let R := forestComponentForestChoiceActualRightQuotientSubgraphCanonical g q hq
  let M := forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical g q hq
  let Q := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  have hDisj : Disjoint R.elements M.elements := by
    rw [Finset.disjoint_left]
    intro δ hδR hδM
    have hδM' : δ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
      simpa [M] using hδM
    have hSelfDisj : δ.Disjoint δ :=
      forestComponentForestChoiceRightRemnant_disjoint g q hq
        δ (by simpa [R] using hδR) δ hδM'
    have hPos :
        0 < δ.internalEdges.card :=
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents
        g q hq δ (by simpa [R] using hδR)
    rcases Multiset.exists_mem_of_ne_zero (Multiset.card_pos.mp hPos) with
      ⟨e, he⟩
    have hsupp := δ.edges_supported e he
    simp [FeynmanEdge.SupportedOn] at hsupp
    exact (Finset.disjoint_left.mp hSelfDisj hsupp.1) hsupp.1
  unfold AdmissibleSubgraph.toHopfH
  rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
  unfold forestComponentForestChoiceActualQuotientComponents
  rw [Finset.prod_union (by simpa [R, M] using hDisj)]
  congr 1
  · apply Finset.prod_congr rfl
    intro δ hδ
    unfold AdmissibleSubgraph.componentToHopfH
    have hδQ :
        δ ∈ (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq).elements := by
      rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
      unfold forestComponentForestChoiceActualQuotientComponents
      exact Finset.mem_union_left _ hδ
    rw [dif_pos hδQ, dif_pos hδ]
  · rw [forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical_elements]
    apply Finset.prod_congr rfl
    intro δ hδ
    unfold AdmissibleSubgraph.componentToHopfH
    have hδQ :
        δ ∈ (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq).elements := by
      rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
      unfold forestComponentForestChoiceActualQuotientComponents
      exact Finset.mem_union_right _ hδ
    have hδM :
        δ ∈ (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
          g q hq).elements := by
      simpa using hδ
    rw [dif_pos hδQ, dif_pos hδM]

/-- The canonical genuine-forest quotient-side forest is nonempty: a genuine
component-forest choice contributes at least one remnant component. -/
private theorem forestComponentForestChoiceActualQuotientSubgraphCanonical_isNonempty
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq).IsNonempty := by
  classical
  have hpForest : q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hHasForest : forestComponentChoiceHasForest q.1.1 q.2 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
  rcases hHasForest with ⟨γ, B, hB⟩
  refine ⟨admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ.1, ?_⟩
  change admissibleSubgraphQuotientRemainderSubgraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph
        (forestComponentForestChoiceOuterIndex g q hq).1
        (forestComponentForestChoiceOuterIndex g q hq).2)
      γ.1 ∈ forestComponentForestChoiceActualQuotientComponents g q hq
  unfold forestComponentForestChoiceActualQuotientComponents
  exact Finset.mem_union_right _
    (forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq γ hB)

/-- Every component of the canonical genuine-forest quotient-side forest has
a nonempty vertex carrier. -/
private theorem
    forestComponentForestChoiceActualQuotientSubgraphCanonical_hasNonemptyComponents
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
      ).HasNonemptyComponents := by
  classical
  intro δ hδ
  change δ ∈ forestComponentForestChoiceActualQuotientComponents g q hq at hδ
  unfold forestComponentForestChoiceActualQuotientComponents at hδ
  rcases Finset.mem_union.mp hδ with hRight | hRemnant
  · rcases
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_mem_exists
        g q hq hRight with
      ⟨γ, rfl⟩
    have hSourceNonempty : γ.1.IsNonempty :=
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
        q.1.2 γ.1
        (forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 γ.2)
    unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hSourceNonempty ⊢
    change 0 <
      (γ.1.vertices.image
        ((forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2))).card
    rcases Finset.card_pos.mp hSourceNonempty with ⟨v, hv⟩
    exact Finset.card_pos.mpr
      ⟨(forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2) v,
        Finset.mem_image.mpr ⟨v, hv, rfl⟩⟩
  · rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hRemnant with
      ⟨γ, B, hB, rfl⟩
    have hSourceNonempty : γ.1.IsNonempty :=
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
        q.1.2 γ.1 γ.2
    unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hSourceNonempty ⊢
    rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
    rcases Finset.card_pos.mp hSourceNonempty with ⟨v, hv⟩
    exact Finset.card_pos.mpr
      ⟨(forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2) v,
        Finset.mem_image.mpr ⟨v, hv, rfl⟩⟩

/-- The canonical genuine-forest quotient-side forest is pairwise
vertex-disjoint. -/
private theorem
    forestComponentForestChoiceActualQuotientSubgraphCanonical_isPairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
      ).IsPairwiseDisjoint := by
  classical
  intro δ₁ hδ₁ δ₂ hδ₂ hne
  change δ₁ ∈ forestComponentForestChoiceActualQuotientComponents g q hq
    at hδ₁
  change δ₂ ∈ forestComponentForestChoiceActualQuotientComponents g q hq
    at hδ₂
  unfold forestComponentForestChoiceActualQuotientComponents at hδ₁ hδ₂
  rcases Finset.mem_union.mp hδ₁ with h₁R | h₁M
  · rcases Finset.mem_union.mp hδ₂ with h₂R | h₂M
    · exact
        forestComponentForestChoiceActualRightQuotientSubgraphCanonical_isPairwiseDisjoint
          g q hq h₁R h₂R hne
    · exact
        forestComponentForestChoiceRightRemnant_disjoint g q hq
          δ₁ h₁R δ₂ h₂M
  · rcases Finset.mem_union.mp hδ₂ with h₂R | h₂M
    · exact
        (forestComponentForestChoiceRightRemnant_disjoint g q hq
          δ₂ h₂R δ₁ h₁M).symm
    · exact
        forestComponentForestChoiceRemnantComponents_disjoint g q hq
          δ₁ h₁M δ₂ h₂M hne

/-- The residual positivity payload for the genuine-forest quotient carrier:
each component-forest remnant `γ / B` must retain a positive internal-edge
carrier in the quotient. -/
private structure forestComponentForestChoiceRemnantPositiveComponentsCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  positive :
    ∀ δ, δ ∈ forestComponentForestChoiceRemnantComponents g q hq →
      0 < δ.internalEdges.card

/-- Source-side form of the remnant positivity payload: whenever a component
choice is genuinely a forest, the internal edges left after removing the
outer splice are nonempty. -/
private structure forestComponentForestChoiceRemnantSourcePositiveCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  positive :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        0 < (γ.1.internalEdges -
          (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges).card

/-- Witness form of source-side remnant positivity: for every genuine component
forest choice, exhibit one internal edge that survives outside the outer splice. -/
private structure forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  edge :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        FeynmanEdge
  edge_mem :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        ∀ hB : q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B,
        edge γ B hB ∈
          (γ.1.internalEdges -
            (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges)

/-- A source-edge witness gives the cardinal positivity certificate. -/
private def
    forestComponentForestChoiceRemnantSourcePositiveCertificateOfEdgeWitness
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate
      g q hq) :
    forestComponentForestChoiceRemnantSourcePositiveCertificate g q hq where
  positive := by
    intro γ B hB
    exact Multiset.card_pos_iff_exists_mem.mpr
      ⟨C.edge γ B hB, C.edge_mem γ B hB⟩

/-- The quotient-remnant positivity certificate follows from the source-side
nonempty complement certificate because the quotient remnant only retargets
that complement by a vertex map. -/
private def
    forestComponentForestChoiceRemnantPositiveComponentsCertificateOfSource
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantSourcePositiveCertificate
      g q hq) :
    forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq where
  positive := by
    intro δ hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists
      g q hq hδ with ⟨γ, B, hB, rfl⟩
    simpa [admissibleSubgraphQuotientRemainderSubgraph_internalEdges]
      using C.positive γ B hB

/-- Component-quotient graph form of remnant positivity: each genuine
component-forest choice leaves a component quotient with a positive
internal-edge carrier. -/
private structure
    forestComponentForestChoiceComponentRemnantPositiveCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  positive :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        0 < (forestComponentForestChoiceComponentRemnantGraph
          g q hq γ B).internalEdges.card

/-- The component-quotient graph positivity certificate supplies the
source-side complement positivity certificate via the canonical literal
internal-edge identification of the retargeted remnant graph. -/
private def
    forestComponentForestChoiceRemnantSourcePositiveCertificateOfComponentGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentRemnantPositiveCertificate
      g q hq) :
    forestComponentForestChoiceRemnantSourcePositiveCertificate g q hq where
  positive := by
    intro γ B hB
    have hGraphPos :
        0 < (forestComponentForestChoiceRetargetedRemnantGraph
          g q hq γ).internalEdges.card := by
      rw [forestComponentForestChoiceRemnantGraph_internalEdges_eq
        g q hq γ hB]
      exact C.positive γ B hB
    simpa [forestComponentForestChoiceRetargetedRemnantGraph_internalEdges]
      using hGraphPos

/-- Component-local complement form of remnant positivity: in every genuine
component-forest choice, the transported component forest leaves at least one
internal edge outside the selected inner forest. -/
private structure
    forestComponentForestChoiceComponentComplementPositiveCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  positive :
    ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        q.2 γ (Finset.mem_attach q.1.1.elements γ) =
          forestCoproductChoice.forest B →
        0 < (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B).complementEdges.card

/-- The strict forest-choice carrier supplies component-local complement
positivity canonically. -/
private def
    forestComponentForestChoiceComponentComplementPositiveCertificateCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq where
  positive := by
    intro γ B hB
    have hpForest :
        q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    have hpCore :
        q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
    have hRepPos :
        0 < B.complementEdges.card :=
      forestComponentChoice_forest_complementEdges_positive_of_core_mem
        hpCore γ hB
    have hcard :
        (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
          (q.1.1.isConnectedDivergent_of_mem γ.2) B
        ).complementEdges.card = B.complementEdges.card := by
      have hmap :=
        mapPermAdmissibleSubgraphPreimage_complementEdges_map
          (feynmanSubgraphToHopfGenRepPerm_spec γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2)) B
      have hcardMap := congrArg Multiset.card hmap
      simpa [feynmanSubgraphRepToComponentAdmissibleSubgraph] using hcardMap
    rw [hcard]
    exact hRepPos

/-- Component complement positivity gives positivity of the component quotient
graph because quotient internal edges are exactly the retargeted complement
edges. -/
private def
    forestComponentForestChoiceComponentRemnantPositiveCertificateOfComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq) :
    forestComponentForestChoiceComponentRemnantPositiveCertificate g q hq where
  positive := by
    intro γ B hB
    simpa [forestComponentForestChoiceComponentRemnantGraph_internalEdges]
      using C.positive γ B hB

/-- Component-complement positivity contains exactly the edge data needed by
the source-edge witness form: choose one edge from the component complement and
transport it back through the literal source/remnant complement identity. -/
private theorem
    forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
        γ ∈ q.1.1.elements})
    (B : AdmissibleSubgraph
      (repG (γ.1.toHopfGen
        (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph)
    (hB : q.2 γ (Finset.mem_attach q.1.1.elements γ) =
      forestCoproductChoice.forest B) :
    ∃ e : FeynmanEdge,
      e ∈ γ.1.internalEdges -
        (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges := by
  have hpos := C.positive γ B hB
  rcases Multiset.card_pos_iff_exists_mem.mp hpos with ⟨e, he⟩
  refine ⟨e, ?_⟩
  rwa [forestComponentForestChoice_gamma_internalEdges_sub_outer_eq_componentRemnant_complementEdges
    g q hq γ hB]

/-- Component-complement positivity supplies the source-edge witness
certificate by choosing a surviving complement edge in each genuine
component-forest case. -/
private noncomputable def
    forestComponentForestChoiceRemnantSourceEdgeWitnessCertificateOfComponentComplement
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceComponentComplementPositiveCertificate
      g q hq) :
    forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq where
  edge := fun γ B hB =>
    Classical.choose
      (forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
        g q hq C γ B hB)
  edge_mem := by
    intro γ B hB
    exact Classical.choose_spec
      (forestComponentForestChoice_remnant_sourceEdge_exists_of_componentComplement
        g q hq C γ B hB)

/-- Positive internal edges for the full genuine-forest quotient carrier
reduce to the remnant positivity payload; right-selected survivors are
canonical. -/
private theorem
    forestComponentForestChoiceActualQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents_of_remnantPositive
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
      ).HasPositiveInternalEdgesComponents := by
  intro δ hδ
  change δ ∈ forestComponentForestChoiceActualQuotientComponents g q hq
    at hδ
  unfold forestComponentForestChoiceActualQuotientComponents at hδ
  rcases Finset.mem_union.mp hδ with hRight | hRemnant
  · exact
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents
        g q hq δ hRight
  · exact C.positive δ hRemnant

/-- The remaining properness data for the genuine-forest quotient carrier.
Nonemptiness, component nonemptiness, and pairwise disjointness are canonical;
the residual hard fact is positive internal edges for every quotient-side
component. -/
private structure forestComponentForestChoiceActualQuotientProperCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) : Type where
  positiveComponents :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
      ).HasPositiveInternalEdgesComponents

/-- Build the genuine-forest quotient properness certificate from the exact
remaining remnant-positive payload. -/
private noncomputable def
    forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    forestComponentForestChoiceActualQuotientProperCertificate g q hq where
  positiveComponents :=
    forestComponentForestChoiceActualQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents_of_remnantPositive
      g q hq C

/-- A genuine-forest quotient properness certificate places the canonical
actual quotient forest in the actual RHS proper carrier. -/
private theorem forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceActualQuotientProperCertificate g q hq) :
    forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq ∈
      (forestOuterActualQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)
      ).properDisjointAdmissibleDivergentSubgraphs := by
  classical
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let A := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  rw [Q.mem_properDisjointAdmissibleDivergentSubgraphs]
  have hNonempty : A.IsNonempty :=
    forestComponentForestChoiceActualQuotientSubgraphCanonical_isNonempty g q hq
  have hNonemptyComponents : A.HasNonemptyComponents :=
    forestComponentForestChoiceActualQuotientSubgraphCanonical_hasNonemptyComponents
      g q hq
  have hPairwise : A.IsPairwiseDisjoint :=
    forestComponentForestChoiceActualQuotientSubgraphCanonical_isPairwiseDisjoint
      g q hq
  refine ⟨?_, hNonemptyComponents, ?_, C.positiveComponents⟩
  · rw [Q.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
      Q.mem_disjointAdmissibleDivergentSubgraphs]
    exact ⟨⟨Q.mem_admissibleDivergentSubgraphs A, hPairwise⟩,
      hNonempty⟩
  · exact admissibleSubgraph_internalEdges_card_pos_of_hasPositive_component
      C.positiveComponents hNonempty

/-- Canonical representative quotient-side forest paired with the
genuine-forest outer splice. -/
private noncomputable def forestComponentForestChoiceRepQuotientSubgraphCanonical
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    AdmissibleSubgraph
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)) :=
  forestComponentForestChoiceRepQuotientSubgraph g q hq
    (forestComponentForestChoiceQuotientCertificateCanonical g q hq)

/-- A genuine-forest quotient properness certificate also places the
representative quotient forest in the RHS proper carrier. -/
private theorem forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceActualQuotientProperCertificate g q hq) :
    forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq ∈
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)
      ).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterActualToRepAdmissibleSubgraph_mem_properDisjoint g
    (forestComponentForestChoiceOuterIndex g q hq)
    (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
      g q hq C)

/-- The canonical representative genuine-forest quotient lands in the RHS
proper carrier from the exact remnant-positivity payload. -/
private theorem
    forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq ∈
      (forestOuterQuotientGraph g
        (forestComponentForestChoiceOuterIndex g q hq)
      ).properDisjointAdmissibleDivergentSubgraphs :=
  forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint
    g q hq
    (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
      g q hq C)

/-- Transporting the full genuine-forest quotient-side forest from the actual
quotient graph to its representative preserves the Hopf product. -/
private theorem
    forestComponentForestChoiceRepQuotientSubgraphCanonical_toHopfH_eq_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq
      ).toHopfH =
        (forestComponentForestChoiceActualQuotientSubgraphCanonical
          g q hq).toHopfH := by
  unfold forestComponentForestChoiceRepQuotientSubgraphCanonical
    forestComponentForestChoiceRepQuotientSubgraph
    forestOuterActualToRepAdmissibleSubgraph
    forestComponentForestChoiceActualQuotientSubgraphCanonical
    forestComponentForestChoiceActualQuotientSubgraph
  rw [mapPermAdmissibleSubgraph_toHopfH]

/-- The representative genuine-forest quotient product splits into the
right-selected survivor product and the selected-remnant product. -/
private theorem
    forestComponentForestChoiceRepQuotientSubgraphCanonical_toHopfH_eq_right_mul_remnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq).toHopfH =
      (forestComponentForestChoiceRepRightQuotientSubgraphCanonical
        g q hq).toHopfH *
        (forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical
          g q hq).toHopfH := by
  rw [forestComponentForestChoiceRepQuotientSubgraphCanonical_toHopfH_eq_actual]
  rw [forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq_actual]
  rw [forestComponentForestChoiceRepRemnantQuotientSubgraphCanonical_toHopfH_eq_actual]
  exact
    forestComponentForestChoiceActualQuotientSubgraphCanonical_toHopfH_eq_right_mul_remnant
      g q hq

/-- A genuine-forest right-factor class equality can be proved on the actual
quotient graph and then transported to the chosen quotient representative. -/
private theorem forestComponentForestChoice_rightContractClass_of_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq)
    (hActual :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (forestOuterActualQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq))
        (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentForestChoiceOuterIndex g q hq))
          (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
          (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C)))).toClass) :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG (forestOuterQuotientHopfGen g
          (forestComponentForestChoiceOuterIndex g q hq))).toFeynmanGraph
        (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG (forestOuterQuotientHopfGen g
            (forestComponentForestChoiceOuterIndex g q hq))).toFeynmanGraph
          (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
          (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
            g q hq C))).toClass := by
  calc
    (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (forestOuterActualQuotientGraph g
            (forestComponentForestChoiceOuterIndex g q hq))
          (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (forestOuterActualQuotientGraph g
              (forestComponentForestChoiceOuterIndex g q hq))
            (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq)
            (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
              g q hq
              (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
                g q hq C)))).toClass := hActual
    _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (forestOuterQuotientHopfGen g
            (forestComponentForestChoiceOuterIndex g q hq))).toFeynmanGraph
          (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (forestOuterQuotientHopfGen g
              (forestComponentForestChoiceOuterIndex g q hq))).toFeynmanGraph
            (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
            (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
              g q hq C))).toClass := by
          simpa [forestComponentForestChoiceRepQuotientSubgraphCanonical,
            forestComponentForestChoiceRepQuotientSubgraph,
            forestOuterQuotientGraph] using
            forestOuterActualToRep_rightContractClass g
              (forestComponentForestChoiceOuterIndex g q hq)
              (forestComponentForestChoiceActualQuotientSubgraphCanonical
                g q hq)
              (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
                g q hq
                (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
                  g q hq C))

