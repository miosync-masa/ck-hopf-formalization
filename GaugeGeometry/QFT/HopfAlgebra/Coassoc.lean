/-
Deprecated connected-only route.

The block below was the original proper-connected-subgraph coassociativity
attempt.  It is intentionally no longer compiled: the active H5.8F proof above
uses the admissible-forest `φ` reindexing route, while this older route stops
at the star-free RHS obstruction noted at the end of the block.  Keeping it in
one comment preserves the design record without making the elaborator revisit
the obsolete tensor expansions.

/-! ### Stage 3a-i — LHS expand

The LHS is `assoc ((Δ ⊗ id) (Δ (X g)))`. Stage 2's expand of `Δ(X g)`
gives 3 terms; distributing `(Δ ⊗ id)` and `assoc` and re-expanding the
inner `Δ` produces 7 distinct shapes:

```
(a) X g ⊗ (1 ⊗ 1)                                    — pure boundary
(b) 1 ⊗ (X g ⊗ 1)                                    — pure boundary
(c) Σ_γ [γ] ⊗ ([Γ/γ] ⊗ 1)                            — sum × right-1
(d) 1 ⊗ (1 ⊗ X g)                                    — pure boundary (from Δ(1))
(e₁) Σ_γ [γ] ⊗ (1 ⊗ [Γ/γ])                           — Δ([γ])-boundary 1
(e₂) Σ_γ 1 ⊗ ([γ] ⊗ [Γ/γ])                           — Δ([γ])-boundary 2
(e₃) Σ_γ Σ_{γ'⊊γ} [γ'] ⊗ ([γ/γ'] ⊗ [Γ/γ])           — main double sum (Stage 3b target)
```

We collect (a)+(b)+(d) as the 3 pure boundaries. (c)+(e₁)+(e₂) are
"mixed" boundary-times-sum terms. (e₃) is the only doubly-indexed sum. -/

/-! #### Per-term abbreviations to avoid `if-then-else` parsing ambiguity

Each of the 6 LHS shapes is given a private name. The full LHS is then
their sum, written with explicit grouping. -/

/-- (a) Pure `X g ⊗ (1 ⊗ 1)`. -/
private noncomputable def termA (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH))

/-- (b) Pure `1 ⊗ (X g ⊗ 1)`. -/
private noncomputable def termB (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (1 : HopfH) ⊗ₜ[ℚ] ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))

/-- (d) Pure `1 ⊗ (1 ⊗ X g)`. -/
private noncomputable def termD (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  (1 : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))

/-- (c) Mixed `Σ_γ [γ] ⊗ ([Γ/γ] ⊗ 1)`. -/
private noncomputable def termC (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
        ((gen (γ.contractToHopfGen
          (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe) : HopfH) ⊗ₜ[ℚ] (1 : HopfH)))
    else 0

/-- (e) Aggregate of (e₁)+(e₂)+(e₃): the part of the LHS where the
inner `Δ` was applied to `[γ]` (left factor). Kept as
`Σ_γ assoc (Δ([γ]) ⊗ [Γ/γ])` for now; further expanded in later stages. -/
private noncomputable def termE (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((coproduct_strict (gen (γ.toHopfGen hγ.1))) ⊗ₜ[ℚ]
          (gen (γ.contractToHopfGen
            (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe)))
    else 0

/-- LHS expand — sum of 5 per-term components. -/
private theorem coassoc_LHS_eq (g : HopfGen) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((Algebra.TensorProduct.map coproduct_strict (AlgHom.id ℚ HopfH))
          (coproduct_strict (MvPolynomial.X g))) =
      termA g + termB g + termC g + termD g + termE g := by
  -- Step 1: expand Δ(X g) once via Stage 2.
  rw [coproduct_strict_X_eq g]
  -- Step 2: distribute (map Δ id) and assoc through the additive structure.
  simp only [map_add, Algebra.TensorProduct.map_tmul, AlgHom.coe_id, id_eq,
    map_one, map_sum]
  -- Step 3: expand Δ(X g) (left-most term) once more via Stage 2,
  -- then distribute (· ⊗ 1) through the inner +.
  rw [coproduct_strict_X_eq g]
  simp only [TensorProduct.add_tmul, TensorProduct.sum_tmul, map_add, map_sum]
  -- Step 4: split Δ(1) ⊗ X g via one_def.
  rw [show ((1 : HopfH ⊗[ℚ] HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
        = ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH) from by
      rw [Algebra.TensorProduct.one_def]]
  -- Step 5: rewrite the (c)-style sum's body via Finset.sum_congr +
  -- assoc_tmul + if-zero handling. The first sum gets `(...)⊗1` form;
  -- the second sum keeps its `(map Δ id) (...)` form (becomes termE).
  rw [show (∑ x ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((if hγ : x.IsConnectedDivergent ∧ 0 < x.internalEdges.card then
              (gen (x.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
                (gen (x.contractToHopfGen
                  (repG_wellFormed g) (repG_isOnePI g) hγ.1
                  (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2)))
            else 0) ⊗ₜ[ℚ] (1 : HopfH))) = termC g from ?cEq]
  case cEq =>
    unfold termC
    apply Finset.sum_congr rfl
    intro x _
    split_ifs with hγ
    · exact Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _
    · simp [TensorProduct.zero_tmul]
  -- The remaining second sum is exactly termE.
  rw [show (∑ x ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
          ((Algebra.TensorProduct.map coproduct_strict (AlgHom.id ℚ HopfH))
            (if h : x.IsConnectedDivergent ∧ 0 < x.internalEdges.card then
              (gen (x.toHopfGen h.1) : HopfH) ⊗ₜ[ℚ]
                gen (x.contractToHopfGen
                  (repG_wellFormed g) (repG_isOnePI g) h.1
                  (FeynmanSubgraph.isNonempty_of_internalEdges_pos h.2))
            else 0))) = termE g from ?eEq]
  case eEq =>
    unfold termE
    apply Finset.sum_congr rfl
    intro x _
    split_ifs with hγ
    · simp [Algebra.TensorProduct.map_tmul]
    · simp
  -- Apply assoc_tmul on the three pure-tmul boundaries.
  -- The two pure-tmul reductions are:
  --   assoc (X g ⊗ 1 ⊗ 1) = X g ⊗ (1 ⊗ 1)  = termA g
  --   assoc (1 ⊗ X g ⊗ 1) = 1 ⊗ (X g ⊗ 1)  = termB g
  --   assoc (1 ⊗ 1 ⊗ X g) = 1 ⊗ (1 ⊗ X g)  = termD g
  unfold termA termB termD
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) =
      (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) =
      (1 : HopfH) ⊗ₜ[ℚ] ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]
  rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH)) =
      (1 : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X g : HopfH))
      from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
        (A := HopfH) (C := HopfH) (D := HopfH) _ _ _]

/-! ### Stage 3a-ii — RHS expand

The RHS is `(map id Δ) (Δ (X g))`. Stage 2's expand of `Δ(X g)` gives
3 terms; distributing `(map id Δ)` produces:

```
(a') X g ⊗ Δ(1) = X g ⊗ (1 ⊗ 1)                         = termA g
(b') 1 ⊗ Δ(X g) = 1 ⊗ (X g ⊗ 1 + 1 ⊗ X g + Σ_γ [γ] ⊗ [Γ/γ])
   = 1 ⊗ (X g ⊗ 1)                                       = termB g
   + 1 ⊗ (1 ⊗ X g)                                       = termD g
   + Σ_γ 1 ⊗ ([γ] ⊗ [Γ/γ])                              = termE2 g
(f') Σ_γ [γ] ⊗ Δ([Γ/γ])                                  = termF g  (Stage 3b target)
```

So `RHS = termA g + termB g + termD g + termE2 g + termF g`.

Note: LHS's termC (= Σ [γ] ⊗ ([Γ/γ] ⊗ 1)) and termE1 (= Σ [γ] ⊗ (1 ⊗ [Γ/γ]))
are **inside** termF g (after expanding Δ([Γ/γ]) once). The bijection
in Stage 3b/3c reorganizes termF to match LHS's termC + termE1 + (e₃). -/

/-- (e₂ from LHS, also second-level term for RHS) `Σ_γ 1 ⊗ ([γ] ⊗ [Γ/γ])`. -/
private noncomputable def termE2 (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      ((1 : HopfH) ⊗ₜ[ℚ]
        ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
          (gen (γ.contractToHopfGen
            (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe) : HopfH)))
    else 0

/-- (f') `Σ_γ [γ] ⊗ Δ([Γ/γ])` — RHS-only aggregate, expanded later. -/
private noncomputable def termF (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
        (coproduct_strict (gen (γ.contractToHopfGen
          (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe))))
    else 0

/-- RHS expand — sum of 5 per-term components. -/
private theorem coassoc_RHS_eq (g : HopfGen) :
    (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict)
        (coproduct_strict (MvPolynomial.X g)) =
      termA g + termB g + termD g + termE2 g + termF g := by
  -- Step 1: expand Δ(X g) once via Stage 2.
  rw [coproduct_strict_X_eq g]
  -- Step 2: distribute (map id Δ) through the additive structure.
  simp only [map_add, Algebra.TensorProduct.map_tmul, AlgHom.coe_id, id_eq,
    map_one, map_sum]
  -- Now we have:
  --   (X g ⊗ Δ(1)) + (1 ⊗ Δ(X g)) + Σ_γ if hγ then [γ] ⊗ Δ([Γ/γ]) else 0
  -- = (X g ⊗ 1) + (1 ⊗ Δ(X g)) + termF g (the last is termF after if-zero handling)
  -- where Δ(1) = 1.
  -- Step 3: expand the inner Δ(X g) (in 1 ⊗ Δ(X g)) via Stage 2.
  rw [coproduct_strict_X_eq g]
  -- Now: (X g ⊗ 1) + (1 ⊗ (X g ⊗ 1 + 1 ⊗ X g + Σ_γ ...)) + Σ_γ [γ] ⊗ Δ([Γ/γ])
  -- Distribute (1 ⊗ ·) through the inner +.
  simp only [TensorProduct.tmul_add, TensorProduct.tmul_sum, map_add, map_sum]
  -- Step 4: split (X g ⊗ 1) where the "1" is in HopfH ⊗ HopfH; it should be 1 ⊗ 1.
  rw [show ((MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] (1 : HopfH ⊗[ℚ] HopfH))
        = (MvPolynomial.X g : HopfH) ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] (1 : HopfH)) from by
      rw [Algebra.TensorProduct.one_def]]
  -- Step 5: handle the (e₂) sum: `Σ if hγ then 1 ⊗ ([γ] ⊗ [Γ/γ]) else 0` = termE2 g
  rw [show (∑ x ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        ((1 : HopfH) ⊗ₜ[ℚ]
          (if hγ : x.IsConnectedDivergent ∧ 0 < x.internalEdges.card then
              (gen (x.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
                gen (x.contractToHopfGen
                  (repG_wellFormed g) (repG_isOnePI g) hγ.1
                  (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2))
            else 0))) = termE2 g from ?e2Eq]
  case e2Eq =>
    unfold termE2
    apply Finset.sum_congr rfl
    intro x _
    split_ifs with hγ
    · rfl
    · simp [TensorProduct.tmul_zero]
  -- Step 6: handle the (f) sum: `Σ if hγ then [γ] ⊗ Δ([Γ/γ]) else 0` = termF g
  rw [show (∑ x ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        (Algebra.TensorProduct.map (AlgHom.id ℚ HopfH) coproduct_strict)
          (if h : x.IsConnectedDivergent ∧ 0 < x.internalEdges.card then
              (gen (x.toHopfGen h.1) : HopfH) ⊗ₜ[ℚ]
                gen (x.contractToHopfGen
                  (repG_wellFormed g) (repG_isOnePI g) h.1
                  (FeynmanSubgraph.isNonempty_of_internalEdges_pos h.2))
            else 0)) = termF g from ?fEq]
  case fEq =>
    unfold termF
    apply Finset.sum_congr rfl
    intro x _
    split_ifs with hγ
    · simp [Algebra.TensorProduct.map_tmul]
    · simp
  -- Now both sides are sums of identical shapes.
  unfold termA termB termD
  abel

/-! ### Stage 3a-iii — termE and termF further expansion

`termE g = Σ_γ assoc (Δ([γ]) ⊗ [Γ/γ])` — expand Δ([γ]) once more.
`termF g = Σ_γ [γ] ⊗ Δ([Γ/γ])` — expand Δ([Γ/γ]) once more.

Each yields 3 sub-terms. Several are duplicates between LHS/RHS,
allowing cancellation; the genuine bijection lives only in the
double-sum termE3 ↔ termF3 part. -/

/-- (e₁) `Σ_γ [γ] ⊗ (1 ⊗ [Γ/γ])`. Symmetric to termE2. -/
private noncomputable def termE1 (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
        ((1 : HopfH) ⊗ₜ[ℚ]
          (gen (γ.contractToHopfGen
            (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe) : HopfH)))
    else 0

/-- (e₃) Double sum: `Σ_γ Σ_{γ'⊊γ} [γ'] ⊗ ([γ/γ'] ⊗ [Γ/γ])`.
Concretely: the third (sum) part of `coproduct_strict (gen γ.toHopfGen)`
crossed with `[Γ/γ]`, then assoc'd. -/
private noncomputable def termE3 (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
        ((coproduct_strict (gen (γ.toHopfGen hγ.1))
          - (gen (γ.toHopfGen hγ.1) ⊗ₜ[ℚ] (1 : HopfH))
          - ((1 : HopfH) ⊗ₜ[ℚ] gen (γ.toHopfGen hγ.1))) ⊗ₜ[ℚ]
          (gen (γ.contractToHopfGen
            (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe) : HopfH))
    else 0

/-- (f₃) Double sum: `Σ_γ Σ_{γ''⊊Γ/γ} [γ] ⊗ ([γ''] ⊗ [(Γ/γ)/γ''])`.
Concretely: `[γ]` crossed with the sum part of `coproduct_strict (gen γ.contractToHopfGen)`. -/
private noncomputable def termF3 (g : HopfGen) : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
    if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
      let hγNe : γ.IsNonempty :=
        FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
      let γc := γ.contractToHopfGen
        (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe
      ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
        (coproduct_strict (gen γc)
          - ((gen γc : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
          - ((1 : HopfH) ⊗ₜ[ℚ] (gen γc : HopfH))))
    else 0

/-- Stage 3a-iii: termE expand into termE1 + termE2 + termE3. -/
private theorem termE_eq (g : HopfGen) :
    termE g = termE1 g + termE2 g + termE3 g := by
  unfold termE termE1 termE2 termE3
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro γ _
  split_ifs with hγ
  · -- For each γ: assoc (Δ([γ]) ⊗ [Γ/γ]) = (e₁) + (e₂) + (e₃) per γ.
    -- Eliminate the let-binding `hγNe` (zeta-reduce) and abbreviate
    -- the two recurring `gen` values without using `set` (which doesn't
    -- traverse `have`-bindings reliably here).
    simp only []
    -- Now both sides are uniform; use linearity of assoc + sub_tmul
    -- to absorb the subtraction term and apply assoc_tmul on each piece.
    rw [show ∀ X : HopfH ⊗[ℚ] HopfH, ∀ a c : HopfH,
          (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
            ((X - (a ⊗ₜ[ℚ] (1 : HopfH)) - ((1 : HopfH) ⊗ₜ[ℚ] a)) ⊗ₜ[ℚ] c) =
          (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom (X ⊗ₜ[ℚ] c)
            - (a ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] c))
            - ((1 : HopfH) ⊗ₜ[ℚ] (a ⊗ₜ[ℚ] c)) from ?subAux]
    case subAux =>
      intro X a c
      rw [TensorProduct.sub_tmul, TensorProduct.sub_tmul, map_sub, map_sub]
      -- After sub distribution, the remaining `assoc (a ⊗ 1 ⊗ c)` and
      -- `assoc (1 ⊗ a ⊗ c)` reduce by assoc_tmul.
      rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
            (a ⊗ₜ[ℚ] (1 : HopfH) ⊗ₜ[ℚ] c) = a ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] c)
          from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
            (A := HopfH) (C := HopfH) (D := HopfH) a 1 c]
      rw [show (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
            ((1 : HopfH) ⊗ₜ[ℚ] a ⊗ₜ[ℚ] c) = (1 : HopfH) ⊗ₜ[ℚ] (a ⊗ₜ[ℚ] c)
          from Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
            (A := HopfH) (C := HopfH) (D := HopfH) 1 a c]
    abel
  · simp

/-- Stage 3a-iii: termF expand into termC + termE1 + termF3. -/
private theorem termF_eq (g : HopfGen) :
    termF g = termC g + termE1 g + termF3 g := by
  unfold termF termC termE1 termF3
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro γ _
  split_ifs with hγ
  · -- Goal: a ⊗ coproduct_strict c =
    --        (a ⊗ (c ⊗ 1)) + (a ⊗ (1 ⊗ c))
    --      + (a ⊗ (coproduct_strict c - c ⊗ 1 - 1 ⊗ c))
    -- by tmul-linearity in the right factor.
    simp only []
    rw [show ∀ a c : HopfH,
          (a ⊗ₜ[ℚ] (coproduct_strict c -
              (c ⊗ₜ[ℚ] (1 : HopfH)) - ((1 : HopfH) ⊗ₜ[ℚ] c))
            : HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH)) =
          (a ⊗ₜ[ℚ] coproduct_strict c)
            - (a ⊗ₜ[ℚ] (c ⊗ₜ[ℚ] (1 : HopfH)))
            - (a ⊗ₜ[ℚ] ((1 : HopfH) ⊗ₜ[ℚ] c)) from ?subAux]
    case subAux =>
      intro a c
      rw [TensorProduct.tmul_sub, TensorProduct.tmul_sub]
    abel
  · simp

/-! ### Stage 3b — termE3 and termF3 inner-sum expansion

We expand the inner `coproduct_strict (gen ...)` in both termE3 and
termF3 via `coproduct_strict_X_eq`, removing boundary terms and
exposing the genuine double-sum structure.

The result is two double sums indexed by chains `(γ_outer, γ_inner)`
that turn out to be in bijection (Stage 3b proper). -/

/-- Helper: the sum part of `coproduct_strict (X h)`, i.e.
`coproduct_strict (X h) - (X h ⊗ 1) - (1 ⊗ X h)`. By Stage 2 this
equals the proper-divergent-subgraph sum. -/
private noncomputable def coproductGen_sumPart (h : HopfGen) : HopfH ⊗[ℚ] HopfH :=
  coproduct_strict (MvPolynomial.X h)
    - ((MvPolynomial.X h : HopfH) ⊗ₜ[ℚ] (1 : HopfH))
    - ((1 : HopfH) ⊗ₜ[ℚ] (MvPolynomial.X h : HopfH))

/-- The `coproductGen_sumPart` equals the proper-divergent-subgraph sum. -/
private theorem coproductGen_sumPart_eq (h : HopfGen) :
    coproductGen_sumPart h =
      ∑ γ ∈ (repG h).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
          let hγNe : γ.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
          (gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
            (gen (γ.contractToHopfGen
              (repG_wellFormed h) (repG_isOnePI h) hγ.1 hγNe) : HopfH)
        else 0 := by
  unfold coproductGen_sumPart
  rw [coproduct_strict_X_eq h]
  abel

/-- termE3 expanded as a sum over `γ_outer` of `gen γ` is replaced by
`coproductGen_sumPart`-driven inner sum. -/
private theorem termE3_eq_sumPart (g : HopfGen) :
    termE3 g =
      ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
          let hγNe : γ.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
          (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
            ((coproductGen_sumPart (γ.toHopfGen hγ.1)) ⊗ₜ[ℚ]
              (gen (γ.contractToHopfGen
                (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe) : HopfH))
        else 0 := by
  unfold termE3 coproductGen_sumPart
  apply Finset.sum_congr rfl
  intro γ _
  split_ifs with hγ
  · -- gen h = MvPolynomial.X h, so coproduct_strict (gen h) = coproduct_strict (X h).
    -- The two formulations are definitionally equal.
    rfl
  · rfl

/-- termF3 expanded analogously. -/
private theorem termF3_eq_sumPart (g : HopfGen) :
    termF3 g =
      ∑ γ ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
          let hγNe : γ.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
          ((gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
            (coproductGen_sumPart (γ.contractToHopfGen
              (repG_wellFormed g) (repG_isOnePI g) hγ.1 hγNe)))
        else 0 := by
  unfold termF3 coproductGen_sumPart
  apply Finset.sum_congr rfl
  intro γ _
  split_ifs with hγ
  · rfl
  · rfl

/-! ### Stage 3b-ii — sigma-form double sums

`termE3` and `termF3` are each rewritten as a sum over a sigma type
`Σ γ_outer ∈ Γ-index, γ_inner ∈ (inner ambient)-index`. The ambients differ:

* termE3: inner ambient is `γ_outer.toFeynmanGraph` (the subgraph itself
  viewed as a graph)
* termF3: inner ambient is `γ_outer.contractToHopfGen.repG` (the
  contracted graph), accessed via `contractToHopfGen`'s representative.

The sigma-form makes the bijection in Stage 3b-iii immediate. -/

/-! Inner-ambient `repG` notation: the inner index for termE3 is
`repG (γ.toHopfGen hγ.1)` (the contracted graph's chosen representative).
This is not literally `γ.toFeynmanGraph` due to `Quotient.out`'s choice. -/

/-- Sigma form of termE3: Σ over (γ_outer, γ_inner) chains. -/
private theorem termE3_sigma_eq (g : HopfGen) :
    termE3 g =
      ∑ γ_outer ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγo : γ_outer.IsConnectedDivergent ∧ 0 < γ_outer.internalEdges.card then
          let hγoNe : γ_outer.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2
          ∑ γ_inner ∈ (repG (γ_outer.toHopfGen hγo.1)).toFeynmanGraph.properConnectedDivergentSubgraphs,
            if hγi : γ_inner.IsConnectedDivergent ∧ 0 < γ_inner.internalEdges.card then
              let hγiNe : γ_inner.IsNonempty :=
                FeynmanSubgraph.isNonempty_of_internalEdges_pos hγi.2
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                (((gen (γ_inner.toHopfGen hγi.1) : HopfH) ⊗ₜ[ℚ]
                  (gen (γ_inner.contractToHopfGen
                    (repG_wellFormed (γ_outer.toHopfGen hγo.1))
                    (repG_isOnePI (γ_outer.toHopfGen hγo.1))
                    hγi.1 hγiNe) : HopfH)) ⊗ₜ[ℚ]
                  (gen (γ_outer.contractToHopfGen
                    (repG_wellFormed g) (repG_isOnePI g) hγo.1 hγoNe) : HopfH))
            else 0
        else 0 := by
  rw [termE3_eq_sumPart]
  apply Finset.sum_congr rfl
  intro γ_outer _
  split_ifs with hγo
  · -- Goal: assoc ((coproductGen_sumPart h_outer) ⊗ c_outer)
  --     = Σ_inner if hγi then assoc (...) else 0
  -- Step: expand sumPart, distribute (· ⊗ c) → sum_tmul, then map_sum.
    simp only []
    rw [coproductGen_sumPart_eq, TensorProduct.sum_tmul, map_sum]
    apply Finset.sum_congr rfl
    intro γ_inner _
    split_ifs with hγi
    · rfl
    · simp [TensorProduct.zero_tmul]
  · rfl

/-- Sigma form of termF3: Σ over (γ_outer, γ_inner_in_quotient) chains. -/
private theorem termF3_sigma_eq (g : HopfGen) :
    termF3 g =
      ∑ γ_outer ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγo : γ_outer.IsConnectedDivergent ∧ 0 < γ_outer.internalEdges.card then
          let hγoNe : γ_outer.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2
          ∑ γ_inner ∈ (repG (γ_outer.contractToHopfGen
              (repG_wellFormed g) (repG_isOnePI g) hγo.1 hγoNe)).toFeynmanGraph.properConnectedDivergentSubgraphs,
            if hγi : γ_inner.IsConnectedDivergent ∧ 0 < γ_inner.internalEdges.card then
              let hγiNe : γ_inner.IsNonempty :=
                FeynmanSubgraph.isNonempty_of_internalEdges_pos hγi.2
              ((gen (γ_outer.toHopfGen hγo.1) : HopfH) ⊗ₜ[ℚ]
                ((gen (γ_inner.toHopfGen hγi.1) : HopfH) ⊗ₜ[ℚ]
                  (gen (γ_inner.contractToHopfGen
                    (repG_wellFormed (γ_outer.contractToHopfGen
                      (repG_wellFormed g) (repG_isOnePI g) hγo.1 hγoNe))
                    (repG_isOnePI (γ_outer.contractToHopfGen
                      (repG_wellFormed g) (repG_isOnePI g) hγo.1 hγoNe))
                    hγi.1 hγiNe) : HopfH)))
            else 0
        else 0 := by
  rw [termF3_eq_sumPart]
  apply Finset.sum_congr rfl
  intro γ_outer _
  split_ifs with hγo
  · simp only []
    rw [coproductGen_sumPart_eq, TensorProduct.tmul_sum]
    apply Finset.sum_congr rfl
    intro γ_inner _
    split_ifs with hγi
    · rfl
    · simp [TensorProduct.tmul_zero]
  · rfl

/-! ### Stage 3b-iii — representative-flexible sumPart equality

`coproductGen_sumPart h` is defined via the chosen representative
`repG h = Quotient.out h.val`. For the bijection in Stage 3b-iv we
need to evaluate it over an arbitrary representative `G` of `h.val`
(specifically `G = γ_outer.toFeynmanGraph` for the outer chain).

The flexibility comes from H4.6's iso-invariance applied at the
sumPart level. We package it as a single representative-flexible
lemma to avoid duplicating the proof for termE3 and termF3.

This pattern will also serve Sprint E's antipode recursion. -/

/-- **Stage 3b-iii core** — `coproductGen_sumPart h` evaluated over an
arbitrary representative `G` of `h.val`. Combines `coproductGen_sumPart_eq`
with iso-invariance (mapPermSubgraph bijection from H4.6 Phase B). -/
private theorem coproductGen_sumPart_eq_amb (h : HopfGen)
    (G : FeynmanGraph) (hWF : G.WellFormed) (hG1PI : G.IsOnePI)
    (hCD : G.IsConnectedDivergent) (hClass : G.toClass = h.val) :
    coproductGen_sumPart h =
      ∑ γ ∈ G.properConnectedDivergentSubgraphs,
        if hγ : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card then
          let hγNe : γ.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ.2
          (gen (γ.toHopfGen hγ.1) : HopfH) ⊗ₜ[ℚ]
            (gen (γ.contractToHopfGen hWF hG1PI hγ.1 hγNe) : HopfH)
        else 0 := by
  -- Step 1: rewrite LHS via coproductGen_sumPart_eq → Σ over (repG h).toFG.
  rw [coproductGen_sumPart_eq h]
  -- Step 2: repG h has class h.val (by repG_toClass h); also hClass : G.toClass = h.val.
  -- So repG h and G are in the same class, hence IsIso.
  have hRepClass : (repG h).toFeynmanGraph.toClass = G.toClass := by
    rw [repG_toClass h, ← hClass]
  have hIso : G.IsIso (repG h).toFeynmanGraph :=
    (FeynmanGraph.toClass_eq_iff G (repG h).toFeynmanGraph).mp hRepClass.symm
  -- Step 3: use mapPermSubgraph from H4.6 to bijectively reindex.
  obtain ⟨π, hπ⟩ := hIso
  -- mapPermSubgraph hπ : FeynmanSubgraph G → FeynmanSubgraph (repG h).toFG
  -- The two index sets correspond bijectively under this map.
  -- We use Finset.sum_bij in the *reverse* direction to match the goal:
  -- Σ over (repG h)-subgraphs = Σ over G-subgraphs (via mapPermSubgraph).
  symm
  apply Finset.sum_bij (fun γ _ => mapPermSubgraph hπ γ)
  · -- maps-into
    intro γ hγ
    exact (mapPermSubgraph_mem_index_iff hπ γ).mpr hγ
  · -- injective: same proof as H4.6 Phase B
    intro γ₁ _ γ₂ _ heq
    apply FeynmanSubgraph.ext_iff.mpr
    have hELInj : Function.Injective (ExternalLeg.map π) := by
      intro ℓ₁ ℓ₂ h
      cases ℓ₁ with
      | mk a₁ s₁ =>
        cases ℓ₂ with
        | mk a₂ s₂ =>
          have hπa : π a₁ = π a₂ := congrArg ExternalLeg.attachedTo h
          have hs : s₁ = s₂ := congrArg ExternalLeg.sector h
          have : a₁ = a₂ := π.injective hπa
          subst this; subst hs; rfl
    refine ⟨?_, ?_, ?_⟩
    · have h := congrArg FeynmanSubgraph.vertices heq
      rw [mapPermSubgraph_vertices, mapPermSubgraph_vertices] at h
      exact Finset.image_injective π.injective h
    · have h := congrArg FeynmanSubgraph.internalEdges heq
      rw [mapPermSubgraph_internalEdges, mapPermSubgraph_internalEdges] at h
      exact Multiset.map_injective
        (FeynmanGraph.FeynmanEdge_map_injective π) h
    · have h := congrArg FeynmanSubgraph.externalLegs heq
      rw [mapPermSubgraph_externalLegs, mapPermSubgraph_externalLegs] at h
      exact Multiset.map_injective hELInj h
  · -- surjective via mapPermSubgraph_preimage
    intro γ' hγ'
    refine ⟨mapPermSubgraph_preimage hπ γ', ?_,
      mapPermSubgraph_preimage_eq hπ γ'⟩
    have := (mapPermSubgraph_mem_index_iff hπ
      (mapPermSubgraph_preimage hπ γ')).mp
    rw [mapPermSubgraph_preimage_eq] at this
    exact this hγ'
  · -- per-term equality: HopfGen subtype ext via mapPermSubgraph_toClass_eq.
    intro γ hγ
    have hγ'full := (G.mem_properConnectedDivergentSubgraphs γ).mp hγ
    have hγ''full := ((repG h).toFeynmanGraph.mem_properConnectedDivergentSubgraphs
        (mapPermSubgraph hπ γ)).mp
      ((mapPermSubgraph_mem_index_iff hπ γ).mpr hγ)
    have hγ' : γ.IsConnectedDivergent ∧ 0 < γ.internalEdges.card :=
      ⟨hγ'full.1, hγ'full.2.1⟩
    have hγ'' : (mapPermSubgraph hπ γ).IsConnectedDivergent ∧
        0 < (mapPermSubgraph hπ γ).internalEdges.card :=
      ⟨hγ''full.1, hγ''full.2.1⟩
    rw [dif_pos hγ', dif_pos hγ'']
    -- Zeta-reduce the let hγNe inside the if-pos body.
    simp only []
    -- Both tensor factors match via Subtype.ext on toClass equality.
    have hLeft : (γ.toHopfGen hγ'.1) =
        (mapPermSubgraph hπ γ).toHopfGen hγ''.1 :=
      Subtype.ext (mapPermSubgraph_toClass_eq hπ γ).symm
    have hRight :
        (γ.contractToHopfGen hWF hG1PI hγ'.1
          (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ'.2)) =
        ((mapPermSubgraph hπ γ).contractToHopfGen
          (repG_wellFormed h) (repG_isOnePI h) hγ''.1
          (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγ''.2)) :=
      Subtype.ext (mapPermSubgraph_contract_toClass_eq hWF hπ γ).symm
    rw [hLeft, hRight]

/-! ### Stage 3b-iv-pre — inner-ambient cleanup via sumPart_eq_amb

Apply `coproductGen_sumPart_eq_amb` to rewrite the inner sums in
`termE3_sigma_eq` and `termF3_sigma_eq` over the natural ambients
`γ_outer.toFeynmanGraph` and `γ_outer.contract`, respectively. -/

/-- termE3 with inner sum reindexed to `γ_outer.toFeynmanGraph`-subgraphs.
This makes the bijection in Stage 3b-iv possible. -/
private theorem termE3_sigma_amb_eq (g : HopfGen) :
    termE3 g =
      ∑ γ_outer ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγo : γ_outer.IsConnectedDivergent ∧ 0 < γ_outer.internalEdges.card then
          let hγoNe : γ_outer.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2
          ∑ γ_inner ∈ γ_outer.toFeynmanGraph.properConnectedDivergentSubgraphs,
            if hγi : γ_inner.IsConnectedDivergent ∧ 0 < γ_inner.internalEdges.card then
              let hγiNe : γ_inner.IsNonempty :=
                FeynmanSubgraph.isNonempty_of_internalEdges_pos hγi.2
              (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toAlgHom
                (((gen (γ_inner.toHopfGen hγi.1) : HopfH) ⊗ₜ[ℚ]
                  (gen (γ_inner.contractToHopfGen
                    γ_outer.toFeynmanGraph_wellFormed
                    hγo.1.isOnePI hγi.1 hγiNe) : HopfH)) ⊗ₜ[ℚ]
                  (gen (γ_outer.contractToHopfGen
                    (repG_wellFormed g) (repG_isOnePI g) hγo.1 hγoNe) : HopfH))
            else 0
        else 0 := by
  rw [termE3_eq_sumPart]
  apply Finset.sum_congr rfl
  intro γ_outer _
  split_ifs with hγo
  · simp only []
    -- Use sumPart_eq_amb on `γ_outer.toHopfGen hγo.1` with `G = γ_outer.toFeynmanGraph`.
    -- The class equality is `γ_outer.toFG.toClass = (γ_outer.toHopfGen hγo.1).val` by toHopfGen_val.
    rw [coproductGen_sumPart_eq_amb (γ_outer.toHopfGen hγo.1)
      γ_outer.toFeynmanGraph
      γ_outer.toFeynmanGraph_wellFormed
      hγo.1.isOnePI
      (γ_outer.toFeynmanGraph_isConnectedDivergent hγo.1)
      rfl]
    rw [TensorProduct.sum_tmul, map_sum]
    apply Finset.sum_congr rfl
    intro γ_inner _
    split_ifs with hγi
    · rfl
    · simp [TensorProduct.zero_tmul]
  · rfl

/-- termF3 with inner sum reindexed to `γ_outer.contract`-subgraphs. -/
private theorem termF3_sigma_amb_eq (g : HopfGen) :
    termF3 g =
      ∑ γ_outer ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs,
        if hγo : γ_outer.IsConnectedDivergent ∧ 0 < γ_outer.internalEdges.card then
          let hγoNe : γ_outer.IsNonempty :=
            FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2
          ∑ γ_inner ∈ γ_outer.contract.properConnectedDivergentSubgraphs,
            if hγi : γ_inner.IsConnectedDivergent ∧ 0 < γ_inner.internalEdges.card then
              let hγiNe : γ_inner.IsNonempty :=
                FeynmanSubgraph.isNonempty_of_internalEdges_pos hγi.2
              ((gen (γ_outer.toHopfGen hγo.1) : HopfH) ⊗ₜ[ℚ]
                ((gen (γ_inner.toHopfGen hγi.1) : HopfH) ⊗ₜ[ℚ]
                  (gen (γ_inner.contractToHopfGen
                    (FeynmanSubgraph.wellFormed_contract (repG_wellFormed g))
                    (FeynmanSubgraph.contract_isOnePI (repG_isOnePI g) hγo.1.isOnePI hγoNe)
                    hγi.1 hγiNe) : HopfH)))
            else 0
        else 0 := by
  rw [termF3_eq_sumPart]
  apply Finset.sum_congr rfl
  intro γ_outer _
  split_ifs with hγo
  · simp only []
    -- Use sumPart_eq_amb on `γ_outer.contractToHopfGen ...` with `G = γ_outer.contract`.
    -- Class equality: γ_outer.contract.toClass = (γ_outer.contractToHopfGen ...).val by contractToHopfGen_val.
    rw [coproductGen_sumPart_eq_amb
      (γ_outer.contractToHopfGen
        (repG_wellFormed g) (repG_isOnePI g) hγo.1
        (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2))
      γ_outer.contract
      (FeynmanSubgraph.wellFormed_contract (repG_wellFormed g))
      (FeynmanSubgraph.contract_isOnePI (repG_isOnePI g) hγo.1.isOnePI
        (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2))
      ?contractCD
      rfl]
    case contractCD =>
      -- γ_outer.contract.IsConnectedDivergent (graph level, ambient-free).
      -- `contractToHopfGen_val` gives the class equality; we need the IsCD predicate
      -- on γ_outer.contract directly. Use the contract preservation chain plus
      -- the subgraph→graph lift (`toFeynmanGraph_isConnectedDivergent`).
      have hSelfCD : (FeynmanSubgraph.self γ_outer.contract
          (FeynmanSubgraph.wellFormed_contract (repG_wellFormed g))).IsConnectedDivergent :=
        FeynmanSubgraph.contract_isConnectedDivergent
          (repG_wellFormed g) (repG_isOnePI g) hγo.1.isOnePI
          (FeynmanSubgraph.isNonempty_of_internalEdges_pos hγo.2) hγo.1.isDivergent
      exact (FeynmanSubgraph.self γ_outer.contract _).toFeynmanGraph_isConnectedDivergent hSelfCD
    rw [TensorProduct.tmul_sum]
    apply Finset.sum_congr rfl
    intro γ_inner _
    split_ifs with hγi
    · rfl
    · simp [TensorProduct.tmul_zero]
  · rfl

/-! ### Stage 3b-iv-A — Subgraph ambient promotion

Given `γ_outer : FeynmanSubgraph G` and `γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph`,
construct `γ_inner.promote γ_outer : FeynmanSubgraph G` with the same
data fields but ambient changed from `γ_outer.toFeynmanGraph` to `G`.

Subset/le witnesses come from transitivity:
- `γ_inner.vertices ⊆ γ_outer.vertices ⊆ G.vertices`
- `γ_inner.internalEdges ≤ γ_outer.internalEdges ≤ G.internalEdges`
- `γ_inner.externalLegs ≤ γ_outer.externalLegs ≤ G.externalLegs`

Support fields are unchanged (vertices stays the same). -/

namespace FeynmanSubgraph

variable {G : FeynmanGraph}

/-- Promote an inner subgraph from `γ_outer.toFeynmanGraph`-ambient to
`G`-ambient. Same data fields, transitive subset/le witnesses. -/
def promote {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) : FeynmanSubgraph G where
  vertices := γ_inner.vertices
  internalEdges := γ_inner.internalEdges
  externalLegs := γ_inner.externalLegs
  vertices_subset := γ_inner.vertices_subset.trans γ_outer.vertices_subset
  internalEdges_le := γ_inner.internalEdges_le.trans γ_outer.internalEdges_le
  externalLegs_le := γ_inner.externalLegs_le.trans γ_outer.externalLegs_le
  edges_supported := γ_inner.edges_supported
  legs_supported := γ_inner.legs_supported

@[simp] theorem promote_vertices {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (promote (γ_outer := γ_outer) γ_inner).vertices = γ_inner.vertices := rfl

@[simp] theorem promote_internalEdges {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (promote (γ_outer := γ_outer) γ_inner).internalEdges = γ_inner.internalEdges := rfl

@[simp] theorem promote_externalLegs {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (promote (γ_outer := γ_outer) γ_inner).externalLegs = γ_inner.externalLegs := rfl

/-- The promoted subgraph's underlying `FeynmanGraph` equals the inner's. -/
@[simp] theorem promote_toFeynmanGraph {γ_outer : FeynmanSubgraph G}
    (γ_inner : FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (promote (γ_outer := γ_outer) γ_inner).toFeynmanGraph = γ_inner.toFeynmanGraph := rfl

end FeynmanSubgraph

/-- The nested-chain forward map used by the original coassoc bijection
attempt. It sends `(γ_outer, γ_inner ⊂ γ_outer)` to
`(γ_inner promoted to Γ, γ_outer/γ_inner)` in the quotient ambient. -/
private noncomputable def coassocNestedForward (g : HopfGen)
    (p : Σ γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph,
        FeynmanSubgraph γ_outer.toFeynmanGraph) :
    Σ γ_outer' : FeynmanSubgraph (repG g).toFeynmanGraph,
        FeynmanSubgraph γ_outer'.contract :=
  let γ_outer := p.1
  let γ_inner := p.2
  let γ_innerP : FeynmanSubgraph (repG g).toFeynmanGraph :=
    FeynmanSubgraph.promote (γ_outer := γ_outer) γ_inner
  have hle : γ_innerP ≤ γ_outer := by
    refine ⟨?_, ?_, ?_⟩
    · exact γ_inner.vertices_subset
    · exact γ_inner.internalEdges_le
    · exact γ_inner.externalLegs_le
  ⟨γ_innerP, FeynmanSubgraph.contractRestrict hle γ_innerP.contractedVertex⟩

/-! ### Stage 3b-iv-B — Sigma flattening + bijection

Both `termE3` (in sigma_amb form) and `termF3` (in sigma_amb form) are
double sums over chains `(γ_outer, γ_inner)`. Flatten each into a single
sum over the sigma type
`Σ γ_outer ∈ index_Γ, γ_outer.toFG.properConnectedDivergentSubgraphs`
(LHS) and similarly with `γ_outer.contract` for RHS.

Then construct a bijection of the flattened sigma sets via:
`(γ_outer, γ_inner) ↦ (γ_inner.promote, γ_outer.contractRestrict γ_inner)`.

The per-term tensor equality (third factor: H1.17 contract_chain) is
handled in Stage 3c. -/

/-- Split a finite sum into the part satisfying a predicate and its complement. -/
private theorem sum_split_by_pred {α β : Type*} [AddCommMonoid β]
    (s : Finset α) (p : α → Prop) [DecidablePred p]
    [DecidablePred (fun a => ¬ p a)] (f : α → β) :
    (∑ a ∈ s, f a) =
      (∑ a ∈ s.filter p, f a) + (∑ a ∈ s.filter (fun a => ¬ p a), f a) := by
  exact (Finset.sum_filter_add_sum_filter_not s p f).symm

/- The old connected-only sigma-flattening lemmas for `termE3`/`termF3`
were intentionally dropped from the compiled file.  They belonged to the
blocked pre-admissible route below, were not referenced by the current H5.8F
proof path, and their fully-expanded dependent tensor statements could exhaust
the elaborator stack in the IDE.  The active proof now proceeds through the
admissible-forest `φ` reindexing interface above. -/

/-- Split the RHS coassoc sigma index according to whether the quotient
subgraph contains the contracted vertex of the outer subgraph. The
star-containing side is the image of the nested-chain `contractRestrict`
map; the star-free side is the obstruction that requires admissible
disjoint unions. -/
private theorem rhs_sigma_split_by_star (g : HopfGen) {β : Type*}
    [AddCommMonoid β]
    (f : (Σ γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph,
            FeynmanSubgraph γ_outer.contract) → β) :
    (∑ p ∈ (repG g).toFeynmanGraph.properConnectedDivergentSubgraphs.sigma
              (fun γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph =>
                γ_outer.contract.properConnectedDivergentSubgraphs),
        f p)
      =
        (∑ p ∈ ((repG g).toFeynmanGraph.properConnectedDivergentSubgraphs.sigma
              (fun γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph =>
                γ_outer.contract.properConnectedDivergentSubgraphs)).filter
              (fun p => p.1.contractedVertex ∈ p.2.vertices),
          f p)
        +
        (∑ p ∈ ((repG g).toFeynmanGraph.properConnectedDivergentSubgraphs.sigma
              (fun γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph =>
                γ_outer.contract.properConnectedDivergentSubgraphs)).filter
              (fun p => p.1.contractedVertex ∉ p.2.vertices),
          f p) := by
  exact sum_split_by_pred _ (fun p => p.1.contractedVertex ∈ p.2.vertices) f

/-! ### Stage 3b-iv-B/C + 3c — termE3 = termF3 via bijection + contract_chain

The forward bijection sends `(γ_outer, γ_inner)` (LHS chain in
`γ_outer.toFG`-ambient) to `(γ_inner.promote, γ_outer.contractRestrict γ_inner)`
(RHS chain in `(repG g).toFG`-ambient + contract-quotient ambient).

Per-term equality uses H1.17 `contract_chain`:
`(γ_inner.promote.contract).contract (γ_outer.contractRestrict γ_inner) = γ_outer.contract`
as `FeynmanGraph` (literal equality), which transports the third tensor
factor's `HopfGen` data via `Subtype.ext`. -/

/-- Range invariant of `contractRestrict`: the second factor's vertex
set always contains the contracted vertex `star`. This is the key
observation that the forward bijection in coassoc covers only the
"star-containing" part of the RHS sum, not the full RHS index. -/
private theorem contractRestrict_star_mem {G : FeynmanGraph}
    {γ₁ γ₂ : FeynmanSubgraph G} (hle : γ₁ ≤ γ₂) (star : VertexId) :
    star ∈ (FeynmanSubgraph.contractRestrict hle star).vertices := by
  rw [FeynmanSubgraph.contractRestrict_vertices]
  exact Finset.mem_union_right _ (Finset.mem_singleton.mpr rfl)

/-- The nested-chain forward map lands in the star-containing component of
the RHS sigma index. This is the Lean-level form of the obstruction: this
map cannot cover star-free quotient subgraphs. -/
private theorem coassocNestedForward_star_mem (g : HopfGen)
    (p : Σ γ_outer : FeynmanSubgraph (repG g).toFeynmanGraph,
        FeynmanSubgraph γ_outer.toFeynmanGraph) :
    (coassocNestedForward g p).1.contractedVertex ∈
      (coassocNestedForward g p).2.vertices := by
  dsimp [coassocNestedForward]
  exact Finset.mem_union_right _ (Finset.mem_singleton.mpr rfl)

