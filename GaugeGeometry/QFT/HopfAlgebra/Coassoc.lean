/-- Sprint F2i-3e: source subgraph candidate.  Bundle the F2i-3a–3d
carriers (vertices, internal edges, external legs) into a
`FeynmanSubgraph (repG g).toFG`.  All five proof fields are
supplied by F2i-3a–3d sanity lemmas; no `IsConnectedDivergent` or
retarget equality proven here. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices := forestQuotientForestSigmaForestCoverSourceVertices g r δ
  internalEdges :=
    forestQuotientForestSigmaForestCoverSourceInternalEdges g r δ
  externalLegs :=
    forestQuotientForestSigmaForestCoverSourceExternalLegs g r δ
  vertices_subset :=
    forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient g r δ
  internalEdges_le :=
    forestQuotientForestSigmaForestCoverSourceInternalEdges_le g r δ
  externalLegs_le :=
    forestQuotientForestSigmaForestCoverSourceExternalLegs_le g r δ
  edges_supported := fun e he =>
    forestQuotientForestSigmaForestCoverSourceInternalEdges_endpoints
      g r δ he
  legs_supported := fun ℓ hℓ =>
    forestQuotientForestSigmaForestCoverSourceExternalLegs_attached
      g r δ hℓ

