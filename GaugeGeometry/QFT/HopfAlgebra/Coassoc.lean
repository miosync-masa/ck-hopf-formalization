private theorem forestComponentForestChoiceSplitStarInjectivityOfBranches
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentForestChoiceSplitStarBranchInjectivityPayload) :
    forestComponentForestChoiceSplitStarInjectivityPayload where
  inj := by
    intro g q hq C ő≥‚āĀ hő≥‚āĀ ő≥‚āā hő≥‚āā hstar
    rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hő≥‚āĀ with hő≥‚āĀL | hő≥‚āĀR | hő≥‚āĀF
    ¬∑ rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hő≥‚āā with hő≥‚āāL | hő≥‚āāR | hő≥‚āāF
      ¬∑ exact T.left_left g q hq C ő≥‚āĀ hő≥‚āĀL ő≥‚āā hő≥‚āāL hstar
      ¬∑ exact False.elim ((T.left_right g q hq C ő≥‚āĀ hő≥‚āĀL ő≥‚āā hő≥‚āāR) hstar)
      ¬∑ rcases hő≥‚āāF with ‚ü®B‚āā, hB‚āā‚ü©
        exact False.elim
          ((T.left_forest g q hq C ő≥‚āĀ hő≥‚āĀL ‚ü®ő≥‚āā, hő≥‚āā‚ü© B‚āā hB‚āā) hstar)
    ¬∑ rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hő≥‚āā with hő≥‚āāL | hő≥‚āāR | hő≥‚āāF
      ¬∑ exact False.elim ((T.left_right g q hq C ő≥‚āā hő≥‚āāL ő≥‚āĀ hő≥‚āĀR) hstar.symm)
      ¬∑ exact T.right_right g q hq C ő≥‚āĀ hő≥‚āĀR ő≥‚āā hő≥‚āāR hstar
      ¬∑ rcases hő≥‚āāF with ‚ü®B‚āā, hB‚āā‚ü©
        exact False.elim
          ((T.right_forest g q hq C ő≥‚āĀ hő≥‚āĀR ‚ü®ő≥‚āā, hő≥‚āā‚ü© B‚āā hB‚āā) hstar)
    ¬∑ rcases hő≥‚āĀF with ‚ü®B‚āĀ, hB‚āĀ‚ü©
      rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hő≥‚āā with hő≥‚āāL | hő≥‚āāR | hő≥‚āāF
      ¬∑ exact False.elim
          ((T.left_forest g q hq C ő≥‚āā hő≥‚āāL ‚ü®ő≥‚āĀ, hő≥‚āĀ‚ü© B‚āĀ hB‚āĀ) hstar.symm)
      ¬∑ exact False.elim
          ((T.right_forest g q hq C ő≥‚āā hő≥‚āāR ‚ü®ő≥‚āĀ, hő≥‚āĀ‚ü© B‚āĀ hB‚āĀ) hstar.symm)
      ¬∑ rcases hő≥‚āāF with ‚ü®B‚āā, hB‚āā‚ü©
        exact T.forest_forest g q hq C ‚ü®ő≥‚āĀ, hő≥‚āĀ‚ü© B‚āĀ hB‚āĀ
