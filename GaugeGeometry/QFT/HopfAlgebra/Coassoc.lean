    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent)
    {B : AdmissibleSubgraph (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph}
    (hB : B ‚ąą
      ((repG (ő≥.toHopfGen hő≥)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs) :
    feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥ hő≥ B ‚ąą
      ő≥.toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
  mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
    (feynmanSubgraphToHopfGenRepPerm_spec ő≥ hő≥) hB

/-- Pulling a selected forest from the representative component graph back to
