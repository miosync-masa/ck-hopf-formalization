    forestComponentForestChoiceActualQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents_of_remnantPositive
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
      ).HasPositiveInternalEdgesComponents := by
  intro őī hőī
  change őī ‚ąą forestComponentForestChoiceActualQuotientComponents g q hq
    at hőī
  unfold forestComponentForestChoiceActualQuotientComponents at hőī
  rcases Finset.mem_union.mp hőī with hRight | hRemnant
  ¬∑ exact
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_hasPositiveInternalEdgesComponents
        g q hq őī hRight
  ¬∑ exact C.positive őī hRemnant

