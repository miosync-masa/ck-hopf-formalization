    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent) : Equiv.Perm VertexId :=
  Classical.choose (feynmanSubgraphToHopfGen_rep_isIso ő≥ hő≥)

/-- Specification of `feynmanSubgraphToHopfGenRepPerm`. -/
