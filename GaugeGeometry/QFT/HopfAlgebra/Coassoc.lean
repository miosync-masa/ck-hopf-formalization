        (forestComponentMixedBoundaryOuterIndex g q hq)
      ).properDisjointAdmissibleDivergentSubgraphs :=
  forestOuterRepRetargetAdmissibleSubgraphOfCert_mem_properDisjoint g
    (forestComponentMixedBoundaryOuterIndex g q hq)
    (forestComponentChoiceRightSubgraph q.1.1 q.2)
    (forestComponentMixedBoundaryRightRetargetCertificateCanonical g q hq)
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
      g q hq)

/-- In the mixed-boundary branch, the actual quotient-side right forest still
leaves the original outer complement as quotient complement edges. -/
private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_complementEdges_card_pos
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    0 <
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq).complementEdges.card := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let A := q.1.1
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  have hDisj : A.IsPairwiseDisjoint :=
    G₀.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hRle : R.internalEdges ≤ L.complementEdges := by
    refine admissibleSubgraph_internalEdges_le_of_components_le R ?_ ?_
    · exact forestComponentChoiceRightSubgraph_isPairwiseDisjoint q.1.1 q.2 hDisj
    · intro γ hγ
      exact forestComponentChoiceRight_internalEdges_le_left_complement
        q.1.1 q.2 hDisj (by simpa [R] using hγ)
  have hV :
      ∀ η ∈ R.elements, ∀ v ∈ η.vertices, v ∉ Aout.vertices := by
    intro η hη v hv
    dsimp [Aout, R]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hη hv
  have hRmap :
      R.internalEdges.map (Aout.retargetEdge outerStar) =
        R.internalEdges := by
    unfold AdmissibleSubgraph.internalEdges
    change (Multiset.mapAddMonoidHom (Aout.retargetEdge outerStar))
        (∑ γ ∈ R.elements, γ.internalEdges) =
      ∑ γ ∈ R.elements, γ.internalEdges
    rw [map_sum (Multiset.mapAddMonoidHom (Aout.retargetEdge outerStar))]
    apply Finset.sum_congr rfl
    intro γ hγ
    exact admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
      Aout outerStar γ
      (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ (by
        simpa [R] using hγ))
      (hV γ hγ)
  have hAactI : Aact.internalEdges = R.internalEdges := by
    have hinj :=
      admissibleSubgraphRetarget_injective_of_not_mem
        Aout outerStar R
        (fun η hη =>
          forestComponentMixedBoundaryRightRetarget_edge_le g q hq η (by
            simpa [R] using hη))
        hV
    unfold AdmissibleSubgraph.internalEdges
    change
      (∑ δ ∈
        (R.elements.attach.image fun γ =>
          admissibleSubgraphRetargetSubgraph
            Aout outerStar γ.1
            (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1
              (by simpa [R] using γ.2))),
        δ.internalEdges) =
      ∑ γ ∈ R.elements, γ.internalEdges
    rw [Finset.sum_image]
    · trans ∑ γ ∈ R.elements.attach, γ.1.internalEdges
      · apply Finset.sum_congr rfl
        intro γ _hγ
        exact admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
          Aout outerStar γ.1
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq γ.1
            (by simpa [R] using γ.2))
          (hV γ.1 γ.2)
      · rw [Finset.sum_attach]
    · intro γ₁ _ γ₂ _ hEq
      exact hinj hEq
  have hSplit :
      A.internalEdges = L.internalEdges + R.internalEdges := by
    have hp :
        q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    have hNoForest : ¬ forestComponentChoiceHasForest q.1.1 q.2 := by
      unfold forestComponentMixedBoundaryChoiceCoreIndex at hp
      exact (Finset.mem_filter.mp hp).2
    have hUnion : L.elements ∪ R.elements = A.elements := by
      ext γ
      constructor
      · intro hγ
        rcases Finset.mem_union.mp hγ with hγL | hγR
        · exact forestComponentChoiceLeftSubgraph_elements_subset
            q.1.1 q.2 (by simpa [L] using hγL)
        · exact forestComponentChoiceRightSubgraph_elements_subset
            q.1.1 q.2 (by simpa [R] using hγR)
      · intro hγA
        have hγAq : γ ∈ q.1.1.elements := by
          simpa [A] using hγA
        rcases forestCoproductChoice_eq_left_or_right_or_forest
            (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγAq))
            (q.2 ⟨γ, hγAq⟩
              (Finset.mem_attach q.1.1.elements ⟨γ, hγAq⟩)) with
          hLeft | hRightOrForest
        · apply Finset.mem_union_left
          rw [show L.elements =
              q.1.1.elements.filter (forestComponentChoiceIsLeft q.1.1 q.2)
            by rfl]
          exact Finset.mem_filter.mpr ⟨hγAq, by
            unfold forestComponentChoiceIsLeft
            rw [dif_pos hγAq]
            exact hLeft⟩
        · rcases hRightOrForest with hRight | hForest
          · apply Finset.mem_union_right
            rw [show R.elements =
                q.1.1.elements.filter (forestComponentChoiceIsRight q.1.1 q.2)
              by rfl]
            exact Finset.mem_filter.mpr ⟨hγAq, by
              unfold forestComponentChoiceIsRight
              rw [dif_pos hγAq]
              exact hRight⟩
          · rcases hForest with ⟨B, hB⟩
            exact False.elim
              (hNoForest ⟨⟨γ, hγAq⟩, B, hB⟩)
    have hDisjLR : Disjoint L.elements R.elements := by
      rw [Finset.disjoint_left]
      intro γ hγL hγR
      exact forestComponentChoiceRightSubgraph_not_mem_left
        q.1.1 q.2 (by simpa [R] using hγR) (by simpa [L] using hγL)
    unfold AdmissibleSubgraph.internalEdges
    rw [← hUnion]
    rw [Finset.sum_union hDisjLR]
  have hQinternal :
      Q.internalEdges =
        (G₀.internalEdges - L.internalEdges).map (Aout.retargetEdge outerStar) := by
    simp [Q, G₀, L, Aout, outerStar, forestOuterActualQuotientGraph,
      forestComponentMixedBoundaryOuterIndex_val,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges,
      AdmissibleSubgraph.complementEdges]
  have hAactComplement :
      Aact.complementEdges =
        ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
          (Aout.retargetEdge outerStar) := by
    unfold AdmissibleSubgraph.complementEdges
    calc
      Q.internalEdges - Aact.internalEdges
          = (G₀.internalEdges - L.internalEdges).map
              (Aout.retargetEdge outerStar) - R.internalEdges := by
            rw [hQinternal, hAactI]
      _ = (G₀.internalEdges - L.internalEdges).map
              (Aout.retargetEdge outerStar) -
            R.internalEdges.map (Aout.retargetEdge outerStar) := by
            rw [hRmap]
      _ = ((G₀.internalEdges - L.internalEdges) - R.internalEdges).map
              (Aout.retargetEdge outerStar) := by
            exact (multiset_map_sub_of_le (Aout.retargetEdge outerStar)
              (by simpa [L] using hRle)).symm
  have hComplementSource :
      (G₀.internalEdges - L.internalEdges) - R.internalEdges =
        G₀.internalEdges - A.internalEdges := by
    rw [hSplit, Multiset.sub_add_eq_sub_sub]
  have hAcomp : 0 < A.complementEdges.card := by
    simpa [A] using (Finset.mem_filter.mp (Finset.mem_sigma.mp hq).1).2
  rw [show
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq).complementEdges = Aact.complementEdges by rfl]
  rw [hAactComplement, hComplementSource]
  simpa [AdmissibleSubgraph.complementEdges, G₀, A] using hAcomp

/-- Representative transport preserves the strict complement positivity of the
mixed-boundary quotient-side right forest. -/
private theorem
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_complementEdges_card_pos
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    0 <
      (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
        g q hq).complementEdges.card := by
  classical
  have hActual :=
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_complementEdges_card_pos
      g q hq
  have hcard :=
    mapPermAdmissibleSubgraph_complementEdges_card
      (forestOuterActualToRepPerm_spec g
        (forestComponentMixedBoundaryOuterIndex g q hq))
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq)
  change 0 <
    (mapPermAdmissibleSubgraph
      (forestOuterActualToRepPerm_spec g
        (forestComponentMixedBoundaryOuterIndex g q hq))
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
        g q hq)).complementEdges.card
  rw [hcard]
  exact hActual

/-- Mixed-boundary transport payload: the original right-selected forest and
its representative quotient-side forest carry the same Hopf product. -/
private theorem
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_toHopfH_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q hq
      ).toHopfH =
        (forestComponentChoiceRightSubgraph q.1.1 q.2).toHopfH := by
  classical
  unfold forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
    forestComponentMixedBoundaryRepRightQuotientSubgraph
  apply forestOuterRepRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
  intro γ hγ v hv
  rw [forestComponentMixedBoundaryOuterIndex_val]
  exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2)
    hγ hv

/-- A mixed-boundary right-factor class equality can be proved on the actual
quotient graph and then transported to the chosen quotient representative. -/
private theorem forestComponentMixedBoundary_rightContractClass_of_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hActual :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (forestOuterActualQuotientGraph g
          (forestComponentMixedBoundaryOuterIndex g q hq))
        (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
          g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))).toClass) :
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG (forestOuterQuotientHopfGen g
          (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
        (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
          g q hq)
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG (forestOuterQuotientHopfGen g
            (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))).toClass := by
  calc
    (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph q.1.1 q.1.2)).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (forestOuterActualQuotientGraph g
              (forestComponentMixedBoundaryOuterIndex g q hq))
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
              g q hq)
            (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
              g q hq))).toClass := hActual
    _ =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (forestOuterQuotientHopfGen g
            (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq)
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (forestOuterQuotientHopfGen g
              (forestComponentMixedBoundaryOuterIndex g q hq))).toFeynmanGraph
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
              g q hq)
            (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
              g q hq))).toClass := by
          simpa [forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical,
            forestComponentMixedBoundaryRepRightQuotientSubgraph,
            forestOuterQuotientGraph] using
            forestOuterActualToRep_rightContractClass g
              (forestComponentMixedBoundaryOuterIndex g q hq)
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
                g q hq)
              (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
                g q hq)

/-- Mixed-boundary component product factored through the final representative
quotient-side right forest. -/
private theorem
    forestComponentMixedBoundary_productTerm_eq_repRightQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentChoiceProductTerm q.1.1 q.2 =
      (forestComponentMixedBoundaryOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
        (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
          g q hq).toHopfH := by
  rw [forestComponentMixedBoundary_productTerm_eq_leftRightSubgraphs g q hq]
  rw [← forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_toHopfH_eq
    g q hq]

/-- Flat RHS carrier shape: an outer forest plus a quotient-side forest. -/
private abbrev forestQuotientForestSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) : Type :=
  Σ A : forestOuterProperIndex g, AdmissibleSubgraph (forestOuterQuotientGraph g A)

/-- Flat RHS carrier for the explicit quotient forest double-sum. -/
private noncomputable def forestQuotientForestSigmaIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestQuotientForestSigma g) :=
  ((forestOuterProperFinset g).filter
    (fun A => 0 < A.1.complementEdges.card)).sigma
    (fun A => forestCoproductProperForestIndex (forestOuterQuotientHopfGen g A))

/-- The tensor term attached to one flat RHS quotient-forest index. -/
private noncomputable def forestQuotientForestSigmaTerm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestQuotientForestSigma g) :
    HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH) :=
  q.1.1.toHopfH ⊗ₜ[ℚ]
    FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars
      (forestOuterQuotientGraph g q.1)
      (forestCanonicalHCD (forestOuterQuotientHopfGen g q.1))
      q.2

/-- The strict RHS quotient-forest carrier additionally needs the full
genuine-forest quotient image to leave a nonempty complement in the quotient
graph.  This payload is separate from quotient properness: positive internal
edges of the quotient components do not by themselves prove strict complement
positivity. -/
private class
    ForestComponentForestChoiceRepQuotientComplementPositiveModel : Prop where
  positive :
    ∀ [IsDivergencePreservedByAdmissibleForestContract]
      (g : HopfGen) (q : forestComponentChoiceSigma g),
      ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      0 <
        (forestComponentForestChoiceRepQuotientSubgraphCanonical
          g q hq).complementEdges.card

variable
  [ForestComponentForestChoiceRepQuotientComplementPositiveModel]

/-- RHS flat index associated to a genuine-forest component-choice term. -/
private noncomputable def forestComponentForestChoiceToQuotientForestSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestQuotientForestSigma g :=
  ⟨forestComponentForestChoiceOuterIndex g q hq,
    forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq⟩

/-- A genuine-forest quotient properness certificate places the branch target
of `φ` in the RHS quotient-forest finite carrier. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceActualQuotientProperCertificate g q hq) :
    forestComponentForestChoiceToQuotientForestSigma g q hq ∈
      forestQuotientForestSigmaIndex g := by
  classical
  unfold forestQuotientForestSigmaIndex
  apply Finset.mem_sigma.mpr
  refine ⟨?_, ?_⟩
  · apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_attach _ _, ?_⟩
    have hpForest :
        q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
      (Finset.mem_sigma.mp hq).2
    have hpCore :
        q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
      (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
    have hAcomp : 0 < q.1.1.complementEdges.card :=
      (Finset.mem_filter.mp (Finset.mem_sigma.mp hq).1).2
    have hDisj :
        q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          q.1.2
    exact admissibleSubgraph_complementEdges_card_pos_of_internalEdges_le
      (forestComponentForestChoiceOuterSubgraph_internalEdges_le_original
        q.1.1 q.2 hpCore hDisj)
      hAcomp
  · change forestComponentForestChoiceRepQuotientSubgraphCanonical
        g q hq ∈
        ((forestOuterQuotientGraph g
          (forestComponentForestChoiceOuterIndex g q hq)
        ).properDisjointAdmissibleDivergentSubgraphs).filter
          (fun A => 0 < A.complementEdges.card)
    exact Finset.mem_filter.mpr ⟨
      forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint
        g q hq C,
      ForestComponentForestChoiceRepQuotientComplementPositiveModel.positive
        g q hq⟩

/-- The genuine-forest branch target of `φ` lands in the RHS finite carrier
once the exact remaining remnant positivity payload is supplied. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_mem_of_remnantPositive
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    forestComponentForestChoiceToQuotientForestSigma g q hq ∈
      forestQuotientForestSigmaIndex g :=
  forestComponentForestChoiceToQuotientForestSigma_mem g q hq
    (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
      g q hq C)

/-- A source-edge witness is enough to place the genuine-forest branch image in
the RHS finite carrier. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_mem_of_sourceEdgeWitness
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate
      g q hq) :
    forestComponentForestChoiceToQuotientForestSigma g q hq ∈
      forestQuotientForestSigmaIndex g :=
  forestComponentForestChoiceToQuotientForestSigma_mem_of_remnantPositive
    g q hq
    (forestComponentForestChoiceRemnantPositiveComponentsCertificateOfSource
      g q hq
      (forestComponentForestChoiceRemnantSourcePositiveCertificateOfEdgeWitness
        g q hq C))

/-- RHS flat index associated to a mixed-boundary component-choice term. -/
private noncomputable def forestComponentMixedBoundaryToQuotientForestSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestQuotientForestSigma g :=
  ⟨forestComponentMixedBoundaryOuterIndex g q hq,
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q hq⟩

/-- Cross-disjointness skeleton, same-outer case (Sprint F1s-2): if the
forest-branch RHS image equals the mixed-branch RHS image and `qF.1 = qM.1`,
then `False`.  Pure wrapper over F1s-1 plus `congrArg Sigma.fst`. -/
private theorem forest_mixed_cross_false_of_same_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {qF qM : forestComponentChoiceSigma g}
    (hqF : qF ∈ forestComponentForestChoiceSigmaIndex g)
    (hqM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hSame : qF.1 = qM.1)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g qF hqF =
      forestComponentMixedBoundaryToQuotientForestSigma g qM hqM) :
    False := by
  classical
  have hpForest : qF.2 ∈ forestComponentForestChoiceCoreIndex qF.1.1 :=
    (Finset.mem_sigma.mp hqF).2
  have hpCore : qF.2 ∈ forestComponentCoreChoiceIndex qF.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  have hAprop : qF.1.1 ∈
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := qF.1.2
  have hA : qF.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hAprop
  have hCompOuterF :
      (forestComponentForestChoiceOuterSubgraph qF.1.1 qF.2 hA).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents
      hpCore hAprop hA
  have hOuterIndex :
      forestComponentForestChoiceOuterIndex g qF hqF =
        forestComponentMixedBoundaryOuterIndex g qM hqM :=
    congrArg Sigma.fst hEq
  have hOuter :
      (forestComponentForestChoiceOuterIndex g qF hqF).1 =
      (forestComponentMixedBoundaryOuterIndex g qM hqM).1 :=
    congrArg Subtype.val hOuterIndex
  exact forestComponentForestChoice_mixedBoundary_cross_same_outer_false
    hqF hqM hSame hCompOuterF hOuter

/-- F2d Target 1 (actual-version): in the mixed-boundary regime, every
component of the **actual** right-retarget quotient is vertex-disjoint
from the outer star carrier.  Right-selected sources sit in `A.elements`
but are filtered as `.right`, so they are disjoint from the
left-selected outer carrier; retargeting acts as identity on their
vertices, which lie outside `A.starVertices`. -/
private theorem forestComponentMixedBoundaryActualRightQuotientSubgraph_no_starVertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ∀ δ,
      δ ∈ (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq).elements →
      Disjoint δ.vertices
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)) := by
  classical
  intro δ hδ
  -- Unfold the canonical construction down to retarget.image.
  unfold forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      forestComponentMixedBoundaryActualRightQuotientSubgraph
      forestOuterActualRetargetAdmissibleSubgraphOfCert
      forestOuterActualRetargetAdmissibleSubgraph
      admissibleSubgraphRetarget at hδ
  -- After unfolding, hδ : δ ∈ (ofElements s _).elements, which is defeq to δ ∈ s.
  rcases Finset.mem_image.mp hδ with ⟨γR, hγRMem, hRetargetEq⟩
  -- γR is right-selected ⇒ disjoint from left outer carrier; vertices stay identity.
  have hA : q.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hVertexId :
      ∀ v ∈ γR.1.vertices,
        v ∉ (forestComponentMixedBoundaryOuterIndex g q hq).1.vertices := by
    intro v hv
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hA γR.2 hv
  -- δ.vertices = γR.vertices (identity retarget for vertices outside outer carrier).
  have hδVertices :
      δ.vertices = γR.1.vertices := by
    rw [← hRetargetEq]
    exact admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
      (forestComponentMixedBoundaryOuterIndex g q hq).1 _ γR.1 _ hVertexId
  -- γR.vertices ⊆ (repG g).toFeynmanGraph.vertices, which is disjoint from starVertices.
  rw [hδVertices]
  have hFresh :
      (forestComponentMixedBoundaryOuterIndex g q hq).1.IsFreshStarAssignment
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2) :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  have hGdisj := hFresh.disjoint_vertices_starVertices
  -- γR ⊆ (repG g).toFG, so γR.vertices ⊆ G.vertices.
  exact (Finset.disjoint_left).mpr fun v hv hStar =>
    (Finset.disjoint_left.mp hGdisj) (γR.1.vertices_subset hv) hStar

/-- F2d Target 2 (actual-version): in the forest-choice regime, at least
one component of the actual quotient subgraph touches the outer star
carrier.  Witnessed by a remnant of a forest-selected `γ` whose
vertices contain a promoted-η image collapsed to `starOf η`. -/
private theorem forestComponentForestChoiceActualQuotientSubgraph_exists_starVertex
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    ∃ δ,
      δ ∈ (forestComponentForestChoiceActualQuotientSubgraphCanonical
            g q hq).elements ∧
      ¬ Disjoint δ.vertices
        ((forestComponentForestChoiceOuterIndex g q hq).1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)) := by
  classical
  -- Step 1: forest core ⇒ ∃ γ ∈ q.1.1.elements, ∃ B, q.2 γ = .forest B.
  have hpForest : q.2 ∈ forestComponentForestChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hpCore : q.2 ∈ forestComponentCoreChoiceIndex q.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).1
  rcases (mem_forestComponentForestChoiceCoreIndex_core_hasForest hpForest).2
    with ⟨γ, B, hPγ⟩
  -- Step 2: promoted γ B is proper-disjoint and nonempty, pick η.
  have hPromProper :
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B ∈
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
      hpCore γ hPγ
  have hPromNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).IsNonempty :=
    properDisjointAdmissibleDivergentSubgraphs_isNonempty hPromProper
  have hPromCompNE :
      (feynmanSubgraphRepForestPromoteAdmissibleSubgraph γ.1
        (q.1.1.isConnectedDivergent_of_mem γ.2) B).HasNonemptyComponents :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      hPromProper
  rcases hPromNE with ⟨η, hηProm⟩
  -- Step 3: candidate δ := admissibleSubgraphQuotientRemainderSubgraph forestOuter starOf γ.1.
  let A := forestComponentForestChoiceOuterIndex g q hq
  let starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2
  let δ := admissibleSubgraphQuotientRemainderSubgraph A.1 starOf γ.1
  -- δ ∈ remnant components (via _mem_of_forest).
  have hδRemnant : δ ∈ forestComponentForestChoiceRemnantComponents g q hq :=
    forestComponentForestChoiceRemnantComponents_mem_of_forest g q hq γ hPγ
  -- δ ∈ ActualQuotientSubgraphCanonical.elements via union-right.
  have hδActual :
      δ ∈ (forestComponentForestChoiceActualQuotientSubgraphCanonical
            g q hq).elements := by
    rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
    unfold forestComponentForestChoiceActualQuotientComponents
    exact Finset.mem_union_right _ hδRemnant
  refine ⟨δ, hδActual, ?_⟩
  -- Step 4: exhibit a star vertex in δ.vertices.
  have hηVtxSub : η.vertices ⊆ γ.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      γ.1 (q.1.1.isConnectedDivergent_of_mem γ.2) B hηProm
  have hηNE : η.IsNonempty := hPromCompNE η hηProm
  rcases Finset.card_pos.mp hηNE with ⟨v, hvη⟩
  have hvγ : v ∈ γ.1.vertices := hηVtxSub hvη
  -- η ∈ forestOuter.elements (via Finset.mem_union_right of promoted).
  have hAdisjQ : q.1.1.IsPairwiseDisjoint :=
    ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hηOuter : η ∈ A.1.elements := by
    have hηPromoted :
        η ∈ forestComponentChoicePromotedForestComponents q.1.1 q.2 :=
      forestComponentChoicePromotedForestComponents_mem_of_forest
        q.1.1 q.2 γ hPγ hηProm
    show η ∈ (forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hAdisjQ).elements
    rw [forestComponentForestChoiceOuterSubgraph_elements]
    exact Finset.mem_union_right _ hηPromoted
  -- The star of η is in starVertices and in δ.vertices via collapse.
  have hStar : starOf η ∈ A.1.starVertices starOf :=
    AdmissibleSubgraph.mem_starVertices.mpr ⟨η, hηOuter, rfl⟩
  have hvOuter : v ∈ A.1.vertices :=
    AdmissibleSubgraph.mem_vertices.mpr ⟨η, hηOuter, hvη⟩
  have hRetV : A.1.retargetVertex starOf v = starOf η := by
    have hAdisj : A.1.IsPairwiseDisjoint :=
      ((repG g).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        A.2
    rw [AdmissibleSubgraph.retargetVertex,
      AdmissibleSubgraph.componentAt?_eq_some_of_mem_vertices hAdisj hηOuter hvη]
  -- δ.vertices contains starOf η.
  have hStarInDelta : starOf η ∈ δ.vertices := by
    rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨v, hvγ, hRetV⟩
  intro hdisj
  exact (Finset.disjoint_left.mp hdisj) hStarInDelta hStar

/-- Sprint F2e Step 1: pull a rep-side RHS quotient subgraph back to the
actual quotient graph via `mapPermAdmissibleSubgraphPreimage`.  This makes
ambient-side starVertices comparisons feasible (the rep version requires
transport across the `Classical.choose`-produced rep permutation, which
is unavailable). -/
private noncomputable def forestQuotientForestSigmaActualQuotientSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (r : forestQuotientForestSigma g) :
    AdmissibleSubgraph (forestOuterActualQuotientGraph g r.1) :=
  mapPermAdmissibleSubgraphPreimage (forestOuterActualToRepPerm_spec g r.1) r.2

/-- Sprint F2e Step 2 (mixed cancellation): actualization of the
mixed-branch RHS image is the canonical actual right quotient subgraph. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_mixed
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestQuotientForestSigmaActualQuotientSubgraph g
        (forestComponentMixedBoundaryToQuotientForestSigma g q hq) =
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq := by
  classical
  -- Rep canonical = forestOuterActualToRepAdmissibleSubgraph (Actual canonical).
  -- Preimage cancels: preimage h₁ (mapPerm h A) = A by F1p-4b roundtrip.
  unfold forestQuotientForestSigmaActualQuotientSubgraph
    forestComponentMixedBoundaryToQuotientForestSigma
    forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
    forestComponentMixedBoundaryRepRightQuotientSubgraph
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    forestComponentMixedBoundaryActualRightQuotientSubgraph
    forestOuterRepRetargetAdmissibleSubgraphOfCert
    forestOuterRepRetargetAdmissibleSubgraph
    forestOuterActualRetargetAdmissibleSubgraphOfCert
  -- The rep version is `forestOuterActualToRepAdmissibleSubgraph` applied to
  -- the actual retarget; the preimage then cancels back.
  exact mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    (forestOuterActualToRepPerm_spec g (forestComponentMixedBoundaryOuterIndex g q hq)) _

/-- Sprint F2e Step 2 (forest cancellation): actualization of the
forest-branch RHS image is the canonical actual quotient subgraph. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestQuotientForestSigmaActualQuotientSubgraph g
        (forestComponentForestChoiceToQuotientForestSigma g q hq) =
      forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq := by
  classical
  unfold forestQuotientForestSigmaActualQuotientSubgraph
    forestComponentForestChoiceToQuotientForestSigma
    forestComponentForestChoiceRepQuotientSubgraphCanonical
    forestComponentForestChoiceRepQuotientSubgraph
    forestComponentForestChoiceActualQuotientSubgraphCanonical
    forestComponentForestChoiceActualQuotientSubgraph
  exact mapPermAdmissibleSubgraphPreimage_mapPerm_eq
    (forestOuterActualToRepPerm_spec g (forestComponentForestChoiceOuterIndex g q hq)) _

/-- Sprint F2f Step 1: actualized branch discriminator.  An RHS flat index
`r` lies in the forest regime iff some component of its actual quotient
subgraph touches the outer star carrier.  This is the actual-level
predicate; the rep-level analogue is unavailable because the
`Classical.choose`-derived `forestOuterActualToRepPerm` carries no
starVertices-preservation spec. -/
private noncomputable def forestQuotientForestSigma_isForestByStar
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (r : forestQuotientForestSigma g) : Prop :=
  ∃ δ,
    δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r).elements ∧
    ¬ Disjoint δ.vertices
      (r.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1 r.1.2))

/-- Sprint F2f Step 2: the canonical forest-branch RHS image satisfies the
discriminator.  Direct composition of the F2e forest cancellation with the
F2d-2 actual-side ∃-witness. -/
private theorem forestQuotientForestSigma_isForestByStar_of_forest
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestQuotientForestSigma_isForestByStar g
      (forestComponentForestChoiceToQuotientForestSigma g q hq) := by
  classical
  unfold forestQuotientForestSigma_isForestByStar
  rw [forestQuotientForestSigmaActualQuotientSubgraph_forest g q hq]
  exact forestComponentForestChoiceActualQuotientSubgraph_exists_starVertex g q hq

/-- Sprint F2f Step 3: the canonical mixed-branch RHS image violates the
discriminator.  Direct composition of the F2e mixed cancellation with the
F2d-1 actual-side disjointness statement. -/
private theorem forestQuotientForestSigma_not_isForestByStar_of_mixed
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    ¬ forestQuotientForestSigma_isForestByStar g
      (forestComponentMixedBoundaryToQuotientForestSigma g q hq) := by
  classical
  unfold forestQuotientForestSigma_isForestByStar
  rw [forestQuotientForestSigmaActualQuotientSubgraph_mixed g q hq]
  rintro ⟨δ, hδ, hNot⟩
  exact hNot
    (forestComponentMixedBoundaryActualRightQuotientSubgraph_no_starVertices
      g q hq δ hδ)

/-- Sprint F2g-0: vertex-level inverse for cover scaffolding.  Any vertex of
a quotient subgraph that is disjoint from the star carrier comes from the
ambient outer complement, i.e. lives in `(repG g).vertices` but outside
`A.vertices`.  This is the first step toward lifting no-star quotient
components back to ambient `FeynmanSubgraph`s; only vertex containment is
asserted here — neither subgraph lift nor `IsConnectedDivergent` are
attempted yet. -/
private theorem forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {v : VertexId} (hv : v ∈ δ.vertices) :
    v ∈ (repG g).toFeynmanGraph.vertices ∧ v ∉ A.1.vertices := by
  classical
  have hvQ : v ∈ (forestOuterActualQuotientGraph g A).vertices :=
    δ.vertices_subset hv
  unfold forestOuterActualQuotientGraph at hvQ
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices] at hvQ
  rcases Finset.mem_union.mp hvQ with hRest | hStar
  · exact ⟨(Finset.mem_sdiff.mp hRest).1, (Finset.mem_sdiff.mp hRest).2⟩
  · exact absurd hStar (Finset.disjoint_left.mp hNoStar hv)

/-- Sprint F2g-1 (membership form, fallback per scout report).  An internal
edge of a no-star quotient component is already an internal edge of the
ambient graph `(repG g).toFG`.  Proof: pull back through
`contractWithStars_internalEdges = A.complementEdges.map (retargetEdge starOf)`,
then show the retarget acts as identity on the pre-image because no endpoint
can be in `A.vertices` (else it would retarget into `A.starVertices`, but
endpoints lie in `δ.vertices` which is disjoint from `A.starVertices`). -/
private theorem forestOuterActualQuotient_noStar_internalEdge_mem_ambient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {e : FeynmanEdge} (he : e ∈ δ.internalEdges) :
    e ∈ (repG g).toFeynmanGraph.internalEdges := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hSup : e.SupportedOn δ.vertices := δ.edges_supported e he
  have heQ : e ∈ (forestOuterActualQuotientGraph g A).internalEdges :=
    Multiset.mem_of_le δ.internalEdges_le he
  unfold forestOuterActualQuotientGraph at heQ
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges] at heQ
  rcases Multiset.mem_map.mp heQ with ⟨e_orig, heOrig, hRet⟩
  have hSrcNotStar : e.source ∉ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup.1
  have hTgtNotStar : e.target ∉ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup.2
  have hRetSrc : A.1.retargetVertex starOf e_orig.source = e.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRetTgt : A.1.retargetVertex starOf e_orig.target = e.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have hSrcOrigNotA : e_orig.source ∉ A.1.vertices := by
    intro hvA
    apply hSrcNotStar
    rw [← hRetSrc, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hTgtOrigNotA : e_orig.target ∉ A.1.vertices := by
    intro hvA
    apply hTgtNotStar
    rw [← hRetTgt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hRSrc := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hSrcOrigNotA
  have hRTgt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hTgtOrigNotA
  have hSrc : e_orig.source = e.source := hRSrc.symm.trans hRetSrc
  have hTgt : e_orig.target = e.target := hRTgt.symm.trans hRetTgt
  have hSec : e_orig.sector = e.sector := by
    have := congrArg FeynmanEdge.sector hRet
    simpa [AdmissibleSubgraph.retargetEdge] using this
  have hEqEdge : e_orig = e := by
    cases e_orig
    cases e
    exact (FeynmanEdge.mk.injEq _ _ _ _ _ _).mpr ⟨hSrc, hTgt, hSec⟩
  rw [← hEqEdge]
  exact AdmissibleSubgraph.mem_ambientInternalEdges_of_mem_complementEdges A.1 heOrig

/-- Sprint F2g-1 (membership form, external leg version).  An external leg of
a no-star quotient component is already an external leg of the ambient graph.
Proof is the leg analogue of the internal-edge version: the
`retargetExternalLeg` pre-image has `attachedTo ∉ A.vertices` (else it would
retarget into `A.starVertices`), so the retarget acts as identity. -/
private theorem forestOuterActualQuotient_noStar_externalLeg_mem_ambient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A)}
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    {ℓ : ExternalLeg} (hℓ : ℓ ∈ δ.externalLegs) :
    ℓ ∈ (repG g).toFeynmanGraph.externalLegs := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hSup : ℓ.SupportedOn δ.vertices := δ.legs_supported ℓ hℓ
  have hℓQ : ℓ ∈ (forestOuterActualQuotientGraph g A).externalLegs :=
    Multiset.mem_of_le δ.externalLegs_le hℓ
  unfold forestOuterActualQuotientGraph at hℓQ
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq] at hℓQ
  change ℓ ∈ (repG g).toFeynmanGraph.externalLegs.map
    (A.1.retargetExternalLeg starOf) at hℓQ
  rcases Multiset.mem_map.mp hℓQ with ⟨ℓ_orig, hℓOrig, hRet⟩
  have hAttNotStar : ℓ.attachedTo ∉ A.1.starVertices starOf :=
    Finset.disjoint_left.mp hNoStar hSup
  have hRetAtt : A.1.retargetVertex starOf ℓ_orig.attachedTo = ℓ.attachedTo := by
    have := congrArg ExternalLeg.attachedTo hRet; simpa using this
  have hAttOrigNotA : ℓ_orig.attachedTo ∉ A.1.vertices := by
    intro hvA
    apply hAttNotStar
    rw [← hRetAtt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hRAtt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hAttOrigNotA
  have hAtt : ℓ_orig.attachedTo = ℓ.attachedTo := hRAtt.symm.trans hRetAtt
  have hSec : ℓ_orig.sector = ℓ.sector := by
    have := congrArg ExternalLeg.sector hRet
    simpa [AdmissibleSubgraph.retargetExternalLeg] using this
  have hEqLeg : ℓ_orig = ℓ := by
    cases ℓ_orig
    cases ℓ
    exact (ExternalLeg.mk.injEq _ _ _ _).mpr ⟨hAtt, hSec⟩
  rw [← hEqLeg]; exact hℓOrig

/-- Sprint F2g-1b helper: retargetEdge uniqueness on no-star targets.  If a
canonical retarget sends `e_orig` to a no-star image `e`, then `e_orig = e`
(retarget acts as identity on edges whose endpoints lie outside both
`A.vertices` and `A.starVertices`).  Extracts the e_orig = e claim that was
inline in F2g-1; reused by the `_le` count chain below. -/
private theorem forestOuterActualQuotient_noStar_retargetEdge_eq_self
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {e_orig e : FeynmanEdge}
    (hRet : A.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2) e_orig = e)
    (hSrcS : e.source ∉ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2))
    (hTgtS : e.target ∉ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)) :
    e_orig = e := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hRSrc : A.1.retargetVertex starOf e_orig.source = e.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRTgt : A.1.retargetVertex starOf e_orig.target = e.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have hSrcNotA : e_orig.source ∉ A.1.vertices := by
    intro hvA; apply hSrcS
    rw [← hRSrc, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hTgtNotA : e_orig.target ∉ A.1.vertices := by
    intro hvA; apply hTgtS
    rw [← hRTgt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hRSId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hSrcNotA
  have hRTId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hTgtNotA
  have hSec : e_orig.sector = e.sector := by
    have := congrArg FeynmanEdge.sector hRet
    simpa [AdmissibleSubgraph.retargetEdge] using this
  cases e_orig; cases e
  exact (FeynmanEdge.mk.injEq _ _ _ _ _ _).mpr
    ⟨hRSId.symm.trans hRSrc, hRTId.symm.trans hRTgt, hSec⟩

/-- Sprint F2g-1b helper: retargetExternalLeg uniqueness on no-star targets.
Leg analogue of `_retargetEdge_eq_self`. -/
private theorem forestOuterActualQuotient_noStar_retargetLeg_eq_self
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {ℓ_orig ℓ : ExternalLeg}
    (hRet : A.1.retargetExternalLeg
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2) ℓ_orig = ℓ)
    (hAttS : ℓ.attachedTo ∉ A.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)) :
    ℓ_orig = ℓ := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  have hRAtt : A.1.retargetVertex starOf ℓ_orig.attachedTo = ℓ.attachedTo := by
    have := congrArg ExternalLeg.attachedTo hRet; simpa using this
  have hAttNotA : ℓ_orig.attachedTo ∉ A.1.vertices := by
    intro hvA; apply hAttS
    rw [← hRAtt, AdmissibleSubgraph.retargetVertex,
      A.1.componentAt?_of_mem hvA]
    exact AdmissibleSubgraph.mem_starVertices.mpr
      ⟨A.1.componentAt hvA, A.1.componentAt_mem hvA, rfl⟩
  have hRAId := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hAttNotA
  have hSec : ℓ_orig.sector = ℓ.sector := by
    have := congrArg ExternalLeg.sector hRet
    simpa [AdmissibleSubgraph.retargetExternalLeg] using this
  cases ℓ_orig; cases ℓ
  exact (ExternalLeg.mk.injEq _ _ _ _).mpr ⟨hRAId.symm.trans hRAtt, hSec⟩

/-- Sprint F2g-1b: lift a no-star quotient component to an ambient
`FeynmanSubgraph` with carriers verbatim equal to those of `δ`.  Admissibility
fields use the helpers `_retargetEdge_eq_self` / `_retargetLeg_eq_self` for
the multiset `_le` proofs (count-chain through quotient → A.complementEdges →
G.internalEdges, with retarget reducing to identity on no-star elements). -/
private noncomputable def forestOuterActualQuotientNoStarComponentLift
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    FeynmanSubgraph (repG g).toFeynmanGraph where
  vertices := δ.vertices
  internalEdges := δ.internalEdges
  externalLegs := δ.externalLegs
  vertices_subset := fun _ hv =>
    (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement g A hNoStar hv).1
  internalEdges_le := by
    classical
    set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2 with hstarOf
    rw [Multiset.le_iff_count]
    intro e
    by_cases hcnt : 0 < Multiset.count e δ.internalEdges
    · have he := Multiset.count_pos.mp hcnt
      have hSup := δ.edges_supported e he
      have hSrcStar : e.source ∉ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup.1
      have hTgtStar : e.target ∉ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup.2
      have hFilterLe : (A.1.complementEdges.filter
            (fun a => e = A.1.retargetEdge starOf a)) ≤
          (A.1.complementEdges.filter (fun a => e = a)) := by
        rw [Multiset.le_iff_count]
        intro x
        rw [Multiset.count_filter, Multiset.count_filter]
        split_ifs with hp hq
        · rfl
        · exfalso; apply hq
          exact (forestOuterActualQuotient_noStar_retargetEdge_eq_self
            g A hp.symm hSrcStar hTgtStar).symm
        all_goals omega
      have hCountComp : Multiset.count e A.1.complementEdges =
          (A.1.complementEdges.filter (fun a => e = a)).card := by
        unfold Multiset.count; exact Multiset.countP_eq_card_filter _ _
      calc Multiset.count e δ.internalEdges
          ≤ Multiset.count e (forestOuterActualQuotientGraph g A).internalEdges :=
            Multiset.count_le_of_le _ δ.internalEdges_le
        _ = (A.1.complementEdges.filter
              (fun a => e = A.1.retargetEdge starOf a)).card := by
            show Multiset.count e (A.1.contractWithStars starOf).internalEdges = _
            rw [AdmissibleSubgraph.contractWithStars_internalEdges, Multiset.count_map]
        _ ≤ (A.1.complementEdges.filter (fun a => e = a)).card :=
            Multiset.card_le_card hFilterLe
        _ = Multiset.count e A.1.complementEdges := hCountComp.symm
        _ ≤ Multiset.count e (repG g).toFeynmanGraph.internalEdges :=
            Multiset.count_le_of_le _ (Multiset.sub_le_self _ _)
    · omega
  externalLegs_le := by
    classical
    set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A.1 A.2 with hstarOf
    rw [Multiset.le_iff_count]
    intro ℓ
    by_cases hcnt : 0 < Multiset.count ℓ δ.externalLegs
    · have hℓ := Multiset.count_pos.mp hcnt
      have hSup := δ.legs_supported ℓ hℓ
      have hAttStar : ℓ.attachedTo ∉ A.1.starVertices starOf :=
        Finset.disjoint_left.mp hNoStar hSup
      have hFilterLe : ((repG g).toFeynmanGraph.externalLegs.filter
            (fun a => ℓ = A.1.retargetExternalLeg starOf a)) ≤
          ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ℓ = a)) := by
        rw [Multiset.le_iff_count]
        intro x
        rw [Multiset.count_filter, Multiset.count_filter]
        split_ifs with hp hq
        · rfl
        · exfalso; apply hq
          exact (forestOuterActualQuotient_noStar_retargetLeg_eq_self
            g A hp.symm hAttStar).symm
        all_goals omega
      have hCountG : Multiset.count ℓ (repG g).toFeynmanGraph.externalLegs =
          ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ℓ = a)).card := by
        unfold Multiset.count; exact Multiset.countP_eq_card_filter _ _
      calc Multiset.count ℓ δ.externalLegs
          ≤ Multiset.count ℓ (forestOuterActualQuotientGraph g A).externalLegs :=
            Multiset.count_le_of_le _ δ.externalLegs_le
        _ = ((repG g).toFeynmanGraph.externalLegs.filter
              (fun a => ℓ = A.1.retargetExternalLeg starOf a)).card := by
            show Multiset.count ℓ (A.1.contractWithStars starOf).externalLegs = _
            rw [AdmissibleSubgraph.contractWithStars_externalLegs, Multiset.count_map]
        _ ≤ ((repG g).toFeynmanGraph.externalLegs.filter (fun a => ℓ = a)).card :=
            Multiset.card_le_card hFilterLe
        _ = Multiset.count ℓ (repG g).toFeynmanGraph.externalLegs := hCountG.symm
    · omega
  edges_supported := δ.edges_supported
  legs_supported := δ.legs_supported

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).vertices = δ.vertices := rfl

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).internalEdges =
      δ.internalEdges := rfl

@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_externalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).externalLegs =
      δ.externalLegs := rfl

/-- Sprint F2g-2: the lift has the same `toFeynmanGraph` as `δ`.  All three
carriers (vertices, internalEdges, externalLegs) coincide by definition of
the lift, so `toFeynmanGraph` is structurally equal. -/
@[simp] private theorem forestOuterActualQuotientNoStarComponentLift_toFeynmanGraph
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2))) :
    (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).toFeynmanGraph =
      δ.toFeynmanGraph := rfl

/-- Sprint F2g-3: subgraph-level `IsConnectedDivergent` transports from `δ`
to its no-star lift.  `IsConnected` and `IsOnePI` are `toFeynmanGraph`-only
predicates so they transport definitionally (F2g-2 is `rfl`).  `IsDivergent`
requires `IsAmbientInvariantDivergence`: both sides reduce to the degree of
`FeynmanSubgraph.self δ.toFeynmanGraph _`, which is `rfl` after the F2g-2
cancellation. -/
private theorem forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    (hδCD : δ.IsConnectedDivergent) :
    (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).IsConnectedDivergent := by
  refine ⟨hδCD.isConnected, hδCD.isOnePI, ?_⟩
  -- IsDivergent: degree transport via IsAmbientInvariantDivergence.
  show 0 ≤ (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).divergenceDegree
  have hDeg :
      (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).divergenceDegree =
        δ.divergenceDegree := by
    show DivergenceMeasure.degree _ = DivergenceMeasure.degree _
    rw [← IsAmbientInvariantDivergence.degree_self_eq
          (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar),
        ← IsAmbientInvariantDivergence.degree_self_eq δ]
    rfl
  rw [hDeg]
  exact hδCD.isDivergent

/-- Sprint F2h-0 Step 1: in the mixed regime (RHS does NOT satisfy
`isForestByStar`), every component of the actualized RHS quotient subgraph
is disjoint from the outer star carrier.  Pure contrapositive of the
predicate definition. -/
private theorem forestQuotientForestSigma_all_noStar_of_not_isForestByStar
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ δ,
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements →
      Disjoint δ.vertices
        (r.1.1.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  intro δ hδ
  by_contra hDisj
  exact hNotForest ⟨δ, hδ, hDisj⟩

/-- Sprint F2h-0 Step 2: in the mixed regime, the actualized RHS quotient
components lift to a `Finset` of ambient `FeynmanSubgraph`s.  Each lifted
component is the F2g-1b no-star lift of the corresponding quotient
component, using the all-noStar disjointness from Step 1. -/
private noncomputable def forestQuotientForestSigmaMixedLiftedRightComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    Finset (FeynmanSubgraph (repG g).toFeynmanGraph) :=
  (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements.attach.image
    (fun δ =>
      forestOuterActualQuotientNoStarComponentLift g r.1.1 δ.1
        (forestQuotientForestSigma_all_noStar_of_not_isForestByStar
          g r hNotForest δ.1 δ.2))

/-- Sprint F2h-0 Step 3: spec of mixed lifted right components.  Existence
form (the full iff is awkward because the lift's proof-argument depends on
δ); membership entails the existence of an actual-side δ whose
`toFeynmanGraph` matches the lifted component. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_mem_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    ∃ δ, δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ∧
      γ.toFeynmanGraph = δ.toFeynmanGraph := by
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨⟨δ, hδ⟩, _, hEq⟩
  refine ⟨δ, hδ, ?_⟩
  rw [← hEq]
  exact forestOuterActualQuotientNoStarComponentLift_toFeynmanGraph
    g r.1.1 δ _

/-- Sprint F2h-0 Step 4: every lifted right component is connected-divergent
in the ambient.  Composition of `isConnectedDivergent_of_mem` on the
actualized RHS quotient subgraph with F2g-3 CD-transport. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_cd
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ γ,
      γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest →
      γ.IsConnectedDivergent := by
  intro γ hγ
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨⟨δ, hδ⟩, _, hEq⟩
  rw [← hEq]
  exact forestOuterActualQuotientNoStarComponentLift_isConnectedDivergent
    g r.1.1 δ _
    ((forestQuotientForestSigmaActualQuotientSubgraph g r.1
      ).isConnectedDivergent_of_mem hδ)

/-- Sprint F2h-0 Step 5: every lifted right component is vertex-disjoint
from the outer subgraph `r.1.1.1`.  Each vertex of the lifted component
comes from `δ.vertices` (via the F2g-1b vertices simp), and F2g-0 gives
that no-star δ-vertices avoid `A.vertices`. -/
private theorem forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ γ,
      γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest →
      Disjoint γ.vertices r.1.1.1.vertices := by
  intro γ hγ
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hγ
  rcases Finset.mem_image.mp hγ with ⟨⟨δ, hδ⟩, _, hEq⟩
  rw [← hEq]
  rw [forestOuterActualQuotientNoStarComponentLift_vertices]
  refine Finset.disjoint_left.mpr fun v hv hvA => ?_
  have hNoStar :=
    forestQuotientForestSigma_all_noStar_of_not_isForestByStar
      g r hNotForest δ hδ
  exact (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
    g r.1.1 hNoStar hv).2 hvA

/-- Sprint F2h-1 Target 1: left-left `NestedOrDisjoint`.  Two distinct
components of `r.1.1.1.elements` are NOD by direct delegation to the
admissible-subgraph forest's `nestedOrDisjoint` field. -/
private theorem forestQuotientForestSigmaMixedCover_left_left_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (_hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ γ₁, γ₁ ∈ r.1.1.1.elements →
    ∀ γ₂, γ₂ ∈ r.1.1.1.elements →
    γ₁ ≠ γ₂ →
      γ₁.NestedOrDisjoint γ₂ := fun γ₁ hγ₁ γ₂ hγ₂ hne =>
  r.1.1.1.forest.nestedOrDisjoint hγ₁ hγ₂ hne

/-- Sprint F2h-1 Target 2: right-right `NestedOrDisjoint`.  Each lifted
component carries the same three carrier fields as its source δ (F2g-1b
simp lemmas), so NOD transports from the actualized RHS quotient's
admissible forest along the carrier equalities. -/
private theorem forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ γ₁,
      γ₁ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest →
    ∀ γ₂,
      γ₂ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest →
    γ₁ ≠ γ₂ →
      γ₁.NestedOrDisjoint γ₂ := by
  intro γ₁ hγ₁ γ₂ hγ₂ hne
  unfold forestQuotientForestSigmaMixedLiftedRightComponents at hγ₁ hγ₂
  rcases Finset.mem_image.mp hγ₁ with ⟨⟨δ₁, hδ₁⟩, _, hEq₁⟩
  rcases Finset.mem_image.mp hγ₂ with ⟨⟨δ₂, hδ₂⟩, _, hEq₂⟩
  have hδne : δ₁ ≠ δ₂ := by
    intro h
    apply hne
    rw [← hEq₁, ← hEq₂]
    subst h
    rfl
  have hδNOD :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).forest.nestedOrDisjoint
      hδ₁ hδ₂ hδne
  rw [← hEq₁, ← hEq₂]
  rcases hδNOD with hN | hD
  · refine Or.inl ?_
    rcases hN with h | h
    · exact Or.inl ⟨h.1, h.2.1, h.2.2⟩
    · exact Or.inr ⟨h.1, h.2.1, h.2.2⟩
  · exact Or.inr hD

/-- Sprint F2h-1 Target 3: left-right `NestedOrDisjoint`.  Lifted right
components are vertex-disjoint from the outer (F2h-0 Step 5), and any
outer-element `γL` has vertices contained in `r.1.1.1.vertices`, so the
case collapses to `Or.inr` (vertex-disjoint). -/
private theorem forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∀ γL, γL ∈ r.1.1.1.elements →
    ∀ γR,
      γR ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest →
      γL.NestedOrDisjoint γR := by
  intro γL hγL γR hγR
  refine Or.inr ?_
  have hOutDisj :=
    forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
      g r hNotForest γR hγR
  refine Finset.disjoint_left.mpr fun v hvL hvR => ?_
  exact Finset.disjoint_left.mp hOutDisj hvR
    (AdmissibleSubgraph.mem_vertices.mpr ⟨γL, hγL, hvL⟩)

/-- Sprint F2h-2: mixed cover outer candidate.  Combines `r.1.1.1.elements`
(left-source admissible components) with the lifted right components
(F2h-0 Step 2) into a single ambient `AdmissibleSubgraph (repG g).toFG`.
CD is the union of outer-side `isConnectedDivergent_of_mem` and F2h-0
Step 4; pairwise `NestedOrDisjoint` dispatches via F2h-1 Targets 1/2/3
on the four `mem_union` cases (the right-left case applies Target 3 with
swapped args, then `.symm`).

This is the `q.1.1` candidate for the mixed branch preimage construction;
choice function `q.2` is built in a separate sprint. -/
private noncomputable def forestQuotientForestSigmaMixedCoverOuterCandidate
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (r.1.1.1.elements ∪
      forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest)
    (by
      refine ⟨?cd, ?nod⟩
      case cd =>
        intro γ hγ
        rcases Finset.mem_union.mp hγ with hLeft | hRight
        · exact r.1.1.1.isConnectedDivergent_of_mem hLeft
        · exact forestQuotientForestSigmaMixedLiftedRightComponents_cd
            g r hNotForest γ hRight
      case nod =>
        intro γ₁ hγ₁ γ₂ hγ₂ hne
        rcases Finset.mem_union.mp hγ₁ with hL1 | hR1
        · rcases Finset.mem_union.mp hγ₂ with hL2 | hR2
          · exact forestQuotientForestSigmaMixedCover_left_left_nestedOrDisjoint
              g r hNotForest γ₁ hL1 γ₂ hL2 hne
          · exact forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
              g r hNotForest γ₁ hL1 γ₂ hR2
        · rcases Finset.mem_union.mp hγ₂ with hL2 | hR2
          · exact (forestQuotientForestSigmaMixedCover_left_right_nestedOrDisjoint
              g r hNotForest γ₂ hL2 γ₁ hR1).symm
          · exact forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
              g r hNotForest γ₁ hR1 γ₂ hR2 hne)

@[simp] private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_elements
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest).elements =
      r.1.1.1.elements ∪
        forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := rfl

/-- Sprint F2h-3a Target 1: outer (left) and lifted-right components are
finset-disjoint.  Any γ in both would have a vertex in `γ.vertices`
(γ.IsNonempty via outer `HasNonemptyComponents`), which would lie in
`r.1.1.1.vertices` (since γ is a component of `r.1.1.1`), contradicting
F2h-0 Step 5 (lifted right components vertex-disjoint from outer). -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    Disjoint r.1.1.1.elements
      (forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) := by
  refine Finset.disjoint_left.mpr fun γ hLeft hRight => ?_
  have hDisj :=
    forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
      g r hNotForest γ hRight
  have hNE : γ.IsNonempty :=
    ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2) γ hLeft
  rcases Finset.card_pos.mp hNE with ⟨v, hv⟩
  exact Finset.disjoint_left.mp hDisj hv
    (AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hLeft, hv⟩)

/-- Sprint F2h-3a Target 2: membership dichotomy.  Every element of the
mixed cover candidate is in either the outer (left) part or the lifted
right part.  Direct `mem_union` unpack via the F2h-2 elements simp. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_mem_left_or_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements) :
    γ ∈ r.1.1.1.elements ∨
      γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := by
  rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements] at hγ
  exact Finset.mem_union.mp hγ

/-- Sprint F2h-3a Target 3a: if `γ` is in the outer (left) part, it is not
in the lifted right part.  Wrapper over Target 1. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_not_right_of_left
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hLeft : γ ∈ r.1.1.1.elements) :
    γ ∉ forestQuotientForestSigmaMixedLiftedRightComponents
      g r hNotForest := fun hRight =>
  Finset.disjoint_left.mp
    (forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
      g r hNotForest) hLeft hRight

/-- Sprint F2h-3a Target 3b: if `γ` is in the lifted right part, it is not
in the outer (left) part.  Symmetric wrapper over Target 1. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_not_left_of_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hRight :
      γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    γ ∉ r.1.1.1.elements := fun hLeft =>
  Finset.disjoint_left.mp
    (forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
      g r hNotForest) hLeft hRight

/-- Sprint F2h-3b: mixed cover choice function.  On the candidate outer
admissible subgraph, every component is either left-source (in
`r.1.1.1.elements`) or a lifted right component; assign `.left` to the
former and `.right` to the latter.  The `forest` branch is unused. -/
private noncomputable def forestQuotientForestSigmaMixedCoverChoiceFn
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceFn
      (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest) :=
  fun γ _ =>
    if γ.1 ∈ r.1.1.1.elements then
      forestCoproductChoice.left
    else
      forestCoproductChoice.right

/-- Sprint F2h-3b evaluation lemma (left): on a left-source component, the
choice function returns `.left`. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    (hLeft : γ ∈ r.1.1.1.elements) :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ⟨γ, hγ⟩
      (Finset.mem_attach _ ⟨γ, hγ⟩) =
      forestCoproductChoice.left := by
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs with h
  · rfl
  · exact absurd hLeft h

/-- Sprint F2h-3b evaluation lemma (right): on a lifted right component, the
choice function returns `.right`.  Uses F2h-3a Target 3b to rule out the
left branch. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    (hRight :
      γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest) :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ⟨γ, hγ⟩
      (Finset.mem_attach _ ⟨γ, hγ⟩) =
      forestCoproductChoice.right := by
  have hNotLeft :=
    forestQuotientForestSigmaMixedCoverOuterCandidate_not_left_of_right
      g r hNotForest hRight
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs with h
  · exact absurd h hNotLeft
  · rfl

/-- Sprint F2h-3b evaluation lemma (no forest): the choice function never
returns a `.forest B` value.  By construction it is binary (left ⊕ right). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_ne_forest
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ :
      γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
            g r hNotForest).elements)
    {B : AdmissibleSubgraph
      (repG (γ.toHopfGen
        ((forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
          ).isConnectedDivergent_of_mem hγ))).toFeynmanGraph} :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ⟨γ, hγ⟩
      (Finset.mem_attach _ ⟨γ, hγ⟩) ≠
      forestCoproductChoice.forest B := by
  unfold forestQuotientForestSigmaMixedCoverChoiceFn
  split_ifs <;> intro heq <;> cases heq

/-- Sprint F2h-3c: the LeftSubgraph of the mixed cover candidate equals the
original RHS outer `r.1.1.1`.  Reduces via `AdmissibleSubgraph.ext` +
`Forest.ext` to a Finset equality, then `Finset.ext` over the union
decomposition: outer elements stay (`isLeft = True` via F2h-3b left
evaluation), lifted-right elements are filtered out (`isLeft = False`
because F2h-3b right evaluation gives `.right ≠ .left`). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_leftSubgraph_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceLeftSubgraph
        (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)
      = r.1.1.1 := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  show (forestComponentChoiceLeftSubgraph
          (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
          (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)).elements =
         r.1.1.1.elements
  rw [forestComponentChoiceLeftSubgraph_elements,
    forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
  ext γ
  rw [Finset.mem_filter]
  constructor
  · rintro ⟨hUnion, hIsLeft⟩
    rcases Finset.mem_union.mp hUnion with hL | hR
    · exact hL
    · exfalso
      have hCand : γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
          g r hNotForest).elements := by
        rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
        exact Finset.mem_union_right _ hR
      unfold forestComponentChoiceIsLeft at hIsLeft
      rw [dif_pos hCand] at hIsLeft
      rw [forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
        g r hNotForest hCand hR] at hIsLeft
      cases hIsLeft
  · intro hL
    have hCand : γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
        g r hNotForest).elements := by
      rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
      exact Finset.mem_union_left _ hL
    refine ⟨Finset.mem_union_left _ hL, ?_⟩
    unfold forestComponentChoiceIsLeft
    rw [dif_pos hCand]
    exact forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
      g r hNotForest hCand hL

/-- Sprint F2h-3d Step 1: lifted right components packaged as an
`AdmissibleSubgraph` of the ambient.  CD per element via F2h-0 Step 4;
pairwise NOD via F2h-1 Target 2 (right-right NOD). -/
private noncomputable def forestQuotientForestSigmaMixedCoverRightCandidate
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    AdmissibleSubgraph (repG g).toFeynmanGraph :=
  AdmissibleSubgraph.ofElements
    (forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest)
    (by
      refine ⟨?cd, ?nod⟩
      case cd =>
        intro γ hγ
        exact forestQuotientForestSigmaMixedLiftedRightComponents_cd
          g r hNotForest γ hγ
      case nod =>
        intro γ₁ hγ₁ γ₂ hγ₂ hne
        exact forestQuotientForestSigmaMixedCover_right_right_nestedOrDisjoint
          g r hNotForest γ₁ hγ₁ γ₂ hγ₂ hne)

@[simp] private theorem forestQuotientForestSigmaMixedCoverRightCandidate_elements
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest).elements =
      forestQuotientForestSigmaMixedLiftedRightComponents g r hNotForest := rfl

/-- Sprint F2h-3d Step 2: the RightSubgraph of the mixed cover candidate
equals the lifted-right candidate.  Symmetric mirror of F2h-3c: the
`isRight` filter retains lifted-right elements (`.right` evaluation via
F2h-3b) and discards left-source elements (F2h-3b left evaluation gives
`.left ≠ .right`). -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_rightSubgraph_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceRightSubgraph
        (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)
      = forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest := by
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  show (forestComponentChoiceRightSubgraph
          (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest)
          (forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest)).elements =
         (forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest).elements
  rw [forestComponentChoiceRightSubgraph_elements,
    forestQuotientForestSigmaMixedCoverOuterCandidate_elements,
    forestQuotientForestSigmaMixedCoverRightCandidate_elements]
  ext γ
  rw [Finset.mem_filter]
  constructor
  · rintro ⟨hUnion, hIsRight⟩
    rcases Finset.mem_union.mp hUnion with hL | hR
    · exfalso
      have hCand : γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
          g r hNotForest).elements := by
        rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
        exact Finset.mem_union_left _ hL
      unfold forestComponentChoiceIsRight at hIsRight
      rw [dif_pos hCand] at hIsRight
      rw [forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
        g r hNotForest hCand hL] at hIsRight
      cases hIsRight
    · exact hR
  · intro hR
    have hCand : γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
        g r hNotForest).elements := by
      rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
      exact Finset.mem_union_right _ hR
    refine ⟨Finset.mem_union_right _ hR, ?_⟩
    unfold forestComponentChoiceIsRight
    rw [dif_pos hCand]
    exact forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
      g r hNotForest hCand hR

/-- Sprint F2h-4a helper 1: the actualized RHS quotient subgraph is in the
proper-disjoint carrier of the actual quotient graph.  Direct transport
via `mapPermAdmissibleSubgraphPreimage_mem_properDisjoint` from r.1.2's
membership in the rep-side `forestCoproductProperForestIndex`. -/
private theorem forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    forestQuotientForestSigmaActualQuotientSubgraph g r.1 ∈
      (forestOuterActualQuotientGraph g r.1.1
        ).properDisjointAdmissibleDivergentSubgraphs := by
  classical
  have hr2_idx := (Finset.mem_sigma.mp r.2).2
  unfold forestCoproductProperForestIndex at hr2_idx
  have hr2_PD := (Finset.mem_filter.mp hr2_idx).1
  unfold forestQuotientForestSigmaActualQuotientSubgraph
  exact mapPermAdmissibleSubgraphPreimage_mem_properDisjoint
    (forestOuterActualToRepPerm_spec g r.1.1) hr2_PD

/-- Sprint F2h-4a helper 2: mixed cover candidate is pairwise-disjoint.
3-way case-split on union membership: LL via outer's properDisjoint;
LR / RL via F2h-0 Step 5 + ambient `mem_vertices`; RR via lift
transport from actualQuotient's `IsPairwiseDisjoint`. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_isPairwiseDisjoint
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
      ).IsPairwiseDisjoint := by
  classical
  have hLIPD :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hActualIPD :=
    (forestOuterActualQuotientGraph g r.1.1
      ).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r)
  intro γ₁ hγ₁ γ₂ hγ₂ hne
  rw [← AdmissibleSubgraph.elements_def,
    forestQuotientForestSigmaMixedCoverOuterCandidate_elements] at hγ₁ hγ₂
  rcases Finset.mem_union.mp hγ₁ with hL1 | hR1
  · rcases Finset.mem_union.mp hγ₂ with hL2 | hR2
    · exact hLIPD hL1 hL2 hne
    · -- L vs R: F2h-0 Step 5 + γL.vertices ⊆ L.vertices
      have hRdisj :=
        forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
          g r hNotForest γ₂ hR2
      refine Finset.disjoint_left.mpr fun v hv1 hv2 => ?_
      exact Finset.disjoint_left.mp hRdisj hv2
        (AdmissibleSubgraph.mem_vertices.mpr ⟨γ₁, hL1, hv1⟩)
  · rcases Finset.mem_union.mp hγ₂ with hL2 | hR2
    · -- R vs L: symmetric
      have hRdisj :=
        forestQuotientForestSigmaMixedLiftedRightComponents_vertices_disjoint_outer
          g r hNotForest γ₁ hR1
      refine Finset.disjoint_left.mpr fun v hv1 hv2 => ?_
      exact Finset.disjoint_left.mp hRdisj hv1
        (AdmissibleSubgraph.mem_vertices.mpr ⟨γ₂, hL2, hv2⟩)
    · -- R vs R: lift transport from actualQuotient.IsPairwiseDisjoint
      unfold forestQuotientForestSigmaMixedLiftedRightComponents at hR1 hR2
      rcases Finset.mem_image.mp hR1 with ⟨⟨δ₁, hδ₁⟩, _, hEq₁⟩
      rcases Finset.mem_image.mp hR2 with ⟨⟨δ₂, hδ₂⟩, _, hEq₂⟩
      have hδne : δ₁ ≠ δ₂ := by
        intro h; apply hne; rw [← hEq₁, ← hEq₂]; subst h; rfl
      have hδDisj := hActualIPD hδ₁ hδ₂ hδne
      rw [← hEq₁, ← hEq₂]
      exact hδDisj

/-- Sprint F2h-4a helper 3: candidate is `IsNonempty`.  Outer side
`r.1.1.1.IsNonempty` is inherited from `r.1.1.2`'s `nonemptyDisjoint` chain. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_isNonempty
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest).IsNonempty := by
  classical
  have hLPDiff :=
    ((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs r.1.1.1).mp r.1.1.2
  have hLNDiff :=
    ((repG g).toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs r.1.1.1).mp
      hLPDiff.1
  have hLNE : r.1.1.1.IsNonempty := hLNDiff.2
  rcases hLNE with ⟨γ, hγ⟩
  show (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest).elements.Nonempty
  refine ⟨γ, ?_⟩
  rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
  exact Finset.mem_union_left _ hγ

/-- Sprint F2h-4a helper 4: candidate has nonempty components.  Outer side
inherits `HasNonemptyComponents` from `r.1.1.2`; right side transports
via the F2g-1b vertices simp (lift preserves `.vertices`). -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_hasNonemptyComponents
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
      ).HasNonemptyComponents := by
  classical
  have hLHNC :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  have hActualHNC :=
    (forestOuterActualQuotientGraph g r.1.1
      ).properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      (forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r)
  intro γ hγ
  rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements] at hγ
  rcases Finset.mem_union.mp hγ with hL | hR
  · exact hLHNC γ hL
  · unfold forestQuotientForestSigmaMixedLiftedRightComponents at hR
    rcases Finset.mem_image.mp hR with ⟨⟨δ, hδ⟩, _, hEq⟩
    rw [← hEq]
    show 0 < (forestOuterActualQuotientNoStarComponentLift g r.1.1 δ _).vertices.card
    rw [forestOuterActualQuotientNoStarComponentLift_vertices]
    exact hActualHNC δ hδ

/-- Sprint F2h-4a helper 5: candidate has positive internal-edges count.
Inherited from `r.1.1.1` whose internal edges sit inside `candidate.internalEdges`
as a summand. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_internalEdges_card_pos
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    0 < (forestQuotientForestSigmaMixedCoverOuterCandidate
          g r hNotForest).internalEdges.card := by
  classical
  have hLIEpos : 0 < r.1.1.1.internalEdges.card :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs
      r.1.1.1).mp r.1.1.2).2.2.1
  -- Get a witness e ∈ r.1.1.1.internalEdges, lift to candidate.internalEdges.
  rcases Multiset.card_pos_iff_exists_mem.mp hLIEpos with ⟨e, he⟩
  rw [AdmissibleSubgraph.mem_internalEdges] at he
  rcases he with ⟨γ, hγL, heγ⟩
  have hγCand : γ ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
      g r hNotForest).elements := by
    rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
    exact Finset.mem_union_left _ hγL
  apply Multiset.card_pos_iff_exists_mem.mpr
  refine ⟨e, ?_⟩
  rw [AdmissibleSubgraph.mem_internalEdges]
  exact ⟨γ, hγCand, heγ⟩

/-- Sprint F2h-4a helper 6: candidate has positive internal edges in every
component.  Outer side via `r.1.1.2`'s accessor; right side via lift
transport (F2g-1b internalEdges simp). -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_hasPositiveInternalEdgesComponents
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
      ).HasPositiveInternalEdgesComponents := by
  classical
  have hLHPIE :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      r.1.1.2
  have hActualHPIE :=
    (forestOuterActualQuotientGraph g r.1.1
      ).properDisjointAdmissibleDivergentSubgraphs_hasPositiveInternalEdgesComponents
      (forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r)
  intro γ hγ
  rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements] at hγ
  rcases Finset.mem_union.mp hγ with hL | hR
  · exact hLHPIE γ hL
  · unfold forestQuotientForestSigmaMixedLiftedRightComponents at hR
    rcases Finset.mem_image.mp hR with ⟨⟨δ, hδ⟩, _, hEq⟩
    rw [← hEq]
    show 0 < (forestOuterActualQuotientNoStarComponentLift g r.1.1 δ _).internalEdges.card
    rw [forestOuterActualQuotientNoStarComponentLift_internalEdges]
    exact hActualHPIE δ hδ

/-- Sprint F2h-4a main: mixed cover candidate ∈ properDisjoint.  Assembles
the five helper lemmas via the unfolded `mem_properDisjoint` chain. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_mem_properDisjoint
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest ∈
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs := by
  rw [FeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs,
      FeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs,
      FeynmanGraph.mem_disjointAdmissibleDivergentSubgraphs]
  exact ⟨⟨⟨(repG g).toFeynmanGraph.mem_admissibleDivergentSubgraphs
        (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest),
      forestQuotientForestSigmaMixedCoverOuterCandidate_isPairwiseDisjoint
        g r hNotForest⟩,
    forestQuotientForestSigmaMixedCoverOuterCandidate_isNonempty
      g r hNotForest⟩,
    forestQuotientForestSigmaMixedCoverOuterCandidate_hasNonemptyComponents
      g r hNotForest,
    forestQuotientForestSigmaMixedCoverOuterCandidate_internalEdges_card_pos
      g r hNotForest,
    forestQuotientForestSigmaMixedCoverOuterCandidate_hasPositiveInternalEdgesComponents
      g r hNotForest⟩

/-- Sprint F2h-4b: mixed cover choice function belongs to the
mixed-boundary core index of the candidate.  Three obligations:
(i) `pi` membership — choiceFn returns `.left` or `.right`, both in the
component choice index; (ii) `≠ allLeft` — lifted right components witness
a `.right` value; (iii) `≠ allRight` — outer left components witness a
`.left` value; (iv) `¬ hasForest` — by F2h-3b `_ne_forest`. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceFn_mem_mixedBoundaryCore
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest ∈
      forestComponentMixedBoundaryChoiceCoreIndex
        (forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest) := by
  classical
  -- Extract candidate witnesses (outer left γL, lifted right γR via δ).
  have hLPDiff :=
    ((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs r.1.1.1).mp r.1.1.2
  have hLNE : r.1.1.1.IsNonempty :=
    (((repG g).toFeynmanGraph.mem_nonemptyDisjointAdmissibleDivergentSubgraphs r.1.1.1).mp
      hLPDiff.1).2
  rcases hLNE with ⟨γL, hγLelem⟩
  have hγLCand : γL ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
      g r hNotForest).elements := by
    rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
    exact Finset.mem_union_left _ hγLelem
  have hActualPD :=
    forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r
  have hActualPDiff :=
    ((forestOuterActualQuotientGraph g r.1.1).mem_properDisjointAdmissibleDivergentSubgraphs
      _).mp hActualPD
  have hActualNE :
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).IsNonempty :=
    (((forestOuterActualQuotientGraph g r.1.1
      ).mem_nonemptyDisjointAdmissibleDivergentSubgraphs _).mp hActualPDiff.1).2
  rcases hActualNE with ⟨δ, hδ⟩
  have hNoStarδ :=
    forestQuotientForestSigma_all_noStar_of_not_isForestByStar
      g r hNotForest δ hδ
  set lifted := forestOuterActualQuotientNoStarComponentLift
    g r.1.1 δ hNoStarδ with hliftedDef
  have hLiftedRightMem :
      lifted ∈ forestQuotientForestSigmaMixedLiftedRightComponents
        g r hNotForest := by
    unfold forestQuotientForestSigmaMixedLiftedRightComponents
    exact Finset.mem_image.mpr ⟨⟨δ, hδ⟩, Finset.mem_attach _ _, rfl⟩
  have hLiftedCand : lifted ∈ (forestQuotientForestSigmaMixedCoverOuterCandidate
      g r hNotForest).elements := by
    rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements]
    exact Finset.mem_union_right _ hLiftedRightMem
  -- Now build mixed-boundary core membership.
  unfold forestComponentMixedBoundaryChoiceCoreIndex
  rw [Finset.mem_filter]
  refine ⟨?core, ?notForest⟩
  case core =>
    rw [mem_forestComponentCoreChoiceIndex]
    refine ⟨?pi, ?notAllLeft, ?notAllRight⟩
    case pi =>
      rw [Finset.mem_pi]
      intro γ _hattach
      unfold forestQuotientForestSigmaMixedCoverChoiceFn forestComponentChoiceIndex
        forestCoproductChoiceIndex
      split_ifs
      · exact Finset.mem_insert_self _ _
      · exact Finset.mem_insert_of_mem (Finset.mem_insert_self _ _)
    case notAllLeft =>
      intro hAllLeft
      have hRight :=
        forestQuotientForestSigmaMixedCoverChoiceFn_eq_right_of_mem_right
          g r hNotForest hLiftedCand hLiftedRightMem
      have hLeft :
          forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest
              ⟨lifted, hLiftedCand⟩ (Finset.mem_attach _ _) =
            forestCoproductChoice.left := by
        rw [hAllLeft]; rfl
      rw [hLeft] at hRight
      cases hRight
    case notAllRight =>
      intro hAllRight
      have hLeft :=
        forestQuotientForestSigmaMixedCoverChoiceFn_eq_left_of_mem_left
          g r hNotForest hγLCand hγLelem
      have hRight :
          forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest
              ⟨γL, hγLCand⟩ (Finset.mem_attach _ _) =
            forestCoproductChoice.right := by
        rw [hAllRight]; rfl
      rw [hRight] at hLeft
      cases hLeft
  case notForest =>
    intro hForest
    rcases hForest with ⟨⟨γ, hγ⟩, B, hB⟩
    exact forestQuotientForestSigmaMixedCoverChoiceFn_ne_forest
      g r hNotForest hγ hB

/-- Sprint F2h-4c helper: lift is injective on actualQuotient.elements.attach.
Carrier fields (vertices, internalEdges, externalLegs) are preserved by lift,
and `FeynmanSubgraph G` is determined by these three carriers under the
project's `DecidableEq` derivation. -/
private theorem forestOuterActualQuotientNoStarComponentLift_inj_on_attach
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {D : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)}
    (hAll :
      ∀ δ ∈ D.elements,
        Disjoint δ.vertices
          (A.1.starVertices
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph A.1 A.2)))
    {δ₁ δ₂ : {δ // δ ∈ D.elements}}
    (h : forestOuterActualQuotientNoStarComponentLift g A δ₁.1 (hAll δ₁.1 δ₁.2) =
         forestOuterActualQuotientNoStarComponentLift g A δ₂.1 (hAll δ₂.1 δ₂.2)) :
    δ₁ = δ₂ := by
  rcases δ₁ with ⟨γ₁, hγ₁⟩
  rcases δ₂ with ⟨γ₂, hγ₂⟩
  apply Subtype.ext
  show γ₁ = γ₂
  have hV := congrArg FeynmanSubgraph.vertices h
  have hI := congrArg FeynmanSubgraph.internalEdges h
  have hE := congrArg FeynmanSubgraph.externalLegs h
  rw [forestOuterActualQuotientNoStarComponentLift_vertices,
      forestOuterActualQuotientNoStarComponentLift_vertices] at hV
  rw [forestOuterActualQuotientNoStarComponentLift_internalEdges,
      forestOuterActualQuotientNoStarComponentLift_internalEdges] at hI
  rw [forestOuterActualQuotientNoStarComponentLift_externalLegs,
      forestOuterActualQuotientNoStarComponentLift_externalLegs] at hE
  cases γ₁; cases γ₂
  cases hV; cases hI; cases hE
  rfl

/-- Sprint F2h-4c: mixed cover candidate has positive complement edges count.
Cardinality chain:
`candidate.complementEdges.card = G.I.card - candidate.I.card`
`candidate.I = L.I + actualQuotient.I` (disjoint sum + lift carrier transport)
`actualQuotient.I.card = r.2.I.card` (mapPerm card preservation)
`r.2.I.card < quotient.I.card = L.complementEdges.card = G.I.card - L.I.card`
(from `r.2.complementEdges.card > 0`).
Therefore `candidate.I.card < G.I.card` and `complementEdges.card > 0`. -/
private theorem forestQuotientForestSigmaMixedCoverOuterCandidate_complementEdges_card_pos
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    0 < (forestQuotientForestSigmaMixedCoverOuterCandidate
          g r hNotForest).complementEdges.card := by
  classical
  set candidate := forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest
    with hCandDef
  set actual := forestQuotientForestSigmaActualQuotientSubgraph g r.1 with hActDef
  -- (1) r.2.complementEdges.card > 0
  have hr2pos : 0 < r.1.2.complementEdges.card := by
    have h := (Finset.mem_sigma.mp r.2).2
    unfold forestCoproductProperForestIndex at h
    exact (Finset.mem_filter.mp h).2
  -- (2) r.2 ∈ properDisjoint of the rep quotient graph (extract its IsPairwiseDisjoint)
  have hr2PD : r.1.2 ∈
      (forestOuterQuotientGraph g r.1.1).properDisjointAdmissibleDivergentSubgraphs := by
    have h := (Finset.mem_sigma.mp r.2).2
    unfold forestCoproductProperForestIndex at h
    exact (Finset.mem_filter.mp h).1
  have hr2IPD :=
    (forestOuterQuotientGraph g r.1.1).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hr2PD
  have hr2Iₗₑ := admissibleSubgraph_internalEdges_le_of_pairwise r.1.2 hr2IPD
  -- (3) r.2.complementEdges.card = forestOuterQuotientGraph.I.card - r.2.I.card
  have hr2ComplCardEq : r.1.2.complementEdges.card =
      (forestOuterQuotientGraph g r.1.1).internalEdges.card - r.1.2.internalEdges.card := by
    show ((forestOuterQuotientGraph g r.1.1).internalEdges - r.1.2.internalEdges).card = _
    exact Multiset.card_sub hr2Iₗₑ
  -- (4) forestOuterQuotientGraph.I.card = forestOuterActualQuotientGraph.I.card
  have hQuotCard : (forestOuterQuotientGraph g r.1.1).internalEdges.card =
      (forestOuterActualQuotientGraph g r.1.1).internalEdges.card := by
    rw [forestOuterActualToRepPerm_spec g r.1.1]
    show ((forestOuterActualQuotientGraph g r.1.1).mapPerm _).internalEdges.card = _
    rw [FeynmanGraph.mapPerm_internalEdges, Multiset.card_map]
  -- (5) forestOuterActualQuotientGraph.I.card = L.complementEdges.card
  have hActGraphCard : (forestOuterActualQuotientGraph g r.1.1).internalEdges.card =
      r.1.1.1.complementEdges.card := by
    unfold forestOuterActualQuotientGraph
    rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
        AdmissibleSubgraph.contractWithStars_internalEdges, Multiset.card_map]
  -- (6) r.2.I.card < L.complementEdges.card
  have hr2IltLCompl : r.1.2.internalEdges.card < r.1.1.1.complementEdges.card := by
    have h1 := hr2pos
    rw [hr2ComplCardEq] at h1
    rw [hQuotCard, hActGraphCard] at h1
    omega
  -- (7) actualQuotient.I = preimage r.2 internalEdges (card preserved via mapPerm)
  have hActICard : actual.internalEdges.card = r.1.2.internalEdges.card := by
    show (forestQuotientForestSigmaActualQuotientSubgraph g r.1
      ).internalEdges.card = _
    unfold forestQuotientForestSigmaActualQuotientSubgraph
    have hMap := mapPermAdmissibleSubgraphPreimage_internalEdges_map
      (forestOuterActualToRepPerm_spec g r.1.1) r.1.2
    have hc := congrArg Multiset.card hMap
    rw [Multiset.card_map] at hc
    exact hc
  -- (8) lifted-right partial sum = actual.internalEdges (multiset equality)
  have hLiftedSum : (∑ γ ∈ forestQuotientForestSigmaMixedLiftedRightComponents
        g r hNotForest, γ.internalEdges) = actual.internalEdges := by
    unfold forestQuotientForestSigmaMixedLiftedRightComponents
    rw [Finset.sum_image]
    · simp only [forestOuterActualQuotientNoStarComponentLift_internalEdges]
      exact Finset.sum_attach actual.elements (fun γ => γ.internalEdges)
    · intro δ₁ _ δ₂ _ h
      exact forestOuterActualQuotientNoStarComponentLift_inj_on_attach
        g r.1.1
        (forestQuotientForestSigma_all_noStar_of_not_isForestByStar g r hNotForest) h
  -- (9) candidate.internalEdges = L.internalEdges + actual.internalEdges
  have hCandI : candidate.internalEdges =
      r.1.1.1.internalEdges + actual.internalEdges := by
    show (∑ γ ∈ candidate.elements, γ.internalEdges) = _
    rw [forestQuotientForestSigmaMixedCoverOuterCandidate_elements,
      Finset.sum_union
        (forestQuotientForestSigmaMixedCoverOuterCandidate_left_right_disjoint
          g r hNotForest)]
    rw [hLiftedSum]
    rfl
  -- (10) L.I ≤ G.I
  have hLIₗₑG :=
    admissibleSubgraph_internalEdges_le_of_pairwise r.1.1.1
      ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        r.1.1.2)
  -- (11) L.complementEdges.card = G.I.card - L.I.card
  have hLComplCard : r.1.1.1.complementEdges.card =
      (repG g).toFeynmanGraph.internalEdges.card - r.1.1.1.internalEdges.card := by
    show ((repG g).toFeynmanGraph.internalEdges - r.1.1.1.internalEdges).card = _
    exact Multiset.card_sub hLIₗₑG
  have hLI_le_GI : r.1.1.1.internalEdges.card ≤
      (repG g).toFeynmanGraph.internalEdges.card :=
    Multiset.card_le_card hLIₗₑG
  -- (12) candidate.I ≤ G.I (so that we can use card_sub)
  have hCandIₗₑG :=
    admissibleSubgraph_internalEdges_le_of_pairwise candidate
      (forestQuotientForestSigmaMixedCoverOuterCandidate_isPairwiseDisjoint
        g r hNotForest)
  -- (13) candidate.complementEdges.card = G.I.card - candidate.I.card
  have hCandComplCard : candidate.complementEdges.card =
      (repG g).toFeynmanGraph.internalEdges.card - candidate.internalEdges.card := by
    show ((repG g).toFeynmanGraph.internalEdges - candidate.internalEdges).card = _
    exact Multiset.card_sub hCandIₗₑG
  -- (14) Combine: candidate.I.card = L.I.card + actual.I.card = L.I.card + r.2.I.card
  have hCandICard : candidate.internalEdges.card =
      r.1.1.1.internalEdges.card + r.1.2.internalEdges.card := by
    rw [hCandI, Multiset.card_add, hActICard]
  -- (15) Final: G.I.card - candidate.I.card > 0 via hr2IltLCompl
  rw [hLComplCard] at hr2IltLCompl
  rw [hCandComplCard, hCandICard]
  omega

/-- Sprint F2h-4d: the mixed cover preimage candidate as a flat LHS sigma.
Packages the outer candidate (with its `properDisjoint` membership) together
with the binary choice function. -/
private noncomputable def forestQuotientForestSigmaMixedCoverChoiceSigma
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentChoiceSigma g :=
  ⟨⟨forestQuotientForestSigmaMixedCoverOuterCandidate g r hNotForest,
      forestQuotientForestSigmaMixedCoverOuterCandidate_mem_properDisjoint
        g r hNotForest⟩,
    forestQuotientForestSigmaMixedCoverChoiceFn g r hNotForest⟩

/-- Sprint F2h-4d: membership of the mixed cover preimage candidate in the
mixed-boundary sigma index.  Assembles F2h-4a (properDisjoint), F2h-4c
(complement positivity) for the outer slot, and F2h-4b (mixed boundary core)
for the choice slot. -/
private theorem forestQuotientForestSigmaMixedCoverChoiceSigma_mem
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestQuotientForestSigmaMixedCoverChoiceSigma g r hNotForest ∈
      forestComponentMixedBoundaryChoiceSigmaIndex g := by
  classical
  unfold forestComponentMixedBoundaryChoiceSigmaIndex
  refine Finset.mem_sigma.mpr ⟨?outer, ?core⟩
  case outer =>
    refine Finset.mem_filter.mpr ⟨?attach, ?pos⟩
    case attach =>
      exact Finset.mem_attach _ _
    case pos =>
      exact forestQuotientForestSigmaMixedCoverOuterCandidate_complementEdges_card_pos
        g r hNotForest
  case core =>
    exact forestQuotientForestSigmaMixedCoverChoiceFn_mem_mixedBoundaryCore
      g r hNotForest

/-- Sprint F2h-5: the mixed-boundary outer index of the cover preimage `q`
equals the RHS outer index `r.1.1`.  Via `Subtype.ext` reduces to the
underlying AdmissibleSubgraph equality, which is F2h-3c's LeftSubgraph
identification (since `q.1.1 = candidate` and `q.2 = choiceFn` by rfl). -/
private theorem forestQuotientForestSigmaMixedCover_outerIndex_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentMixedBoundaryOuterIndex g
        (forestQuotientForestSigmaMixedCoverChoiceSigma g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceSigma_mem g r hNotForest)
      = r.1.1 := by
  apply Subtype.ext
  rw [forestComponentMixedBoundaryOuterIndex_val]
  exact forestQuotientForestSigmaMixedCoverChoiceFn_leftSubgraph_eq
    g r hNotForest

/-- Sprint F2h-6a local: retargeting a no-star lift through the outer
returns to the original quotient component.  On no-star δ, every vertex
of `lift δ` is outside `A.vertices` (F2g-0), so retarget acts as
identity component-wise.  Hence the retarget-subgraph reduces to a
FeynmanSubgraph whose three carriers coincide with δ's. -/
private theorem forestOuterActualQuotientNoStarComponentLift_retarget_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g A))
    (hNoStar :
      Disjoint δ.vertices
        (A.1.starVertices
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A.1 A.2)))
    (hEdges :
      (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).internalEdges ≤
        A.1.complementEdges) :
    admissibleSubgraphRetargetSubgraph A.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph A.1 A.2)
        (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar) hEdges
      = δ := by
  classical
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph A.1 A.2 with hstarOf
  -- Vertices: image of identity-on-no-star
  have hV :
      (admissibleSubgraphRetargetSubgraph A.1 starOf
        (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar) hEdges).vertices =
        δ.vertices := by
    show (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).vertices.image
        (A.1.retargetVertex starOf) = δ.vertices
    rw [forestOuterActualQuotientNoStarComponentLift_vertices]
    ext v
    simp only [Finset.mem_image]
    refine ⟨?_, ?_⟩
    · rintro ⟨u, hu, hRet⟩
      have hUnotA :=
        (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
          g A hNoStar hu).2
      rw [AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hUnotA] at hRet
      rw [← hRet]; exact hu
    · intro hv
      refine ⟨v, hv, ?_⟩
      have hvNotA :=
        (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
          g A hNoStar hv).2
      exact AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hvNotA
  -- InternalEdges: map of identity-on-no-star edges
  have hI :
      (admissibleSubgraphRetargetSubgraph A.1 starOf
        (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar) hEdges).internalEdges =
        δ.internalEdges := by
    show (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).internalEdges.map
        (A.1.retargetEdge starOf) = δ.internalEdges
    rw [forestOuterActualQuotientNoStarComponentLift_internalEdges]
    conv_rhs => rw [← Multiset.map_id δ.internalEdges]
    apply Multiset.map_congr rfl
    intro e he
    have hSup := δ.edges_supported e he
    have hSrcNotA :=
      (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
        g A hNoStar hSup.1).2
    have hTgtNotA :=
      (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
        g A hNoStar hSup.2).2
    have hRSrc := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hSrcNotA
    have hRTgt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hTgtNotA
    cases e
    show (⟨_, _, _⟩ : FeynmanEdge) = id _
    simp [AdmissibleSubgraph.retargetEdge, hRSrc, hRTgt]
  -- ExternalLegs: map of identity-on-no-star legs
  have hE :
      (admissibleSubgraphRetargetSubgraph A.1 starOf
        (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar) hEdges).externalLegs =
        δ.externalLegs := by
    show (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar).externalLegs.map
        (A.1.retargetExternalLeg starOf) = δ.externalLegs
    rw [forestOuterActualQuotientNoStarComponentLift_externalLegs]
    conv_rhs => rw [← Multiset.map_id δ.externalLegs]
    apply Multiset.map_congr rfl
    intro ℓ hℓ
    have hSup := δ.legs_supported ℓ hℓ
    have hAttNotA :=
      (forestOuterActualQuotient_noStar_vertex_mem_ambient_complement
        g A hNoStar hSup).2
    have hRAtt := AdmissibleSubgraph.retargetVertex_of_not_mem A.1 starOf hAttNotA
    cases ℓ
    show (⟨_, _⟩ : ExternalLeg) = id _
    simp [AdmissibleSubgraph.retargetExternalLeg, hRAtt]
  -- Assemble FeynmanSubgraph equality from 3 carrier equalities.
  generalize hLhsDef : admissibleSubgraphRetargetSubgraph A.1 starOf
      (forestOuterActualQuotientNoStarComponentLift g A δ hNoStar) hEdges = lhs at hV hI hE
  cases lhs; cases δ
  cases hV; cases hI; cases hE
  rfl

/-- Sprint F2h-6b Step 1: the missing direction of the mapPerm↔preimage
roundtrip — applying `mapPerm` to a `Preimage` recovers the original. -/
private theorem mapPermAdmissibleSubgraph_mapPermAdmissibleSubgraphPreimage_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (hπ : G₂ = G₁.mapPerm π) (A : AdmissibleSubgraph G₂) :
    mapPermAdmissibleSubgraph hπ
      (mapPermAdmissibleSubgraphPreimage hπ A) = A := by
  apply mapPermAdmissibleSubgraphPreimage_injective hπ
  exact mapPermAdmissibleSubgraphPreimage_mapPerm_eq hπ
    (mapPermAdmissibleSubgraphPreimage hπ A)

/-- Sprint F2h-6b Step 2: q-independent actual side equality.  Given a
generic `q` whose outer index matches `r.1.1` and whose right subgraph
matches the mixed-cover right candidate, the actual right quotient
subgraph (transported via `hOuter`) equals the actualized RHS quotient
forest.  Proof: destructure `r` so `r.1.1` becomes a free variable, then
`cases hOuter` aligns types; reduce to `.elements` equality via
`AdmissibleSubgraph.ext` / `Forest.ext` / `Finset.ext`, and use the
local retarget identity to match each lifted source δ with itself. -/
private theorem forestComponentMixedBoundaryActualRightQuotientSubgraph_eq_of_outer_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hOuter : forestComponentMixedBoundaryOuterIndex g q hq = r.1.1)
    (hRight :
      forestComponentChoiceRightSubgraph q.1.1 q.2 =
        forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest) :
    hOuter ▸
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq
      = forestQuotientForestSigmaActualQuotientSubgraph g r.1 := by
  classical
  -- Destructure r to expose r.1.1 as a free variable.
  obtain ⟨⟨A, D⟩, hr⟩ := r
  cases hOuter
  -- Now A := mixedBoundaryOuterIndex g q hq (free var substituted by the expression).
  apply AdmissibleSubgraph.ext
  apply Forest.ext
  apply Finset.ext
  intro δ
  -- Membership equivalence; both sides unfold by rfl-level defn.
  constructor
  · -- Forward: δ ∈ LHS → δ ∈ RHS.
    intro hδLHS
    -- hδLHS : δ ∈ LHS's forest.elements = LHS.elements (by rfl-level defn)
    --       = δ ∈ (RightSubgraph q.1.1 q.2).elements.attach.image
    --             (fun γ => admissibleSubgraphRetargetSubgraph A starOf γ.1 _)
    rcases Finset.mem_image.mp hδLHS with ⟨γ, _, hRetγ⟩
    obtain ⟨γ_val, γ_mem_orig⟩ := γ
    have γ_mem_lifted : γ_val ∈
        forestQuotientForestSigmaMixedLiftedRightComponents
          g ⟨⟨_, D⟩, hr⟩ hNotForest := by
      rw [← forestQuotientForestSigmaMixedCoverRightCandidate_elements
        g ⟨⟨_, D⟩, hr⟩ hNotForest, ← hRight]
      exact γ_mem_orig
    unfold forestQuotientForestSigmaMixedLiftedRightComponents at γ_mem_lifted
    rcases Finset.mem_image.mp γ_mem_lifted with ⟨δ₀, _, hLiftEq⟩
    have hNoStarδ₀ :=
      forestQuotientForestSigma_all_noStar_of_not_isForestByStar
        g ⟨⟨_, D⟩, hr⟩ hNotForest δ₀.1 δ₀.2
    subst hLiftEq
    have hδEqδ₀ : δ = δ₀.1 := by
      rw [← hRetγ]
      exact forestOuterActualQuotientNoStarComponentLift_retarget_eq
        g (forestComponentMixedBoundaryOuterIndex g q hq) δ₀.1 hNoStarδ₀
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq _ γ_mem_orig)
    rw [hδEqδ₀]
    exact δ₀.2
  · -- Backward: δ ∈ RHS → δ ∈ LHS.
    intro hδRHS
    have hNoStarδ :=
      forestQuotientForestSigma_all_noStar_of_not_isForestByStar
        g ⟨⟨_, D⟩, hr⟩ hNotForest δ hδRHS
    set lifted := forestOuterActualQuotientNoStarComponentLift g
      (forestComponentMixedBoundaryOuterIndex g q hq) δ hNoStarδ with hLiftedDef
    have hLiftedRight :
        lifted ∈ forestQuotientForestSigmaMixedLiftedRightComponents
          g ⟨⟨_, D⟩, hr⟩ hNotForest := by
      unfold forestQuotientForestSigmaMixedLiftedRightComponents
      exact Finset.mem_image.mpr ⟨⟨δ, hδRHS⟩, Finset.mem_attach _ _, rfl⟩
    have hLiftedInRightSubgraph : lifted ∈
        (forestComponentChoiceRightSubgraph q.1.1 q.2).elements := by
      rw [hRight, forestQuotientForestSigmaMixedCoverRightCandidate_elements]
      exact hLiftedRight
    refine Finset.mem_image.mpr
      ⟨⟨lifted, hLiftedInRightSubgraph⟩, Finset.mem_attach _ _, ?_⟩
    exact forestOuterActualQuotientNoStarComponentLift_retarget_eq
      g (forestComponentMixedBoundaryOuterIndex g q hq) δ hNoStarδ _

/-- Sprint F2h-6b Step 3 helper: `forestOuterActualToRepAdmissibleSubgraph`
applied to the actualization of `⟨A, D⟩` recovers `D` via the mapPerm
roundtrip identity. -/
private theorem forestOuterActualToRep_actualized_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    (D : AdmissibleSubgraph (forestOuterQuotientGraph g A)) :
    forestOuterActualToRepAdmissibleSubgraph g A
        (forestQuotientForestSigmaActualQuotientSubgraph g ⟨A, D⟩)
      = D := by
  unfold forestOuterActualToRepAdmissibleSubgraph
    forestQuotientForestSigmaActualQuotientSubgraph
  exact mapPermAdmissibleSubgraph_mapPermAdmissibleSubgraphPreimage_eq
    (forestOuterActualToRepPerm_spec g A) D

/-- Sprint F2h-6b Step 3: q-independent rep side equality.  Compose the
Step 2 actual-side equality with the Step 3 helper roundtrip. -/
private theorem forestComponentMixedBoundaryRepRightQuotientSubgraph_eq_of_outer_right
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hOuter : forestComponentMixedBoundaryOuterIndex g q hq = r.1.1)
    (hRight :
      forestComponentChoiceRightSubgraph q.1.1 q.2 =
        forestQuotientForestSigmaMixedCoverRightCandidate g r hNotForest) :
    hOuter ▸
      forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q hq
      = r.1.2 := by
  classical
  have hActual := forestComponentMixedBoundaryActualRightQuotientSubgraph_eq_of_outer_right
    g r hNotForest q hq hOuter hRight
  obtain ⟨⟨A, D⟩, hr⟩ := r
  cases hOuter
  -- Strip the now-trivial transport in hActual to a same-type Eq.
  change forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq
    = forestQuotientForestSigmaActualQuotientSubgraph g
        ⟨forestComponentMixedBoundaryOuterIndex g q hq, D⟩ at hActual
  show forestOuterActualToRepAdmissibleSubgraph g
      (forestComponentMixedBoundaryOuterIndex g q hq)
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq) = D
  rw [hActual]
  exact forestOuterActualToRep_actualized_eq g _ D

/-- Sprint F2h-6c: final sigma equality of the mixed cover preimage.
Combines F2h-5 (outer index equality) and Step 3 (rep right quotient
transport equality) via `Sigma.ext`.  The Step 3 transport Eq is converted
to HEq for the second component of `Sigma.ext` via
`eqRec_heq_iff_heq.mp ∘ heq_of_eq`. -/
private theorem forestQuotientForestSigmaMixedCover_toQuotientForestSigma_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    forestComponentMixedBoundaryToQuotientForestSigma g
        (forestQuotientForestSigmaMixedCoverChoiceSigma g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceSigma_mem g r hNotForest)
      = r.1 := by
  apply Sigma.ext
  · exact forestQuotientForestSigmaMixedCover_outerIndex_eq g r hNotForest
  · exact eqRec_heq_iff_heq.mp (heq_of_eq
      (forestComponentMixedBoundaryRepRightQuotientSubgraph_eq_of_outer_right
        g r hNotForest _ _
        (forestQuotientForestSigmaMixedCover_outerIndex_eq g r hNotForest)
        (forestQuotientForestSigmaMixedCoverChoiceFn_rightSubgraph_eq g r hNotForest)))

/-- Sprint F2h-7: mixed-branch preimage existence packaged from F2h-6c. -/
private theorem forestQuotientForestSigma_mixedPreimage_of_not_isForestByStar
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    ∃ q : forestComponentChoiceSigma g,
      ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1 :=
  ⟨forestQuotientForestSigmaMixedCoverChoiceSigma g r hNotForest,
    forestQuotientForestSigmaMixedCoverChoiceSigma_mem g r hNotForest,
    forestQuotientForestSigmaMixedCover_toQuotientForestSigma_eq g r hNotForest⟩

/-- Sprint F2h-7 disjunction wrapper: every RHS element is covered by either
the forest-branch image (TBD) or the mixed-branch image (provided here).
The forest-branch half remains for a future sprint; mixed-branch goes
through `Or.inr`. -/
private theorem forestQuotientForestSigma_cover_mixed_half
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hNotForest : ¬ forestQuotientForestSigma_isForestByStar g r.1) :
    (∃ q : forestComponentChoiceSigma g,
        ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q hq = r.1) ∨
    (∃ q : forestComponentChoiceSigma g,
        ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1) :=
  Or.inr (forestQuotientForestSigma_mixedPreimage_of_not_isForestByStar
    g r hNotForest)

/-- Sprint F2i-3a: candidate source-vertex set for forest-cover preimage
construction.  Given an RHS index `r` and an actualized quotient
component `δ`, produce the canonical `Finset VertexId` that should be
`γ.vertices` for the source component `γ` in the forest-branch
preimage.  Edges and legs are NOT touched in this sprint; we only
fix the vertex carrier.

Construction: take δ's non-star vertices (which lie in
`G.vertices \ A.vertices`, hence belong to γ's exterior), and union
with every `η.vertices` for `η ∈ A.elements` whose star lies in δ
(these η are the promoted forest components of γ, hence sit inside γ). -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceVertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Finset VertexId :=
  let starOf := FeynmanGraph.admissibleForestCanonicalStarOf
    (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  (δ.vertices \ r.1.1.1.starVertices starOf) ∪
    r.1.1.1.elements.biUnion (fun η =>
      if starOf η ∈ δ.vertices then η.vertices else ∅)

/-- Sprint F2i-3a sanity lemma 1: every non-star δ-vertex belongs to the
recovered source vertices. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    {v : VertexId} (hvδ : v ∈ δ.vertices)
    (hvNotStar :
      v ∉ r.1.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) :
    v ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  unfold forestQuotientForestSigmaForestCoverSourceVertices
  exact Finset.mem_union_left _ (Finset.mem_sdiff.mpr ⟨hvδ, hvNotStar⟩)

/-- Sprint F2i-3q-4l-1a: a non-star δ-vertex lies outside the outer
`r.1.1.1.vertices`.  Sharper per-vertex form of F2g-0's
`forestOuterActualQuotient_noStar_vertex_mem_ambient_complement` (which
required *all* of δ to be no-star); here only the single vertex needs to
be non-star.  Used by the F2i-3q-4l-1b disjoint proof (Left η vs Plus δF). -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    {v : VertexId}
    (hvδ : v ∈ δ.vertices)
    (hvNotStar :
      v ∉ r.1.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) :
    v ∉ r.1.1.1.vertices := by
  classical
  have hvQ : v ∈ (forestOuterActualQuotientGraph g r.1.1).vertices :=
    δ.vertices_subset hvδ
  unfold forestOuterActualQuotientGraph at hvQ
  simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices] at hvQ
  rcases Finset.mem_union.mp hvQ with hComp | hStar
  · exact (Finset.mem_sdiff.mp hComp).2
  · exact absurd hStar hvNotStar

/-- Sprint F2i-3q-4l-1b: a non-promoted outer element `η` (whose canonical
star does NOT lie in `δ.vertices`) has vertices disjoint from `Plus(δ)`'s
recovered source vertices.  Both `SourceVertices` branches are ruled out:
- non-star part `δ.vertices \ starVertices` lies outside `r.1.1.1.vertices`
  (F2i-3q-4l-1a), but `η ⊆ r.1.1.1`.
- promoted η'-union only contains η' with `starOf η' ∈ δ.vertices`, so
  η' ≠ η; by `r.1.1.1`'s pairwise disjointness, η.vertices ∩ η'.vertices = ∅. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_disjoint_nonPromoted_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hηA : η ∈ r.1.1.1.elements)
    (hηNonPromoted :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∉ δ.vertices) :
    Disjoint η.vertices
      (forestQuotientForestSigmaForestCoverSourceVertices g r δ) := by
  classical
  rw [Finset.disjoint_right]
  intro v hvSrc hvη
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hvSrc
  rcases Finset.mem_union.mp hvSrc with hNonStar | hPromoted
  · -- non-star branch: v ∉ r.1.1.1.vertices, but η ⊆ r.1.1.1.
    rcases Finset.mem_sdiff.mp hNonStar with ⟨hvδ, hvNotStar⟩
    have hvNotOuter :
        v ∉ r.1.1.1.vertices :=
      forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
        g r hvδ hvNotStar
    exact hvNotOuter
      (AdmissibleSubgraph.mem_vertices.mpr ⟨η, hηA, hvη⟩)
  · -- promoted branch: η' ≠ η, pairwise disjoint in r.1.1.1.
    rcases Finset.mem_biUnion.mp hPromoted with ⟨η', hη'A, hvBranch⟩
    by_cases hStar :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η' ∈ δ.vertices
    · simp only [hStar, if_true] at hvBranch
      have hne : η' ≠ η := by
        intro h; subst h; exact hηNonPromoted hStar
      have hPairwise : r.1.1.1.IsPairwiseDisjoint :=
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          r.1.1.2
      have hDisj : η'.Disjoint η := hPairwise hη'A hηA hne
      exact (Finset.disjoint_left.mp hDisj hvBranch) hvη
    · simp only [hStar, if_false] at hvBranch
      exact (Finset.notMem_empty v hvBranch).elim

/-- Sprint F2i-3a sanity lemma 2: for every outer element `η` whose
star lies in δ, all η-vertices belong to the recovered source. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hηA : η ∈ r.1.1.1.elements)
    (hStarInδ :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices) :
    η.vertices ⊆ forestQuotientForestSigmaForestCoverSourceVertices g r δ := by
  intro v hvη
  unfold forestQuotientForestSigmaForestCoverSourceVertices
  refine Finset.mem_union_right _ (Finset.mem_biUnion.mpr ⟨η, hηA, ?_⟩)
  simp only [hStarInδ, if_true]
  exact hvη

/-- Sprint F2i-3b: the recovered source-vertex set sits inside the ambient
graph `(repG g).toFG.vertices`.  Two cases:
- non-star δ-vertices come from the quotient graph's complement side,
  which is the ambient outer-complement (F2g-0 pattern).
- star-touching η.vertices come from outer elements of `r.1.1.1`, hence
  are in `A.vertices ⊆ ambient`. -/
private theorem forestQuotientForestSigmaForestCoverSourceVertices_subset_ambient
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverSourceVertices g r δ ⊆
      (repG g).toFeynmanGraph.vertices := by
  classical
  intro v hv
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hv
  rcases Finset.mem_union.mp hv with hLeft | hRight
  · -- non-star δ-vertex → ambient complement (F2g-0 pattern, no full disjointness needed).
    rcases Finset.mem_sdiff.mp hLeft with ⟨hvδ, hvNotStar⟩
    have hvQ : v ∈ (forestOuterActualQuotientGraph g r.1.1).vertices :=
      δ.vertices_subset hvδ
    unfold forestOuterActualQuotientGraph at hvQ
    simp only [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices] at hvQ
    rcases Finset.mem_union.mp hvQ with hRest | hStar
    · exact (Finset.mem_sdiff.mp hRest).1
    · exact absurd hStar hvNotStar
  · -- star-touching η.vertices → A.vertices → ambient.
    rcases Finset.mem_biUnion.mp hRight with ⟨η, hηA, hvBranch⟩
    by_cases hStarη :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η ∈ δ.vertices
    · simp only [hStarη, if_true] at hvBranch
      exact r.1.1.1.vertices_subset
        (AdmissibleSubgraph.mem_vertices.mpr ⟨η, hηA, hvBranch⟩)
    · simp only [hStarη, if_false] at hvBranch
      exact (Finset.notMem_empty v hvBranch).elim

/-- Sprint F2i-3c: internal-edge preimage compatibility predicate for the
forest-cover source subgraph.  A candidate multiset `E` of ambient edges
is a valid preimage of δ.internalEdges if:
- `E.map (A.retargetEdge starOf) = δ.internalEdges` (retarget produces δ),
- `E ≤ G.internalEdges` (subset of ambient edges),
- every edge in `E` has both endpoints in the recovered source vertices.

The third clause is needed so the resulting source subgraph is
well-formed (`edges_supported` field) without retroactive surgery. -/
private def forestQuotientForestSigmaForestCoverEdgePreimage
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (E : Multiset FeynmanEdge) : Prop :=
  let A := r.1.1.1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A r.1.1.2
  let V := forestQuotientForestSigmaForestCoverSourceVertices g r δ
  E.map (A.retargetEdge starOf) = δ.internalEdges ∧
  E ≤ (repG g).toFeynmanGraph.internalEdges ∧
  ∀ e ∈ E, e.source ∈ V ∧ e.target ∈ V

/-- Sprint F2i-3c: external-leg preimage compatibility predicate for the
forest-cover source subgraph.  Analogous to the edge predicate: retarget
recovers δ.externalLegs, multiset ≤ G.externalLegs, and every leg's
attachment is in the recovered source vertices. -/
private def forestQuotientForestSigmaForestCoverExternalLegPreimage
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (L : Multiset ExternalLeg) : Prop :=
  let A := r.1.1.1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph A r.1.1.2
  let V := forestQuotientForestSigmaForestCoverSourceVertices g r δ
  L.map (A.retargetExternalLeg starOf) = δ.externalLegs ∧
  L ≤ (repG g).toFeynmanGraph.externalLegs ∧
  ∀ ℓ ∈ L, ℓ.attachedTo ∈ V

/-- Sprint F2i-3d: explicit edge carrier for the forest-cover source
subgraph.  Take all ambient internal edges whose both endpoints lie in
the recovered source vertices.  Retarget equality with δ is NOT proven
here — only the membership / support fields. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset FeynmanEdge := by
  classical
  exact (repG g).toFeynmanGraph.internalEdges.filter fun e =>
    e.source ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ ∧
      e.target ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ

/-- Sprint F2i-3d: explicit external-leg carrier — ambient legs whose
attachment is in the recovered source vertices. -/
private noncomputable def forestQuotientForestSigmaForestCoverSourceExternalLegs
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset ExternalLeg := by
  classical
  exact (repG g).toFeynmanGraph.externalLegs.filter fun ℓ =>
    ℓ.attachedTo ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ

/-- Sprint F2i-3d: source internal edges are a sub-multiset of ambient. -/
private theorem forestQuotientForestSigmaForestCoverSourceInternalEdges_le
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    forestQuotientForestSigmaForestCoverSourceInternalEdges g r δ ≤
      (repG g).toFeynmanGraph.internalEdges := by
