private theorem graph_eq_mapPerm_inv_of_eq_mapPerm
    (G₀ G₁ : FeynmanGraph) (τ : Equiv.Perm VertexId)
    (h : G₀ = G₁.mapPerm τ) :
    G₁ = G₀.mapPerm τ⁻¹ := by
  calc
    G₁ = G₁.mapPerm (1 : Equiv.Perm VertexId) := (FeynmanGraph.mapPerm_one G₁).symm
    _ = G₁.mapPerm (τ⁻¹ * τ) := by simp
    _ = (G₁.mapPerm τ).mapPerm τ⁻¹ := by
      rw [← FeynmanGraph.mapPerm_mul]
    _ = G₀.mapPerm τ⁻¹ := by
      rw [← h]

/-- A split-star model supplies the final actual right-factor field
relabeling by applying fixed-forest fresh-star relabeling to the original
component forest. -/
private theorem forestComponentActualRightContractionFieldRelabelingOfSplitStarModel
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentActualRightContractionSplitStarModel) :
    forestComponentActualRightContractionFieldRelabeling where
  forest_field_relabel := by
    intro g q hq C
    rcases T.forest_model g q hq C with ⟨starOf, hFresh, hActual⟩
    rcases admissibleForestContractFreshStarFieldRelabeling_of_wellFormed
        (repG_wellFormed g) q.1.1 q.1.2 starOf hFresh with
      ⟨τ, hV, hI, hE⟩
    have hOrig :
        forestComponentChoiceOriginalRightContractGraph g q =
          (FeynmanGraph.admissibleForestContractGraphWithStars
            (repG g).toFeynmanGraph q.1.1 starOf).mapPerm τ := by
      apply FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr
      exact ⟨hV, hI, hE⟩
    have hOrigActual :
        forestComponentChoiceOriginalRightContractGraph g q =
          (forestComponentForestChoiceActualRightContractGraph g q hq C
            ).mapPerm τ := by
      rw [hOrig, hActual]
    have hActualGraph :
        forestComponentForestChoiceActualRightContractGraph g q hq C =
          (forestComponentChoiceOriginalRightContractGraph g q).mapPerm τ⁻¹ :=
      graph_eq_mapPerm_inv_of_eq_mapPerm
        (forestComponentChoiceOriginalRightContractGraph g q)
        (forestComponentForestChoiceActualRightContractGraph g q hq C)
        τ hOrigActual
    refine ⟨τ⁻¹, ?_, ?_, ?_⟩
    · exact congrArg FeynmanGraph.vertices hActualGraph
    · exact congrArg FeynmanGraph.internalEdges hActualGraph
    · exact congrArg FeynmanGraph.externalLegs hActualGraph
  mixed_field_relabel := by
    intro g q hq
    rcases T.mixed_model g q hq with ⟨starOf, hFresh, hActual⟩
    rcases admissibleForestContractFreshStarFieldRelabeling_of_wellFormed
        (repG_wellFormed g) q.1.1 q.1.2 starOf hFresh with
      ⟨τ, hV, hI, hE⟩
    have hOrig :
        forestComponentChoiceOriginalRightContractGraph g q =
          (FeynmanGraph.admissibleForestContractGraphWithStars
            (repG g).toFeynmanGraph q.1.1 starOf).mapPerm τ := by
      apply FeynmanGraph.mk.injEq _ _ _ _ _ _ |>.mpr
      exact ⟨hV, hI, hE⟩
    have hOrigActual :
        forestComponentChoiceOriginalRightContractGraph g q =
          (forestComponentMixedBoundaryActualRightContractGraph g q hq
            ).mapPerm τ := by
      rw [hOrig, hActual]
    have hActualGraph :
        forestComponentMixedBoundaryActualRightContractGraph g q hq =
          (forestComponentChoiceOriginalRightContractGraph g q).mapPerm τ⁻¹ :=
      graph_eq_mapPerm_inv_of_eq_mapPerm
        (forestComponentChoiceOriginalRightContractGraph g q)
        (forestComponentMixedBoundaryActualRightContractGraph g q hq)
        τ hOrigActual
    refine ⟨τ⁻¹, ?_, ?_, ?_⟩
    · exact congrArg FeynmanGraph.vertices hActualGraph
    · exact congrArg FeynmanGraph.internalEdges hActualGraph
    · exact congrArg FeynmanGraph.externalLegs hActualGraph

/-- Fieldwise actual right-factor relabeling gives literal graph relabeling. -/
private noncomputable def
    forestComponentActualRightContractionRelabelingOfFields
    [IsDivergencePreservedByAdmissibleForestContract]
    (T : forestComponentActualRightContractionFieldRelabeling) :
    forestComponentActualRightContractionRelabeling where
  forest_relabel := by
