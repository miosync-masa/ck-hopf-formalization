      forestComponentForestChoiceOuterIndex g q‚āā hq‚āā := congrArg Sigma.fst hEq
  have hFP := forestComponentForestChoiceToQuotientForestSigma_forestParents_eq_of_eq
    hq‚āĀ hq‚āā hEq
  have hA‚āĀ : q‚āĀ.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āĀ.1.2
  have hA‚āā : q‚āā.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q‚āā.1.2
  have hNE‚āĀ : q‚āĀ.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
