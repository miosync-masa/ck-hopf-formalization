        rw [forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical_elements]
        simpa [rem] using
          forestComponentForestChoiceRemnantComponents_mem_of_forest
            g q hq γ hChoice
      have hComponent :
          (forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
            g q hq).componentToHopfH rem =
          forestRightHopfH
            (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))
            B hBmem := by
        unfold AdmissibleSubgraph.componentToHopfH forestRightHopfH gen
        rw [dif_pos hremMem]
        apply congrArg MvPolynomial.X
        apply Subtype.ext
        simpa [rem, FeynmanSubgraph.toHopfGen_val,
          FeynmanGraph.admissibleForestRightWithCanonicalStars_val] using
          hClass B hChoice
      have hRemnant :
          forestComponentChoiceRemnantInnerTensorFactor q.1.1 q.2 hpCore γ
              (Finset.mem_attach q.1.1.elements γ) =
          forestRightHopfH
            (γ.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem γ.2))
            B hBmem := by
        simp [forestComponentChoiceRemnantInnerTensorFactor, hChoice, hBmem,
          hpCore]
      rw [hRemnant]
      have hCarrier :
          forestComponentForestChoiceRemnantComponentsForChoice
            g q hq γ (Finset.mem_attach q.1.1.elements γ) =
          ({rem} :
            Finset (FeynmanSubgraph
              (forestOuterActualQuotientGraph g
                (forestComponentForestChoiceOuterIndex g q hq)))) := by
        simp [forestComponentForestChoiceRemnantComponentsForChoice,
          hChoice, rem]
        rfl
      rw [hCarrier]
      rw [Finset.prod_singleton]
      exact hComponent

/-- Component-level contracted-graph class identifications imply the
graph-level remnant product transport package. -/
private noncomputable def
    forestComponentForestChoiceRemnantInnerProductGraphTransportOfComponentClass
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (T : forestComponentForestChoiceRemnantComponentClassTransport g) :
    forestComponentForestChoiceRemnantInnerProductGraphTransport g where
  pairwise := T.pairwise
  factor_product := by
    intro q hq γ
    exact forestComponentForestChoiceRemnant_factor_product_eq_of_componentClass
      g q hq γ (T.component_class q hq γ)

/-- Remaining bridge from the component-side contraction to the representative
contraction used by the component Hopf generator.  The quotient-remnant side is
already identified canonically with the component-side contraction. -/
private structure forestComponentForestChoiceComponentToRepContractionClassTransport
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  pairwise :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      Set.PairwiseDisjoint (↑q.1.1.elements.attach)
        (fun γ =>
          forestComponentForestChoiceRemnantComponentsForChoice g q hq γ
            (Finset.mem_attach q.1.1.elements γ))
  component_to_rep_class :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph //
          γ ∈ q.1.1.elements},
      ∀ B : AdmissibleSubgraph
        (repG (γ.1.toHopfGen
          (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph,
        (hB : q.2 γ (Finset.mem_attach q.1.1.elements γ) =
            forestCoproductChoice.forest B) →
        (FeynmanGraph.admissibleForestContractGraphWithStars γ.1.toFeynmanGraph
          (feynmanSubgraphRepToComponentAdmissibleSubgraph γ.1
            (q.1.1.isConnectedDivergent_of_mem γ.2) B)
          (forestComponentForestChoiceComponentRemnantStarOf g q hq γ B)).toClass =
        (FeynmanGraph.admissibleForestContractGraphWithStars
          (repG (γ.1.toHopfGen
            (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
          B
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG (γ.1.toHopfGen
              (q.1.1.isConnectedDivergent_of_mem γ.2))).toFeynmanGraph
            B
            (forestComponentChoice_forest_mem_properDisjoint_of_core_mem
              (mem_forestComponentForestChoiceCoreIndex_core_hasForest
                ((Finset.mem_sigma.mp hq).2)).1
              γ hB))).toClass

/-- After the quotient-remnant carrier disjointness is discharged
canonically, the only remnant transport datum left is the component-to-
representative contraction class bridge. -/
private structure forestComponentForestChoiceComponentToRepContractionClassBridge
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  component_to_rep_class :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
