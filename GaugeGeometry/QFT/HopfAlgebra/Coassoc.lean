private theorem mem_forestComponentCoreChoiceIndex
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : ‚ąÄ ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements},
      ő≥ ‚ąą A.elements.attach ‚Üí
        forestCoproductChoice
          (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))) :
    p ‚ąą forestComponentCoreChoiceIndex A ‚ÜĒ
      p ‚ąą A.elements.attach.pi (forestComponentChoiceIndex A) ‚ąß
        p ‚Č† forestComponentAllLeftChoice A ‚ąß
        p ‚Č† forestComponentAllRightChoice A := by
  unfold forestComponentCoreChoiceIndex
  rw [Finset.mem_filter]

/-- If a core component choice selects a genuine forest summand, that forest
comes from the strict forest-choice carrier for the component. -/
private theorem forestComponentChoice_forest_mem_coproductProperForestIndex_of_core_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : ‚ąÄ ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements},
      ő≥ ‚ąą A.elements.attach ‚Üí
        forestCoproductChoice
          (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (ő≥ : {ő≥ : FeynmanSubgraph G // ő≥ ‚ąą A.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hB :
      p ő≥ (Finset.mem_attach A.elements ő≥) =
        forestCoproductChoice.forest B) :
    B ‚ąą forestCoproductProperForestIndex
      (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2)) := by
  classical
  have hpPi :
      p ‚ąą A.elements.attach.pi (forestComponentChoiceIndex A) :=
    ((mem_forestComponentCoreChoiceIndex A p).mp hp).1
  rw [Finset.mem_pi] at hpPi
  have hChoice :
      p ő≥ (Finset.mem_attach A.elements ő≥) ‚ąą
        forestComponentChoiceIndex A ő≥ :=
    hpPi ő≥ (Finset.mem_attach A.elements ő≥)
  unfold forestComponentChoiceIndex forestCoproductChoiceIndex at hChoice
  rw [hB] at hChoice
  rw [Finset.mem_insert] at hChoice
  rcases hChoice with hLeft | hChoice
  ¬∑ cases hLeft
  rw [Finset.mem_insert] at hChoice
  rcases hChoice with hRight | hForest
  ¬∑ cases hRight
  rw [Finset.mem_image] at hForest
  rcases hForest with ‚ü®B', hB', hEq‚ü©
  have hB'eq : B' = B :=
    forestCoproductChoice_forest_injective
      (ő≥.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥.2)) hEq
  subst B'
  exact hB'

