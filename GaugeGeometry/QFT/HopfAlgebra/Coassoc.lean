/-- The indexed classifier supplies branch injectivity and cross-branch
separation, using component-complement positivity only to certify genuine
branch images as RHS carrier elements. -/
private def
    forestComponentSplitPhiBranchInjectivitySeparationOfIndexedClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceComponentComplementPositiveCertificate g q hq)
    (X : forestComponentSplitPhiIndexedBranchClassifier g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    let r₁ : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g q₁ hq₁ (C q₁ hq₁)⟩
    let r₂ : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g q₂ hq₂ (C q₂ hq₂)⟩
    have hr : r₁ = r₂ := Subtype.ext hφ
    have h₁ : X.preimage r₁ = Sum.inl q₁ :=
      X.forest_inv q₁ hq₁ r₁.2
    have h₂ : X.preimage r₂ = Sum.inl q₂ :=
      X.forest_inv q₂ hq₂ r₂.2
    rw [hr] at h₁
    exact Sum.inl.inj (h₁.symm.trans h₂)
  mixed_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    let r₁ : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q₁ hq₁⟩
    let r₂ : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q₂ hq₂⟩
    have hr : r₁ = r₂ := Subtype.ext hφ
    have h₁ : X.preimage r₁ = Sum.inr q₁ :=
      X.mixed_inv q₁ hq₁ r₁.2
    have h₂ : X.preimage r₂ = Sum.inr q₂ :=
      X.mixed_inv q₂ hq₂ r₂.2
    rw [hr] at h₁
    exact Sum.inr.inj (h₁.symm.trans h₂)
  cross := by
    intro qF hF qM hM hφ
    let rF : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentForestChoiceToQuotientForestSigma g qF hF,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_componentComplementPositive
          g qF hF (C qF hF)⟩
    let rM : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentMixedBoundaryToQuotientForestSigma g qM hM,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g qM hM⟩
    have hr : rF = rM := Subtype.ext hφ
    have hFpre : X.preimage rF = Sum.inl qF :=
      X.forest_inv qF hF rF.2
    have hMpre : X.preimage rM = Sum.inr qM :=
      X.mixed_inv qM hM rM.2
    rw [hr] at hFpre
    have hsum : Sum.inl qF = Sum.inr qM := hFpre.symm.trans hMpre
    cases hsum

