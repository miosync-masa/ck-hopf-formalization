/-- Forget the equality witness in a branch decision and keep only the chosen
split-LHS preimage.  The explicit return type keeps the two `Sum` branches from
leaving metavariables for Lean to infer. -/
private def forestComponentSplitPhiBranchDecisionPreimageOfClassify
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (classify :
      ‚ąÄ r : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g},
        forestComponentSplitPhiForestPreimageData g r.1 ‚äē
          forestComponentSplitPhiMixedPreimageData g r.1)
    (r : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g}) :
    forestComponentSplitChoiceSigma g :=
  match classify r with
  | Sum.inl data => (Sum.inl data.1 : forestComponentSplitChoiceSigma g)
  | Sum.inr data => (Sum.inr data.1 : forestComponentSplitChoiceSigma g)

/-- A propositional RHS branch-cover certificate can be turned into branch
decision cover data by choosing one of the finite preimage witnesses. -/
private noncomputable def forestComponentSplitPhiBranchDecisionCoverOfCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiBranchCoverCertificate g) :
    forestComponentSplitPhiBranchDecisionCover g where
  classify := by
    intro r
    by_cases hF :
      ‚ąÉ q, ‚ąÉ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq = r.1
    ¬∑ let q := Classical.choose hF
      let hqTarget := Classical.choose_spec hF
      let hq := Classical.choose hqTarget
      let htarget := Classical.choose_spec hqTarget
      exact Sum.inl ‚ü®q, ‚ü®hq, htarget‚ü©‚ü©
    ¬∑ have hM :
        ‚ąÉ q, ‚ąÉ hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1 := by
        rcases K.cover r.1 r.2 with hF' | hM
        ¬∑ exact False.elim (hF hF')
        ¬∑ exact hM
      let q := Classical.choose hM
      let hqTarget := Classical.choose_spec hM
      let hq := Classical.choose hqTarget
      let htarget := Classical.choose_spec hqTarget
      exact Sum.inr ‚ü®q, ‚ü®hq, htarget‚ü©‚ü©

/-- Image-normalization laws for a branch-cover classifier: when the RHS term is
already the canonical image of a genuine or mixed branch point, the classifier
returns that same branch point. -/
private structure forestComponentSplitPhiBranchDecisionImageLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g) where
  forest_preimage :
    ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      ‚ąÄ hr :
        forestComponentForestChoiceToQuotientForestSigma g q hq ‚ąą
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g D.classify
          ‚ü®forestComponentForestChoiceToQuotientForestSigma g q hq, hr‚ü© =
          Sum.inl q
  mixed_preimage :
    ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
      ‚ąÄ hr :
        forestComponentMixedBoundaryToQuotientForestSigma g q hq ‚ąą
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g D.classify
          ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr‚ü© =
          Sum.inr q

/-- Branch injectivity and cross-branch separation normalize any chosen RHS cover
classifier on canonical genuine and mixed images. -/
private def forestComponentSplitPhiBranchDecisionImageLawsOfSeparated
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g) :
    forestComponentSplitPhiBranchDecisionImageLaws g D where
  forest_preimage := by
    intro q hq hr
    cases h : D.classify
        ‚ü®forestComponentForestChoiceToQuotientForestSigma g q hq, hr‚ü© with
    | inl data =>
        have hqeq : data.1 = q :=
          J.forest_inj data.1 data.2.1 q hq data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h, hqeq]
    | inr data =>
        have hcross :
            forestComponentForestChoiceToQuotientForestSigma g q hq ‚Č†
              forestComponentMixedBoundaryToQuotientForestSigma g data.1 data.2.1 :=
          J.cross q hq data.1 data.2.1
        exact False.elim (hcross data.2.2.symm)
  mixed_preimage := by
    intro q hq hr
    cases h : D.classify
        ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr‚ü© with
    | inl data =>
        have hcross :
            forestComponentForestChoiceToQuotientForestSigma g data.1 data.2.1 ‚Č†
              forestComponentMixedBoundaryToQuotientForestSigma g q hq :=
          J.cross data.1 data.2.1 q hq
        exact False.elim (hcross data.2.2)
    | inr data =>
        have hqeq : data.1 = q :=
          J.mixed_inj data.1 data.2.1 q hq data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h, hqeq]

/-- Branch-decision plus reconstruction data for the RHS finite carrier.  This
is the final classifier payload in constructive form: every RHS term is
classified as a genuine or mixed image, with enough equality data to prove the
right inverse, and with branch-image laws for the canonical images. -/
private structure forestComponentSplitPhiBranchDecisionReconstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  classify :
    ‚ąÄ r : {r : forestQuotientForestSigma g // r ‚ąą forestQuotientForestSigmaIndex g},
      forestComponentSplitPhiForestPreimageData g r.1 ‚äē
        forestComponentSplitPhiMixedPreimageData g r.1
  forest_preimage :
    ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentForestChoiceSigmaIndex g,
      ‚ąÄ hr :
        forestComponentForestChoiceToQuotientForestSigma g q hq ‚ąą
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g classify
          ‚ü®forestComponentForestChoiceToQuotientForestSigma g q hq, hr‚ü© =
          Sum.inl q
  mixed_preimage :
    ‚ąÄ q, ‚ąÄ hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g,
      ‚ąÄ hr :
        forestComponentMixedBoundaryToQuotientForestSigma g q hq ‚ąą
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g classify
          ‚ü®forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr‚ü© =
          Sum.inr q

/-- Separate branch-cover data plus image laws rebuild the previous
decision/reconstruction package. -/
private def forestComponentSplitPhiBranchDecisionReconstructionOfCoverLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g)
    (L : forestComponentSplitPhiBranchDecisionImageLaws g D) :
    forestComponentSplitPhiBranchDecisionReconstruction g where
  classify := D.classify
  forest_preimage := L.forest_preimage
  mixed_preimage := L.mixed_preimage

/-- A branch decision/reconstruction package supplies the indexed branch
classifier. -/
private def forestComponentSplitPhiIndexedBranchClassifierOfDecision
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiBranchDecisionReconstruction g) :
    forestComponentSplitPhiIndexedBranchClassifier g where
  preimage := forestComponentSplitPhiBranchDecisionPreimageOfClassify g X.classify
  preimage_mem := by
    intro r
    cases h : X.classify r with
    | inl data =>
        have hq : data.1 ‚ąą forestComponentForestChoiceSigmaIndex g :=
          data.2.1
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitChoiceSigmaIndex] using hq
    | inr data =>
        have hq : data.1 ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g :=
          data.2.1
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitChoiceSigmaIndex] using hq
  right_inv := by
    intro r
    cases h : X.classify r with
    | inl data =>
        have hq : data.1 ‚ąą forestComponentForestChoiceSigmaIndex g :=
          data.2.1
        have htarget :
            forestComponentForestChoiceToQuotientForestSigma g data.1 hq =
              r.1 := data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitPhi_inl_of_mem g data.1 hq] using htarget
    | inr data =>
        have hq : data.1 ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g :=
          data.2.1
        have htarget :
            forestComponentMixedBoundaryToQuotientForestSigma g data.1 hq =
              r.1 := data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h,
          forestComponentSplitPhi_inr_of_mem g data.1 hq] using htarget
  forest_inv := by
    intro q hq hr
    exact X.forest_preimage q hq hr
  mixed_inv := by
    intro q hq hr
    exact X.mixed_preimage q hq hr

/-- Build the RHS indexed branch classifier from an ordinary branch cover plus
branch injectivity/separation.  This is the concrete finite-classifier
constructor used by the final source-edge H5.8 cut. -/
private noncomputable def
    forestComponentSplitPhiIndexedBranchClassifierOfSeparatedCover
