    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hEq :
      forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
      forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) :
    HEq
      (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q₁ hq₁)
      (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q₂ hq₂) := by
  unfold forestComponentMixedBoundaryToQuotientForestSigma at hEq
  exact Sigma_snd_heq_of_eq hEq

/-- Sprint F2-Track-B-HEq-1: casted-`Eq` form of the `RepRightQuotient`
equality, in `Sigma.snd` projection form.  This is the literal specialization
of `Sigma_snd_eqRec_of_eq` to the mixed `toQuotient` equality; the `.snd`
projections are defeq to `RepRightQuotientSubgraphCanonical` and the `.fst`
projections to `MixedOuterIndex`, but are kept in projection form here so the
`▸` motive matches the equation `congrArg Sigma.fst hEq` syntactically.
Downstream proofs reduce the projections in-context (`show`/`simp`). -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_repRight_eqRec_of_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hEq :
      forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
      forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) :
    (congrArg Sigma.fst hEq) ▸
        (forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁).snd =
      (forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂).snd :=
  Sigma_snd_eqRec_of_eq hEq

/-- Sprint F2-Track-B-HEq-2: `forestOuterActualToRepAdmissibleSubgraph` is
injective (fixed outer index `A`).  Un-perm step: apply the preimage and use
the `mapPermAdmissibleSubgraphPreimage_mapPerm_eq` round-trip. -/
private theorem forestOuterActualToRepAdmissibleSubgraph_injective
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : forestOuterProperIndex g)
    {B₁ B₂ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A)}
    (h : forestOuterActualToRepAdmissibleSubgraph g A B₁ =
      forestOuterActualToRepAdmissibleSubgraph g A B₂) :
    B₁ = B₂ := by
  unfold forestOuterActualToRepAdmissibleSubgraph at h
  have h2 := congrArg
    (mapPermAdmissibleSubgraphPreimage (forestOuterActualToRepPerm_spec g A)) h
  rwa [mapPermAdmissibleSubgraphPreimage_mapPerm_eq,
    mapPermAdmissibleSubgraphPreimage_mapPerm_eq] at h2

/-- Sprint F2-Track-B-HEq-2: generic un-perm under index transport.  For a
*free* outer-index equality `hA : A₁ = A₂` (so `cases hA` closes), the
`eqRec`-transported equality of `toRep`-images descends to an `eqRec`-equality
of the underlying actual-quotient forests.  Specialized later to the computed
`MixedOuterIndex` equality. -/
private theorem forestOuterActualToRep_eqRec_inj
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {B₁ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₁)}
    {B₂ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₂)}
    (h : hA ▸ forestOuterActualToRepAdmissibleSubgraph g A₁ B₁ =
      forestOuterActualToRepAdmissibleSubgraph g A₂ B₂) :
    hA ▸ B₁ = B₂ := by
  cases hA
  exact forestOuterActualToRepAdmissibleSubgraph_injective g A₁ h

/-- **Track B-forest-final-3 — genuine-forest quotient equality descends to the
actual quotient forest.**  The genuine-forest `toQuotient` image is
`⟨OuterIndex, toRep ActualQuotient⟩`; an equality of images gives an outer-index
equality (`fst`) and an `eqRec`-transported equality of `toRep ActualQuotient`
(`Sigma_snd_eqRec_of_eq`); un-`mapPerm` (`forestOuterActualToRep_eqRec_inj`) then
descends it to the underlying actual quotient forest.  This is the genuine-forest
analogue of the mixed-branch un-perm step, with the *actual* quotient forest
(carrying the star-collapsed remnants) recovered before the semantic
insertion-uniqueness kernel is invoked. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_actualQuotient_eqRec_of_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    hOuter ▸
        forestComponentForestChoiceActualQuotientSubgraphCanonical g q₁ hq₁ =
      forestComponentForestChoiceActualQuotientSubgraphCanonical g q₂ hq₂ :=
  forestOuterActualToRep_eqRec_inj g hOuter
    (Sigma_snd_eqRec_of_eq hEq)

/-- Generic `eqRec`/`elements` congruence over a **free** outer-index equality:
`cases hA` collapses the transport (legal because `A₁ A₂` are free variables),
then `.elements` is a plain `congrArg`.  This is the wall-free replacement for a
direct `cases` on a *computed* outer equality (`cases` on
`OuterIndex q₁ = OuterIndex q₂` fails dependent elimination — the computed-fst
wall). -/
private theorem admissibleSubgraph_elements_eqRec_of_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {B₁ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₁)}
    {B₂ : AdmissibleSubgraph (forestOuterActualQuotientGraph g A₂)}
    (h : hA ▸ B₁ = B₂) :
    hA ▸ B₁.elements = B₂.elements := by
  cases hA
  exact congrArg AdmissibleSubgraph.elements h

private theorem
    forestComponentForestChoiceActualQuotientComponents_eq_of_eqRec
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂)
    (h :
      hOuter ▸
          forestComponentForestChoiceActualQuotientSubgraphCanonical g q₁ hq₁ =
        forestComponentForestChoiceActualQuotientSubgraphCanonical g q₂ hq₂) :
    hOuter ▸ forestComponentForestChoiceActualQuotientComponents g q₁ hq₁ =
      forestComponentForestChoiceActualQuotientComponents g q₂ hq₂ :=
  admissibleSubgraph_elements_eqRec_of_eq g hOuter h

/-- Sprint F2-Track-B-HEq-3: data-preserving injectivity of
`admissibleSubgraphRetargetSubgraph` on subgraphs **vertex-disjoint from the
carrier** `A`.  Unlike the star-collapse injectivity (B-1b-2), here retarget
preserves all data (`toFeynmanGraph_eq_of_not_mem`), so equal retargets force
equal sources via `FeynmanSubgraph.ext`.  This is the relevant case for the
mixed-branch RightSubgraph (its components are disjoint from the LeftSubgraph
carrier). -/
private theorem admissibleSubgraphRetargetSubgraph_inj_of_not_mem
    {G : FeynmanGraph} [DivergenceMeasure G]
    (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G → VertexId)
    {γ₁ γ₂ : FeynmanSubgraph G}
    (hE₁ : γ₁.internalEdges ≤ A.complementEdges)
    (hE₂ : γ₂.internalEdges ≤ A.complementEdges)
    (hV₁ : ∀ v ∈ γ₁.vertices, v ∉ A.vertices)
    (hV₂ : ∀ v ∈ γ₂.vertices, v ∉ A.vertices)
    (h : admissibleSubgraphRetargetSubgraph A starOf γ₁ hE₁ =
      admissibleSubgraphRetargetSubgraph A starOf γ₂ hE₂) :
    γ₁ = γ₂ := by
  have h1 : γ₁.toFeynmanGraph = γ₂.toFeynmanGraph := by
    have hc := congrArg FeynmanSubgraph.toFeynmanGraph h
    rwa [admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem A starOf γ₁ hE₁ hV₁,
      admissibleSubgraphRetargetSubgraph_toFeynmanGraph_eq_of_not_mem A starOf γ₂ hE₂ hV₂] at hc
  exact FeynmanSubgraph.ext_iff.mpr
    ⟨congrArg FeynmanGraph.vertices h1,
     congrArg FeynmanGraph.internalEdges h1,
     congrArg FeynmanGraph.externalLegs h1⟩

/-- Sprint F2-Track-B-HEq-4: from an `eqRec`-equality of certificate-built
actual retargeted forests (free outer index), recover the underlying source
forest element-set equality.  `cases hA` collapses the transport (free index),
then a `Finset.ext` uses the off-carrier retarget injectivity (B-HEq-3) on both
directions.  `hV₁`/`hV₂` supply the vertex-disjointness of the source elements
from the carrier. -/
private theorem forestOuterActualRetargetOfCert_elements_eq_of_eqRec
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) {A₁ A₂ : forestOuterProperIndex g} (hA : A₁ = A₂)
    {S₁ S₂ : AdmissibleSubgraph (repG g).toFeynmanGraph}
    (C₁ : forestOuterActualRetargetCertificate g A₁ S₁)
    (C₂ : forestOuterActualRetargetCertificate g A₂ S₂)
    (hV₁ : ∀ γ ∈ S₁.elements, ∀ v ∈ γ.vertices, v ∉ A₁.1.vertices)
    (hV₂ : ∀ γ ∈ S₂.elements, ∀ v ∈ γ.vertices, v ∉ A₂.1.vertices)
    (h : hA ▸ forestOuterActualRetargetAdmissibleSubgraphOfCert g A₁ S₁ C₁ =
      forestOuterActualRetargetAdmissibleSubgraphOfCert g A₂ S₂ C₂) :
    S₁.elements = S₂.elements := by
  cases hA
  change forestOuterActualRetargetAdmissibleSubgraphOfCert g A₁ S₁ C₁ =
    forestOuterActualRetargetAdmissibleSubgraphOfCert g A₁ S₂ C₂ at h
  -- `.elements` of OfCert reduces to the retarget image by `rfl`; coerce.
  have he :
      S₁.elements.attach.image (fun γ =>
        admissibleSubgraphRetargetSubgraph A₁.1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A₁.1 A₁.2) γ.1 (C₁.edge_le γ.1 γ.2)) =
      S₂.elements.attach.image (fun γ =>
        admissibleSubgraphRetargetSubgraph A₁.1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A₁.1 A₁.2) γ.1 (C₂.edge_le γ.1 γ.2)) :=
    congrArg AdmissibleSubgraph.elements h
  apply Finset.ext
  intro x
  constructor
  · intro hx
    have hxim :
        admissibleSubgraphRetargetSubgraph A₁.1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A₁.1 A₁.2) x (C₁.edge_le x hx) ∈
        S₁.elements.attach.image (fun γ =>
          admissibleSubgraphRetargetSubgraph A₁.1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph A₁.1 A₁.2) γ.1 (C₁.edge_le γ.1 γ.2)) :=
      Finset.mem_image.mpr ⟨⟨x, hx⟩, Finset.mem_attach _ _, rfl⟩
    rw [he] at hxim
    obtain ⟨⟨y, hy⟩, _, hxy⟩ := Finset.mem_image.mp hxim
    have hyx : y = x :=
      admissibleSubgraphRetargetSubgraph_inj_of_not_mem A₁.1 _
        (C₂.edge_le y hy) (C₁.edge_le x hx) (hV₂ y hy) (hV₁ x hx) hxy
    rwa [hyx] at hy
  · intro hx
    have hxim :
        admissibleSubgraphRetargetSubgraph A₁.1
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph A₁.1 A₁.2) x (C₂.edge_le x hx) ∈
        S₂.elements.attach.image (fun γ =>
          admissibleSubgraphRetargetSubgraph A₁.1
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph A₁.1 A₁.2) γ.1 (C₂.edge_le γ.1 γ.2)) :=
      Finset.mem_image.mpr ⟨⟨x, hx⟩, Finset.mem_attach _ _, rfl⟩
    rw [← he] at hxim
    obtain ⟨⟨y, hy⟩, _, hxy⟩ := Finset.mem_image.mp hxim
    have hyx : y = x :=
      admissibleSubgraphRetargetSubgraph_inj_of_not_mem A₁.1 _
        (C₁.edge_le y hy) (C₂.edge_le x hx) (hV₁ y hy) (hV₂ x hx) hxy
    rwa [hyx] at hy

/-- Sprint F2-Track-B-1a: mixed `toQuotient` equality gives `LeftSubgraph`
equality at the underlying-AdmissibleSubgraph level.  Take `Sigma.fst` of the
target Sigma equality, then unfold `MixedOuterIndex.val` (the simp lemma) to
expose the LeftSubgraph. -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_leftSubgraph_eq_of_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hEq :
      forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
      forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) :
    forestComponentChoiceLeftSubgraph q₁.1.1 q₁.2 =
      forestComponentChoiceLeftSubgraph q₂.1.1 q₂.2 := by
  have hOuter : forestComponentMixedBoundaryOuterIndex g q₁ hq₁ =
      forestComponentMixedBoundaryOuterIndex g q₂ hq₂ :=
    congrArg Sigma.fst hEq
  have hVal := congrArg Subtype.val hOuter
  simpa [forestComponentMixedBoundaryOuterIndex_val] using hVal

/-- Sprint F2-Track-B-HEq-5a: mixed-branch Left/Right partition of the outer
admissible elements.  In the mixed-boundary regime every component is left or
right (no forest choice), so `Left.elements ∪ Right.elements = A.elements`.
(Local copy preceding the q.1-recovery proof; an identical lemma exists
downstream for the original cover-side caller.) -/
private theorem forestComponentMixedBoundary_left_union_right_elements_recovery
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
        (forestComponentChoiceRightSubgraph q.1.1 q.2).elements =
      q.1.1.elements := by
  classical
  have hp : q.2 ∈ forestComponentMixedBoundaryChoiceCoreIndex q.1.1 :=
    (Finset.mem_sigma.mp hq).2
  have hNoForest : ¬ forestComponentChoiceHasForest q.1.1 q.2 := by
    unfold forestComponentMixedBoundaryChoiceCoreIndex at hp
    exact (Finset.mem_filter.mp hp).2
  ext γ
  constructor
  · intro hγ
    rcases Finset.mem_union.mp hγ with hγL | hγR
    · exact forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hγL
    · exact forestComponentChoiceRightSubgraph_elements_subset q.1.1 q.2 hγR
  · intro hγA
    rcases forestCoproductChoice_eq_left_or_right_or_forest
        (γ.toHopfGen (q.1.1.isConnectedDivergent_of_mem hγA))
        (q.2 ⟨γ, hγA⟩ (Finset.mem_attach q.1.1.elements ⟨γ, hγA⟩)) with
      hLeft | hRightOrForest
    · apply Finset.mem_union_left
      rw [forestComponentChoiceLeftSubgraph_elements]
      exact Finset.mem_filter.mpr ⟨hγA, by
        unfold forestComponentChoiceIsLeft
        rw [dif_pos hγA]; exact hLeft⟩
    · rcases hRightOrForest with hRight | hForest
      · apply Finset.mem_union_right
        rw [forestComponentChoiceRightSubgraph_elements]
        exact Finset.mem_filter.mpr ⟨hγA, by
          unfold forestComponentChoiceIsRight
          rw [dif_pos hγA]; exact hRight⟩
      · rcases hForest with ⟨B, hB⟩
        exact False.elim (hNoForest ⟨⟨γ, hγA⟩, B, hB⟩)

/-- Sprint F2-Track-B-HEq-5b: **mixed `q.1` recovery**.  From `toQuotient`
equality, recover the outer proper-index value `q₁.1 = q₂.1`.  Chain:
LeftSubgraph eq (B-1a) + RightSubgraph elements eq (B-HEq-1 → un-perm B-HEq-2
→ un-retarget B-HEq-4) + Left/Right partition (B-HEq-5a) gives `A.elements`
equality, closed by `forestOuterProperIndex_eq_of_elements_eq`. -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_q1_recovery
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hEq :
      forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
      forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) :
    q₁.1 = q₂.1 := by
  -- LeftSubgraph equality (B-1a)
  have hLeft := forestComponentMixedBoundaryToQuotientForestSigma_leftSubgraph_eq_of_eq
    hq₁ hq₂ hEq
  -- off-carrier vertex-disjointness for Right components
  have hPD₁ : q₁.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q₁.1.2
  have hPD₂ : q₂.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q₂.1.2
  -- RightSubgraph elements equality: un-perm (B-HEq-2) then un-retarget (B-HEq-4)
  have hRight :
      (forestComponentChoiceRightSubgraph q₁.1.1 q₁.2).elements =
      (forestComponentChoiceRightSubgraph q₂.1.1 q₂.2).elements :=
    forestOuterActualRetargetOfCert_elements_eq_of_eqRec g (congrArg Sigma.fst hEq)
      (forestComponentMixedBoundaryRightRetargetCertificateCanonical g q₁ hq₁)
      (forestComponentMixedBoundaryRightRetargetCertificateCanonical g q₂ hq₂)
      (fun γ hγ v hv =>
        forestComponentChoiceRight_vertices_not_mem_leftSubgraph q₁.1.1 q₁.2 hPD₁ hγ hv)
      (fun γ hγ v hv =>
        forestComponentChoiceRight_vertices_not_mem_leftSubgraph q₂.1.1 q₂.2 hPD₂ hγ hv)
      (forestOuterActualToRep_eqRec_inj g (congrArg Sigma.fst hEq)
        (forestComponentMixedBoundaryToQuotientForestSigma_repRight_eqRec_of_eq hq₁ hq₂ hEq))
  -- combine via partition
  apply forestOuterProperIndex_eq_of_elements_eq
  rw [← forestComponentMixedBoundary_left_union_right_elements_recovery q₁ hq₁,
      ← forestComponentMixedBoundary_left_union_right_elements_recovery q₂ hq₂,
      hRight]
  rw [show (forestComponentChoiceLeftSubgraph q₁.1.1 q₁.2).elements =
        (forestComponentChoiceLeftSubgraph q₂.1.1 q₂.2).elements from
      congrArg AdmissibleSubgraph.elements hLeft]

/-- Sprint F2-Track-B-HEq-6: **mixed-branch same-branch injectivity** (the
`mixed_inj` field of `BranchInjectivitySeparation`).  Combines the `q.1`
recovery (B-HEq-5b) with the q.1-fixed injectivity `_inj_of_q1_eq` (F1r-2b). -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_inj
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen}
    {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hEq :
      forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
      forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) :
    q₁ = q₂ :=
  forestComponentMixedBoundaryToQuotientForestSigma_inj_of_q1_eq hq₁ hq₂
    (forestComponentMixedBoundaryToQuotientForestSigma_q1_recovery hq₁ hq₂ hEq)
    (congrArg Sigma.fst hEq)

/-- **Track B-forest-final-5a — RightParents equality.**  From a genuine-forest
`toQuotient` equality, the right-selected parent carriers agree.  Chain: outer
equality (`fst`) → actual-quotient `eqRec` (final-3) → component-carrier `eqRec`
→ `ActualRight` `eqRec` (raw star-touch separation) → off-carrier un-retarget
(`forestOuterActualRetargetOfCert_elements_eq_of_eqRec`, the same data-preserving
route as the mixed branch).  No model, no `cases` on the computed outer
equality. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_rightParents_eq_of_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    (forestComponentChoiceRightSubgraph q₁.1.1 q₁.2).elements =
      (forestComponentChoiceRightSubgraph q₂.1.1 q₂.2).elements := by
  classical
  have hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂ := congrArg Sigma.fst hEq
  have hActual :=
    forestComponentForestChoiceToQuotientForestSigma_actualQuotient_eqRec_of_eq
      hq₁ hq₂ hOuter hEq
  have hComp :=
    forestComponentForestChoiceActualQuotientComponents_eq_of_eqRec
      g hq₁ hq₂ hOuter hActual
  have hActualRight :=
    forestComponentForestChoiceActualRight_eqRec_of_components_eqRec
      g hq₁ hq₂ hOuter hComp
  have hPD₁ : q₁.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₁.1.2
  have hPD₂ : q₂.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₂.1.2
  exact forestOuterActualRetargetOfCert_elements_eq_of_eqRec g hOuter
    (forestComponentForestChoiceRightRetargetCertificateCanonical g q₁ hq₁)
    (forestComponentForestChoiceRightRetargetCertificateCanonical g q₂ hq₂)
    (fun γ hγ v hv =>
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q₁.1.1 q₁.2 hPD₁ hγ hv)
    (fun γ hγ v hv =>
      forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
        q₂.1.1 q₂.2 hPD₂ hγ hv)
    hActualRight

/-- **Track B-forest-final-4c — ForestParents equality.**  From a genuine-forest
`toQuotient` equality, the forest-chosen parent carriers agree.  Chain: outer
equality (`fst`) → actual-quotient `eqRec` (final-3) → component-carrier `eqRec`
→ `RemnantComponents` `eqRec` (positive star-touch filter) → `ForestParents`
equality (cross-`q` recovery through the insertion-uniqueness model).  This is
the *only* genuine-forest branch step that consumes
`ForestGraphInsertionUniquenessModel`. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_forestParents_eq_of_eq
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    forestComponentForestChoiceForestParents g q₁ =
      forestComponentForestChoiceForestParents g q₂ := by
  classical
  have hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂ := congrArg Sigma.fst hEq
  have hActual :=
    forestComponentForestChoiceToQuotientForestSigma_actualQuotient_eqRec_of_eq
      hq₁ hq₂ hOuter hEq
  have hComp :=
    forestComponentForestChoiceActualQuotientComponents_eq_of_eqRec
      g hq₁ hq₂ hOuter hActual
  have hRem :=
    forestComponentForestChoiceRemnantComponents_eq_of_components_eqRec
      g hq₁ hq₂ hOuter hComp
  exact forestComponentForestChoiceForestParents_eq_of_remnant_eqRec
    g hq₁ hq₂ hOuter hRem

/-- **Track B-forest-final-5b — LeftParents equality.**  From a genuine-forest
`toQuotient` equality, the left-selected parent carriers agree.  Plain (no
transport): the outer subgraph carriers agree (`fst`), the forest parents agree
(4c), and `Left = OuterSubgraph \ inside-forest` (helper); rewriting both. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_leftParents_eq_of_eq
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    (forestComponentChoiceLeftSubgraph q₁.1.1 q₁.2).elements =
      (forestComponentChoiceLeftSubgraph q₂.1.1 q₂.2).elements := by
  classical
  have hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂ := congrArg Sigma.fst hEq
  have hFP := forestComponentForestChoiceToQuotientForestSigma_forestParents_eq_of_eq
    hq₁ hq₂ hEq
  have hA₁ : q₁.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₁.1.2
  have hA₂ : q₂.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₂.1.2
  have hNE₁ : q₁.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q₁.1.2).2.1
  have hNE₂ : q₂.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q₂.1.2).2.1
  have hOuterElems :
      (forestComponentForestChoiceOuterSubgraph q₁.1.1 q₁.2 hA₁).elements =
        (forestComponentForestChoiceOuterSubgraph q₂.1.1 q₂.2 hA₂).elements := by
    rw [← forestComponentForestChoiceOuterIndex_val g q₁ hq₁,
        ← forestComponentForestChoiceOuterIndex_val g q₂ hq₂]
    exact congrArg (fun A => (A : forestOuterProperIndex g).1.elements) hOuter
  rw [forestComponentChoiceLeftSubgraph_elements_eq_filter_not_inside_forestParents
        g q₁ hA₁ hNE₁,
      forestComponentChoiceLeftSubgraph_elements_eq_filter_not_inside_forestParents
        g q₂ hA₂ hNE₂,
      hFP, hOuterElems]

/-- **Track B-forest-final-5c — genuine-forest `q.1` recovery.**  The outer
proper-index value is recovered from the `toQuotient` equality: its element set
splits as `Left ∪ Right ∪ ForestParents` (the parent three-way partition), each
piece recovered by 5b/5a/4c, then `forestOuterProperIndex_eq_of_elements_eq`. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_q1_recovery
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    q₁.1 = q₂.1 := by
  refine forestOuterProperIndex_eq_of_elements_eq ?_
  rw [← forestComponentForestChoice_parents_partition g q₁,
      ← forestComponentForestChoice_parents_partition g q₂,
      forestComponentForestChoiceToQuotientForestSigma_leftParents_eq_of_eq hq₁ hq₂ hEq,
      forestComponentForestChoiceToQuotientForestSigma_rightParents_eq_of_eq hq₁ hq₂ hEq,
      forestComponentForestChoiceToQuotientForestSigma_forestParents_eq_of_eq hq₁ hq₂ hEq]

/-- **Track B-forest-final-6 — fixed-`q.1` injectivity.**  With the outer index
recovered (`q₁.1 = q₂.1`), the outer-subgraph equality (`fst`) pins the entire
choice function `p` — including the genuine-forest `B` payloads — via the
fixed-`A` injectivity `forestComponentForestChoiceOuterSubgraph_inj` (which
already internalizes the forest-choice match).  No separate `B`-recovery needed. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_inj_of_q1_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq1 : q₁.1 = q₂.1)
    (hOuter :
      forestComponentForestChoiceOuterIndex g q₁ hq₁ =
      forestComponentForestChoiceOuterIndex g q₂ hq₂) :
    q₁ = q₂ := by
  classical
  have hA₁ : q₁.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₁.1.2
  have hA₂ : q₂.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q₂.1.2
  have hpCore₁ : q₁.2 ∈ forestComponentCoreChoiceIndex q₁.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      (Finset.mem_sigma.mp hq₁).2).1
  have hpCore₂ : q₂.2 ∈ forestComponentCoreChoiceIndex q₂.1.1 :=
    (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      (Finset.mem_sigma.mp hq₂).2).1
  have hNE₁ : q₁.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q₁.1.2).2.1
  have hNE₂ : q₂.1.1.HasNonemptyComponents :=
    (((repG g).toFeynmanGraph.mem_properDisjointAdmissibleDivergentSubgraphs _).mp
      q₂.1.2).2.1
  have hCO₁ :
      (forestComponentForestChoiceOuterSubgraph q₁.1.1 q₁.2 hA₁).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents hpCore₁ q₁.1.2 hA₁
  have hCO₂ :
      (forestComponentForestChoiceOuterSubgraph q₂.1.1 q₂.2 hA₂).HasNonemptyComponents :=
    forestComponentForestChoiceOuterSubgraph_hasNonemptyComponents hpCore₂ q₂.1.2 hA₂
  have hOuterSubEq :
      forestComponentForestChoiceOuterSubgraph q₁.1.1 q₁.2 hA₁ =
      forestComponentForestChoiceOuterSubgraph q₂.1.1 q₂.2 hA₂ := by
    have h := congrArg Subtype.val hOuter
    simpa [forestComponentForestChoiceOuterIndex_val] using h
  refine Sigma.ext hq1 ?_
  rcases q₁ with ⟨A₁, p₁⟩
  rcases q₂ with ⟨A₂, p₂⟩
  cases hq1
  refine heq_of_eq ?_
  exact forestComponentForestChoiceOuterSubgraph_inj
    hpCore₁ hpCore₂ hA₁ hNE₁ hCO₁ hCO₂ hOuterSubEq

/-- **Track B-forest-final — genuine-forest same-branch injectivity** (the
`forest_inj` field of the split-φ classifier).  Combines the `q.1` recovery
(5c) with the fixed-`q.1` injectivity (6), exactly mirroring `mixed_inj`.  This
is the last open piece of `CoassocStrictForestH58Ready` modulo
`ForestGraphInsertionUniquenessModel`. -/
private theorem forestComponentForestChoiceToQuotientForestSigma_inj
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    {g : HopfGen} {q₁ q₂ : forestComponentChoiceSigma g}
    (hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g)
    (hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g)
    (hEq :
      forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
      forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) :
    q₁ = q₂ :=
  forestComponentForestChoiceToQuotientForestSigma_inj_of_q1_eq hq₁ hq₂
    (forestComponentForestChoiceToQuotientForestSigma_q1_recovery hq₁ hq₂ hEq)
    (congrArg Sigma.fst hEq)

/-- Common tensor calculation for branch term equality.  Once the component
choice product has been identified as `outer ⊗ inner`, and the original right
factor has been identified with the final quotient right factor, the
associator gives the RHS quotient-forest tensor term. -/
private theorem forestComponentChoiceSigmaTerm_eq_quotientForestSigmaTerm_of_factorization
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (A : forestOuterProperIndex g)
    (B : AdmissibleSubgraph (forestOuterQuotientGraph g A))
    (hB : B ∈ (forestOuterQuotientGraph g A
      ).properDisjointAdmissibleDivergentSubgraphs)
    (hProduct :
      forestComponentChoiceProductTerm q.1.1 q.2 =
        A.1.toHopfH ⊗ₜ[ℚ] B.toHopfH)
    (hRight :
      forestRightHopfH g q.1.1 q.1.2 =
        forestRightHopfH (forestOuterQuotientHopfGen g A) B hB) :
    forestComponentChoiceSigmaTerm g q =
      forestQuotientForestSigmaTerm g ⟨A, B⟩ := by
  unfold forestComponentChoiceSigmaTerm forestQuotientForestSigmaTerm
  rw [hProduct, hRight]
  rw [FeynmanGraph.admissibleForestStrictSummandWithCanonicalStars_of_mem
    (forestOuterQuotientGraph g A)
    (forestCanonicalHCD (forestOuterQuotientHopfGen g A))
    B hB]
  unfold forestRightHopfH
  exact Algebra.TensorProduct.assoc_tmul (R := ℚ) (S := ℚ) (T := ℚ)
    (A := HopfH) (C := HopfH) (D := HopfH) _ _ _

/-- Mixed-boundary component-choice terms land in the RHS quotient-forest
finite carrier. -/
private theorem forestComponentMixedBoundaryToQuotientForestSigma_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentMixedBoundaryToQuotientForestSigma g q hq ∈
      forestQuotientForestSigmaIndex g := by
  classical
  unfold forestQuotientForestSigmaIndex
  apply Finset.mem_sigma.mpr
  refine ⟨?_, ?_⟩
  · apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_attach _ _, ?_⟩
    have hAcomp : 0 < q.1.1.complementEdges.card :=
      (Finset.mem_filter.mp (Finset.mem_sigma.mp hq).1).2
    have hDisj :
        q.1.1.IsPairwiseDisjoint :=
      (repG g).toFeynmanGraph
        |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
          q.1.2
    have hLeftLe :
        (forestComponentChoiceLeftSubgraph q.1.1 q.2).internalEdges ≤
          q.1.1.internalEdges := by
      refine admissibleSubgraph_internalEdges_le_of_components_le
        (forestComponentChoiceLeftSubgraph q.1.1 q.2)
        (forestComponentChoiceLeftSubgraph_isPairwiseDisjoint q.1.1 q.2 hDisj)
        ?_
      intro δ hδ
      exact feynmanSubgraph_internalEdges_le_admissible_internalEdges_of_mem
        q.1.1 hDisj
        (forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hδ)
    exact admissibleSubgraph_complementEdges_card_pos_of_internalEdges_le
      hLeftLe hAcomp
  · change forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
        g q hq ∈
        ((forestOuterQuotientGraph g
          (forestComponentMixedBoundaryOuterIndex g q hq)
        ).properDisjointAdmissibleDivergentSubgraphs).filter
          (fun A => 0 < A.complementEdges.card)
    exact Finset.mem_filter.mpr ⟨
      forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
        g q hq,
      forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_complementEdges_card_pos
        g q hq⟩

/-- Genuine-forest branch term equality from the two concrete factorization
facts: the component product gives the RHS outer and inner forests, and the
old outer quotient right factor agrees with the final quotient right factor. -/
private theorem forestComponentForestChoice_branch_term_eq_of_factorization
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (hProduct :
      forestComponentChoiceProductTerm q.1.1 q.2 =
        (forestComponentForestChoiceOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
          (forestComponentForestChoiceRepQuotientSubgraphCanonical
            g q hq).toHopfH)
    (hRight :
      forestRightHopfH g q.1.1 q.1.2 =
        forestRightHopfH
          (forestOuterQuotientHopfGen g
            (forestComponentForestChoiceOuterIndex g q hq))
          (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
          (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
            g q hq C)) :
    forestComponentChoiceSigmaTerm g q =
      forestQuotientForestSigmaTerm g
        (forestComponentForestChoiceToQuotientForestSigma g q hq) := by
  simpa [forestComponentForestChoiceToQuotientForestSigma] using
    forestComponentChoiceSigmaTerm_eq_quotientForestSigmaTerm_of_factorization
      g q
      (forestComponentForestChoiceOuterIndex g q hq)
      (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
      (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
        g q hq C)
      hProduct hRight

/-- Mixed-boundary branch term equality from the two concrete factorization
facts: left-selected components form the RHS outer forest, right-selected
components form the quotient-side forest, and the remaining right factor is
identified by the contraction chain. -/
private theorem forestComponentMixedBoundary_branch_term_eq_of_factorization
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g)
    (hProduct :
      forestComponentChoiceProductTerm q.1.1 q.2 =
        (forestComponentMixedBoundaryOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq).toHopfH)
    (hRight :
      forestRightHopfH g q.1.1 q.1.2 =
        forestRightHopfH
          (forestOuterQuotientHopfGen g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)) :
    forestComponentChoiceSigmaTerm g q =
      forestQuotientForestSigmaTerm g
        (forestComponentMixedBoundaryToQuotientForestSigma g q hq) := by
  simpa [forestComponentMixedBoundaryToQuotientForestSigma] using
    forestComponentChoiceSigmaTerm_eq_quotientForestSigmaTerm_of_factorization
      g q
      (forestComponentMixedBoundaryOuterIndex g q hq)
      (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical g q hq)
      (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical_mem_properDisjoint
        g q hq)
      hProduct hRight

/-- Flatten the RHS explicit quotient forest double-sum. -/
private theorem forestTermFQuotientForestChoicesExpanded_eq_sigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestTermFQuotientForestChoicesExpanded g =
      ∑ q ∈ forestQuotientForestSigmaIndex g,
        forestQuotientForestSigmaTerm g q := by
  classical
  unfold forestTermFQuotientForestChoicesExpanded
    forestQuotientForestSigmaIndex forestOuterProperFinset
    forestOuterQuotientGraph forestOuterQuotientHopfGen
    forestCoproductProperForestIndex
  rw [sum_dite_filter_sigma_attach_subtype]
  unfold forestQuotientForestSigmaTerm
  apply Finset.sum_congr rfl
  intro q hq
  rfl

/-- Combined LHS split-regime carrier. -/
private abbrev forestComponentSplitChoiceSigma
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) : Type :=
  forestComponentChoiceSigma g ⊕ forestComponentChoiceSigma g

/-- Combined LHS split-regime finite carrier. -/
private noncomputable def forestComponentSplitChoiceSigmaIndex
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    Finset (forestComponentSplitChoiceSigma g) :=
  (forestComponentForestChoiceSigmaIndex g).disjSum
    (forestComponentMixedBoundaryChoiceSigmaIndex g)

/-- Combined LHS split-regime term. -/
private noncomputable def forestComponentSplitChoiceSigmaTerm
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitChoiceSigma g → HopfH ⊗[ℚ] (HopfH ⊗[ℚ] HopfH)
  | Sum.inl q => forestComponentChoiceSigmaTerm g q
  | Sum.inr q => forestComponentChoiceSigmaTerm g q

/-- Harmless total-map fallback for non-indexed split choices.  Indexed
inputs never use this branch; it just makes `φ` a total function on the full
split sigma type. -/
private noncomputable def forestComponentSplitPhiDefault
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitChoiceSigma g → forestQuotientForestSigma g
  | Sum.inl q =>
      ⟨q.1, AdmissibleSubgraph.empty (forestOuterQuotientGraph g q.1)⟩
  | Sum.inr q =>
      ⟨q.1, AdmissibleSubgraph.empty (forestOuterQuotientGraph g q.1)⟩

/-- The graph-level candidate `φ`: genuine-forest split choices map to the
canonical full quotient forest; mixed-boundary choices map to the canonical
right-selected quotient forest. -/
private noncomputable def forestComponentSplitPhi
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitChoiceSigma g → forestQuotientForestSigma g
  | Sum.inl q =>
      if hq : q ∈ forestComponentForestChoiceSigmaIndex g then
        forestComponentForestChoiceToQuotientForestSigma g q hq
      else
        forestComponentSplitPhiDefault g (Sum.inl q)
  | Sum.inr q =>
      if hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g then
        forestComponentMixedBoundaryToQuotientForestSigma g q hq
      else
        forestComponentSplitPhiDefault g (Sum.inr q)

private theorem forestComponentSplitPhi_inl_of_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g) :
    forestComponentSplitPhi g (Sum.inl q) =
      forestComponentForestChoiceToQuotientForestSigma g q hq := by
  unfold forestComponentSplitPhi
  change (if hq' : q ∈ forestComponentForestChoiceSigmaIndex g then
      forestComponentForestChoiceToQuotientForestSigma g q hq'
    else forestComponentSplitPhiDefault g (Sum.inl q)) =
      forestComponentForestChoiceToQuotientForestSigma g q hq
  rw [dif_pos hq]

private theorem forestComponentSplitPhi_inr_of_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g) :
    forestComponentSplitPhi g (Sum.inr q) =
      forestComponentMixedBoundaryToQuotientForestSigma g q hq := by
  unfold forestComponentSplitPhi
  change (if hq' : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g then
      forestComponentMixedBoundaryToQuotientForestSigma g q hq'
    else forestComponentSplitPhiDefault g (Sum.inr q)) =
      forestComponentMixedBoundaryToQuotientForestSigma g q hq
  rw [dif_pos hq]

/-- The mixed-boundary half of `φ` has the required RHS membership. -/
private theorem forestComponentSplitPhi_map_mem_mixedBoundary
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : Sum.inr q ∈ forestComponentSplitChoiceSigmaIndex g) :
    forestComponentSplitPhi g (Sum.inr q) ∈
      forestQuotientForestSigmaIndex g := by
  classical
  have hqMixed : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
    simpa [forestComponentSplitChoiceSigmaIndex] using hq
  rw [forestComponentSplitPhi_inr_of_mem g q hqMixed]
  exact forestComponentMixedBoundaryToQuotientForestSigma_mem g q hqMixed

/-- Membership for the total `φ` is reduced to the genuine-forest branch,
since the mixed-boundary branch is already canonical. -/
private theorem forestComponentSplitPhi_map_mem_of_forestBranch
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForest :
      ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g) :
    ∀ q, q ∈ forestComponentSplitChoiceSigmaIndex g →
      forestComponentSplitPhi g q ∈ forestQuotientForestSigmaIndex g := by
  classical
  intro q hq
  cases q with
  | inl q =>
      have hqForest : q ∈ forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitPhi_inl_of_mem g q hqForest]
      exact hForest q hqForest
  | inr q =>
      exact forestComponentSplitPhi_map_mem_mixedBoundary g q hq

/-- Concrete `φ` membership from canonical mixed-boundary membership plus the
remaining genuine-forest remnant-positivity certificates. -/
private theorem forestComponentSplitPhi_map_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq) :
    ∀ q, q ∈ forestComponentSplitChoiceSigmaIndex g →
      forestComponentSplitPhi g q ∈ forestQuotientForestSigmaIndex g :=
  forestComponentSplitPhi_map_mem_of_forestBranch g
    (fun q hq => forestComponentForestChoiceToQuotientForestSigma_mem_of_remnantPositive
      g q hq (C q hq))

/-- Concrete `φ` injectivity reduces to the two same-branch injectivity
statements plus the cross-branch separation statement. -/
private theorem forestComponentSplitPhi_inj_on_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForest :
      ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g,
        ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
            forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂ →
            q₁ = q₂)
    (hMixed :
      ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
            forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂ →
            q₁ = q₂)
    (hCross :
      ∀ qF, ∀ hF : qF ∈ forestComponentForestChoiceSigmaIndex g,
        ∀ qM, ∀ hM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g qF hF ≠
            forestComponentMixedBoundaryToQuotientForestSigma g qM hM) :
    ∀ q₁, q₁ ∈ forestComponentSplitChoiceSigmaIndex g →
      ∀ q₂, q₂ ∈ forestComponentSplitChoiceSigmaIndex g →
        forestComponentSplitPhi g q₁ = forestComponentSplitPhi g q₂ →
          q₁ = q₂ := by
  classical
  intro q₁ hq₁ q₂ hq₂ hφ
  cases q₁ with
  | inl q₁ =>
      have hq₁Forest : q₁ ∈ forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq₁
      rw [forestComponentSplitPhi_inl_of_mem g q₁ hq₁Forest] at hφ
      cases q₂ with
      | inl q₂ =>
          have hq₂Forest : q₂ ∈ forestComponentForestChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
          rw [forestComponentSplitPhi_inl_of_mem g q₂ hq₂Forest] at hφ
          exact congrArg Sum.inl
            (hForest q₁ hq₁Forest q₂ hq₂Forest hφ)
      | inr q₂ =>
          have hq₂Mixed :
              q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
          rw [forestComponentSplitPhi_inr_of_mem g q₂ hq₂Mixed] at hφ
          exact False.elim
            ((hCross q₁ hq₁Forest q₂ hq₂Mixed) hφ)
  | inr q₁ =>
      have hq₁Mixed :
          q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq₁
      rw [forestComponentSplitPhi_inr_of_mem g q₁ hq₁Mixed] at hφ
      cases q₂ with
      | inl q₂ =>
          have hq₂Forest : q₂ ∈ forestComponentForestChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
          rw [forestComponentSplitPhi_inl_of_mem g q₂ hq₂Forest] at hφ
          exact False.elim
            ((hCross q₂ hq₂Forest q₁ hq₁Mixed) hφ.symm)
      | inr q₂ =>
          have hq₂Mixed :
              q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
            simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
          rw [forestComponentSplitPhi_inr_of_mem g q₂ hq₂Mixed] at hφ
          exact congrArg Sum.inr
            (hMixed q₁ hq₁Mixed q₂ hq₂Mixed hφ)

/-- Concrete `φ` surjectivity reduces to a branch-covering statement for the
RHS quotient-forest carrier. -/
private theorem forestComponentSplitPhi_surj_on_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hCover :
      ∀ r, r ∈ forestQuotientForestSigmaIndex g →
        (∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q hq = r) ∨
        (∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r)) :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      ∃ q, ∃ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
        forestComponentSplitPhi g q = r := by
  classical
  intro r hr
  rcases hCover r hr with hForest | hMixed
  · rcases hForest with ⟨q, hq, hφ⟩
    refine ⟨Sum.inl q, ?_, ?_⟩
    · simpa [forestComponentSplitChoiceSigmaIndex] using hq
    · rw [forestComponentSplitPhi_inl_of_mem g q hq]
      exact hφ
  · rcases hMixed with ⟨q, hq, hφ⟩
    refine ⟨Sum.inr q, ?_, ?_⟩
    · simpa [forestComponentSplitChoiceSigmaIndex] using hq
    · rw [forestComponentSplitPhi_inr_of_mem g q hq]
      exact hφ

/-- Concrete `φ` term equality reduces to the genuine-forest and mixed-boundary
branch term-identification statements. -/
private theorem forestComponentSplitPhi_term_eq_of_split
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (hForestTerm :
      ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q =
          forestQuotientForestSigmaTerm g
            (forestComponentForestChoiceToQuotientForestSigma g q hq))
    (hMixedTerm :
      ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentChoiceSigmaTerm g q =
          forestQuotientForestSigmaTerm g
            (forestComponentMixedBoundaryToQuotientForestSigma g q hq)) :
    ∀ q, ∀ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
      forestComponentSplitChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g (forestComponentSplitPhi g q) := by
  classical
  intro q hq
  cases q with
  | inl q =>
      have hqForest : q ∈ forestComponentForestChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitChoiceSigmaTerm,
        forestComponentSplitPhi_inl_of_mem g q hqForest]
      exact hForestTerm q hqForest
  | inr q =>
      have hqMixed : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
        simpa [forestComponentSplitChoiceSigmaIndex] using hq
      rw [forestComponentSplitChoiceSigmaTerm,
        forestComponentSplitPhi_inr_of_mem g q hqMixed]
      exact hMixedTerm q hqMixed

/-- Branchwise proof package for the concrete `φ` map.  This is the final
finite-reindexing problem after carrier membership has been reduced to remnant
positivity. -/
private structure forestComponentSplitPhiBranchReindexing
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  forest_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
          forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  mixed_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
          forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  cross :
    ∀ qF, ∀ hF : qF ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ qM, ∀ hM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g qF hF ≠
          forestComponentMixedBoundaryToQuotientForestSigma g qM hM
  cover :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      (∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq = r) ∨
      (∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q hq = r)
  forest_term :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g
          (forestComponentForestChoiceToQuotientForestSigma g q hq)
  mixed_term :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      forestComponentChoiceSigmaTerm g q =
        forestQuotientForestSigmaTerm g
          (forestComponentMixedBoundaryToQuotientForestSigma g q hq)

/-- The branch inverse/cover half of the concrete `φ` reindexing.  It keeps the
set-theoretic bijection problem separate from the tensor term calculation. -/
private structure forestComponentSplitPhiBranchInverseCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  forest_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
          forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  mixed_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
          forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  cross :
    ∀ qF, ∀ hF : qF ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ qM, ∀ hM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g qF hF ≠
          forestComponentMixedBoundaryToQuotientForestSigma g qM hM
  cover :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      (∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq = r) ∨
      (∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q hq = r)

/-- The injectivity and branch-separation half of the concrete split `φ`
reindexing.  The RHS cover is kept separate so the last set-theoretic climb can
be attacked in two independent graph-level pieces. -/
private structure forestComponentSplitPhiBranchInjectivitySeparation
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  forest_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
          forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  mixed_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
          forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂
  cross :
    ∀ qF, ∀ hF : qF ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ qM, ∀ hM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g qF hF ≠
          forestComponentMixedBoundaryToQuotientForestSigma g qM hM

/-- Same-branch injectivity for the genuine-forest branch of `φ`. -/
private structure forestComponentSplitPhiForestBranchInjectivity
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  forest_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁ =
          forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂

/-- **Track B-forest-final — forest branch injectivity straight from the model.**
The genuine-forest same-branch injectivity is supplied directly by
`ForestGraphInsertionUniquenessModel` (via the full `forest_inj` campaign), with
no forest-image normalizer facade required. -/
private def forestComponentSplitPhiForestBranchInjectivityOfModel
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitPhiForestBranchInjectivity g where
  forest_inj := fun _q₁ hq₁ _q₂ hq₂ hφ =>
    forestComponentForestChoiceToQuotientForestSigma_inj hq₁ hq₂ hφ

/-- Same-branch injectivity for the mixed-boundary branch of `φ`. -/
private structure forestComponentSplitPhiMixedBranchInjectivity
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  mixed_inj :
    ∀ q₁, ∀ hq₁ : q₁ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ q₂, ∀ hq₂ : q₂ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁ =
          forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂ →
          q₁ = q₂

/-- Cross-branch separation between genuine-forest and mixed-boundary images. -/
private structure forestComponentSplitPhiCrossBranchSeparation
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  cross :
    ∀ qF, ∀ hF : qF ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ qM, ∀ hM : qM ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g qF hF ≠
          forestComponentMixedBoundaryToQuotientForestSigma g qM hM

/-- Reassemble branch injectivity/separation from its three independent pieces. -/
private def forestComponentSplitPhiBranchInjectivitySeparationOfPieces
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (JF : forestComponentSplitPhiForestBranchInjectivity g)
    (JM : forestComponentSplitPhiMixedBranchInjectivity g)
    (JC : forestComponentSplitPhiCrossBranchSeparation g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := JF.forest_inj
  mixed_inj := JM.mixed_inj
  cross := JC.cross

/-- **Track B-forest-final — branch injectivity/separation straight from the
model.**  All three pieces are now proven: `forest_inj` from the campaign (gated
on `ForestGraphInsertionUniquenessModel`), `mixed_inj` and `cross` already
discharged.  No normalizer facades. -/
private def forestComponentSplitPhiBranchInjectivitySeparationOfModel
    [ForestGraphInsertionUniquenessModel]
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := fun _q₁ hq₁ _q₂ hq₂ hφ =>
    forestComponentForestChoiceToQuotientForestSigma_inj hq₁ hq₂ hφ
  mixed_inj := fun _q₁ hq₁ _q₂ hq₂ hφ =>
    forestComponentMixedBoundaryToQuotientForestSigma_inj hq₁ hq₂ hφ
  cross := fun qF hF qM hM =>
    forestComponentSplitPhi_cross_separation g qF hF qM hM

/-- Project the genuine same-branch injectivity field out of the combined
branch injectivity/separation package. -/
private def forestComponentSplitPhiForestBranchInjectivityOfSeparation
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g) :
    forestComponentSplitPhiForestBranchInjectivity g where
  forest_inj := J.forest_inj

/-- Project the mixed same-branch injectivity field out of the combined branch
injectivity/separation package. -/
private def forestComponentSplitPhiMixedBranchInjectivityOfSeparation
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g) :
    forestComponentSplitPhiMixedBranchInjectivity g where
  mixed_inj := J.mixed_inj

/-- Project cross-branch separation out of the combined branch
injectivity/separation package. -/
private def forestComponentSplitPhiCrossBranchSeparationOfSeparation
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g) :
    forestComponentSplitPhiCrossBranchSeparation g where
  cross := J.cross

/-- The RHS branch cover half of the concrete split `φ` reindexing. -/
private structure forestComponentSplitPhiBranchCoverCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  cover :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      (∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq = r) ∨
      (∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
        forestComponentMixedBoundaryToQuotientForestSigma g q hq = r)

/-- Forget the tensor-term fields of a complete branch reindexing package,
keeping only the same-branch injectivity and cross-branch separation data. -/
private def forestComponentSplitPhiBranchInjectivitySeparationOfReindexing
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (R : forestComponentSplitPhiBranchReindexing g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := R.forest_inj
  mixed_inj := R.mixed_inj
  cross := R.cross

/-- Forget the tensor-term fields of a complete branch reindexing package,
keeping only the RHS branch cover data. -/
private def forestComponentSplitPhiBranchCoverCertificateOfReindexing
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (R : forestComponentSplitPhiBranchReindexing g) :
    forestComponentSplitPhiBranchCoverCertificate g where
  cover := R.cover

/-- Forget the packaging of a branch inverse/cover certificate, keeping only
the same-branch injectivity and cross-branch separation fields. -/
private def forestComponentSplitPhiBranchInjectivitySeparationOfInverseCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (I : forestComponentSplitPhiBranchInverseCover g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := I.forest_inj
  mixed_inj := I.mixed_inj
  cross := I.cross

/-- Forget the packaging of a branch inverse/cover certificate, keeping only
the RHS branch cover field. -/
private def forestComponentSplitPhiBranchCoverCertificateOfInverseCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (I : forestComponentSplitPhiBranchInverseCover g) :
    forestComponentSplitPhiBranchCoverCertificate g where
  cover := I.cover

/-- Reassemble the original branch inverse/cover package from the separated
injectivity/separation and cover certificates. -/
private def forestComponentSplitPhiBranchInverseCoverOfSeparated
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g)
    (K : forestComponentSplitPhiBranchCoverCertificate g) :
    forestComponentSplitPhiBranchInverseCover g where
  forest_inj := J.forest_inj
  mixed_inj := J.mixed_inj
  cross := J.cross
  cover := K.cover

/-- A concrete inverse for the final split `φ` map on the finite carriers.
This is the narrowest set-theoretic form of the branch reindexing problem:
construct one RHS-to-LHS preimage map, prove it lands in the split carrier,
and prove the two inverse laws on the indexed carriers. -/
private structure forestComponentSplitPhiInverseConstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  inv : forestQuotientForestSigma g → forestComponentSplitChoiceSigma g
  inv_mem :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      inv r ∈ forestComponentSplitChoiceSigmaIndex g
  right_inv :
    ∀ r, ∀ hr : r ∈ forestQuotientForestSigmaIndex g,
      forestComponentSplitPhi g (inv r) = r
  left_inv :
    ∀ q, ∀ hq : q ∈ forestComponentSplitChoiceSigmaIndex g,
      inv (forestComponentSplitPhi g q) = q

/-- Branch-classifier form of the final inverse construction.  Instead of one
monolithic `left_inv`, it states separately how the classifier acts on the two
canonical branch images. -/
private structure forestComponentSplitPhiBranchClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  inv : forestQuotientForestSigma g → forestComponentSplitChoiceSigma g
  inv_mem :
    ∀ r, r ∈ forestQuotientForestSigmaIndex g →
      inv r ∈ forestComponentSplitChoiceSigmaIndex g
  right_inv :
    ∀ r, ∀ hr : r ∈ forestQuotientForestSigmaIndex g,
      forestComponentSplitPhi g (inv r) = r
  forest_inv :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      inv (forestComponentForestChoiceToQuotientForestSigma g q hq) =
        Sum.inl q
  mixed_inv :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      inv (forestComponentMixedBoundaryToQuotientForestSigma g q hq) =
        Sum.inr q

/-- Indexed branch-classifier form: the inverse map is only required on the
actual RHS finite carrier.  This avoids choosing an arbitrary total inverse
outside the summation carrier and is the closest finite-reindexing payload to
the eventual construction. -/
private structure forestComponentSplitPhiIndexedBranchClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  preimage :
    {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} →
      forestComponentSplitChoiceSigma g
  preimage_mem :
    ∀ r, preimage r ∈ forestComponentSplitChoiceSigmaIndex g
  right_inv :
    ∀ r, forestComponentSplitPhi g (preimage r) = r.1
  forest_inv :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ hr :
        forestComponentForestChoiceToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g,
        preimage
          ⟨forestComponentForestChoiceToQuotientForestSigma g q hq, hr⟩ =
          Sum.inl q
  mixed_inv :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ hr :
        forestComponentMixedBoundaryToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g,
        preimage
          ⟨forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr⟩ =
          Sum.inr q

/-- Data returned when an RHS indexed quotient-forest term is classified as
coming from the genuine-forest branch. -/
private abbrev forestComponentSplitPhiForestPreimageData
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (r : forestQuotientForestSigma g) : Type :=
  Σ q : forestComponentChoiceSigma g,
    { hq : q ∈ forestComponentForestChoiceSigmaIndex g //
      forestComponentForestChoiceToQuotientForestSigma g q hq = r }

/-- Data returned when an RHS indexed quotient-forest term is classified as
coming from the mixed-boundary branch. -/
private abbrev forestComponentSplitPhiMixedPreimageData
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (r : forestQuotientForestSigma g) : Type :=
  Σ q : forestComponentChoiceSigma g,
    { hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g //
      forestComponentMixedBoundaryToQuotientForestSigma g q hq = r }

/-- Pure RHS branch-cover data: every RHS finite quotient-forest term is
classified as either a genuine-forest image or a mixed-boundary image, together
with the witnessing preimage and target equality. -/
private structure forestComponentSplitPhiBranchDecisionCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  classify :
    ∀ r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g},
      forestComponentSplitPhiForestPreimageData g r.1 ⊕
        forestComponentSplitPhiMixedPreimageData g r.1

/-- Predicate-oriented construction data for the RHS decision cover: provide a
branch predicate on RHS terms, a genuine preimage whenever the predicate holds,
and a mixed preimage whenever it fails. -/
private structure forestComponentSplitPhiBranchDecisionPredicateCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  isForest :
    {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} →
      Prop
  forest_data :
    ∀ r, isForest r → forestComponentSplitPhiForestPreimageData g r.1
  mixed_data :
    ∀ r, ¬ isForest r → forestComponentSplitPhiMixedPreimageData g r.1

/-- The predicate part of the RHS classifier, separated from the branch-specific
preimage constructors. -/
private structure forestComponentSplitPhiRHSBranchPredicate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  isForest :
    {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} →
      Prop

/-- Genuine-forest preimage constructor for RHS terms satisfying the branch
predicate. -/
private structure forestComponentSplitPhiForestPreimageConstructor
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g) where
  forest_data :
    ∀ r, B.isForest r → forestComponentSplitPhiForestPreimageData g r.1

/-- Mixed-boundary preimage constructor for RHS terms failing the branch
predicate. -/
private structure forestComponentSplitPhiMixedPreimageConstructor
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g) where
  mixed_data :
    ∀ r, ¬ B.isForest r → forestComponentSplitPhiMixedPreimageData g r.1

/-- The genuine-forest branch preimage choice, before proving membership and
target equality for the chosen source. -/
private structure forestComponentSplitPhiForestPreimageChoice
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g) where
  choice :
    ∀ r, B.isForest r → forestComponentChoiceSigma g

/-- Membership and reconstruction laws for the genuine-forest preimage choice. -/
private structure forestComponentSplitPhiForestPreimageChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (F : forestComponentSplitPhiForestPreimageChoice g B) where
  choice_mem :
    ∀ r h, F.choice r h ∈ forestComponentForestChoiceSigmaIndex g
  target_eq :
    ∀ r h,
      forestComponentForestChoiceToQuotientForestSigma g
        (F.choice r h) (choice_mem r h) = r.1

/-- Build the genuine-forest constructor from a choice plus its membership and
target laws. -/
private def forestComponentSplitPhiForestPreimageConstructorOfChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (F : forestComponentSplitPhiForestPreimageChoice g B)
    (L : forestComponentSplitPhiForestPreimageChoiceLaws g B F) :
    forestComponentSplitPhiForestPreimageConstructor g B where
  forest_data := fun r h =>
    ⟨F.choice r h, ⟨L.choice_mem r h, L.target_eq r h⟩⟩

/-- The mixed-boundary branch preimage choice, before proving membership and
target equality for the chosen source. -/
private structure forestComponentSplitPhiMixedPreimageChoice
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g) where
  choice :
    ∀ r, ¬ B.isForest r → forestComponentChoiceSigma g

/-- Membership and reconstruction laws for the mixed-boundary preimage choice. -/
private structure forestComponentSplitPhiMixedPreimageChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (M : forestComponentSplitPhiMixedPreimageChoice g B) where
  choice_mem :
    ∀ r h, M.choice r h ∈ forestComponentMixedBoundaryChoiceSigmaIndex g
  target_eq :
    ∀ r h,
      forestComponentMixedBoundaryToQuotientForestSigma g
        (M.choice r h) (choice_mem r h) = r.1

/-- Build the mixed-boundary constructor from a choice plus its membership and
target laws. -/
private def forestComponentSplitPhiMixedPreimageConstructorOfChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (M : forestComponentSplitPhiMixedPreimageChoice g B)
    (L : forestComponentSplitPhiMixedPreimageChoiceLaws g B M) :
    forestComponentSplitPhiMixedPreimageConstructor g B where
  mixed_data := fun r h =>
    ⟨M.choice r h, ⟨L.choice_mem r h, L.target_eq r h⟩⟩

/-- Reassemble the predicate-cover package from the predicate and the two
branch-specific preimage constructors. -/
private def forestComponentSplitPhiBranchDecisionPredicateCoverOfConstructors
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (F : forestComponentSplitPhiForestPreimageConstructor g B)
    (M : forestComponentSplitPhiMixedPreimageConstructor g B) :
    forestComponentSplitPhiBranchDecisionPredicateCover g where
  isForest := B.isForest
  forest_data := F.forest_data
  mixed_data := M.mixed_data

/-- A predicate-oriented RHS branch cover yields the decision-cover classifier. -/
private noncomputable def forestComponentSplitPhiBranchDecisionCoverOfPredicate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (P : forestComponentSplitPhiBranchDecisionPredicateCover g) :
    forestComponentSplitPhiBranchDecisionCover g where
  classify := by
    intro r
    by_cases h : P.isForest r
    · exact Sum.inl (P.forest_data r h)
    · exact Sum.inr (P.mixed_data r h)

/-- Forget the executable branch decision and keep only the propositional RHS
cover supplied by its preimage data. -/
private def forestComponentSplitPhiBranchCoverCertificateOfDecisionCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g) :
    forestComponentSplitPhiBranchCoverCertificate g where
  cover := by
    intro r hr
    let r' : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨r, hr⟩
    cases h : D.classify r' with
    | inl data =>
        left
        refine ⟨data.1, data.2.1, ?_⟩
        exact data.2.2
    | inr data =>
        right
        refine ⟨data.1, data.2.1, ?_⟩
        exact data.2.2

/-- Rebuild the propositional RHS cover directly from the branch predicate and
the choice/membership/target laws. -/
private def forestComponentSplitPhiBranchCoverCertificateOfChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (B : forestComponentSplitPhiRHSBranchPredicate g)
    (F : forestComponentSplitPhiForestPreimageChoice g B)
    (FL : forestComponentSplitPhiForestPreimageChoiceLaws g B F)
    (M : forestComponentSplitPhiMixedPreimageChoice g B)
    (ML : forestComponentSplitPhiMixedPreimageChoiceLaws g B M) :
    forestComponentSplitPhiBranchCoverCertificate g :=
  forestComponentSplitPhiBranchCoverCertificateOfDecisionCover g
    (forestComponentSplitPhiBranchDecisionCoverOfPredicate g
      (forestComponentSplitPhiBranchDecisionPredicateCoverOfConstructors
        g B
        (forestComponentSplitPhiForestPreimageConstructorOfChoiceLaws
          g B F FL)
        (forestComponentSplitPhiMixedPreimageConstructorOfChoiceLaws
          g B M ML)))

/-- Canonical RHS branch predicate: an indexed RHS quotient-forest term belongs
to the genuine branch exactly when it has a genuine-forest preimage. -/
private noncomputable def forestComponentSplitPhiCanonicalRHSBranchPredicate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitPhiRHSBranchPredicate g where
  isForest := fun r =>
    ∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceToQuotientForestSigma g q hq = r.1

/-- Canonical-predicate form of cross-branch separation: no mixed-boundary
image is also a genuine-forest image. -/
private structure forestComponentSplitPhiMixedImageNotForest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  not_forest :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ¬ (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest
        ⟨forestComponentMixedBoundaryToQuotientForestSigma g q hq,
          forestComponentMixedBoundaryToQuotientForestSigma_mem g q hq⟩

/-- A mixed-image/non-forest law supplies the usual cross-branch separation. -/
private def forestComponentSplitPhiCrossBranchSeparationOfMixedImageNotForest
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiMixedImageNotForest g) :
    forestComponentSplitPhiCrossBranchSeparation g where
  cross := by
    intro qF hF qM hM hφ
    apply J.not_forest qM hM
    exact ⟨qF, hF, hφ⟩

/-- Ordinary cross-branch separation says exactly that mixed images are not
classified by the canonical genuine-preimage predicate. -/
private def forestComponentSplitPhiMixedImageNotForestOfCross
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiCrossBranchSeparation g) :
    forestComponentSplitPhiMixedImageNotForest g where
  not_forest := by
    intro qM hM hForest
    rcases hForest with ⟨qF, hF, htarget⟩
    exact J.cross qF hF qM hM htarget

/-- The canonical genuine-forest preimage choice, obtained from the existential
branch predicate. -/
private noncomputable def forestComponentSplitPhiCanonicalForestPreimageChoice
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitPhiForestPreimageChoice g
      (forestComponentSplitPhiCanonicalRHSBranchPredicate g) where
  choice := fun _ h => Classical.choose h

/-- The canonical genuine-forest preimage choice satisfies membership and
target reconstruction by unpacking the existential branch predicate. -/
private noncomputable def
    forestComponentSplitPhiCanonicalForestPreimageChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) :
    forestComponentSplitPhiForestPreimageChoiceLaws g
      (forestComponentSplitPhiCanonicalRHSBranchPredicate g)
      (forestComponentSplitPhiCanonicalForestPreimageChoice g) where
  choice_mem := by
    intro r h
    exact Classical.choose (Classical.choose_spec h)
  target_eq := by
    intro r h
    change forestComponentForestChoiceToQuotientForestSigma g
        (Classical.choose h)
        (Classical.choose (Classical.choose_spec h)) = r.1
    exact Classical.choose_spec (Classical.choose_spec h)

/-- Normalization of the canonical genuine-forest preimage choice on genuine
branch images. -/
private structure forestComponentSplitPhiCanonicalForestImageNormalizer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  normalizes :
    ∀ r : {r : forestQuotientForestSigma g //
        r ∈ forestQuotientForestSigmaIndex g},
      ∀ h : (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r,
        ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
          forestComponentForestChoiceToQuotientForestSigma g q hq = r.1 →
            (forestComponentSplitPhiCanonicalForestPreimageChoice g).choice r h =
              q

/-- A canonical forest-image normalizer supplies same-branch injectivity for
the genuine-forest branch. -/
private def forestComponentSplitPhiForestBranchInjectivityOfCanonicalNormalizer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq)
    (N : forestComponentSplitPhiCanonicalForestImageNormalizer g) :
    forestComponentSplitPhiForestBranchInjectivity g where
  forest_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    let r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁,
        forestComponentForestChoiceToQuotientForestSigma_mem_of_sourceEdgeWitness
          g q₁ hq₁ (C q₁ hq₁)⟩
    have h₁ : (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r :=
      ⟨q₁, hq₁, rfl⟩
    have h₂ : (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r :=
      ⟨q₂, hq₂, hφ.symm⟩
    have hn₁ :
        (forestComponentSplitPhiCanonicalForestPreimageChoice g).choice r h₁ =
          q₁ :=
      N.normalizes r h₁ q₁ hq₁ rfl
    have hn₂ :
        (forestComponentSplitPhiCanonicalForestPreimageChoice g).choice r h₂ =
          q₂ :=
      N.normalizes r h₂ q₂ hq₂ hφ.symm
    have hh : h₁ = h₂ := Subsingleton.elim _ _
    rw [hh] at hn₁
    exact hn₁.symm.trans hn₂

/-- Same-branch genuine injectivity supplies normalization of the canonical
genuine preimage choice. -/
private noncomputable def
    forestComponentSplitPhiCanonicalForestImageNormalizerOfInjectivity
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (J : forestComponentSplitPhiForestBranchInjectivity g) :
    forestComponentSplitPhiCanonicalForestImageNormalizer g where
  normalizes := by
    intro r h q hq htarget
    let q₀ : forestComponentChoiceSigma g := Classical.choose h
    let hq₀ : q₀ ∈ forestComponentForestChoiceSigmaIndex g :=
      Classical.choose (Classical.choose_spec h)
    have htarget₀ :
        forestComponentForestChoiceToQuotientForestSigma g q₀ hq₀ = r.1 :=
      Classical.choose_spec (Classical.choose_spec h)
    change q₀ = q
    exact J.forest_inj q₀ hq₀ q hq (htarget₀.trans htarget.symm)

/-- Residual genuine-forest branch classifier: source edge witnesses supply RHS
carrier membership, and the canonical genuine preimage choice normalizes on
genuine branch images. -/
private structure forestComponentSplitPhiResidualForestBranchClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  edge_witness :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq
  normalizer : forestComponentSplitPhiCanonicalForestImageNormalizer g

/-- The only remaining cover content after using the canonical branch
predicate: every non-genuine RHS term has a mixed-boundary preimage. -/
private structure forestComponentSplitPhiNoForestMixedCoverCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  mixed_exists :
    ∀ r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g},
      ¬ (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r →
        ∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1

/-- A usual RHS branch-cover certificate supplies the residual mixed cover once
the genuine-preimage case is excluded by the canonical predicate. -/
private def forestComponentSplitPhiNoForestMixedCoverCertificateOfBranchCover
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiBranchCoverCertificate g) :
    forestComponentSplitPhiNoForestMixedCoverCertificate g where
  mixed_exists := by
    intro r hNotForest
    rcases K.cover r.1 r.2 with hForest | hMixed
    · exact False.elim (hNotForest hForest)
    · exact hMixed

/-- Canonical mixed preimage choice from the residual non-genuine cover
certificate. -/
private noncomputable def forestComponentSplitPhiCanonicalMixedPreimageChoice
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g) :
    forestComponentSplitPhiMixedPreimageChoice g
      (forestComponentSplitPhiCanonicalRHSBranchPredicate g) where
  choice := fun r h => Classical.choose (K.mixed_exists r h)

/-- The canonical mixed choice satisfies membership and target reconstruction by
unpacking the residual non-genuine cover certificate. -/
private noncomputable def
    forestComponentSplitPhiCanonicalMixedPreimageChoiceLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g) :
    forestComponentSplitPhiMixedPreimageChoiceLaws g
      (forestComponentSplitPhiCanonicalRHSBranchPredicate g)
      (forestComponentSplitPhiCanonicalMixedPreimageChoice g K) where
  choice_mem := by
    intro r h
    exact Classical.choose (Classical.choose_spec (K.mixed_exists r h))
  target_eq := by
    intro r h
    change forestComponentMixedBoundaryToQuotientForestSigma g
        (Classical.choose (K.mixed_exists r h))
        (Classical.choose (Classical.choose_spec (K.mixed_exists r h))) = r.1
    exact Classical.choose_spec (Classical.choose_spec (K.mixed_exists r h))

/-- Normalization of the canonical mixed-boundary preimage choice on mixed
branch images. -/
private structure forestComponentSplitPhiCanonicalMixedImageNormalizer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g) where
  normalizes :
    ∀ r : {r : forestQuotientForestSigma g //
        r ∈ forestQuotientForestSigmaIndex g},
      ∀ h : ¬ (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r,
        ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1 →
            (forestComponentSplitPhiCanonicalMixedPreimageChoice g K).choice r h =
              q

/-- A canonical mixed-image normalizer supplies same-branch injectivity for the
mixed-boundary branch. -/
private def forestComponentSplitPhiMixedBranchInjectivityOfCanonicalNormalizer
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g)
    (JX : forestComponentSplitPhiMixedImageNotForest g)
    (N : forestComponentSplitPhiCanonicalMixedImageNormalizer g K) :
    forestComponentSplitPhiMixedBranchInjectivity g where
  mixed_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    let r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁,
        forestComponentMixedBoundaryToQuotientForestSigma_mem g q₁ hq₁⟩
    have hNot :
        ¬ (forestComponentSplitPhiCanonicalRHSBranchPredicate g).isForest r :=
      JX.not_forest q₁ hq₁
    have hn₁ :
        (forestComponentSplitPhiCanonicalMixedPreimageChoice g K).choice r hNot =
          q₁ :=
      N.normalizes r hNot q₁ hq₁ rfl
    have hn₂ :
        (forestComponentSplitPhiCanonicalMixedPreimageChoice g K).choice r hNot =
          q₂ :=
      N.normalizes r hNot q₂ hq₂ hφ.symm
    exact hn₁.symm.trans hn₂

/-- Same-branch mixed injectivity supplies normalization of the canonical mixed
preimage choice once the residual mixed cover chooses a preimage. -/
private noncomputable def
    forestComponentSplitPhiCanonicalMixedImageNormalizerOfInjectivity
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g)
    (J : forestComponentSplitPhiMixedBranchInjectivity g) :
    forestComponentSplitPhiCanonicalMixedImageNormalizer g K where
  normalizes := by
    intro r h q hq htarget
    let q₀ : forestComponentChoiceSigma g :=
      Classical.choose (K.mixed_exists r h)
    let hq₀ : q₀ ∈ forestComponentMixedBoundaryChoiceSigmaIndex g :=
      Classical.choose (Classical.choose_spec (K.mixed_exists r h))
    have htarget₀ :
        forestComponentMixedBoundaryToQuotientForestSigma g q₀ hq₀ = r.1 :=
      Classical.choose_spec (Classical.choose_spec (K.mixed_exists r h))
    change q₀ = q
    exact J.mixed_inj q₀ hq₀ q hq (htarget₀.trans htarget.symm)

/-- Residual mixed-branch classifier after the RHS predicate has been
canonicalized: mixed images are not genuine images, every non-genuine RHS term
has a mixed preimage, and the canonical mixed choice normalizes on mixed
images. -/
private structure forestComponentSplitPhiResidualMixedBranchClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  not_forest : forestComponentSplitPhiMixedImageNotForest g
  cover : forestComponentSplitPhiNoForestMixedCoverCertificate g
  normalizer : forestComponentSplitPhiCanonicalMixedImageNormalizer g cover

/-- The final residual split-branch classifier: after all algebra and graph
transport has been discharged, this is the remaining finite branch
classification payload for H5.8F. -/
private structure forestComponentSplitPhiResidualBranchClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  forest : forestComponentSplitPhiResidualForestBranchClassifier g
  mixed : forestComponentSplitPhiResidualMixedBranchClassifier g

/-- Build the final residual classifier from the remaining explicit branch
facts.  This is the constructor form used right before the final H5.8F cut. -/
private noncomputable def forestComponentSplitPhiResidualBranchClassifierOfPieces
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantSourceEdgeWitnessCertificate g q hq)
    (JF : forestComponentSplitPhiForestBranchInjectivity g)
    (JM : forestComponentSplitPhiMixedBranchInjectivity g)
    (JX : forestComponentSplitPhiMixedImageNotForest g)
    (K : forestComponentSplitPhiNoForestMixedCoverCertificate g) :
    forestComponentSplitPhiResidualBranchClassifier g where
  forest :=
    { edge_witness := C
      normalizer :=
        forestComponentSplitPhiCanonicalForestImageNormalizerOfInjectivity g JF }
  mixed :=
    { not_forest := JX
      cover := K
      normalizer :=
        forestComponentSplitPhiCanonicalMixedImageNormalizerOfInjectivity g K JM }

/-- Forget the equality witness in a branch decision and keep only the chosen
split-LHS preimage.  The explicit return type keeps the two `Sum` branches from
leaving metavariables for Lean to infer. -/
private def forestComponentSplitPhiBranchDecisionPreimageOfClassify
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (classify :
      ∀ r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g},
        forestComponentSplitPhiForestPreimageData g r.1 ⊕
          forestComponentSplitPhiMixedPreimageData g r.1)
    (r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g}) :
    forestComponentSplitChoiceSigma g :=
  match classify r with
  | Sum.inl data => (Sum.inl data.1 : forestComponentSplitChoiceSigma g)
  | Sum.inr data => (Sum.inr data.1 : forestComponentSplitChoiceSigma g)

/-- A propositional RHS branch-cover certificate can be turned into branch
decision cover data by choosing one of the finite preimage witnesses. -/
private noncomputable def forestComponentSplitPhiBranchDecisionCoverOfCertificate
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (K : forestComponentSplitPhiBranchCoverCertificate g) :
    forestComponentSplitPhiBranchDecisionCover g where
  classify := by
    intro r
    by_cases hF :
      ∃ q, ∃ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
        forestComponentForestChoiceToQuotientForestSigma g q hq = r.1
    · let q := Classical.choose hF
      let hqTarget := Classical.choose_spec hF
      let hq := Classical.choose hqTarget
      let htarget := Classical.choose_spec hqTarget
      exact Sum.inl ⟨q, ⟨hq, htarget⟩⟩
    · have hM :
        ∃ q, ∃ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
          forestComponentMixedBoundaryToQuotientForestSigma g q hq = r.1 := by
        rcases K.cover r.1 r.2 with hF' | hM
        · exact False.elim (hF hF')
        · exact hM
      let q := Classical.choose hM
      let hqTarget := Classical.choose_spec hM
      let hq := Classical.choose hqTarget
      let htarget := Classical.choose_spec hqTarget
      exact Sum.inr ⟨q, ⟨hq, htarget⟩⟩

/-- Image-normalization laws for a branch-cover classifier: when the RHS term is
already the canonical image of a genuine or mixed branch point, the classifier
returns that same branch point. -/
private structure forestComponentSplitPhiBranchDecisionImageLaws
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g) where
  forest_preimage :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ hr :
        forestComponentForestChoiceToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g D.classify
          ⟨forestComponentForestChoiceToQuotientForestSigma g q hq, hr⟩ =
          Sum.inl q
  mixed_preimage :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      ∀ hr :
        forestComponentMixedBoundaryToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g D.classify
          ⟨forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr⟩ =
          Sum.inr q

/-- Branch injectivity and cross-branch separation normalize any chosen RHS cover
classifier on canonical genuine and mixed images. -/
private def forestComponentSplitPhiBranchDecisionImageLawsOfSeparated
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (D : forestComponentSplitPhiBranchDecisionCover g)
    (J : forestComponentSplitPhiBranchInjectivitySeparation g) :
    forestComponentSplitPhiBranchDecisionImageLaws g D where
  forest_preimage := by
    intro q hq hr
    cases h : D.classify
        ⟨forestComponentForestChoiceToQuotientForestSigma g q hq, hr⟩ with
    | inl data =>
        have hqeq : data.1 = q :=
          J.forest_inj data.1 data.2.1 q hq data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h, hqeq]
    | inr data =>
        have hcross :
            forestComponentForestChoiceToQuotientForestSigma g q hq ≠
              forestComponentMixedBoundaryToQuotientForestSigma g data.1 data.2.1 :=
          J.cross q hq data.1 data.2.1
        exact False.elim (hcross data.2.2.symm)
  mixed_preimage := by
    intro q hq hr
    cases h : D.classify
        ⟨forestComponentMixedBoundaryToQuotientForestSigma g q hq, hr⟩ with
    | inl data =>
        have hcross :
            forestComponentForestChoiceToQuotientForestSigma g data.1 data.2.1 ≠
              forestComponentMixedBoundaryToQuotientForestSigma g q hq :=
          J.cross data.1 data.2.1 q hq
        exact False.elim (hcross data.2.2)
    | inr data =>
        have hqeq : data.1 = q :=
          J.mixed_inj data.1 data.2.1 q hq data.2.2
        simpa [forestComponentSplitPhiBranchDecisionPreimageOfClassify, h, hqeq]

/-- Branch-decision plus reconstruction data for the RHS finite carrier.  This
is the final classifier payload in constructive form: every RHS term is
classified as a genuine or mixed image, with enough equality data to prove the
right inverse, and with branch-image laws for the canonical images. -/
private structure forestComponentSplitPhiBranchDecisionReconstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen) where
  classify :
    ∀ r : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g},
      forestComponentSplitPhiForestPreimageData g r.1 ⊕
        forestComponentSplitPhiMixedPreimageData g r.1
  forest_preimage :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      ∀ hr :
        forestComponentForestChoiceToQuotientForestSigma g q hq ∈
          forestQuotientForestSigmaIndex g,
        forestComponentSplitPhiBranchDecisionPreimageOfClassify g classify
          ⟨forestComponentForestChoiceToQuotientForestSigma g q hq, hr⟩ =
