  unfold forestComponentForestChoiceRepRightQuotientSubgraphCanonical
    forestComponentForestChoiceRepRightQuotientSubgraph
  apply forestOuterRepRetargetAdmissibleSubgraphOfCert_toHopfH_eq_of_not_mem
  intro ő≥ hő≥ v hv
  rw [forestComponentForestChoiceOuterIndex_val]
  exact forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
    q.1.1 q.2
    ((repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2)
    hő≥ hv

/-- The representative transport for the genuine-forest right-selected
survivor forest preserves the Hopf product relative to its actual quotient
carrier. -/
private theorem
    forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq_actual
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
