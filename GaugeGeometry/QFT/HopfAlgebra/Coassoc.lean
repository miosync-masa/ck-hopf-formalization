    ((forestQuotientForestSigmaActualQuotientSubgraph g r.1).isConnectedDivergent_of_mem
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ).1).1
  have hrem :=
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r δ
  have hsplit :
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges.erase e =
        forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
          (forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ).erase e := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    exact Multiset.erase_add_right_pos _ he
  have hExLe :
      forestQuotientForestSigmaForestCoverExactInternalEdges g r δ ≤
        ((forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.eraseInternalEdge
          e).internalEdges := by
    rw [FeynmanGraph.eraseInternalEdge_internalEdges]
    show forestQuotientForestSigmaForestCoverExactInternalEdges g r δ ≤
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges.erase e
    rw [hsplit]
    exact Multiset.le_add_right _ _
  intro u v hu hv
  rw [FeynmanGraph.eraseInternalEdge_vertices] at hu hv
  have hu' : u ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := hu
  have hv' : v ∈ forestQuotientForestSigmaForestCoverSourceVertices g r δ := hv
  have hretu :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
