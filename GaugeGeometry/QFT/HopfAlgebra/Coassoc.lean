        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)) =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges := by
  classical
