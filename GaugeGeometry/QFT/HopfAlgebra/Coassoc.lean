    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices

/-- Sprint F2i-3o-2b: membership characterization for promoted components. -/
private theorem forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {ő∑ : FeynmanSubgraph (repG g).toFeynmanGraph} :
    ő∑ ‚ąą forestQuotientForestSigmaForestCoverPromotedComponents g r őī ‚ÜĒ
      ő∑ ‚ąą r.1.1.1.elements ‚ąß
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices := by
  unfold forestQuotientForestSigmaForestCoverPromotedComponents
  exact Finset.mem_filter

/-- Sprint F2i-3o-2b: total internal-edge multiset contributed by the
promoted components.  This is the additive term required by the corrected
source subgraph design `ő≥.internalEdges = E + promoted_A.internalEdges`,
so that the quotient remainder cancels `A.internalEdges` exactly. -/
private noncomputable def forestQuotientForestSigmaForestCoverPromotedInternalEdges
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    Multiset FeynmanEdge :=
  (forestQuotientForestSigmaForestCoverPromotedComponents g r őī).sum
    (fun ő∑ => ő∑.internalEdges)

/-- Sprint F2i-3o-2b: every promoted internal edge has both endpoints inside
the recovered source vertices.  The proof unpacks the `Finset.sum` membership
into `ő∑ ‚ąą PromotedComponents`, then uses F2i-3a `_eta_subset` to send
each endpoint into SourceVertices via `ő∑.vertices`. -/
private theorem forestQuotientForestSigmaForestCoverPromotedInternalEdges_endpoints
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (he : e ‚ąą forestQuotientForestSigmaForestCoverPromotedInternalEdges g r őī) :
    e.source ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī ‚ąß
      e.target ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī := by
  classical
  unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges at he
  rcases Multiset.mem_sum.mp he with ‚ü®ő∑, hő∑Promoted, heI‚ü©
  rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff]
    at hő∑Promoted
  obtain ‚ü®hő∑A, hStarInőī‚ü© := hő∑Promoted
  have hSupp : e.source ‚ąą ő∑.vertices ‚ąß e.target ‚ąą ő∑.vertices :=
    ő∑.edges_supported e heI
  refine ‚ü®?_, ?_‚ü©
  ¬∑ exact forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hő∑A hStarInőī hSupp.1
  ¬∑ exact forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hő∑A hStarInőī hSupp.2

/-- Sprint F2i-3o-2e-pre-2: standalone packaging of the F2i-3o-2c inner step.
