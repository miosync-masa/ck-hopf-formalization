/-- **Track CoverData-disjoint — `SourceSubgraphExactPlus` vertex-disjointness is
structural.**  Distinct forest cover components have disjoint spliced source
carriers.  The proof is purely structural (no boundary facade): the quotient
forest components are proper-disjoint, the outer forest `r.1.1.1` is
pairwise-disjoint, and non-star δ-vertices live outside the outer carrier while
promoted vertices live inside it.  This discharges the `forest_disjoint` half of
`CoassocStrictForestH58CoverData` canonically. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ₁ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (hδ₁ : δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r)
    (hδ₂ : δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r)
    (hne : δ₁ ≠ δ₂) :
    Disjoint
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₁).vertices
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ₂).vertices := by
  classical
  have hApd : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hδdisj : Disjoint δ₁.vertices δ₂.vertices :=
    ((forestOuterActualQuotientGraph g r.1.1).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r))
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ₁).1
      ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ₂).1
      hne
  show Disjoint
    (forestQuotientForestSigmaForestCoverSourceVertices g r δ₁)
    (forestQuotientForestSigmaForestCoverSourceVertices g r δ₂)
  rw [Finset.disjoint_left]
  intro v hv₁ hv₂
  unfold forestQuotientForestSigmaForestCoverSourceVertices at hv₁ hv₂
  rcases Finset.mem_union.mp hv₁ with h1ns | h1pr
  · rcases Finset.mem_sdiff.mp h1ns with ⟨hv1δ, hv1ns⟩
    have hvNotA : v ∉ r.1.1.1.vertices :=
      forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
        g r hv1δ hv1ns
    rcases Finset.mem_union.mp hv₂ with h2ns | h2pr
    · exact Finset.disjoint_left.mp hδdisj hv1δ (Finset.mem_sdiff.mp h2ns).1
    · rcases Finset.mem_biUnion.mp h2pr with ⟨η₂, hη₂A, hvB⟩
      by_cases hs₂ :
        FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η₂ ∈ δ₂.vertices
      · simp only [hs₂, if_true] at hvB
        exact hvNotA (AdmissibleSubgraph.mem_vertices.mpr ⟨η₂, hη₂A, hvB⟩)
      · simp only [hs₂, if_false] at hvB
        exact (Finset.notMem_empty v hvB).elim
  · rcases Finset.mem_biUnion.mp h1pr with ⟨η₁, hη₁A, hvB1⟩
    by_cases hs₁ :
      FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η₁ ∈ δ₁.vertices
    · simp only [hs₁, if_true] at hvB1
      rcases Finset.mem_union.mp hv₂ with h2ns | h2pr
      · rcases Finset.mem_sdiff.mp h2ns with ⟨hv2δ, hv2ns⟩
        have hvNotA : v ∉ r.1.1.1.vertices :=
          forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem_not_mem_outer
            g r hv2δ hv2ns
        exact hvNotA (AdmissibleSubgraph.mem_vertices.mpr ⟨η₁, hη₁A, hvB1⟩)
      · rcases Finset.mem_biUnion.mp h2pr with ⟨η₂, hη₂A, hvB2⟩
        by_cases hs₂ :
          FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 η₂ ∈ δ₂.vertices
        · simp only [hs₂, if_true] at hvB2
          by_cases hηe : η₁ = η₂
          · subst hηe
            exact Finset.disjoint_left.mp hδdisj hs₁ hs₂
          · exact (Finset.disjoint_left.mp (hApd hη₁A hη₂A hηe) hvB1) hvB2
        · simp only [hs₂, if_false] at hvB2
          exact (Finset.notMem_empty v hvB2).elim
    · simp only [hs₁, if_false] at hvB1
      exact (Finset.notMem_empty v hvB1).elim

