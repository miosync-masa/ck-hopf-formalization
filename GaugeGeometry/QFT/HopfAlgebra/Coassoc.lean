      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = eδ.source := by
    rw [← hmap]; rfl
  have hrt :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = eδ.target := by
    rw [← hmap]; rfl
  -- `Plus.eraseInternalEdge e` still contains `eE` and all Promoted edges.
  have heraseEq :
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges.erase e =
        (forestQuotientForestSigmaForestCoverExactInternalEdges g r δ).erase e +
          forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    exact Multiset.erase_add_left_pos _ he
  have hKle :
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤
        ((forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.eraseInternalEdge
          e).internalEdges := by
    rw [FeynmanGraph.eraseInternalEdge_internalEdges]
    show forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ ≤
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges.erase e
    rw [heraseEq]
    exact Multiset.le_add_left _ _
  have heEPlus : eE ∈
      ((forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.eraseInternalEdge
        e).internalEdges := by
    rw [FeynmanGraph.eraseInternalEdge_internalEdges]
    show eE ∈
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges.erase e
    rw [heraseEq]
    exact Multiset.mem_add.mpr (Or.inl heEerase)
  have plusAdj : eE.source ≠ eE.target →
      ((forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.eraseInternalEdge
        e).SupportReachable eE.source eE.target :=
    fun hne => SimpleGraph.Adj.reachable
      (show ((forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).toFeynmanGraph.eraseInternalEdge
          e).SupportAdj eE.source eE.target from ⟨hne, eE, heEPlus, Or.inl ⟨rfl, rfl⟩⟩)
  rcases hend with ⟨hsc, htb⟩ | ⟨hsb, htc⟩
  · have hsEc :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.source = c := hrs.trans hsc
    have htEb :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) eE.target = b := hrt.trans htb
    have hne : eE.source ≠ eE.target := fun h =>
      hcb (hsEc.symm.trans ((congrArg _ h).trans htEb))
    exact ⟨eE.target, htE, htEb,
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_sameRetarget_reachable_in
        g r δ hKle hwc hsE (hwcc.trans hsEc.symm)).trans (plusAdj hne)⟩
  · have hsEb :
        r.1.1.1.retargetVertex
