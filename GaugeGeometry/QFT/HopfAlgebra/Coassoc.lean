  exact lt_of_lt_of_le hζEdges (Multiset.card_le_card hLe)

/-- Sprint F2i-3q-model-4a-6-helper-1: `FeynmanGraph.mapPerm` is injective in
its FeynmanGraph argument.  Apply `mapPerm π⁻¹` to both sides; `mapPerm_mul`
+ `mul_inv_cancel` + `mapPerm_one` collapse to the identity. -/
private theorem feynmanGraph_mapPerm_injective
    {G₁ G₂ : FeynmanGraph} {π : Equiv.Perm VertexId}
    (h : G₁.mapPerm π = G₂.mapPerm π) :
    G₁ = G₂ := by
  have hInv : (G₁.mapPerm π).mapPerm π⁻¹ = (G₂.mapPerm π).mapPerm π⁻¹ :=
    congrArg (fun G => G.mapPerm π⁻¹) h
  rw [← FeynmanGraph.mapPerm_mul, ← FeynmanGraph.mapPerm_mul,
      inv_mul_cancel, FeynmanGraph.mapPerm_one,
      FeynmanGraph.mapPerm_one] at hInv
  exact hInv

