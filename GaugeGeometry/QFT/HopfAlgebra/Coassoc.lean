    forestComponentForestChoice_gamma_internalEdges_sub_outer_eq_componentRemnant_complementEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph // ő≥ ‚ąą q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
