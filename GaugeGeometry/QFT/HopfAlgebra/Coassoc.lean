                g q hq hőīP
          have hvAct : outerStar őī ‚ąą Aact.vertices := by
            rw [hAactVertices]
            exact Finset.mem_union_right _ hvM
          exact False.elim (hvNotAct hvAct)
    ¬∑ rw [AdmissibleSubgraph.mem_starVertices] at hvStarAct
      rcases hvStarAct with ‚ü®őī, hőīAct, rfl‚ü©
      rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements] at hőīAct
      unfold forestComponentForestChoiceActualQuotientComponents at hőīAct
