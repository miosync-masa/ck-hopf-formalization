    (hRem : forestComponentForestChoiceParentRemnant g q hq ő≥‚āĀ =
            forestComponentForestChoiceParentRemnant g q hq ő≥‚āā) :
    ő≥‚āĀ = ő≥‚āā := by
  classical
  have hA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hAoutPD :
