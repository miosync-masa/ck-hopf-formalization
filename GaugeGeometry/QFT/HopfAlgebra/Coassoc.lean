    rw [← hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨u, hu', rfl⟩
  have hretv :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v ∈ δ.vertices := by
    rw [← hrem, admissibleSubgraphQuotientRemainderSubgraph_vertices]
    exact Finset.mem_image.mpr ⟨v, hv', rfl⟩
