/-- Sprint F2i-3g helper: an ambient endpoint whose retarget lies in őī-vertex
belongs to the recovered source vertices.  Two cases: (i) ambient endpoint
‚ąČ A.vertices ‚ÄĒ retarget is identity, endpoint equals őī-side, and is
non-star (because ambient G.vertices is disjoint from fresh star
vertices); F2i-3a `_nonstar_mem` applies.  (ii) ambient endpoint
‚ąą A.vertices ‚ÄĒ `componentAt` returns ő∑ ‚ąą A.elements with endpoint ‚ąą
ő∑.vertices, retarget collapses to `starOf ő∑ ‚ąą őī.vertices`; F2i-3a
`_eta_subset` applies. -/
private theorem forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {v : VertexId} (hvG : v ‚ąą (repG g).toFeynmanGraph.vertices)
    {v' : VertexId}
    (hRet :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v = v')
    (hv'őī : v' ‚ąą őī.vertices) :
    v ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī := by
  classical
  by_cases hvA : v ‚ąą r.1.1.1.vertices
  ¬∑ -- v ‚ąą A.vertices: componentAt v gives ő∑ ‚ąą A.elements with v ‚ąą ő∑.vertices.
    set ő∑ := r.1.1.1.componentAt hvA with hő∑Def
    have hő∑A : ő∑ ‚ąą r.1.1.1.elements := r.1.1.1.componentAt_mem hvA
    have hvő∑ : v ‚ąą ő∑.vertices := r.1.1.1.componentAt_vertex_mem hvA
    have hRető∑ :
        r.1.1.1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) v =
          FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ := by
      rw [AdmissibleSubgraph.retargetVertex, r.1.1.1.componentAt?_of_mem hvA]
    have hStarEq : FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ = v' :=
      hRető∑.symm.trans hRet
    have hStarő∑ : FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2 ő∑ ‚ąą őī.vertices := by
      rw [hStarEq]; exact hv'őī
    exact (forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
      g r hő∑A hStarő∑) hvő∑
  ¬∑ -- v ‚ąČ A.vertices: retarget is identity, v ‚ąą G.vertices ‚ąČ A.starVertices (fresh).
    have hRetId := AdmissibleSubgraph.retargetVertex_of_not_mem r.1.1.1
      (FeynmanGraph.admissibleForestCanonicalStarOf
        (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) hvA
    have hvEq : v = v' := hRetId.symm.trans hRet
    have hFresh := FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
    have hvNotStar : v ‚ąČ r.1.1.1.starVertices
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) := fun hStar =>
      hFresh.star_not_mem_vertices hStar hvG
    have hvőī : v ‚ąą őī.vertices := hvEq.symm ‚Ėł hv'őī
    exact forestQuotientForestSigmaForestCoverSourceVertices_nonstar_mem
      g r hvőī hvNotStar

/-- Sprint F2i-3g: every őī-edge has at least one ambient preimage with
endpoints in the recovered source vertices.  Multiset existence; no
uniqueness, no global construction yet. -/
private theorem forestQuotientForestSigmaForestCover_edgePreimage_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e' : FeynmanEdge} (he' : e' ‚ąą őī.internalEdges) :
    ‚ąÉ e : FeynmanEdge,
      e ‚ąą (repG g).toFeynmanGraph.internalEdges ‚ąß
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e = e' ‚ąß
      e.source ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī ‚ąß
      e.target ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī := by
  classical
  have he'Q : e' ‚ąą (forestOuterActualQuotientGraph g r.1.1).internalEdges :=
    Multiset.mem_of_le őī.internalEdges_le he'
  unfold forestOuterActualQuotientGraph at he'Q
  rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_internalEdges] at he'Q
  rcases Multiset.mem_map.mp he'Q with ‚ü®e, heC, hRet‚ü©
  have heG : e ‚ąą (repG g).toFeynmanGraph.internalEdges :=
    AdmissibleSubgraph.mem_ambientInternalEdges_of_mem_complementEdges _ heC
  have heSupp := őī.edges_supported e' he'
  have hRetSrc :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.source = e'.source := by
    have := congrArg FeynmanEdge.source hRet; simpa using this
  have hRetTgt :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e.target = e'.target := by
    have := congrArg FeynmanEdge.target hRet; simpa using this
  have heGsupp := FeynmanGraph.wellFormed_internal (repG_wellFormed g) heG
  refine ‚ü®e, heG, hRet, ?_, ?_‚ü©
  ¬∑ exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r őī heGsupp.1 hRetSrc heSupp.1
  ¬∑ exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r őī heGsupp.2 hRetTgt heSupp.2

