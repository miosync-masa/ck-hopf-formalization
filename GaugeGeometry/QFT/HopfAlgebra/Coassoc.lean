private theorem forestComponentForestChoiceOuterSubgraph_mem_source_internalEdges_le
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {őī : FeynmanSubgraph G}
    (hőī : őī ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements) :
    ‚ąÉ ő≥ ‚ąą A.elements, őī.internalEdges ‚Č§ ő≥.internalEdges := by
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hőī
  rcases Finset.mem_union.mp hőī with hőīL | hőīF
