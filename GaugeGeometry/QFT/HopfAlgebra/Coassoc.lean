            (forestComponentForestChoiceOuterIndex g q hq).2)) := by
  classical
  let G‚āÄ := (repG g).toFeynmanGraph
  let A := q.1.1
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G‚āÄ Aout (forestComponentForestChoiceOuterIndex g q hq).2
  have hADisj : A.IsPairwiseDisjoint :=
    G‚āÄ.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by simpa [G‚āÄ, A] using q.1.2)
  have hpCore : q.2 ‚ąą forestComponentCoreChoiceIndex A := by
    exact (mem_forestComponentForestChoiceCoreIndex_core_hasForest
      ((Finset.mem_sigma.mp hq).2)).1
  have hA_le_G : A.internalEdges ‚Č§ G‚āÄ.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise A hADisj
  have hAout_le_A : Aout.internalEdges ‚Č§ A.internalEdges := by
    simpa [Aout, A, forestComponentForestChoiceOuterIndex_val] using
      forestComponentForestChoiceOuterSubgraph_internalEdges_le_original
        q.1.1 q.2 hpCore hADisj
  have hDiff_le :
      A.internalEdges - Aout.internalEdges ‚Č§
        G‚āÄ.internalEdges - Aout.internalEdges := by
    rw [Multiset.le_iff_count]
    intro e
    rw [Multiset.count_sub, Multiset.count_sub]
    have hcount := Multiset.count_le_of_le e hA_le_G
    omega
  have hSubSub :
      (G‚āÄ.internalEdges - Aout.internalEdges) -
          (A.internalEdges - Aout.internalEdges) =
        G‚āÄ.internalEdges - A.internalEdges := by
    refine Multiset.ext.mpr ?_
    intro e
    simp only [Multiset.count_sub]
    have hAoutA := Multiset.count_le_of_le e hAout_le_A
    have hAG := Multiset.count_le_of_le e hA_le_G
    omega
  have hQinternal :
      Q.internalEdges =
        (G‚āÄ.internalEdges - Aout.internalEdges).map
          (Aout.retargetEdge outerStar) := by
    simp [Q, G‚āÄ, Aout, outerStar, forestOuterActualQuotientGraph,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges,
      AdmissibleSubgraph.complementEdges]
  unfold AdmissibleSubgraph.complementEdges
  calc
    Q.internalEdges - Aact.internalEdges =
        (G‚āÄ.internalEdges - Aout.internalEdges).map
          (Aout.retargetEdge outerStar) -
          (A.internalEdges - Aout.internalEdges).map
            (Aout.retargetEdge outerStar) := by
          rw [hQinternal]
          rw [hInternal]
    _ = ((G‚āÄ.internalEdges - Aout.internalEdges) -
            (A.internalEdges - Aout.internalEdges)).map
          (Aout.retargetEdge outerStar) := by
          exact (multiset_map_sub_of_le (Aout.retargetEdge outerStar)
            hDiff_le).symm
    _ = (G‚āÄ.internalEdges - A.internalEdges).map
          (Aout.retargetEdge outerStar) := by
          rw [hSubSub]

private theorem forestComponentForestChoice_splitStar_internalEdges_eq_of_actual_internalEdges
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    (hInternal :
      (forestComponentForestChoiceActualQuotientSubgraphCanonical
        g q hq).internalEdges =
        (q.1.1.internalEdges -
          (forestComponentForestChoiceOuterIndex g q hq).1.internalEdges).map
          ((forestComponentForestChoiceOuterIndex g q hq).1.retargetEdge
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph
              (forestComponentForestChoiceOuterIndex g q hq).1
              (forestComponentForestChoiceOuterIndex g q hq).2))) :
    (forestComponentForestChoiceActualRightContractGraph g q hq C).internalEdges =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentForestChoiceSplitStarOf g q hq C)).internalEdges := by
  exact forestComponentForestChoice_splitStar_internalEdges_eq_of_complement
    g q hq C
    (forestComponentForestChoice_actualQuotient_complementEdges_eq_original_complement_map_of_internalEdges
      g q hq hInternal)

/-- The actual quotient-side final right contraction graph in the
mixed-boundary branch. -/
private noncomputable def forestComponentMixedBoundaryActualRightContractGraph
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    FeynmanGraph :=
  FeynmanGraph.admissibleForestContractGraphWithStars
    (forestOuterActualQuotientGraph g
      (forestComponentMixedBoundaryOuterIndex g q hq))
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq)
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (forestOuterActualQuotientGraph g
        (forestComponentMixedBoundaryOuterIndex g q hq))
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical g q hq)
      (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
        g q hq))

private theorem forestComponentMixedBoundary_splitStar_vertices_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightContractGraph g q hq).vertices =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentMixedBoundarySplitStarOf g q hq)).vertices := by
  classical
  let G‚āÄ := (repG g).toFeynmanGraph
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let A := q.1.1
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G‚āÄ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  let splitStar := forestComponentMixedBoundarySplitStarOf g q hq
  have hQvertices :
      Q.vertices = (G‚āÄ.vertices \ L.vertices) ‚ą™ L.starVertices outerStar := by
    simp [Q, G‚āÄ, forestOuterActualQuotientGraph, L, Aout, outerStar,
      forestComponentMixedBoundaryOuterIndex_val,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices]
  have hAactVertices : Aact.vertices = R.vertices := by
    simpa [Aact, R] using
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hAvertices : A.vertices = L.vertices ‚ą™ R.vertices := by
    simpa [A, L, R] using
      (forestComponentMixedBoundary_left_union_right_vertices g q hq).symm
  have hSplitStars :
      A.starVertices splitStar =
        L.starVertices splitStar ‚ą™ R.starVertices splitStar := by
    simpa [A, L, R, splitStar] using
      forestComponentMixedBoundary_splitStar_starVertices_eq_union g q hq
  have hLeftStars :
      L.starVertices splitStar = L.starVertices outerStar := by
    simpa [L, Aout, outerStar, splitStar] using
      forestComponentMixedBoundary_left_splitStar_starVertices_eq_outer g q hq
  have hRightStars :
      R.starVertices splitStar = Aact.starVertices rightStar := by
    simpa [R, Aact, Q, rightStar, splitStar] using
      forestComponentMixedBoundary_right_splitStar_starVertices_eq_actualRight
        g q hq
  have hLStarFresh :
      ‚ąÄ {v}, v ‚ąą L.starVertices outerStar ‚Üí v ‚ąČ G‚āÄ.vertices := by
    intro v hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ‚ü®ő≥, hő≥L, rfl‚ü©
    have hFresh :
        Aout.IsFreshStarAssignment outerStar := by
      simpa [G‚āÄ, Aout, outerStar] using
        FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
          (repG g).toFeynmanGraph
          (forestComponentMixedBoundaryOuterIndex g q hq).1
          (forestComponentMixedBoundaryOuterIndex g q hq).2
    exact hFresh.fresh (by
      simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using hő≥L)
  have hRsubsetG : R.vertices ‚äÜ G‚āÄ.vertices := by
    intro v hv
    simpa [G‚āÄ, R] using R.vertices_subset hv
  simp only [forestComponentMixedBoundaryActualRightContractGraph,
    FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices]
  ext v
  constructor
  ¬∑ intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStarR
    ¬∑ rcases Finset.mem_sdiff.mp hvDiff with ‚ü®hvQ, hvNotAct‚ü©
      rw [hQvertices] at hvQ
      rcases Finset.mem_union.mp hvQ with hvGnotL | hvLStar
      ¬∑ rcases Finset.mem_sdiff.mp hvGnotL with ‚ü®hvG, hvNotL‚ü©
        refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ‚ü®hvG, ?_‚ü©
        rw [hAvertices, Finset.mem_union]
        exact fun hLR => hLR.elim hvNotL (fun hvR =>
          hvNotAct (by exact hAactVertices.symm ‚Ėł hvR))
      ¬∑ refine Finset.mem_union_right _ ?_
        rw [hSplitStars, hLeftStars]
        exact Finset.mem_union_left _ hvLStar
    ¬∑ refine Finset.mem_union_right _ ?_
      rw [hSplitStars, hRightStars]
      exact Finset.mem_union_right _ hvStarR
  ¬∑ intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStar
    ¬∑ rcases Finset.mem_sdiff.mp hvDiff with ‚ü®hvG, hvNotA‚ü©
      refine Finset.mem_union_left _ ?_
      refine Finset.mem_sdiff.mpr ‚ü®?_, ?_‚ü©
      ¬∑ rw [hQvertices]
        refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ‚ü®hvG, ?_‚ü©
        intro hvL
        exact hvNotA (by
          rw [hAvertices, Finset.mem_union]
          exact Or.inl hvL)
      ¬∑ intro hvAct
        exact hvNotA (by
          rw [hAvertices, Finset.mem_union]
          exact Or.inr (by exact hAactVertices ‚Ėł hvAct))
    ¬∑ rw [hSplitStars, hLeftStars, hRightStars] at hvStar
      rcases Finset.mem_union.mp hvStar with hvLStar | hvRStar
      ¬∑ refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ‚ü®?_, ?_‚ü©
        ¬∑ rw [hQvertices]
          exact Finset.mem_union_right _ hvLStar
        ¬∑ intro hvAct
          exact hLStarFresh hvLStar (hRsubsetG (by
            exact hAactVertices ‚Ėł hvAct))
      ¬∑ exact Finset.mem_union_right _ hvRStar

private theorem forestComponentMixedBoundary_twoStep_retargetVertex_eq_splitStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g)
    (v : VertexId) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentMixedBoundaryOuterIndex g q hq))
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
            g q hq)
          (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq))
        ((forestComponentMixedBoundaryOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2)
          v) =
      q.1.1.retargetVertex
        (forestComponentMixedBoundarySplitStarOf g q hq) v := by
  classical
  let G‚āÄ := (repG g).toFeynmanGraph
  let A := q.1.1
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentMixedBoundaryOuterIndex g q hq)
  let Aact := forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G‚āÄ Aout (forestComponentMixedBoundaryOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  let splitStar := forestComponentMixedBoundarySplitStarOf g q hq
  have hADisj : A.IsPairwiseDisjoint :=
    G‚āÄ.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by simpa [G‚āÄ, A] using q.1.2)
  have hAoutDisj : Aout.IsPairwiseDisjoint := by
    simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using
      forestComponentChoiceLeftSubgraph_isPairwiseDisjoint q.1.1 q.2 hADisj
  have hAactDisj : Aact.IsPairwiseDisjoint :=
    Q.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by
        simpa [Q, Aact] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_properDisjoint
            g q hq)
  have hAoutVertices : Aout.vertices = L.vertices := by
    simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val]
  have hAactVertices : Aact.vertices = R.vertices := by
    simpa [Aact, R] using
      forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hAvertices : A.vertices = L.vertices ‚ą™ R.vertices := by
    simpa [A, L, R] using
      (forestComponentMixedBoundary_left_union_right_vertices g q hq).symm
  by_cases hvA : v ‚ąą A.vertices
  ¬∑ let ő≥ := A.componentAt hvA
    have hő≥A : ő≥ ‚ąą A.elements := A.componentAt_mem hvA
    have hvő≥ : v ‚ąą ő≥.vertices := A.componentAt_vertex_mem hvA
    rcases forestComponentMixedBoundary_choice_left_or_right g q hq ő≥ hő≥A with
      hő≥L | hő≥R
    ¬∑ have hő≥Aout : ő≥ ‚ąą Aout.elements := by
        simpa [Aout, L, forestComponentMixedBoundaryOuterIndex_val] using hő≥L
      have hOuter :
          Aout.retargetVertex outerStar v = outerStar ő≥ := by
        exact AdmissibleSubgraph.retargetVertex_of_mem_component
          hAoutDisj outerStar hő≥Aout hvő≥
      have hFreshOuter :
          Aout.IsFreshStarAssignment outerStar := by
        simpa [G‚āÄ, Aout, outerStar] using
          FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
            (repG g).toFeynmanGraph
            (forestComponentMixedBoundaryOuterIndex g q hq).1
            (forestComponentMixedBoundaryOuterIndex g q hq).2
      have hOuterNotAct : outerStar ő≥ ‚ąČ Aact.vertices := by
        intro hvAct
        have hvR : outerStar ő≥ ‚ąą R.vertices := by
          exact hAactVertices ‚Ėł hvAct
        exact hFreshOuter.fresh hő≥Aout (R.vertices_subset hvR)
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar (outerStar ő≥) := by rw [hOuter]
        _ = outerStar ő≥ := by
          exact AdmissibleSubgraph.retargetVertex_of_not_mem
            Aact rightStar hOuterNotAct
        _ = splitStar ő≥ := by
          simpa [outerStar, splitStar] using
            (forestComponentMixedBoundarySplitStarOf_left
              g q hq hő≥L).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hő≥A hvő≥]
    ¬∑ have hNotAout : v ‚ąČ Aout.vertices := by
        intro hvOut
        have hvL : v ‚ąą L.vertices := by
          exact hAoutVertices ‚Ėł hvOut
        exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
          q.1.1 q.2 hADisj hő≥R hvő≥ hvL
      have hOuter : Aout.retargetVertex outerStar v = v :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hNotAout
      let őī :=
        admissibleSubgraphRetargetSubgraph
          Aout outerStar ő≥
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥ hő≥R)
      have hőī : őī ‚ąą Aact.elements := by
        simpa [Aout, outerStar, Aact, őī] using
          forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
            g q hq hő≥R
      have hvőī : v ‚ąą őī.vertices := by
        change v ‚ąą ő≥.vertices.image (Aout.retargetVertex outerStar)
        exact Finset.mem_image.mpr ‚ü®v, hvő≥, hOuter‚ü©
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar v := by rw [hOuter]
        _ = rightStar őī := by
          exact AdmissibleSubgraph.retargetVertex_of_mem_component
            hAactDisj rightStar hőī hvőī
        _ = splitStar ő≥ := by
          simpa [Aout, outerStar, Q, Aact, rightStar, splitStar, őī] using
            (forestComponentMixedBoundarySplitStarOf_right
              g q hq hő≥R).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hő≥A hvő≥]
  ¬∑ have hNotAout : v ‚ąČ Aout.vertices := by
      intro hvOut
      apply hvA
      rw [hAvertices]
      exact Finset.mem_union_left _ (by exact hAoutVertices ‚Ėł hvOut)
    have hNotAct : v ‚ąČ Aact.vertices := by
      intro hvAct
      apply hvA
      rw [hAvertices]
      exact Finset.mem_union_right _ (by exact hAactVertices ‚Ėł hvAct)
    have hOuter : Aout.retargetVertex outerStar v = v :=
      AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hNotAout
    calc
      Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
          = Aact.retargetVertex rightStar v := by rw [hOuter]
      _ = v := by
        exact AdmissibleSubgraph.retargetVertex_of_not_mem
          Aact rightStar hNotAct
      _ = A.retargetVertex splitStar v := by
        rw [AdmissibleSubgraph.retargetVertex_of_not_mem A splitStar hvA]

private theorem forestComponentMixedBoundary_twoStep_retargetExternalLeg_eq_splitStar
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
