    (hη₁ : η₁ ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ))
    (hη₂ : η₂ ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ))
    (h : forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η₁ hη₁ =
      forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η₂ hη₂) :
