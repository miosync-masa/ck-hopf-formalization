    {wc : VertexId}
    (hwc : wc ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī)
    (hwcc :
      r.1.1.1.retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
