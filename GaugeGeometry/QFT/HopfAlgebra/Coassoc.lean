    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) : Type where
  cd : ‚ąÄ őī ‚ąą forestComponentForestChoiceRemnantComponents g q hq,
    őī.IsConnectedDivergent
  compat : ‚ąÄ őī‚āĀ, őī‚āĀ ‚ąą forestComponentForestChoiceRemnantComponents g q hq ‚Üí
    ‚ąÄ őī‚āā, őī‚āā ‚ąą forestComponentForestChoiceRemnantComponents g q hq ‚Üí
      őī‚āĀ ‚Č† őī‚āā ‚Üí őī‚āĀ.NestedOrDisjoint őī‚āā

/-- Once each selected component remnant has been identified as a connected
