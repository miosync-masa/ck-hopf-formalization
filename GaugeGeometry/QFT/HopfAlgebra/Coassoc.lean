/-- In the promoted genuine-forest splice, the total multiplicity of an
internal edge of the selected component is exactly the multiplicity contributed
by the transported component forest. -/
private theorem
    forestComponentForestChoice_promotedForestComponents_internalEdges_count_eq_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (_hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph // ő≥ ‚ąą q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hB :
      q.2 ő≥ (Finset.mem_attach q.1.1.elements ő≥) =
        forestCoproductChoice.forest B)
    {e : FeynmanEdge} (heő≥ : e ‚ąą ő≥.1.internalEdges) :
    (‚ąĎ őī ‚ąą forestComponentChoicePromotedForestComponents q.1.1 q.2,
        Multiset.count e őī.internalEdges) =
      Multiset.count e
        (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
          (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).internalEdges := by
  classical
  have hDisjA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
  have hsuppő≥ := ő≥.1.edges_supported e heő≥
  simp [FeynmanEdge.SupportedOn] at hsuppő≥
  unfold forestComponentChoicePromotedForestComponents
  rw [Finset.sum_biUnion_of_pairwise_eq_zero (M := Nat)]
  ¬∑ calc
      _ = _ := by
        rw [Finset.sum_eq_single ő≥]
        ¬∑ intro ő∑ _hő∑ hő∑ő≥
          cases hő∑Choice :
              q.2 ő∑ (Finset.mem_attach q.1.1.elements ő∑) with
          | left =>
              simp
          | right =>
              simp
          | forest Bő∑ =>
              simp
              intro őī hőī heőī
              have hsuppőī := őī.edges_supported e heőī
              simp [FeynmanEdge.SupportedOn] at hsuppőī
              have hőīSubset :
                  őī.vertices ‚äÜ ő∑.1.vertices :=
                feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                  ő∑.1 (q.1.1.isConnectedDivergent_of_mem ő∑.2) Bő∑ hőī
              have hő∑ő≥Ne : ő∑.1 ‚Č† ő≥.1 := by
                intro hEq
                exact hő∑ő≥ (Subtype.ext hEq)
              have hdisj : ő∑.1.Disjoint ő≥.1 := hDisjA ő∑.2 ő≥.2 hő∑ő≥Ne
              exact (Finset.disjoint_left.mp hdisj (hőīSubset hsuppőī.1)) hsuppő≥.1
        ¬∑ intro hő≥not
          exact False.elim (hő≥not (Finset.mem_attach q.1.1.elements ő≥))
      _ =
        Multiset.count e
          (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
            (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).internalEdges := by
        rw [show q.2 ő≥ _ = q.2 ő≥
            (Finset.mem_attach q.1.1.elements ő≥) by
          congr]
        rw [hB]
        change
          (‚ąĎ őī ‚ąą
              (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
                (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).elements,
            Multiset.count e őī.internalEdges) =
            Multiset.count e
              (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
                (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).internalEdges
        rw [‚Üź Multiset.count_sum']
        exact congrArg (Multiset.count e)
          (feynmanSubgraphRepForestPromoteAdmissibleSubgraph_internalEdges
            ő≥.1 (q.1.1.isConnectedDivergent_of_mem ő≥.2) B)
  ¬∑ intro ő∑ _hő∑ őł _hőł hő∑őł őī hőī
    apply Multiset.count_eq_zero.mpr
    intro heőī
    rcases Finset.mem_inter.mp hőī with ‚ü®hőīő∑, hőīőł‚ü©
    have hsuppőī := őī.edges_supported e heőī
    simp [FeynmanEdge.SupportedOn] at hsuppőī
    cases hő∑Choice :
        q.2 ő∑ (Finset.mem_attach q.1.1.elements ő∑) with
    | left =>
        simp [hő∑Choice] at hőīő∑
    | right =>
        simp [hő∑Choice] at hőīő∑
    | forest Bő∑ =>
        cases hőłChoice :
            q.2 őł (Finset.mem_attach q.1.1.elements őł) with
        | left =>
            simp [hőłChoice] at hőīőł
        | right =>
            simp [hőłChoice] at hőīőł
        | forest Bőł =>
            have hőīSubsető∑ :
                őī.vertices ‚äÜ ő∑.1.vertices :=
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                ő∑.1 (q.1.1.isConnectedDivergent_of_mem ő∑.2) Bő∑
                (by simpa [hő∑Choice] using hőīő∑)
            have hőīSubsetőł :
                őī.vertices ‚äÜ őł.1.vertices :=
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
                őł.1 (q.1.1.isConnectedDivergent_of_mem őł.2) Bőł
                (by simpa [hőłChoice] using hőīőł)
            by_cases hő∑őłVal : ő∑.1 = őł.1
            ¬∑ exact hő∑őł (Subtype.ext hő∑őłVal)
            ¬∑ have hdisj : ő∑.1.Disjoint őł.1 := hDisjA ő∑.2 őł.2 hő∑őłVal
              exact (Finset.disjoint_left.mp hdisj
                (hőīSubsető∑ hsuppőī.1)) (hőīSubsetőł hsuppőī.1)

/-- A left-selected outer component contributes no multiplicity to an internal
edge of a component whose choice is a genuine forest. -/
private theorem
    forestComponentForestChoice_leftSubgraph_internalEdges_count_eq_zero_of_component
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
