/-- Genuine-forest branch transport payload for the right-selected survivor
forest: retargeting through the spliced outer forest and transporting to the
representative quotient preserve the Hopf product. -/
private theorem
    forestComponentForestChoiceRepRightQuotientSubgraphCanonical_toHopfH_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g) :
    (forestComponentForestChoiceRepRightQuotientSubgraphCanonical g q hq
      ).toHopfH =
        (forestComponentChoiceRightSubgraph q.1.1 q.2).toHopfH := by
