/-- Inside a component selected by a genuine forest choice, the vertices hit by
the spliced outer forest are exactly the vertices hit by the transported
component forest. -/
private theorem
    forestComponentForestChoice_vertex_mem_outer_iff_componentRemnant
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    (ő≥ : {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph // ő≥ ‚ąą q.1.1.elements})
    {B : AdmissibleSubgraph
      (repG (ő≥.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem ő≥.2))).toFeynmanGraph}
    (hB :
      q.2 ő≥ (Finset.mem_attach q.1.1.elements ő≥) =
        forestCoproductChoice.forest B)
    {u : VertexId} (huő≥ : u ‚ąą ő≥.1.vertices) :
    u ‚ąą (forestComponentForestChoiceOuterIndex g q hq).1.vertices ‚ÜĒ
      u ‚ąą (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
        (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).vertices := by
  classical
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Bc := feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
    (q.1.1.isConnectedDivergent_of_mem ő≥.2) B
  constructor
  ¬∑ intro huOuter
    rcases AdmissibleSubgraph.mem_vertices.mp huOuter with
      ‚ü®őī, hőīOuter, huőī‚ü©
    rw [forestComponentForestChoiceOuterIndex_val,
      forestComponentForestChoiceOuterSubgraph_elements] at hőīOuter
    rcases Finset.mem_union.mp hőīOuter with hőīLeft | hőīForest
    ¬∑ have hőīA : őī ‚ąą q.1.1.elements :=
        forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hőīLeft
      by_cases hőīő≥ : őī = ő≥.1
      ¬∑ subst őī
        rw [forestComponentChoiceLeftSubgraph_elements] at hőīLeft
        have hLeft := (Finset.mem_filter.mp hőīLeft).2
        unfold forestComponentChoiceIsLeft at hLeft
        rw [dif_pos ő≥.2] at hLeft
        rw [hB] at hLeft
        cases hLeft
      ¬∑ have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : őī.Disjoint ő≥.1 := hDisjA hőīA ő≥.2 hőīő≥
        exact False.elim ((Finset.disjoint_left.mp hdisj huőī) huő≥)
    ¬∑ rcases forestComponentChoicePromotedForestComponents_mem_exists
        q.1.1 q.2 hőīForest with
        ‚ü®ő∑, Bő∑, hBő∑, hőīBő∑‚ü©
      have hőīSubset :
          őī.vertices ‚äÜ ő∑.1.vertices :=
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
          ő∑.1 (q.1.1.isConnectedDivergent_of_mem ő∑.2) Bő∑ hőīBő∑
      have huő∑ : u ‚ąą ő∑.1.vertices := hőīSubset huőī
      by_cases hő∑ő≥ : ő∑.1 = ő≥.1
      ¬∑ have hő∑sub : ő∑ = ő≥ := Subtype.ext hő∑ő≥
        subst ő∑
        have hBő∑Eq : Bő∑ = B := by
          apply forestCoproductChoice_forest_injective
            (ő≥.1.toHopfGen (q.1.1.isConnectedDivergent_of_mem ő≥.2))
          rw [‚Üź hBő∑, ‚Üź hB]
        subst Bő∑
        unfold feynmanSubgraphRepForestPromoteAdmissibleSubgraph at hőīBő∑
        rw [feynmanSubgraphPromoteAdmissibleSubgraph_elements] at hőīBő∑
        rcases Finset.mem_image.mp hőīBő∑ with ‚ü®ő∑Inner, _hő∑Attach, hő∑Prom‚ü©
        have hő∑Mem : ő∑Inner.1 ‚ąą Bc.elements := by
          simpa [Bc] using ő∑Inner.2
        have huő∑Inner : u ‚ąą ő∑Inner.1.vertices := by
          simpa [‚Üź hő∑Prom] using huőī
        exact AdmissibleSubgraph.mem_vertices.mpr
          ‚ü®ő∑Inner.1, hő∑Mem, huő∑Inner‚ü©
      ¬∑ have hDisjA : q.1.1.IsPairwiseDisjoint :=
          (repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
        have hdisj : ő∑.1.Disjoint ő≥.1 := hDisjA ő∑.2 ő≥.2 hő∑ő≥
        exact False.elim ((Finset.disjoint_left.mp hdisj huő∑) huő≥)
  ¬∑ intro huBc
    rcases AdmissibleSubgraph.mem_vertices.mp huBc with
      ‚ü®ő∑, hő∑, huő∑‚ü©
    have hő∑Outer :
        feynmanSubgraphPromote (ő≥_outer := ő≥.1) ő∑ ‚ąą Aout.elements := by
      simpa [Aout, Bc] using
        forestComponentForestChoice_componentRemnantStar_promote_mem_outer
          g q hq ő≥ hB (ő∑ := ő∑) hő∑
    exact AdmissibleSubgraph.mem_vertices.mpr
      ‚ü®feynmanSubgraphPromote (ő≥_outer := ő≥.1) ő∑, hő∑Outer, by simpa using huő∑‚ü©

