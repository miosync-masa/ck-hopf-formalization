/-- Final H5.8F cut with the final actual right-factor class equalities
reduced to explicit graph relabeling witnesses. -/
private theorem coassoc_strict_forest_linear_of_split_phi_actual_right_relabeling
    [IsDivergencePreservedByAdmissibleForestContract]
    (C : ∀ g q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq)
    (I : ∀ g : HopfGen, forestComponentSplitPhiBranchInverseCover g)
    (T : forestComponentActualRightContractionRelabeling) :
    (Algebra.TensorProduct.assoc ℚ ℚ ℚ HopfH HopfH HopfH).toLinearMap ∘ₗ
        coproduct_strict_forest.toLinearMap.rTensor HopfH ∘ₗ
        coproduct_strict_forest.toLinearMap
      =
    coproduct_strict_forest.toLinearMap.lTensor HopfH ∘ₗ
      coproduct_strict_forest.toLinearMap :=
  coassoc_strict_forest_linear_of_split_phi_actual_right_payloads C I
    (fun g q hq => by
      change
        (forestComponentChoiceOriginalRightContractGraph g q).toClass =
          (forestComponentForestChoiceActualRightContractGraph
            g q hq (C g q hq)).toClass
      rcases T.forest_relabel g q hq (C g q hq) with ⟨τ, hτ⟩
      exact (FeynmanGraph.toClass_eq_iff _ _).mpr ⟨τ, hτ⟩)
    (fun g q hq => by
      change
        (forestComponentChoiceOriginalRightContractGraph g q).toClass =
          (forestComponentMixedBoundaryActualRightContractGraph g q hq).toClass
      rcases T.mixed_relabel g q hq with ⟨τ, hτ⟩
      exact (FeynmanGraph.toClass_eq_iff _ _).mpr ⟨τ, hτ⟩)

