  refine ⟨forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_isConnected g r δ hδ, ?_⟩
  intro e he hBridge
  rcases forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdge_exact_or_promoted
    g r δ he with hex | hpr
  · exact hBridge.not_supportConnected_of_erase
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_erase_exact_isSupportConnected
        g r δ hδ hex)
  · exact hBridge.not_supportConnected_of_erase
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_erase_promoted_isSupportConnected
        g r δ hδ hpr)

