private noncomputable def forestComponentForestChoiceRemnantComponentsForChoice
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (γ : {γ : FeynmanSubgraph (repG g).toFeynmanGraph // γ ∈ q.1.1.elements})
