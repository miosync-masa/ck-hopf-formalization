/-- **Track B-forest-final-4b (bare).**  The bare remnant map is injective on
parents (membership-explicit, ready for cross-`q` union arguments).  Sole
consumer of `ForestGraphInsertionUniquenessModel` in the genuine-forest branch. -/
private theorem forestComponentForestChoiceParentRemnantBare_injOn
    [ForestGraphInsertionUniquenessModel]
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentForestChoiceSigmaIndex g)
    {ő≥‚āĀ ő≥‚āā : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hő≥‚āĀ : ő≥‚āĀ ‚ąą q.1.1.elements) (hő≥‚āā : ő≥‚āā ‚ąą q.1.1.elements)
    (hRem : forestComponentForestChoiceParentRemnantBare g q hq ő≥‚āĀ =
            forestComponentForestChoiceParentRemnantBare g q hq ő≥‚āā) :
    ő≥‚āĀ = ő≥‚āā := by
  classical
  have hA : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      q.1.2
  have hAoutPD :
      forestComponentForestChoiceOuterSubgraph q.1.1 q.2 hA ‚ąą
        (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs :=
    forestComponentForestChoiceOuterSubgraph_mem_properDisjoint q.1.2
