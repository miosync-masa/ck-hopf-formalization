/-- Sprint forest_cd-divergent: `SourceSubgraphExactPlus` is superficially
divergent.  The quotient remainder of `Plus őī` along the outer forest is exactly
`őī` (`_remainder_eq`), and `őī` is divergent as a forest cover component (its
ambient actual-quotient admissible subgraph has divergent elements); every outer
forest component is divergent by admissibility.  The reverse power-counting
reflection (`IsDivergenceReflectedByAdmissibleForestContract`) then transports
divergence back from the remainder `őī` to the source `Plus őī` ‚ÄĒ the Weinberg / CK
additivity `ŌČ(Plus) = ŌČ(őī) + ő£_{ő∑} ŌČ(ő∑)`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_divergent
    [IsDivergencePreservedByAdmissibleForestContract]
    [IsDivergenceReflectedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hőī : őī ‚ąą forestQuotientForestSigmaForestCoverForestComponents g r) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī).IsDivergent := by
  have hDisj : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hCompNE : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  have hFresh :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  have hForestDiv : ‚ąÄ ő∑ ‚ąą r.1.1.1.elements, ő∑.IsDivergent :=
    fun ő∑ hő∑ => r.1.1.1.isDivergent_of_mem hő∑
  have hőīmem :
      őī ‚ąą (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hőī).1
  have hőīDiv : őī.IsDivergent :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).isDivergent_of_mem hőīmem
  have hRemDiv :
      (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī)).IsDivergent := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r őī]
    exact hőīDiv
  exact admissibleSubgraphQuotientRemainderSubgraph_isDivergent_reflect
    r.1.1.1 hDisj hCompNE hForestDiv
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
    hFresh
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r őī)
    hRemDiv

