            g r δ).IsConnectedDivergent)
    (hB : forestQuotientForestSigmaForestCoverForestBWitness g r hForestCD)
    (γ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    AdmissibleSubgraph
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
