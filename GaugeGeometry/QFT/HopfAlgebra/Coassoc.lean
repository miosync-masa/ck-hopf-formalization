/-- Promoted component carriers contributed by distinct original components
are disjoint as finite carriers. -/
private theorem forestComponentChoicePromotedForestComponentsForChoice_pairwiseDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    Set.PairwiseDisjoint (‚ÜĎA.elements.attach)
      (fun ő≥ =>
        forestComponentChoicePromotedForestComponentsForChoice A p ő≥
          (Finset.mem_attach A.elements ő≥)) := by
  classical
  intro ő≥ _hő≥ ő∑ _hő∑ hő≥ő∑
  change Disjoint
    (forestComponentChoicePromotedForestComponentsForChoice A p ő≥
      (Finset.mem_attach A.elements ő≥))
    (forestComponentChoicePromotedForestComponentsForChoice A p ő∑
      (Finset.mem_attach A.elements ő∑))
  rw [Finset.disjoint_left]
  intro őī hőīő≥ hőīő∑
  cases hő≥Choice : p ő≥ (Finset.mem_attach A.elements ő≥) with
  | left =>
      simp [forestComponentChoicePromotedForestComponentsForChoice, hő≥Choice] at hőīő≥
  | right =>
      simp [forestComponentChoicePromotedForestComponentsForChoice, hő≥Choice] at hőīő≥
  | forest Bő≥ =>
      cases hő∑Choice : p ő∑ (Finset.mem_attach A.elements ő∑) with
      | left =>
          simp [forestComponentChoicePromotedForestComponentsForChoice, hő∑Choice] at hőīő∑
      | right =>
          simp [forestComponentChoicePromotedForestComponentsForChoice, hő∑Choice] at hőīő∑
      | forest Bő∑ =>
          have hőīő≥' :
              őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
                (A.isConnectedDivergent_of_mem ő≥.2) Bő≥).elements := by
            simpa [forestComponentChoicePromotedForestComponentsForChoice,
              hő≥Choice] using hőīő≥
          have hőīő∑' :
              őī ‚ąą (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő∑.1
                (A.isConnectedDivergent_of_mem ő∑.2) Bő∑).elements := by
            simpa [forestComponentChoicePromotedForestComponentsForChoice,
              hő∑Choice] using hőīő∑
          have hő≥Val : ő≥.1 ‚Č† ő∑.1 := by
            intro h
            exact hő≥ő∑ (Subtype.ext h)
          have hSourceDisj : ő≥.1.Disjoint ő∑.1 := hA ő≥.2 ő∑.2 hő≥Val
          have hőīSubsető≥ :
              őī.vertices ‚äÜ ő≥.1.vertices :=
            feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
              ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) Bő≥ hőīő≥'
          have hőīSubsető∑ :
              őī.vertices ‚äÜ ő∑.1.vertices :=
            feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
              ő∑.1 (A.isConnectedDivergent_of_mem ő∑.2) Bő∑ hőīő∑'
          have hPromotedProper :
              feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
                (A.isConnectedDivergent_of_mem ő≥.2) Bő≥ ‚ąą
                G.properDisjointAdmissibleDivergentSubgraphs :=
            forestComponentChoice_promotedForest_mem_properDisjoint_of_core_mem
              hp ő≥ hő≥Choice
          have hőīNonempty : őī.IsNonempty :=
            G.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
              hPromotedProper őī hőīő≥'
          unfold FeynmanSubgraph.IsNonempty FeynmanSubgraph.vertexCount at hőīNonempty
          rcases Finset.card_pos.mp hőīNonempty with ‚ü®v, hv‚ü©
          exact (Finset.disjoint_left.mp hSourceDisj
            (hőīSubsető≥ hv)) (hőīSubsető∑ hv)

/-- The ő≥-indexed product of promoted representative forests is the product
over the actual promoted component carrier. -/
private theorem
    forestComponentChoicePromotedOuterTensorFactor_product_eq_promotedComponentsHopfProduct_of_core
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A)
    (hp : p ‚ąą forestComponentCoreChoiceIndex A)
    (hA : A.IsPairwiseDisjoint) :
    (‚ąŹ ő≥ ‚ąą A.elements.attach,
        forestComponentChoicePromotedOuterTensorFactor A p ő≥
          (Finset.mem_attach A.elements ő≥)) =
      forestComponentChoicePromotedComponentsHopfProduct A p := by
  classical
  unfold forestComponentChoicePromotedComponentsHopfProduct
  symm
  change
    (‚ąŹ őī ‚ąą A.elements.attach.biUnion (fun ő≥ =>
        forestComponentChoicePromotedForestComponentsForChoice A p ő≥
          (Finset.mem_attach A.elements ő≥)),
      if hőī : őī ‚ąą forestComponentChoicePromotedForestComponents A p then
        (MvPolynomial.X
          (őī.toHopfGen
            (forestComponentChoicePromotedForestComponents_isConnectedDivergent
              A p hőī)) : HopfH)
      else 1) =
      ‚ąŹ ő≥ ‚ąą A.elements.attach,
        forestComponentChoicePromotedOuterTensorFactor A p ő≥
          (Finset.mem_attach A.elements ő≥)
  rw [Finset.prod_biUnion
    (forestComponentChoicePromotedForestComponentsForChoice_pairwiseDisjoint
      hp hA)]
  apply Finset.prod_congr rfl
  intro ő≥ _hő≥
  cases hChoice : p ő≥ (Finset.mem_attach A.elements ő≥) with
  | left =>
      simp [forestComponentChoicePromotedForestComponentsForChoice,
        forestComponentChoicePromotedOuterTensorFactor, hChoice]
  | right =>
      simp [forestComponentChoicePromotedForestComponentsForChoice,
        forestComponentChoicePromotedOuterTensorFactor, hChoice]
  | forest B =>
      let P :=
        feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥.1
          (A.isConnectedDivergent_of_mem ő≥.2) B
      have hToHopf :
          P.toHopfH = B.toHopfH := by
        simpa [P] using
          feynmanSubgraphRepForestPromoteAdmissibleSubgraph_toHopfH
            ő≥.1 (A.isConnectedDivergent_of_mem ő≥.2) B
      have hProd :
          (‚ąŹ őī ‚ąą forestComponentChoicePromotedForestComponentsForChoice A p ő≥
              (Finset.mem_attach A.elements ő≥),
            if hőī : őī ‚ąą forestComponentChoicePromotedForestComponents A p then
              (MvPolynomial.X
                (őī.toHopfGen
                  (forestComponentChoicePromotedForestComponents_isConnectedDivergent
                    A p hőī)) : HopfH)
            else 1) = P.toHopfH := by
        unfold AdmissibleSubgraph.toHopfH
        have hCarrier :
            forestComponentChoicePromotedForestComponentsForChoice A p ő≥
              (Finset.mem_attach A.elements ő≥) = P.elements := by
          simp [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P]
        rw [hCarrier]
        apply Finset.prod_congr rfl
        intro őī hőī
        unfold AdmissibleSubgraph.componentToHopfH gen
        have hőīGlobalBiUnion :
            őī ‚ąą A.elements.attach.biUnion (fun ő≥ =>
              forestComponentChoicePromotedForestComponentsForChoice A p ő≥
                (Finset.mem_attach A.elements ő≥)) := by
          rw [Finset.mem_biUnion]
          refine ‚ü®ő≥, Finset.mem_attach A.elements ő≥, ?_‚ü©
          simpa [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P] using hőī
        have hőīGlobal :
            őī ‚ąą forestComponentChoicePromotedForestComponents A p := by
          rw [forestComponentChoicePromotedForestComponents_eq_biUnion_forChoice]
          exact hőīGlobalBiUnion
        have hőīP : őī ‚ąą P.elements := by
          simpa [forestComponentChoicePromotedForestComponentsForChoice,
            hChoice, P] using hőī
        rw [dif_pos hőīGlobal, dif_pos hőīP]
      calc
        (‚ąŹ őī ‚ąą forestComponentChoicePromotedForestComponentsForChoice A p ő≥
              (Finset.mem_attach A.elements ő≥),
            if hőī : őī ‚ąą forestComponentChoicePromotedForestComponents A p then
              (MvPolynomial.X
                (őī.toHopfGen
                  (forestComponentChoicePromotedForestComponents_isConnectedDivergent
                    A p hőī)) : HopfH)
            else 1)
            = P.toHopfH := hProd
        _ = B.toHopfH := hToHopf
        _ = forestComponentChoicePromotedOuterTensorFactor A p ő≥
              (Finset.mem_attach A.elements ő≥) := by
              simp [forestComponentChoicePromotedOuterTensorFactor, hChoice]

/-- A left-selected original component is vertex-disjoint from every promoted
forest component coming from a genuine forest choice. -/
private theorem forestComponentChoiceLeft_promotedForestComponent_disjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {ő≥ őī : FeynmanSubgraph G}
    (hő≥L : ő≥ ‚ąą (forestComponentChoiceLeftSubgraph A p).elements)
    (hőīF : őī ‚ąą forestComponentChoicePromotedForestComponents A p) :
    ő≥.Disjoint őī := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hőīF with
    ‚ü®ő∑, B, hB, hőīB‚ü©
  have hő≥A : ő≥ ‚ąą A.elements :=
    forestComponentChoiceLeftSubgraph_elements_subset A p hő≥L
  have hőīSubset :
      őī.vertices ‚äÜ ő∑.1.vertices :=
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
      ő∑.1 (A.isConnectedDivergent_of_mem ő∑.2) B hőīB
  by_cases hő≥ő∑ : ő≥ = ő∑.1
  ¬∑ subst ő≥
    rw [forestComponentChoiceLeftSubgraph_elements] at hő≥L
    rcases Finset.mem_filter.mp hő≥L with ‚ü®_hő∑A, hLeft‚ü©
    unfold forestComponentChoiceIsLeft at hLeft
    rw [dif_pos ő∑.2] at hLeft
    rw [hB] at hLeft
    cases hLeft
  ¬∑ have hdisj : ő≥.Disjoint ő∑.1 := hA hő≥A ő∑.2 hő≥ő∑
    unfold FeynmanSubgraph.Disjoint at hdisj ‚äĘ
    exact Finset.disjoint_left.mpr fun v hvő≥ hvőī =>
      (Finset.disjoint_left.mp hdisj hvő≥) (hőīSubset hvőī)

/-- Promoted forest components are pairwise Zimmermann-compatible; components
from the same original component use the selected forest, while components
from different original components use the disjointness of the outer carrier. -/
private theorem forestComponentChoicePromotedForestComponents_nestedOrDisjoint
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {őī‚āĀ őī‚āā : FeynmanSubgraph G}
    (hőī‚āĀ : őī‚āĀ ‚ąą forestComponentChoicePromotedForestComponents A p)
    (hőī‚āā : őī‚āā ‚ąą forestComponentChoicePromotedForestComponents A p)
    (hne : őī‚āĀ ‚Č† őī‚āā) :
    őī‚āĀ.NestedOrDisjoint őī‚āā := by
  classical
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hőī‚āĀ with
    ‚ü®ő≥‚āĀ, B‚āĀ, hB‚āĀ, hőīB‚āĀ‚ü©
  rcases forestComponentChoicePromotedForestComponents_mem_exists A p hőī‚āā with
    ‚ü®ő≥‚āā, B‚āā, hB‚āā, hőīB‚āā‚ü©
  by_cases hő≥ : ő≥‚āĀ.1 = ő≥‚āā.1
  ¬∑ have hő≥Subtype : ő≥‚āĀ = ő≥‚āā := Subtype.ext hő≥
    subst ő≥‚āā
    have hB : B‚āĀ = B‚āā := by
      apply forestCoproductChoice_forest_injective
        (ő≥‚āĀ.1.toHopfGen (A.isConnectedDivergent_of_mem ő≥‚āĀ.2))
      rw [‚Üź hB‚āĀ, ‚Üź hB‚āā]
    subst B‚āā
    exact (feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥‚āĀ.1
      (A.isConnectedDivergent_of_mem ő≥‚āĀ.2) B‚āĀ).forest.nestedOrDisjoint
        hőīB‚āĀ hőīB‚āā hne
  ¬∑ have hdisjOuter : ő≥‚āĀ.1.Disjoint ő≥‚āā.1 := hA ő≥‚āĀ.2 ő≥‚āā.2 hő≥
    have hőī‚āĀSubset :
        őī‚āĀ.vertices ‚äÜ ő≥‚āĀ.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        ő≥‚āĀ.1 (A.isConnectedDivergent_of_mem ő≥‚āĀ.2) B‚āĀ hőīB‚āĀ
    have hőī‚āāSubset :
        őī‚āā.vertices ‚äÜ ő≥‚āā.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        ő≥‚āā.1 (A.isConnectedDivergent_of_mem ő≥‚āā.2) B‚āā hőīB‚āā
    refine Or.inr ?_
    unfold FeynmanSubgraph.Disjoint at hdisjOuter ‚äĘ
    exact Finset.disjoint_left.mpr fun v hv‚āĀ hv‚āā =>
      (Finset.disjoint_left.mp hdisjOuter (hőī‚āĀSubset hv‚āĀ)) (hőī‚āāSubset hv‚āā)

/-- The graph-level outer forest for the genuine-forest component-choice
regime: keep every left-selected original component and splice in all
promoted components of every selected genuine component forest. -/
private noncomputable def forestComponentForestChoiceOuterSubgraph
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    AdmissibleSubgraph G :=
  AdmissibleSubgraph.ofElements
    ((forestComponentChoiceLeftSubgraph A p).elements ‚ą™
      forestComponentChoicePromotedForestComponents A p)
    (by
      constructor
      ¬∑ intro őī hőī
        rcases Finset.mem_union.mp hőī with hőīL | hőīF
        ¬∑ exact (forestComponentChoiceLeftSubgraph A p).isConnectedDivergent_of_mem hőīL
        ¬∑ exact forestComponentChoicePromotedForestComponents_isConnectedDivergent
            A p hőīF
      ¬∑ intro őī‚āĀ hőī‚āĀ őī‚āā hőī‚āā hne
        rcases Finset.mem_union.mp hőī‚āĀ with hőī‚āĀL | hőī‚āĀF
        ¬∑ rcases Finset.mem_union.mp hőī‚āā with hőī‚āāL | hőī‚āāF
          ¬∑ exact (forestComponentChoiceLeftSubgraph A p).forest.nestedOrDisjoint
              hőī‚āĀL hőī‚āāL hne
          ¬∑ exact Or.inr
              (forestComponentChoiceLeft_promotedForestComponent_disjoint
                A p hA hőī‚āĀL hőī‚āāF)
        ¬∑ rcases Finset.mem_union.mp hőī‚āā with hőī‚āāL | hőī‚āāF
          ¬∑ exact Or.inr
              (forestComponentChoiceLeft_promotedForestComponent_disjoint
                A p hA hőī‚āāL hőī‚āĀF).symm
          ¬∑ exact forestComponentChoicePromotedForestComponents_nestedOrDisjoint
              A p hA hőī‚āĀF hőī‚āāF hne)

@[simp] private theorem forestComponentForestChoiceOuterSubgraph_elements
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint) :
    (forestComponentForestChoiceOuterSubgraph A p hA).elements =
      (forestComponentChoiceLeftSubgraph A p).elements ‚ą™
        forestComponentChoicePromotedForestComponents A p := rfl

/-- Sprint F2-Track-B-forest-2a-pre3: a genuine-forest `OuterSubgraph` element
that meets a forest-choice parent `ő≥` is contained in `ő≥`.  Left elements are
distinct A-components (disjoint from ő≥); promoted elements lie in their parent
component, which must be `ő≥` when it meets `ő≥` (pairwise disjointness). -/
private theorem forestComponentForestChoiceOuterSubgraph_elt_subset_parent_of_meets
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} (A : AdmissibleSubgraph G)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    {ő≥ : FeynmanSubgraph G} (hő≥ : ő≥ ‚ąą A.elements)
    {ő∑ : FeynmanSubgraph G}
    (hő∑ : ő∑ ‚ąą (forestComponentForestChoiceOuterSubgraph A p hA).elements)
    (hmeet : ‚ąÉ v, v ‚ąą ő∑.vertices ‚ąß v ‚ąą ő≥.vertices) :
    ő∑.vertices ‚äÜ ő≥.vertices := by
  classical
  rw [forestComponentForestChoiceOuterSubgraph_elements] at hő∑
  rcases Finset.mem_union.mp hő∑ with hő∑L | hő∑P
  ¬∑ -- Left component: ő∑ ‚ąą A.elements; either ő∑ = ő≥ (refl) or disjoint (contradiction).
    have hő∑A : ő∑ ‚ąą A.elements :=
      forestComponentChoiceLeftSubgraph_elements_subset A p hő∑L
    by_cases hő∑ő≥ : ő∑ = ő≥
    ¬∑ subst hő∑ő≥; exact Finset.Subset.refl _
    ¬∑ obtain ‚ü®v, hvő∑, hvő≥‚ü© := hmeet
      exact absurd ((hA hő∑A hő≥ hő∑ő≥ : ő∑.Disjoint ő≥)) (by
        rw [FeynmanSubgraph.Disjoint, Finset.disjoint_left]
        exact fun hd => hd hvő∑ hvő≥)
  ¬∑ -- Promoted component: lies in its parent ő≥', which meets ő≥ ‚áí ő≥' = ő≥.
    rcases forestComponentChoicePromotedForestComponents_mem_exists A p hő∑P with
      ‚ü®ő≥', B', _hpő≥', hő∑ő≥'‚ü©
    have hő∑Sub : ő∑.vertices ‚äÜ ő≥'.1.vertices :=
      feynmanSubgraphRepForestPromoteAdmissibleSubgraph_vertices_subset_outer
        ő≥'.1 (A.isConnectedDivergent_of_mem ő≥'.2) B' hő∑ő≥'
    obtain ‚ü®v, hvő∑, hvő≥‚ü© := hmeet
    have hő≥'ő≥ : ő≥'.1 = ő≥ :=
      hA.eq_of_mem_vertices ő≥'.2 hő≥ (hő∑Sub hvő∑) hvő≥
    rw [‚Üź hő≥'ő≥]; exact hő∑Sub

/-- Sprint F2-Track-B-forest-2a: **parent vertex recovery**.  The generic source
vertices of the remnant of a forest-choice parent `ő≥` (in the contracted graph
`OuterSubgraph A p hA`) recover exactly `ő≥.vertices`.  Forward: a non-star
source vertex un-retargets to itself in ő≥; a promoted source vertex lies in an
`OuterSubgraph` component meeting ő≥, hence ‚äÜ ő≥ (pre3).  Backward: an Aout-vertex
of ő≥ contributes through its component's star (pre2); a non-Aout vertex stays
identity in the remnant and is not a (fresh) star. -/
private theorem forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen) (A : AdmissibleSubgraph (repG g).toFeynmanGraph)
    (p : forestComponentChoiceFn A) (hA : A.IsPairwiseDisjoint)
    (hAoutPD : forestComponentForestChoiceOuterSubgraph A p hA ‚ąą
      (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs)
    {ő≥ : FeynmanSubgraph (repG g).toFeynmanGraph} (hő≥ : ő≥ ‚ąą A.elements) :
    admissibleSubgraphRemainderSourceVertices
        (forestComponentForestChoiceOuterSubgraph A p hA)
        (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
          (forestComponentForestChoiceOuterSubgraph A p hA) hAoutPD)
        (admissibleSubgraphQuotientRemainderSubgraph
          (forestComponentForestChoiceOuterSubgraph A p hA)
          (FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterSubgraph A p hA) hAoutPD)
          ő≥) = ő≥.vertices := by
  classical
  set Aout := forestComponentForestChoiceOuterSubgraph A p hA with hAoutDef
  set starOf := FeynmanGraph.admissibleForestCanonicalStarOf (repG g).toFeynmanGraph
    Aout hAoutPD with hstarOf
  have hFresh := FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
    (repG g).toFeynmanGraph Aout hAoutPD
  ext v
  rw [mem_admissibleSubgraphRemainderSourceVertices]
  constructor
  ¬∑ rintro (‚ü®hvőī, hvNotStar‚ü© | ‚ü®ő∑, hő∑Aout, hStar, hvő∑‚ü©)
    ¬∑ rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hvőī
      obtain ‚ü®u, huő≥, hret‚ü© := Finset.mem_image.mp hvőī
      by_cases huAout : u ‚ąą Aout.vertices
      ¬∑ exfalso
        apply hvNotStar
        rw [‚Üź hret, AdmissibleSubgraph.retargetVertex, Aout.componentAt?_of_mem huAout,
          AdmissibleSubgraph.mem_starVertices]
        exact ‚ü®Aout.componentAt huAout, Aout.componentAt_mem huAout, rfl‚ü©
      ¬∑ rw [AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf huAout] at hret
        rw [‚Üź hret]; exact huő≥
    ¬∑ have hMeet :=
        (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
          Aout hAoutPD ő≥ hő∑Aout).mp hStar
      exact forestComponentForestChoiceOuterSubgraph_elt_subset_parent_of_meets
        A p hA hő≥ hő∑Aout hMeet hvő∑
  ¬∑ intro hvő≥
    by_cases hvAout : v ‚ąą Aout.vertices
    ¬∑ refine Or.inr ‚ü®Aout.componentAt hvAout, Aout.componentAt_mem hvAout, ?_,
        Aout.componentAt_vertex_mem hvAout‚ü©
      exact (admissibleSubgraph_star_mem_remainder_vertices_iff_intersects
        Aout hAoutPD ő≥ (Aout.componentAt_mem hvAout)).mpr
        ‚ü®v, Aout.componentAt_vertex_mem hvAout, hvő≥‚ü©
    ¬∑ refine Or.inl ‚ü®?_, ?_‚ü©
      ¬∑ rw [admissibleSubgraphQuotientRemainderSubgraph_vertices]
        exact Finset.mem_image.mpr
          ‚ü®v, hvő≥, AdmissibleSubgraph.retargetVertex_of_not_mem Aout starOf hvAout‚ü©
      ¬∑ intro hvStar
        exact (hFresh.star_not_mem_vertices hvStar) (ő≥.vertices_subset hvő≥)

/-- **Track B-forest-inj-finalize ‚ÄĒ CK graph-insertion uniqueness facade.**

`forest_inj` (genuine-forest same-branch injectivity for the H5.8 split-ŌÜ
indexed classifier) reduces, after the constructive vertex recovery
(`forestComponentForestChoice_remnant_sourceVertices_eq_parent_vertices`),
to recovering a forest-choice **parent** `ő≥` from its quotient image.  The
remnant `ő≥/B` contracts the promoted children to their stars; boundary-crossing
internal edges of `ő≥` collapse onto those stars, so `remnant(ő≥).internalEdges`
is **not** injective in `ő≥` on its own.  Morally the lost boundary data lives in
the promoted children's `externalLegs`, but `FeynmanSubgraph` keeps
`externalLegs` as an independent multiset (only `attachedTo + sector`, not the
collapsed interior endpoint), so uniqueness of re-insertion is a genuine
*semantic* kernel ‚ÄĒ the formalization has exposed CK 1998's implicit
graph-insertion uniqueness.

This facade isolates exactly that: two forest-choice parents with the same
promoted contribution (in `OuterSubgraph`) and the same remnant (in
`RepQuotient`) are equal.  It is the genuine-forest analogue of the
`mixed_q1_recovery` step, where the off-carrier (data-preserving) case made the
recovery constructive without a uniqueness assumption. -/
class ForestGraphInsertionUniquenessModel : Prop where
  parent_eq_of_remnant_eq :
    ‚ąÄ {G : FeynmanGraph} [DivergenceMeasure G]
      (A : AdmissibleSubgraph G) (starOf : FeynmanSubgraph G ‚Üí VertexId)
      {ő≥‚āĀ ő≥‚āā : FeynmanSubgraph G},
        -- vertices already recovered (B-forest-2a); the remnant (contraction
        -- `ő≥/A`) records edges-up-to-star-collapse and the full external legs.
        -- The semantic kernel: this data determines the parent uniquely
        -- (CK graph-insertion uniqueness, exposed by the flexible carrier).
        ő≥‚āĀ.vertices = ő≥‚āā.vertices ‚Üí
        admissibleSubgraphQuotientRemainderSubgraph A starOf ő≥‚āĀ =
          admissibleSubgraphQuotientRemainderSubgraph A starOf ő≥‚āā ‚Üí
        ő≥‚āĀ = ő≥‚āā

/-- Membership in the genuine-forest component-choice regime gives both the
core component-choice membership and an actual forest summand. -/
private theorem mem_forestComponentForestChoiceCoreIndex_core_hasForest
    [IsDivergencePreservedByAdmissibleForestContract]
    {G : FeynmanGraph} {A : AdmissibleSubgraph G}
    {p : forestComponentChoiceFn A}
    (hp : p ‚ąą forestComponentForestChoiceCoreIndex A) :
