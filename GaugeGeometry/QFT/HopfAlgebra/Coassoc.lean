      (forestComponentForestChoiceOuterIndex g q hq).2
  intro hv
  have hFreshOuter : Aout.IsFreshStarAssignment outerStar := by
    dsimp [Aout, outerStar]
    exact FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph
      (forestComponentForestChoiceOuterIndex g q hq).1
      (forestComponentForestChoiceOuterIndex g q hq).2
  have hγLout : γL ∈ Aout.elements := by
    simpa [Aout] using
      forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγL
  have hStarNotG : outerStar γL ∉ G₀.vertices := by
    simpa [G₀, Aout, outerStar] using hFreshOuter.fresh hγLout
  have hActSplit :=
    forestComponentForestChoiceActualQuotientSubgraphCanonical_vertices_eq_right_union_remnant
      g q hq
  rw [hActSplit] at hv
  rcases Finset.mem_union.mp hv with hvR | hvM
  · have hvR' :
        outerStar γL ∈
          (forestComponentChoiceRightSubgraph q.1.1 q.2).vertices := by
      exact forestComponentForestChoiceActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq ▸ hvR
    exact hStarNotG ((forestComponentChoiceRightSubgraph q.1.1 q.2).vertices_subset hvR')
  · rcases AdmissibleSubgraph.mem_vertices.mp hvM with ⟨δ, hδ, hvδ⟩
    have hδ' : δ ∈ forestComponentForestChoiceRemnantComponents g q hq := by
      simpa [forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical]
        using hδ
    rcases forestComponentForestChoiceRemnantComponents_mem_exists
        g q hq hδ' with
      ⟨γF, B, hB, rfl⟩
    rw [admissibleSubgraphQuotientRemainderSubgraph_vertices] at hvδ
    rcases Finset.mem_image.mp hvδ with ⟨u, huγF, huv⟩
    by_cases huOut : u ∈ Aout.vertices
    · have hAoutDisj : Aout.IsPairwiseDisjoint := by
        dsimp [Aout]
        exact (repG g).toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
            (forestComponentForestChoiceOuterIndex g q hq).2
      have hRet :
          Aout.retargetVertex outerStar u =
            outerStar (Aout.componentAt huOut) :=
        AdmissibleSubgraph.retargetVertex_of_mem_component
          hAoutDisj outerStar (Aout.componentAt_mem huOut)
          (Aout.componentAt_vertex_mem huOut)
      have hStarEq :
          outerStar (Aout.componentAt huOut) = outerStar γL :=
        hRet.symm.trans huv
      have hCompEq : Aout.componentAt huOut = γL :=
        hFreshOuter.eq_of_star_eq (Aout.componentAt_mem huOut) hγLout hStarEq
      have hDisjA : q.1.1.IsPairwiseDisjoint :=
        (repG g).toFeynmanGraph
          |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint q.1.2
      have hSubset :
          (Aout.componentAt huOut).vertices ⊆ γF.1.vertices := by
        simpa [Aout] using
          forestComponentForestChoiceOuterSubgraph_componentAt_vertices_subset_source
            q.1.1 q.2 hDisjA γF hB huγF (by
              simpa [Aout] using huOut)
      have huL : u ∈ γL.vertices := by
        simpa [hCompEq] using Aout.componentAt_vertex_mem huOut
      have hγLA : γL ∈ q.1.1.elements :=
        forestComponentChoiceLeftSubgraph_elements_subset q.1.1 q.2 hγL
      have hne : γL ≠ γF.1 := by
        intro hEq
        have hγFLeft :
            γF.1 ∈ (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements := by
          simpa [hEq] using hγL
        rw [forestComponentChoiceLeftSubgraph_elements] at hγFLeft
        rcases Finset.mem_filter.mp hγFLeft with ⟨_hγA, hLeft⟩
        unfold forestComponentChoiceIsLeft at hLeft
        have hLeftChoice :
            q.2 γF (Finset.mem_attach q.1.1.elements γF) =
              forestCoproductChoice.left := by
          simpa [dif_pos γF.2] using hLeft
        rw [hB] at hLeftChoice
        cases hLeftChoice
      have hDisj : γL.Disjoint γF.1 := hDisjA hγLA γF.2 hne
      exact (Finset.disjoint_left.mp hDisj huL) huγF
    · have hRet : Aout.retargetVertex outerStar u = u :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar huOut
      have huEq : u = outerStar γL := hRet.symm.trans huv
      exact hStarNotG (by simpa [huEq] using γF.1.vertices_subset huγF)

private theorem forestComponentForestChoice_splitStar_vertices_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq) :
    (forestComponentForestChoiceActualRightContractGraph g q hq C).vertices =
      (FeynmanGraph.admissibleForestContractGraphWithStars
        (repG g).toFeynmanGraph q.1.1
        (forestComponentForestChoiceSplitStarOf g q hq C)).vertices := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let A := q.1.1
  let L := forestComponentChoiceLeftSubgraph q.1.1 q.2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical
    g q hq
  let Ract := forestComponentForestChoiceActualRightQuotientSubgraphCanonical
    g q hq
  let Mact := forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentForestChoiceOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let splitStar := forestComponentForestChoiceSplitStarOf g q hq C
  have hQvertices :
      Q.vertices = (G₀.vertices \ Aout.vertices) ∪
        Aout.starVertices outerStar := by
    simp [Q, G₀, Aout, outerStar, forestOuterActualQuotientGraph,
      FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_vertices]
  have hAactVertices :
      Aact.vertices = Ract.vertices ∪ Mact.vertices := by
    simpa [Aact, Ract, Mact] using
      forestComponentForestChoiceActualQuotientSubgraphCanonical_vertices_eq_right_union_remnant
        g q hq
  have hRactVertices : Ract.vertices = R.vertices := by
    simpa [Ract, R] using
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hSplitStars :
      A.starVertices splitStar =
        L.starVertices splitStar ∪
          (R.starVertices splitStar ∪
            forestComponentForestChoiceForestSplitStarVertices g q hq C) := by
    simpa [A, L, R, splitStar] using
      forestComponentForestChoice_splitStar_starVertices_eq_union g q hq C
  have hLeftStars :
      L.starVertices splitStar = L.starVertices outerStar := by
    simpa [L, Aout, outerStar, splitStar] using
      forestComponentForestChoice_left_splitStar_starVertices_eq_outer
        g q hq C
  have hRightStars :
      R.starVertices splitStar = Ract.starVertices rightStar := by
    simpa [R, Ract, Q, Aact, rightStar, splitStar] using
      forestComponentForestChoice_right_splitStar_starVertices_eq_actual
        g q hq C
  have hForestStars :
      forestComponentForestChoiceForestSplitStarVertices g q hq C =
        Mact.starVertices rightStar := by
    simpa [Mact, Q, Aact, rightStar] using
      forestComponentForestChoice_forest_splitStar_starVertices_eq_remnant
        g q hq C
  have hAoutSubsetA : Aout.vertices ⊆ A.vertices := by
    intro v hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ⟨δ, hδ, hvδ⟩
    rcases
        forestComponentForestChoiceOuterSubgraph_mem_source
          q.1.1 q.2
          ((repG g).toFeynmanGraph
            |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
              q.1.2)
          (by simpa [Aout, forestComponentForestChoiceOuterIndex_val] using hδ) with
      ⟨γ, hγA, hδγ⟩
    exact AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hγA, hδγ hvδ⟩
  have hRsubsetG : R.vertices ⊆ G₀.vertices := by
    intro v hv
    simpa [G₀, R] using R.vertices_subset hv
  have hLeftStarNotAct :
      ∀ {v}, v ∈ L.starVertices outerStar → v ∉ Aact.vertices := by
    intro v hv
    rw [AdmissibleSubgraph.mem_starVertices] at hv
    rcases hv with ⟨γ, hγL, rfl⟩
    simpa [Aact, outerStar] using
      forestComponentForestChoice_left_outer_star_not_actual_quotient_vertices
        g q hq C hγL
  simp only [forestComponentForestChoiceActualRightContractGraph,
    FeynmanGraph.admissibleForestContractGraphWithStars_eq,
    AdmissibleSubgraph.contractWithStars_vertices]
  ext v
  constructor
  · intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStarAct
    · rcases Finset.mem_sdiff.mp hvDiff with ⟨hvQ, hvNotAct⟩
      rw [hQvertices] at hvQ
      rcases Finset.mem_union.mp hvQ with hvGnotOut | hvOuterStar
      · rcases Finset.mem_sdiff.mp hvGnotOut with ⟨hvG, hvNotOut⟩
        by_cases hvA : v ∈ A.vertices
        · rcases AdmissibleSubgraph.mem_vertices.mp hvA with ⟨γ, hγA, hvγ⟩
          rcases forestComponentForestChoice_choice_left_or_right_or_forest
              g q hq hγA with hγL | hγR | hγF
          · have hvOut : v ∈ Aout.vertices := by
              exact AdmissibleSubgraph.mem_vertices.mpr
                ⟨γ, by
                  simpa [Aout] using
                    forestComponentForestChoiceOuterIndex_mem_of_left
                      g q hq hγL, hvγ⟩
            exact False.elim (hvNotOut hvOut)
          · have hvAct : v ∈ Aact.vertices := by
              rw [hAactVertices]
              exact Finset.mem_union_left _
                (by
                  rw [hRactVertices]
                  exact AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hγR, hvγ⟩)
            exact False.elim (hvNotAct hvAct)
          · rcases hγF with ⟨B, hB⟩
            have hRet :
                Aout.retargetVertex outerStar v = v :=
              AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hvNotOut
            have hvM : v ∈ Mact.vertices := by
              have hvMret :
                  Aout.retargetVertex outerStar v ∈ Mact.vertices := by
                simpa [Mact, Aout, outerStar] using
                  forestComponentForestChoice_actualRemnant_vertices_mem_of_forest_vertex
                    g q hq ⟨γ, hγA⟩ hB hvγ
              exact hRet ▸ hvMret
            have hvAct : v ∈ Aact.vertices := by
              rw [hAactVertices]
              exact Finset.mem_union_right _ hvM
            exact False.elim (hvNotAct hvAct)
        · refine Finset.mem_union_left _ ?_
          exact Finset.mem_sdiff.mpr ⟨hvG, hvA⟩
      · rw [AdmissibleSubgraph.mem_starVertices] at hvOuterStar
        rcases hvOuterStar with ⟨δ, hδOut, rfl⟩
        dsimp [Aout] at hδOut
        change δ ∈
          (forestComponentChoiceLeftSubgraph q.1.1 q.2).elements ∪
            forestComponentChoicePromotedForestComponents q.1.1 q.2 at hδOut
        rcases Finset.mem_union.mp hδOut with hδL | hδP
        · refine Finset.mem_union_right _ ?_
          rw [hSplitStars, hLeftStars]
          exact Finset.mem_union_left _
            (AdmissibleSubgraph.mem_starVertices.mpr ⟨δ, hδL, rfl⟩)
        · have hvM : outerStar δ ∈ Mact.vertices := by
            simpa [Mact, outerStar] using
              forestComponentForestChoice_promoted_outer_star_mem_actual_remnant_vertices
                g q hq hδP
          have hvAct : outerStar δ ∈ Aact.vertices := by
            rw [hAactVertices]
            exact Finset.mem_union_right _ hvM
          exact False.elim (hvNotAct hvAct)
    · rw [AdmissibleSubgraph.mem_starVertices] at hvStarAct
      rcases hvStarAct with ⟨δ, hδAct, rfl⟩
      rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements] at hδAct
      unfold forestComponentForestChoiceActualQuotientComponents at hδAct
      rcases Finset.mem_union.mp hδAct with hδR | hδM
      · refine Finset.mem_union_right _ ?_
        rw [hSplitStars, hRightStars]
        exact Finset.mem_union_right _
          (Finset.mem_union_left _
            (AdmissibleSubgraph.mem_starVertices.mpr ⟨δ, hδR, rfl⟩))
      · refine Finset.mem_union_right _ ?_
        rw [hSplitStars, hForestStars]
        exact Finset.mem_union_right _
          (Finset.mem_union_right _
            (AdmissibleSubgraph.mem_starVertices.mpr ⟨δ, by
              simpa [Mact] using hδM, rfl⟩))
  · intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStar
    · rcases Finset.mem_sdiff.mp hvDiff with ⟨hvG, hvNotA⟩
      refine Finset.mem_union_left _ ?_
      refine Finset.mem_sdiff.mpr ⟨?_, ?_⟩
      · rw [hQvertices]
        refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ⟨hvG, ?_⟩
        intro hvOut
        exact hvNotA (hAoutSubsetA hvOut)
      · intro hvAct
        rw [hAactVertices] at hvAct
        rcases Finset.mem_union.mp hvAct with hvR | hvM
        · exact hvNotA (by
            have hvRorig : v ∈ R.vertices := hRactVertices ▸ hvR
            rcases AdmissibleSubgraph.mem_vertices.mp hvRorig with
              ⟨δ, hδ, hvδ⟩
            exact AdmissibleSubgraph.mem_vertices.mpr
              ⟨δ,
                forestComponentChoiceRightSubgraph_elements_subset
                  q.1.1 q.2 hδ, hvδ⟩)
        · exact hvNotA
            (forestComponentForestChoice_actualRemnant_vertex_mem_original_of_mem_graph
              g q hq (by simpa [Mact] using hvM) hvG)
    · rw [hSplitStars, hLeftStars, hRightStars, hForestStars] at hvStar
      rcases Finset.mem_union.mp hvStar with hvLStar | hvRest
      · refine Finset.mem_union_left _ ?_
        refine Finset.mem_sdiff.mpr ⟨?_, ?_⟩
        · rw [hQvertices]
          have hvAoutStar : v ∈ Aout.starVertices outerStar := by
            rw [AdmissibleSubgraph.mem_starVertices] at hvLStar ⊢
            rcases hvLStar with ⟨γ, hγL, rfl⟩
            exact ⟨γ, by
              simpa [Aout] using
                forestComponentForestChoiceOuterIndex_mem_of_left
                  g q hq hγL, rfl⟩
          exact Finset.mem_union_right _ hvAoutStar
        · exact hLeftStarNotAct hvLStar
      · rcases Finset.mem_union.mp hvRest with hvRStar | hvMStar
        · refine Finset.mem_union_right _ ?_
          rw [AdmissibleSubgraph.mem_starVertices] at hvRStar
          rcases hvRStar with ⟨δ, hδR, rfl⟩
          exact AdmissibleSubgraph.mem_starVertices.mpr ⟨δ, by
            rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
            unfold forestComponentForestChoiceActualQuotientComponents
            exact Finset.mem_union_left _ hδR, rfl⟩
        · refine Finset.mem_union_right _ ?_
          rw [AdmissibleSubgraph.mem_starVertices] at hvMStar
          rcases hvMStar with ⟨δ, hδM, rfl⟩
          exact AdmissibleSubgraph.mem_starVertices.mpr ⟨δ, by
            rw [forestComponentForestChoiceActualQuotientSubgraphCanonical_elements]
            unfold forestComponentForestChoiceActualQuotientComponents
            exact Finset.mem_union_right _ (by
              simpa [Mact] using hδM), rfl⟩

private theorem
    forestComponentForestChoice_twoStep_retargetVertex_eq_splitStar_of_mem
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ∈ forestComponentForestChoiceSigmaIndex g)
    (C : forestComponentForestChoiceRemnantPositiveComponentsCertificate
      g q hq)
    {v : VertexId} (hvG : v ∈ (repG g).toFeynmanGraph.vertices) :
    (forestComponentForestChoiceActualQuotientSubgraphCanonical
      g q hq).retargetVertex
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (forestOuterActualQuotientGraph g
            (forestComponentForestChoiceOuterIndex g q hq))
          (forestComponentForestChoiceActualQuotientSubgraphCanonical
            g q hq)
          (forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C)))
        ((forestComponentForestChoiceOuterIndex g q hq).1.retargetVertex
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph
            (forestComponentForestChoiceOuterIndex g q hq).1
            (forestComponentForestChoiceOuterIndex g q hq).2)
          v) =
      q.1.1.retargetVertex
        (forestComponentForestChoiceSplitStarOf g q hq C) v := by
  classical
  let G₀ := (repG g).toFeynmanGraph
  let A := q.1.1
  let Aout := (forestComponentForestChoiceOuterIndex g q hq).1
  let Q := forestOuterActualQuotientGraph g
    (forestComponentForestChoiceOuterIndex g q hq)
  let Aact := forestComponentForestChoiceActualQuotientSubgraphCanonical
    g q hq
  let Ract := forestComponentForestChoiceActualRightQuotientSubgraphCanonical
    g q hq
  let Mact := forestComponentForestChoiceActualRemnantQuotientSubgraphCanonical
    g q hq
  let outerStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      G₀ Aout (forestComponentForestChoiceOuterIndex g q hq).2
  let rightStar :=
    FeynmanGraph.admissibleForestCanonicalStarOf Q Aact
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  let splitStar := forestComponentForestChoiceSplitStarOf g q hq C
  have hADisj : A.IsPairwiseDisjoint :=
    G₀.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by simpa [G₀, A] using q.1.2)
  have hAoutDisj : Aout.IsPairwiseDisjoint := by
    simpa [Aout] using
      G₀.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        (forestComponentForestChoiceOuterIndex g q hq).2
  have hAactDisj : Aact.IsPairwiseDisjoint :=
    Q.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (by
        simpa [Q, Aact] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_properDisjoint
            g q hq
            (forestComponentForestChoiceActualQuotientProperCertificateOfRemnantPositive
              g q hq C))
  have hAactVertices :
      Aact.vertices = Ract.vertices ∪ Mact.vertices := by
    simpa [Aact, Ract, Mact] using
      forestComponentForestChoiceActualQuotientSubgraphCanonical_vertices_eq_right_union_remnant
        g q hq
  have hRactVertices :
      Ract.vertices =
        (forestComponentChoiceRightSubgraph q.1.1 q.2).vertices := by
    simpa [Ract] using
      forestComponentForestChoiceActualRightQuotientSubgraphCanonical_vertices_eq_right
        g q hq
  have hAoutSubsetA : Aout.vertices ⊆ A.vertices := by
    intro u hu
    rcases AdmissibleSubgraph.mem_vertices.mp hu with ⟨δ, hδ, huδ⟩
    rcases
        forestComponentForestChoiceOuterSubgraph_mem_source
          q.1.1 q.2 hADisj
          (by simpa [Aout, forestComponentForestChoiceOuterIndex_val] using hδ) with
      ⟨γ, hγA, hδγ⟩
    exact AdmissibleSubgraph.mem_vertices.mpr ⟨γ, hγA, hδγ huδ⟩
  by_cases hvA : v ∈ A.vertices
  · let γ := A.componentAt hvA
    have hγA : γ ∈ A.elements := A.componentAt_mem hvA
    have hvγ : v ∈ γ.vertices := A.componentAt_vertex_mem hvA
    rcases forestComponentForestChoice_choice_left_or_right_or_forest
        g q hq hγA with hγL | hγR | hγF
    · have hγAout : γ ∈ Aout.elements := by
        simpa [Aout] using
          forestComponentForestChoiceOuterIndex_mem_of_left g q hq hγL
      have hOuter :
          Aout.retargetVertex outerStar v = outerStar γ := by
        exact AdmissibleSubgraph.retargetVertex_of_mem_component
          hAoutDisj outerStar hγAout hvγ
      have hOuterNotAct : outerStar γ ∉ Aact.vertices := by
        simpa [Aact, outerStar] using
          forestComponentForestChoice_left_outer_star_not_actual_quotient_vertices
            g q hq C hγL
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar (outerStar γ) := by rw [hOuter]
        _ = outerStar γ := by
          exact AdmissibleSubgraph.retargetVertex_of_not_mem
            Aact rightStar hOuterNotAct
        _ = splitStar γ := by
          simpa [outerStar, splitStar] using
            (forestComponentForestChoiceSplitStarOf_left
              g q hq C hγL).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hγA hvγ]
    · have hNotAout : v ∉ Aout.vertices := by
        simpa [Aout, forestComponentForestChoiceOuterIndex_val] using
          forestComponentChoiceRight_vertices_not_mem_forestOuterSubgraph
            q.1.1 q.2 hADisj hγR hvγ
      have hOuter : Aout.retargetVertex outerStar v = v :=
        AdmissibleSubgraph.retargetVertex_of_not_mem Aout outerStar hNotAout
      let δ :=
        admissibleSubgraphRetargetSubgraph Aout outerStar γ
          (forestComponentForestChoiceRightRetarget_edge_le g q hq γ hγR)
      have hδ : δ ∈ Aact.elements := by
        simpa [Aact, δ, Aout, outerStar] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_right
            g q hq hγR
      have hvδ : v ∈ δ.vertices := by
        change v ∈ γ.vertices.image (Aout.retargetVertex outerStar)
        exact Finset.mem_image.mpr ⟨v, hvγ, hOuter⟩
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = Aact.retargetVertex rightStar v := by rw [hOuter]
        _ = rightStar δ := by
          exact AdmissibleSubgraph.retargetVertex_of_mem_component
            hAactDisj rightStar hδ hvδ
        _ = splitStar γ := by
          simpa [Aout, outerStar, Q, Aact, rightStar, splitStar, δ] using
            (forestComponentForestChoiceSplitStarOf_right
              g q hq C hγR).symm
        _ = A.retargetVertex splitStar v := by
          rw [AdmissibleSubgraph.retargetVertex_of_mem_component
            hADisj splitStar hγA hvγ]
    · rcases hγF with ⟨B, hB⟩
      let δ :=
        admissibleSubgraphQuotientRemainderSubgraph Aout outerStar γ
      have hδ : δ ∈ Aact.elements := by
        simpa [Aact, δ, Aout, outerStar] using
          forestComponentForestChoiceActualQuotientSubgraphCanonical_mem_of_forest
            g q hq ⟨γ, hγA⟩ hB
      have hvδ :
          Aout.retargetVertex outerStar v ∈ δ.vertices := by
        change Aout.retargetVertex outerStar v ∈
          γ.vertices.image (Aout.retargetVertex outerStar)
        exact Finset.mem_image.mpr ⟨v, hvγ, rfl⟩
      calc
        Aact.retargetVertex rightStar (Aout.retargetVertex outerStar v)
            = rightStar δ := by
          exact AdmissibleSubgraph.retargetVertex_of_mem_component
            hAactDisj rightStar hδ hvδ
        _ = splitStar γ := by
          simpa [Aout, outerStar, Q, Aact, rightStar, splitStar, δ] using
            (forestComponentForestChoiceSplitStarOf_forest
              g q hq C ⟨γ, hγA⟩ hB).symm
