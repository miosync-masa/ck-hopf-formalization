private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_vertices_eq_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).vertices =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).vertices := by
  classical
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  have hV :
      ‚ąÄ ő∑ ‚ąą (forestComponentChoiceRightSubgraph q.1.1 q.2).elements,
        ‚ąÄ v ‚ąą ő∑.vertices, v ‚ąČ Aout.vertices := by
    intro ő∑ hő∑ v hv
    dsimp [Aout]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hő∑ hv
  ext v
  constructor
  ¬∑ intro hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ‚ü®őī, hőī, hvőī‚ü©
    rcases
        forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_exists
          g q hq hőī with
      ‚ü®ő≥, rfl‚ü©
    have hVeq :=
      admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
        Aout starOf ő≥.1
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥.1 ő≥.2)
        (hV ő≥.1 ő≥.2)
    exact AdmissibleSubgraph.mem_vertices.mpr ‚ü®ő≥.1, ő≥.2, by
      exact hVeq ‚Ėł hvőī‚ü©
  ¬∑ intro hv
    rcases AdmissibleSubgraph.mem_vertices.mp hv with ‚ü®ő≥, hő≥, hvő≥‚ü©
    let őī :=
      admissibleSubgraphRetargetSubgraph
        Aout starOf ő≥
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥ hő≥)
    have hVeq :
        őī.vertices = ő≥.vertices := by
      simpa [őī] using
        admissibleSubgraphRetargetSubgraph_vertices_eq_of_not_mem
          Aout starOf ő≥
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥ hő≥)
          (hV ő≥ hő≥)
    exact AdmissibleSubgraph.mem_vertices.mpr ‚ü®őī, by
      simpa [őī] using
        forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_mem_of_right
          g q hq hő≥, by
      simpa [hVeq] using hvő≥‚ü©

private theorem
    forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical_internalEdges_eq_right
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (q : forestComponentChoiceSigma g)
    (hq : q ‚ąą forestComponentMixedBoundaryChoiceSigmaIndex g) :
    (forestComponentMixedBoundaryActualRightQuotientSubgraphCanonical
      g q hq).internalEdges =
      (forestComponentChoiceRightSubgraph q.1.1 q.2).internalEdges := by
  classical
  have hDisj : q.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph
      |>.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        q.1.2
  let Aout := (forestComponentMixedBoundaryOuterIndex g q hq).1
  let starOf :=
    FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph
      (forestComponentMixedBoundaryOuterIndex g q hq).1
      (forestComponentMixedBoundaryOuterIndex g q hq).2
  let R := forestComponentChoiceRightSubgraph q.1.1 q.2
  have hV :
      ‚ąÄ ő∑ ‚ąą R.elements, ‚ąÄ v ‚ąą ő∑.vertices, v ‚ąČ Aout.vertices := by
    intro ő∑ hő∑ v hv
    dsimp [Aout, R]
    exact forestComponentChoiceRight_vertices_not_mem_leftSubgraph
      q.1.1 q.2 hDisj hő∑ hv
  have hinj :=
    admissibleSubgraphRetarget_injective_of_not_mem
      Aout starOf R
      (fun ő∑ hő∑ =>
        forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő∑ (by
          simpa [R] using hő∑))
      hV
  unfold AdmissibleSubgraph.internalEdges
  change
    (‚ąĎ őī ‚ąą
      (R.elements.attach.image fun ő≥ =>
        admissibleSubgraphRetargetSubgraph
          Aout starOf ő≥.1
          (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥.1
            (by simpa [R] using ő≥.2))),
      őī.internalEdges) =
    ‚ąĎ ő≥ ‚ąą R.elements, ő≥.internalEdges
  rw [Finset.sum_image]
  ¬∑ trans ‚ąĎ ő≥ ‚ąą R.elements.attach, ő≥.1.internalEdges
    ¬∑ apply Finset.sum_congr rfl
      intro ő≥ _hő≥
      exact admissibleSubgraphRetargetSubgraph_internalEdges_eq_of_not_mem
        Aout starOf ő≥.1
        (forestComponentMixedBoundaryRightRetarget_edge_le g q hq ő≥.1
          (by simpa [R] using ő≥.2))
        (hV ő≥.1 ő≥.2)
    ¬∑ rw [Finset.sum_attach]
  ¬∑ intro ő≥‚āĀ _ ő≥‚āā _ hEq
    exact hinj hEq

private theorem forestComponentMixedBoundary_right_internalEdges_outerRetarget_eq
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
