/-- The indexed classifier supplies RHS branch cover by inspecting the selected
preimage branch. -/
private def forestComponentSplitPhiBranchCoverCertificateOfIndexedClassifier
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiIndexedBranchClassifier g) :
    forestComponentSplitPhiBranchCoverCertificate g where
  cover := by
    intro r hr
    let r' : {r : forestQuotientForestSigma g // r ∈ forestQuotientForestSigmaIndex g} :=
      ⟨r, hr⟩
    have hmem := X.preimage_mem r'
    have hright := X.right_inv r'
    cases hp : X.preimage r' with
    | inl q =>
        left
        have hq : q ∈ forestComponentForestChoiceSigmaIndex g := by
          simpa [forestComponentSplitChoiceSigmaIndex, hp] using hmem
        refine ⟨q, hq, ?_⟩
        rw [hp, forestComponentSplitPhi_inl_of_mem g q hq] at hright
        exact hright
    | inr q =>
        right
        have hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
          simpa [forestComponentSplitChoiceSigmaIndex, hp] using hmem
        refine ⟨q, hq, ?_⟩
        rw [hp, forestComponentSplitPhi_inr_of_mem g q hq] at hright
        exact hright

/-- A concrete inverse construction supplies same-branch injectivity and
cross-branch separation for the branch targets. -/
private def
    forestComponentSplitPhiBranchInjectivitySeparationOfInverseConstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiInverseConstruction g) :
    forestComponentSplitPhiBranchInjectivitySeparation g where
  forest_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    have hq₁Split :
        Sum.inl q₁ ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq₁
    have hq₂Split :
        Sum.inl q₂ ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
    have h₁ := X.left_inv (Sum.inl q₁) hq₁Split
    have h₂ := X.left_inv (Sum.inl q₂) hq₂Split
    rw [forestComponentSplitPhi_inl_of_mem g q₁ hq₁] at h₁
    rw [forestComponentSplitPhi_inl_of_mem g q₂ hq₂] at h₂
    apply Sum.inl.inj
    calc
      Sum.inl q₁ = X.inv (forestComponentForestChoiceToQuotientForestSigma g q₁ hq₁) :=
        h₁.symm
      _ = X.inv (forestComponentForestChoiceToQuotientForestSigma g q₂ hq₂) := by
        rw [hφ]
      _ = Sum.inl q₂ := h₂
  mixed_inj := by
    intro q₁ hq₁ q₂ hq₂ hφ
    have hq₁Split :
        Sum.inr q₁ ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq₁
    have hq₂Split :
        Sum.inr q₂ ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hq₂
    have h₁ := X.left_inv (Sum.inr q₁) hq₁Split
    have h₂ := X.left_inv (Sum.inr q₂) hq₂Split
    rw [forestComponentSplitPhi_inr_of_mem g q₁ hq₁] at h₁
    rw [forestComponentSplitPhi_inr_of_mem g q₂ hq₂] at h₂
    apply Sum.inr.inj
    calc
      Sum.inr q₁ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g q₁ hq₁) :=
        h₁.symm
      _ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g q₂ hq₂) := by
        rw [hφ]
      _ = Sum.inr q₂ := h₂
  cross := by
    intro qF hF qM hM hφ
    have hFSplit :
        Sum.inl qF ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hF
    have hMSplit :
        Sum.inr qM ∈ forestComponentSplitChoiceSigmaIndex g := by
      simpa [forestComponentSplitChoiceSigmaIndex] using hM
    have hFInv := X.left_inv (Sum.inl qF) hFSplit
    have hMInv := X.left_inv (Sum.inr qM) hMSplit
    rw [forestComponentSplitPhi_inl_of_mem g qF hF] at hFInv
    rw [forestComponentSplitPhi_inr_of_mem g qM hM] at hMInv
    have hsum : Sum.inl qF = Sum.inr qM := by
      calc
        Sum.inl qF =
            X.inv (forestComponentForestChoiceToQuotientForestSigma g qF hF) :=
          hFInv.symm
        _ = X.inv (forestComponentMixedBoundaryToQuotientForestSigma g qM hM) := by
          rw [hφ]
        _ = Sum.inr qM := hMInv
    cases hsum

/-- A concrete inverse construction supplies the RHS branch cover. -/
private def forestComponentSplitPhiBranchCoverCertificateOfInverseConstruction
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (X : forestComponentSplitPhiInverseConstruction g) :
    forestComponentSplitPhiBranchCoverCertificate g where
  cover := by
    intro r hr
    have hInvMem := X.inv_mem r hr
    have hRight := X.right_inv r hr
    cases hInv : X.inv r with
    | inl q =>
        left
        have hq : q ∈ forestComponentForestChoiceSigmaIndex g := by
          simpa [forestComponentSplitChoiceSigmaIndex, hInv] using hInvMem
        refine ⟨q, hq, ?_⟩
        rw [hInv, forestComponentSplitPhi_inl_of_mem g q hq] at hRight
        exact hRight
    | inr q =>
        right
        have hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g := by
          simpa [forestComponentSplitChoiceSigmaIndex, hInv] using hInvMem
        refine ⟨q, hq, ?_⟩
        rw [hInv, forestComponentSplitPhi_inr_of_mem g q hq] at hRight
        exact hRight

/-- The per-branch tensor factorization payload for the concrete `φ`.  Each
branch term equality is reduced to a product factorization and a final quotient
right-factor identification. -/
private structure forestComponentSplitPhiBranchTermFactorization
    [IsDivergencePreservedByAdmissibleForestContract] (g : HopfGen)
    (C : ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentForestChoiceRemnantPositiveComponentsCertificate g q hq) where
  forest_product :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestComponentChoiceProductTerm q.1.1 q.2 =
        (forestComponentForestChoiceOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
          (forestComponentForestChoiceRepQuotientSubgraphCanonical
            g q hq).toHopfH
  forest_right :
    ∀ q, ∀ hq : q ∈ forestComponentForestChoiceSigmaIndex g,
      forestRightHopfH g q.1.1 q.1.2 =
        forestRightHopfH
          (forestOuterQuotientHopfGen g
            (forestComponentForestChoiceOuterIndex g q hq))
          (forestComponentForestChoiceRepQuotientSubgraphCanonical g q hq)
          (forestComponentForestChoiceRepQuotientSubgraphCanonical_mem_properDisjoint_of_remnantPositive
            g q hq (C q hq))
  mixed_product :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      forestComponentChoiceProductTerm q.1.1 q.2 =
        (forestComponentMixedBoundaryOuterIndex g q hq).1.toHopfH ⊗ₜ[ℚ]
          (forestComponentMixedBoundaryRepRightQuotientSubgraphCanonical
            g q hq).toHopfH
  mixed_right :
    ∀ q, ∀ hq : q ∈ forestComponentMixedBoundaryChoiceSigmaIndex g,
      forestRightHopfH g q.1.1 q.1.2 =
        forestRightHopfH
