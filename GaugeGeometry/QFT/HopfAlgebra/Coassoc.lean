/-- Sprint F2i-3q-4a: membership iff for forest-type components. -/
private theorem forestQuotientForestSigmaForestCoverForestComponents_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)} :
    δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r ↔
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements ∧
        ¬ Disjoint δ.vertices
          (r.1.1.1.starVertices
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
  unfold forestQuotientForestSigmaForestCoverForestComponents
  exact Finset.mem_filter

/-- Sprint forest_cd-divergent: `SourceSubgraphExactPlus` is superficially
divergent.  The quotient remainder of `Plus δ` along the outer forest is exactly
`δ` (`_remainder_eq`), and `δ` is divergent as a forest cover component (its
ambient actual-quotient admissible subgraph has divergent elements); every outer
forest component is divergent by admissibility.  The reverse power-counting
reflection (`IsDivergenceReflectedByAdmissibleForestContract`) then transports
divergence back from the remainder `δ` to the source `Plus δ` — the Weinberg / CK
additivity `ω(Plus) = ω(δ) + Σ_{η} ω(η)`. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_divergent
    [IsDivergencePreservedByAdmissibleForestContract]
    [IsDivergenceReflectedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (hδ : δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r) :
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).IsDivergent := by
  have hDisj : r.1.1.1.IsPairwiseDisjoint :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      r.1.1.2
  have hCompNE : r.1.1.1.HasNonemptyComponents :=
    (repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_hasNonemptyComponents
      r.1.1.2
  have hFresh :=
    FeynmanGraph.admissibleForestCanonicalStarOf_isFreshStarAssignment
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2
  have hForestDiv : ∀ η ∈ r.1.1.1.elements, η.IsDivergent :=
    fun η hη => r.1.1.1.isDivergent_of_mem hη
  have hδmem :
      δ ∈ (forestQuotientForestSigmaActualQuotientSubgraph g r.1).elements :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ).1
  have hδDiv : δ.IsDivergent :=
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).isDivergent_of_mem hδmem
  have hRemDiv :
      (admissibleSubgraphQuotientRemainderSubgraph
        r.1.1.1
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)).IsDivergent := by
    rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_remainder_eq g r δ]
    exact hδDiv
  exact admissibleSubgraphQuotientRemainderSubgraph_isDivergent_reflect
    r.1.1.1 hDisj hCompNE hForestDiv
    (FeynmanGraph.admissibleForestCanonicalStarOf
      (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)
    hFresh
    (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ)
    hRemDiv

/-- Sprint forest_cd-onePI-1a: classify an internal edge of `SourceSubgraphExactPlus`
as either an Exact edge (retargets to a `δ`-edge) or a Promoted edge (lives in
an outer forest component).  Immediate from
`SourceSubgraphExactPlus_internalEdges = Exact + Promoted` and `Multiset.mem_add`.
This is the case-split foundation of the bridge-free (`IsOnePI`) argument: Exact
edges are not bridges via `δ`'s 1PI-ness; Promoted edges via the forest
component's 1PI-ness. -/
private theorem forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdge_exact_or_promoted
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {e : FeynmanEdge}
    (he : e ∈ (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r δ).internalEdges) :
    e ∈ forestQuotientForestSigmaForestCoverExactInternalEdges g r δ ∨
      e ∈ forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ := by
  rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges] at he
  exact Multiset.mem_add.mp he

/-- Sprint F2i-3q-4l-1-defs: aggregated promoted components across **all**
forest-type δ's of `D`.  These are the outer `r.1.1.1.elements` that get
absorbed into some `Plus(δ)` lift via the canonical star structure. -/
private noncomputable def forestQuotientForestSigmaForestCoverAllPromotedComponents
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
