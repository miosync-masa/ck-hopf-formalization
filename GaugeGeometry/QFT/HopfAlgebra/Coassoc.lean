  AdmissibleSubgraph.ofElements
    (forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
    ⟨fun _ hγ =>
        forestQuotientForestSigmaForestCoverLiftedRightComponents_cd g r hγ,
      fun _ hγ₁ _ hγ₂ hne =>
        forestQuotientForestSigmaForestCoverLiftedRightComponents_nestedOrDisjoint
          g r hγ₁ hγ₂ hne⟩

@[simp] private theorem forestQuotientForestSigmaForestCoverRightCandidate_v3_elements
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
