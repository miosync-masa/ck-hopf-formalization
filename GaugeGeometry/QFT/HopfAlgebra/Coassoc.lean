private theorem
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph_mem_properDisjoint
    {G : FeynmanGraph} (ő≥ : FeynmanSubgraph G)
    (hő≥ : ő≥.IsConnectedDivergent)
    {B : AdmissibleSubgraph (repG (ő≥.toHopfGen hő≥)).toFeynmanGraph}
    (hB : B ‚ąą
      ((repG (ő≥.toHopfGen hő≥)).toFeynmanGraph).properDisjointAdmissibleDivergentSubgraphs) :
    feynmanSubgraphRepForestPromoteAdmissibleSubgraph ő≥ hő≥ B ‚ąą
