/-- Sprint F2i-3i: general Multiset submultiset-preimage existence.
If `t ‚Č§ s.map f`, then some sub-multiset of `s` maps onto `t`.  Pure
Multiset combinatorics ‚ÄĒ no `FeynmanEdge` / `retargetEdge` / source
vertices.  Used as the multiplicity-aware substitute for per-element
`Classical.choose` in the forest-cover edge construction. -/
private theorem Multiset.exists_le_of_le_map
    {őĪ ő≤ : Type*} [DecidableEq őĪ] [DecidableEq ő≤]
    (f : őĪ ‚Üí ő≤) (t : Multiset ő≤) :
    ‚ąÄ s : Multiset őĪ, t ‚Č§ s.map f ‚Üí
      ‚ąÉ u : Multiset őĪ, u ‚Č§ s ‚ąß u.map f = t := by
  induction t using Multiset.induction_on with
  | empty =>
    intro s _
    exact ‚ü®0, Multiset.zero_le _, by simp‚ü©
  | cons b t' ih =>
    intro s h
    have hb : b ‚ąą s.map f :=
      Multiset.mem_of_le h (Multiset.mem_cons_self b t')
    rcases Multiset.mem_map.mp hb with ‚ü®a, ha, hfa‚ü©
    have h_map_erase : (s.erase a).map f = (s.map f).erase b := by
      have := Multiset.map_erase_of_mem f s ha
      rw [hfa] at this; exact this
    have ht' : t' ‚Č§ (s.erase a).map f := by
      rw [Multiset.le_iff_count]
      intro x
      rw [h_map_erase]
      have h1 : Multiset.count x (b ::‚āė t') ‚Č§ Multiset.count x (s.map f) :=
        Multiset.count_le_of_le x h
      rw [Multiset.count_cons] at h1
      by_cases hxb : x = b
      ¬∑ subst hxb
        rw [Multiset.count_erase_self]
        simp at h1
        omega
      ¬∑ rw [Multiset.count_erase_of_ne hxb]
        simp [hxb] at h1
        exact h1
    rcases ih (s.erase a) ht' with ‚ü®u', hu'le, hu'map‚ü©
    refine ‚ü®a ::‚āė u', ?_, ?_‚ü©
    ¬∑ calc a ::‚āė u'
          ‚Č§ a ::‚āė (s.erase a) := Multiset.cons_le_cons a hu'le
        _ = s := Multiset.cons_erase ha
    ¬∑ rw [Multiset.map_cons, hu'map, hfa]

/-- Sprint F2i-3j: existence of a multiplicity-preserving edge multiset
that retargets onto `őī.internalEdges` with endpoints in source vertices.
Pure existence, no `Classical.choose` wrapper ‚ÄĒ F2i-3k will package this. -/
private theorem forestQuotientForestSigmaForestCoverExactInternalEdges_exists
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ‚ąą forestQuotientForestSigmaIndex g})
    (őī : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)) :
    ‚ąÉ E : Multiset FeynmanEdge,
      E ‚Č§ r.1.1.1.complementEdges ‚ąß
      E ‚Č§ (repG g).toFeynmanGraph.internalEdges ‚ąß
      E.map
        (r.1.1.1.retargetEdge
          (FeynmanGraph.admissibleForestCanonicalStarOf
            (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) =
        őī.internalEdges ‚ąß
      ‚ąÄ e ‚ąą E,
        e.source ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī ‚ąß
        e.target ‚ąą forestQuotientForestSigmaForestCoverSourceVertices g r őī := by
  classical
  have hőīLe : őī.internalEdges ‚Č§
      (forestOuterActualQuotientGraph g r.1.1).internalEdges :=
    őī.internalEdges_le
  have hActualEq :
      (forestOuterActualQuotientGraph g r.1.1).internalEdges =
        r.1.1.1.complementEdges.map
          (r.1.1.1.retargetEdge
            (FeynmanGraph.admissibleForestCanonicalStarOf
              (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) := by
    unfold forestOuterActualQuotientGraph
    rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
      AdmissibleSubgraph.contractWithStars_internalEdges]
  rw [hActualEq] at hőīLe
  rcases Multiset.exists_le_of_le_map _ _ _ hőīLe with ‚ü®E, hELe, hEmap‚ü©
  have hCompLe :
      r.1.1.1.complementEdges ‚Č§ (repG g).toFeynmanGraph.internalEdges := by
    unfold AdmissibleSubgraph.complementEdges
    exact Multiset.sub_le_self _ _
  have hEGLe : E ‚Č§ (repG g).toFeynmanGraph.internalEdges := hELe.trans hCompLe
  refine ‚ü®E, hELe, hEGLe, hEmap, ?_‚ü©
  intro e he
  have hfe :
      r.1.1.1.retargetEdge
        (FeynmanGraph.admissibleForestCanonicalStarOf
          (repG g).toFeynmanGraph r.1.1.1 r.1.1.2) e ‚ąą őī.internalEdges := by
    rw [‚Üź hEmap]
    exact Multiset.mem_map_of_mem _ he
  have hfeSupp := őī.edges_supported _ hfe
  have heG : e ‚ąą (repG g).toFeynmanGraph.internalEdges :=
    Multiset.mem_of_le hEGLe he
  have heGsupp := FeynmanGraph.wellFormed_internal (repG_wellFormed g) heG
  refine ‚ü®?_, ?_‚ü©
  ¬∑ exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r őī heGsupp.1 rfl hfeSupp.1
  ¬∑ exact forestQuotientForestSigmaForestCover_endpoint_mem_sourceVertices
      g r őī heGsupp.2 rfl hfeSupp.2

