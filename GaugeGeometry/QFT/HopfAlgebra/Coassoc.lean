      (feynmanSubgraphRepToComponentAdmissibleSubgraph ő≥.1
        (q.1.1.isConnectedDivergent_of_mem ő≥.2) B).complementEdges := by
  classical
  refine Multiset.ext.mpr ?_
  intro e
