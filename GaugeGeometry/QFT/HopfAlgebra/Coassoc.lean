/-- Range invariant of `contractRestrict`: the second factor's vertex
set always contains the contracted vertex `star`. This is the key
observation that the forward bijection in coassoc covers only the
"star-containing" part of the RHS sum, not the full RHS index. -/
private theorem contractRestrict_star_mem {G : FeynmanGraph}
    {ő≥‚āĀ ő≥‚āā : FeynmanSubgraph G} (hle : ő≥‚āĀ ‚Č§ ő≥‚āā) (star : VertexId) :
    star ‚ąą (FeynmanSubgraph.contractRestrict hle star).vertices := by
  rw [FeynmanSubgraph.contractRestrict_vertices]
  exact Finset.mem_union_right _ (Finset.mem_singleton.mpr rfl)

/-- The nested-chain forward map lands in the star-containing component of
the RHS sigma index. This is the Lean-level form of the obstruction: this
map cannot cover star-free quotient subgraphs. -/
private theorem coassocNestedForward_star_mem (g : HopfGen)
    (p : ő£ ő≥_outer : FeynmanSubgraph (repG g).toFeynmanGraph,
        FeynmanSubgraph ő≥_outer.toFeynmanGraph) :
    (coassocNestedForward g p).1.contractedVertex ‚ąą
      (coassocNestedForward g p).2.vertices := by
  dsimp [coassocNestedForward]
  exact Finset.mem_union_right _ (Finset.mem_singleton.mpr rfl)

