      ¬∑ refine Finset.mem_union_right _ ?_
        rw [hSplitStars, hForestStars]
        exact Finset.mem_union_right _
          (Finset.mem_union_right _
            (AdmissibleSubgraph.mem_starVertices.mpr ‚ü®őī, by
              simpa [Mact] using hőīM, rfl‚ü©))
  ¬∑ intro hv
    rcases Finset.mem_union.mp hv with hvDiff | hvStar
    ¬∑ rcases Finset.mem_sdiff.mp hvDiff with ‚ü®hvG, hvNotA‚ü©
      refine Finset.mem_union_left _ ?_
