/-- Sprint F2i-3q-4k-1b-i: distinct forest-type components have Finset-disjoint
promoted-component sets.  Key invariant for the upcoming card bound:
distinct δ₁, δ₂ ∈ ForestComponents share no promoted η, because a common
η would have `starOf η ∈ δ₁.V ∩ δ₂.V` contradicting D.IsPairwiseDisjoint. -/
private theorem forestQuotientForestSigmaForestCoverPromotedComponents_disjoint_of_ne
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {δ₁ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1)}
    (hδ₁ : δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r)
    (hδ₂ : δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r)
    (hne : δ₁ ≠ δ₂) :
    Disjoint
      (forestQuotientForestSigmaForestCoverPromotedComponents g r δ₁)
      (forestQuotientForestSigmaForestCoverPromotedComponents g r δ₂) := by
  classical
  rw [Finset.disjoint_left]
  intro η hη₁ hη₂
  rw [forestQuotientForestSigmaForestCover_mem_promotedComponents_iff] at hη₁ hη₂
  obtain ⟨_hηA, hStar₁⟩ := hη₁
  obtain ⟨_, hStar₂⟩ := hη₂
  have hδ₁D :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ₁).1
  have hδ₂D :=
    ((forestQuotientForestSigmaForestCoverForestComponents_mem g r).mp hδ₂).1
  have hDPair :=
    (forestOuterActualQuotientGraph g r.1.1
      ).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      (forestQuotientForestSigmaActualQuotientSubgraph_mem_properDisjoint g r)
  have hVDisj : Disjoint δ₁.vertices δ₂.vertices :=
    hDPair hδ₁D hδ₂D hne
  exact (Finset.disjoint_left.mp hVDisj hStar₁) hStar₂

/-- Sprint F2i-3q-4k-1b-ii: aggregate cardinality bound for the forest-side
promoted internal edges.  Combining 4k-1b-i (disjoint promoted-component
finsets) with `Finset.sum_biUnion`, the sum over ForestComponents of
PromotedInternalEdges merges into a single sum over the disjoint biUnion of
promoted components, which is a subset of `A_final.elements`.  Cardinality
monotonicity then yields the bound. -/
private theorem forestQuotientForestSigmaForestCoverLiftedForestPromotedInternalEdges_card_le_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    ((forestQuotientForestSigmaForestCoverForestComponents g r).sum
        (fun δ => forestQuotientForestSigmaForestCoverPromotedInternalEdges
          g r δ)).card ≤
      r.1.1.1.internalEdges.card := by
  classical
  -- Step 1: rewrite the outer sum into a biUnion-based sum
  have hBiUnEq :
      (forestQuotientForestSigmaForestCoverForestComponents g r).sum
          (fun δ => forestQuotientForestSigmaForestCoverPromotedInternalEdges
            g r δ) =
        ((forestQuotientForestSigmaForestCoverForestComponents g r).biUnion
          (fun δ => forestQuotientForestSigmaForestCoverPromotedComponents g r δ)).sum
          (fun η => η.internalEdges) := by
    unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges
    rw [Finset.sum_biUnion]
    intro δ₁ hδ₁ δ₂ hδ₂ hne
    exact forestQuotientForestSigmaForestCoverPromotedComponents_disjoint_of_ne
      g r hδ₁ hδ₂ hne
  rw [hBiUnEq]
  -- Step 2: biUnion ⊆ A_final.elements
  have hSub :
      (forestQuotientForestSigmaForestCoverForestComponents g r).biUnion
          (fun δ => forestQuotientForestSigmaForestCoverPromotedComponents g r δ) ⊆
        r.1.1.1.elements := by
    intro η hη
    rcases Finset.mem_biUnion.mp hη with ⟨δ, _, hηδ⟩
    exact
      ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
          g r δ).mp hηδ).1
  -- Step 3: sum over biUnion ≤ sum over A_final.elements as multiset
  have hSumLe :
      ((forestQuotientForestSigmaForestCoverForestComponents g r).biUnion
          (fun δ => forestQuotientForestSigmaForestCoverPromotedComponents g r δ)).sum
          (fun η => η.internalEdges) ≤
        r.1.1.1.elements.sum (fun η => η.internalEdges) :=
    Finset.sum_le_sum_of_subset hSub
  -- Step 4: card chain; RHS sum = A_final.internalEdges by def
  exact Multiset.card_le_card hSumLe

/-- Sprint F2i-3q-hForestCompl-1: cardinality partition of `r.1.1.1.internalEdges`
into the Left and Promoted halves.  Combines 4l-1-defs's `AllPromotedComponents`
biUnion presentation with the 4l-actual-partition's
`LeftComponents ⊔ AllPromotedComponents = r.1.1.1.elements` to express
`r.1.1.1.internalEdges.card` as the sum of the Left-half and the
ForestComponents-PromotedInternalEdges card. -/
private theorem forestQuotientForestSigmaForestCover_left_add_promotedInternalEdges_card_eq_outer
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    ((forestQuotientForestSigmaForestCoverLeftComponents g r).sum
        (fun η => η.internalEdges)).card +
      ((forestQuotientForestSigmaForestCoverForestComponents g r).sum
        (fun δ => forestQuotientForestSigmaForestCoverPromotedInternalEdges
          g r δ)).card =
      r.1.1.1.internalEdges.card := by
  classical
  -- Step 1: convert ForestComponents-sum of PromotedInternalEdges into
  --   AllPromotedComponents-sum of η.internalEdges (via `Finset.sum_biUnion`
  --   + per-pair disjointness of promoted components).
  have hForestSum :
      (forestQuotientForestSigmaForestCoverForestComponents g r).sum
          (fun δ => forestQuotientForestSigmaForestCoverPromotedInternalEdges
            g r δ) =
        (forestQuotientForestSigmaForestCoverAllPromotedComponents g r).sum
          (fun η => η.internalEdges) := by
    unfold forestQuotientForestSigmaForestCoverAllPromotedComponents
      forestQuotientForestSigmaForestCoverPromotedInternalEdges
    rw [Finset.sum_biUnion]
    intro δ₁ hδ₁ δ₂ hδ₂ hne
    exact forestQuotientForestSigmaForestCoverPromotedComponents_disjoint_of_ne
      g r hδ₁ hδ₂ hne
  -- Step 2: combine Left and AllPromoted via `Finset.sum_union`
  --   (LeftComponents ⊥ AllPromotedComponents from 4l-actual-partition).
  rw [hForestSum, ← Multiset.card_add,
    ← Finset.sum_union
      (forestQuotientForestSigmaForestCover_left_disjoint_allPromotedComponents g r),
    forestQuotientForestSigmaForestCover_left_union_allPromotedComponents]
  rfl

/-- Sprint F2i-3q-hForestCompl-2: cardinality decomposition of
`A_source_v3.internalEdges` into the 3-way Left/LiftedRight/LiftedForest sums.
Direct expansion of `_v3_elements` simp lemma + `Finset.sum_union` (twice) +
`Multiset.card_add` (twice).  All three Finsets are pairwise disjoint by
F2i-3q-4l-2e-2 (Left vs LiftedRight/LiftedForest) + F2i-3q-4h-3a
(LiftedRight vs LiftedForest). -/
private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_internalEdges_card_eq_parts
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices) :
    (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
      g r hForestCD hForestDisjoint).internalEdges.card =
      ((forestQuotientForestSigmaForestCoverLeftComponents g r).sum
        (fun η => η.internalEdges)).card +
      ((forestQuotientForestSigmaForestCoverLiftedRightComponents g r).sum
        (fun γ => γ.internalEdges)).card +
      ((forestQuotientForestSigmaForestCoverLiftedForestComponents g r).sum
        (fun γ => γ.internalEdges)).card := by
  classical
  have hRF :
      Disjoint
        (forestQuotientForestSigmaForestCoverLiftedRightComponents g r)
        (forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :=
    forestQuotientForestSigmaForestCover_liftedRight_disjoint_liftedForestComponents g r
  have hLD :
      Disjoint
        (forestQuotientForestSigmaForestCoverLeftComponents g r)
        (forestQuotientForestSigmaForestCoverLiftedRightComponents g r ∪
          forestQuotientForestSigmaForestCoverLiftedForestComponents g r) := by
    rw [Finset.disjoint_union_right]
    exact
      ⟨forestQuotientForestSigmaForestCover_leftComponents_disjoint_liftedRightComponents
        g r,
       forestQuotientForestSigmaForestCover_leftComponents_disjoint_liftedForestComponents
        g r⟩
  show ((forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint).elements.sum
      (fun η => η.internalEdges)).card = _
  rw [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_elements]
  unfold forestQuotientForestSigmaForestCoverSourceElements_v3
  rw [Finset.sum_union hLD, Finset.sum_union hRF,
    Multiset.card_add, Multiset.card_add, Nat.add_assoc]

/-- Sprint F2i-3q-hForestCompl-3a: `LiftedRightComponents`-sum of internalEdges
equals `LiftedRightInternalEdges` (the canonical RightComponents-sum from
F2i-3q-4k-1a).  Forest analog of mixed pattern at [Coassoc.lean:15103-15112].
Uses `Finset.sum_image` with per-element no-star injectivity (via
`_inj_on_attach` on `RightActualSubgraph` whose `.elements = RightComponents`). -/
private theorem forestQuotientForestSigmaForestCover_liftedRightInternalEdges_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    (forestQuotientForestSigmaForestCoverLiftedRightComponents g r).sum
        (fun γ => γ.internalEdges) =
      forestQuotientForestSigmaForestCoverLiftedRightInternalEdges g r := by
  classical
  unfold forestQuotientForestSigmaForestCoverLiftedRightComponents
    forestQuotientForestSigmaForestCoverLiftedRightInternalEdges
  rw [Finset.sum_image]
  · simp only [forestOuterActualQuotientNoStarComponentLift_internalEdges]
    exact Finset.sum_attach
      (forestQuotientForestSigmaForestCoverRightComponents g r)
      (fun δ => δ.internalEdges)
  · intro δ₁ _ δ₂ _ h
    have hAllNoStar :
        ∀ δ ∈ (forestQuotientForestSigmaForestCoverRightActualSubgraph g r).elements,
          Disjoint δ.vertices
            (r.1.1.1.starVertices
              (FeynmanGraph.admissibleForestCanonicalStarOf
                (repG g).toFeynmanGraph r.1.1.1 r.1.1.2)) :=
      fun δ hδ =>
        ((forestQuotientForestSigmaForestCoverRightComponents_mem g r).mp hδ).2
    exact forestOuterActualQuotientNoStarComponentLift_inj_on_attach
      g r.1.1 hAllNoStar h

/-- Sprint F2i-3q-hForestCompl-3b: `LiftedForestComponents`-sum of internalEdges
splits as `LiftedForestExactInternalEdges + ForestComponents-sum-of-PromotedInternalEdges`.
Uses `Finset.sum_image` + Plus injective (F2i-3q-4l-actual-7a) +
`SourceSubgraphExactPlus_internalEdges` simp + `Finset.sum_attach` + Multiset
add distribution. -/
private theorem forestQuotientForestSigmaForestCover_liftedForestInternalEdges_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    (forestQuotientForestSigmaForestCoverLiftedForestComponents g r).sum
        (fun γ => γ.internalEdges) =
      forestQuotientForestSigmaForestCoverLiftedForestExactInternalEdges g r +
      (forestQuotientForestSigmaForestCoverForestComponents g r).sum
        (fun δ => forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ) := by
  classical
  unfold forestQuotientForestSigmaForestCoverLiftedForestComponents
    forestQuotientForestSigmaForestCoverLiftedForestExactInternalEdges
  rw [Finset.sum_image]
  · simp only [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
    rw [Finset.sum_attach
      (forestQuotientForestSigmaForestCoverForestComponents g r)
      (fun δ => forestQuotientForestSigmaForestCoverExactInternalEdges g r δ +
        forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ)]
    exact Finset.sum_add_distrib
  · intro δ₁ _ δ₂ _ h
    apply Subtype.ext
    exact forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_injective g r h

/-- Sprint F2i-3q-hForestCompl-4: cardinality decomposition
`A_v3.I.card = A_final.I.card + D.I.card`.  Combines hForestCompl-1 (Left +
Promoted partition of `A_final`), hForestCompl-2 (3-way `A_v3` partition),
hForestCompl-3a/3b (LiftedRight/LiftedForest aggregation), and 4k-1a
(D-side `RightInternalEdges + ExactInternalEdges`). -/
private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_internalEdges_card_eq_outer_add_actual
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices) :
    (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
      g r hForestCD hForestDisjoint).internalEdges.card =
      r.1.1.1.internalEdges.card +
        (forestQuotientForestSigmaActualQuotientSubgraph g r.1).internalEdges.card := by
  classical
  have hOuter :=
    forestQuotientForestSigmaForestCover_left_add_promotedInternalEdges_card_eq_outer g r
  have hActual :=
    forestQuotientForestSigmaForestCover_exactInternalEdges_card_eq_actual g r
  rw [forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_internalEdges_card_eq_parts
      g r hForestCD hForestDisjoint,
    forestQuotientForestSigmaForestCover_liftedRightInternalEdges_eq,
    forestQuotientForestSigmaForestCover_liftedForestInternalEdges_eq,
    Multiset.card_add]
  omega

/-- Sprint F2i-3q-hForestCompl-5: `D.I.card < A_final.complementEdges.card`.
Reuses the mixed F2h-4c chain ([Coassoc.lean:15054-15101]) for the
`r.2 ∈ properDisjoint`-driven complement positivity + mapPerm preimage card
preservation + `outerActualQuotientGraph` carrier identification. -/
private theorem forestQuotientForestSigmaActualQuotient_internalEdges_card_lt_outerComplement
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g}) :
    (forestQuotientForestSigmaActualQuotientSubgraph g r.1).internalEdges.card <
      r.1.1.1.complementEdges.card := by
  classical
  have hr2pos : 0 < r.1.2.complementEdges.card := by
    have h := (Finset.mem_sigma.mp r.2).2
    unfold forestCoproductProperForestIndex at h
    exact (Finset.mem_filter.mp h).2
  have hr2PD : r.1.2 ∈
      (forestOuterQuotientGraph g r.1.1).properDisjointAdmissibleDivergentSubgraphs := by
    have h := (Finset.mem_sigma.mp r.2).2
    unfold forestCoproductProperForestIndex at h
    exact (Finset.mem_filter.mp h).1
  have hr2IPD :=
    (forestOuterQuotientGraph g r.1.1).properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
      hr2PD
  have hr2Iₗₑ := admissibleSubgraph_internalEdges_le_of_pairwise r.1.2 hr2IPD
  have hr2ComplCardEq : r.1.2.complementEdges.card =
      (forestOuterQuotientGraph g r.1.1).internalEdges.card -
        r.1.2.internalEdges.card := by
    show ((forestOuterQuotientGraph g r.1.1).internalEdges - r.1.2.internalEdges).card = _
    exact Multiset.card_sub hr2Iₗₑ
  have hQuotCard : (forestOuterQuotientGraph g r.1.1).internalEdges.card =
      (forestOuterActualQuotientGraph g r.1.1).internalEdges.card := by
    rw [forestOuterActualToRepPerm_spec g r.1.1]
    show ((forestOuterActualQuotientGraph g r.1.1).mapPerm _).internalEdges.card = _
    rw [FeynmanGraph.mapPerm_internalEdges, Multiset.card_map]
  have hActGraphCard : (forestOuterActualQuotientGraph g r.1.1).internalEdges.card =
      r.1.1.1.complementEdges.card := by
    unfold forestOuterActualQuotientGraph
    rw [FeynmanGraph.admissibleForestContractGraphWithStars_eq,
        AdmissibleSubgraph.contractWithStars_internalEdges, Multiset.card_map]
  have hActICard :
      (forestQuotientForestSigmaActualQuotientSubgraph g r.1).internalEdges.card =
        r.1.2.internalEdges.card := by
    unfold forestQuotientForestSigmaActualQuotientSubgraph
    have hMap := mapPermAdmissibleSubgraphPreimage_internalEdges_map
      (forestOuterActualToRepPerm_spec g r.1.1) r.1.2
    have hc := congrArg Multiset.card hMap
    rw [Multiset.card_map] at hc
    exact hc
  rw [hr2ComplCardEq, hQuotCard, hActGraphCard] at hr2pos
  rw [hActICard]
  omega

/-- Sprint F2i-3q-hForestCompl: discharge of the deferred complement-positivity
witness for `A_source_v3`.  Chain:
- hForestCompl-4: `A_v3.I.card = A_final.I.card + D.I.card`
- hForestCompl-5: `D.I.card < A_final.complementEdges.card = G.I.card - A_final.I.card`
- ∴ `A_v3.I.card < G.I.card`, so `A_v3.complementEdges.card > 0`. -/
private theorem forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_complementEdges_card_pos
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    (hForestDisjoint :
      ∀ δ₁ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₁ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
      ∀ δ₂ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ₂ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
        δ₁ ≠ δ₂ →
          Disjoint
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₁).vertices
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ₂).vertices) :
    0 < (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint).complementEdges.card := by
  classical
  have hI_sum :=
    forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_internalEdges_card_eq_outer_add_actual
      g r hForestCD hForestDisjoint
  have hD_lt :=
    forestQuotientForestSigmaActualQuotient_internalEdges_card_lt_outerComplement g r
  have hAfinalLeG : r.1.1.1.internalEdges ≤
      (repG g).toFeynmanGraph.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise r.1.1.1
      ((repG g).toFeynmanGraph.properDisjointAdmissibleDivergentSubgraphs_isPairwiseDisjoint
        r.1.1.2)
  have hAfinalComplCard : r.1.1.1.complementEdges.card =
      (repG g).toFeynmanGraph.internalEdges.card - r.1.1.1.internalEdges.card := by
    show ((repG g).toFeynmanGraph.internalEdges - r.1.1.1.internalEdges).card = _
    exact Multiset.card_sub hAfinalLeG
  have hAv3LeG :
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
          g r hForestCD hForestDisjoint).internalEdges ≤
        (repG g).toFeynmanGraph.internalEdges :=
    admissibleSubgraph_internalEdges_le_of_pairwise _
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3_isPairwiseDisjoint
        g r hForestCD hForestDisjoint)
  have hAv3ComplCard :
      (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
        g r hForestCD hForestDisjoint).complementEdges.card =
      (repG g).toFeynmanGraph.internalEdges.card -
        (forestQuotientForestSigmaForestCoverSourceAdmissibleSubgraph_v3
          g r hForestCD hForestDisjoint).internalEdges.card := by
    show ((repG g).toFeynmanGraph.internalEdges - _).card = _
    exact Multiset.card_sub hAv3LeG
  have hAfinalCardLeG : r.1.1.1.internalEdges.card ≤
      (repG g).toFeynmanGraph.internalEdges.card :=
    Multiset.card_le_card hAfinalLeG
  rw [hAfinalComplCard] at hD_lt
  rw [hAv3ComplCard, hI_sum]
  omega

/-- Sprint F2i-3q-hBP-1c: facade model for the G2 obstruction — the
external-leg liftability for promoted components.  Isolates the
mathematical content that is non-injectivity of `retargetExternalLeg` on
legs attaching inside `γ.vertices` (F2i-3q-2g / F2i-3q-4h-pre scout).
Mirrors `ForestComponentForestChoiceRepQuotientComplementPositiveModel`
([Coassoc.lean:13334-13342]) pattern. -/
class
    ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel : Prop where
  promoted_externalLegs_le_plus :
    ∀ [IsDivergencePreservedByAdmissibleForestContract]
      (g : HopfGen)
      (r : {r : forestQuotientForestSigma g //
        r ∈ forestQuotientForestSigmaIndex g})
      (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
      (η : FeynmanSubgraph (repG g).toFeynmanGraph),
        η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ →
          η.externalLegs ≤
            (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
              g r δ).externalLegs

/-- Sprint F2i-3q-hBP-1c: wrapper exposing the model field as a direct theorem
for the G2 containment, parallel to F2i-3q-hBP-1a (internalEdges) and
F2i-3q-hBP-1b-1 (vertices).  Discharges the `hLegs` hypothesis of the
component construction (`_promotedComponentAsComponent`) under the
`Model` instance. -/
private theorem forestQuotientForestSigmaForestCover_promotedComponent_externalLegs_le_plus
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ) :
    η.externalLegs ≤
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
        g r δ).externalLegs :=
  ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel.promoted_externalLegs_le_plus
    g r δ η hη

/-- Sprint F2i-3q-hBP-1a: a `PromotedComponents`-element `η`'s internalEdges
multiset is dominated by `Plus(δ).internalEdges`.  Follows from the per-η
inclusion into `PromotedInternalEdges` (= sum over `PromotedComponents`) +
`Plus.I = ExactInternalEdges + PromotedInternalEdges` (simp). -/
private theorem forestQuotientForestSigmaForestCover_promotedComponent_internalEdges_le_plus
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ) :
    η.internalEdges ≤
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
        g r δ).internalEdges := by
  classical
  have hLe1 : η.internalEdges ≤
      forestQuotientForestSigmaForestCoverPromotedInternalEdges g r δ := by
    unfold forestQuotientForestSigmaForestCoverPromotedInternalEdges
    exact Finset.single_le_sum (f := fun η' => η'.internalEdges)
      (fun _ _ => Multiset.zero_le _) hη
  rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_internalEdges]
  exact hLe1.trans (Multiset.le_add_left _ _)

/-- Sprint F2i-3q-hBP-1b-1: a `PromotedComponents`-element `η`'s vertex
set is contained in `Plus(δ).vertices`.  Follows from `SourceVertices_eta_subset`
(F2i-3a sanity lemma 2) + `Plus.vertices = SourceVertices` (rfl simp). -/
private theorem forestQuotientForestSigmaForestCover_promotedComponent_vertices_subset_plus
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    {η : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ) :
    η.vertices ⊆
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
        g r δ).vertices := by
  rw [forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus_vertices]
  rcases (forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
    g r δ).mp hη with ⟨hηA, hStarInδ⟩
  exact forestQuotientForestSigmaForestCoverSourceVertices_eta_subset
    g r hηA hStarInδ

/-- Sprint F2i-3q-hBP-1b-2: a `PromotedComponents`-element `η` repackaged as a
component `FeynmanSubgraph` of `γ.toFeynmanGraph` (with γ := `Plus δ`), under
the deferred `hLegs` hypothesis for the externalLegs containment (G2). -/
private noncomputable def forestQuotientForestSigmaForestCover_promotedComponentAsComponent
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (η : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
    (hLegs :
      η.externalLegs ≤
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
          g r δ).externalLegs) :
    FeynmanSubgraph
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
        g r δ).toFeynmanGraph where
  vertices := η.vertices
  internalEdges := η.internalEdges
  externalLegs := η.externalLegs
  vertices_subset :=
    forestQuotientForestSigmaForestCover_promotedComponent_vertices_subset_plus
      g r δ hη
  internalEdges_le :=
    forestQuotientForestSigmaForestCover_promotedComponent_internalEdges_le_plus
      g r δ hη
  externalLegs_le := hLegs
  edges_supported := fun e he => η.edges_supported e he
  legs_supported := fun ℓ hl => η.legs_supported ℓ hl

/-- Sprint F2i-3q-hBP-1b-3: promote round-trip on the component repackaging.
The carriers are unchanged by `feynmanSubgraphPromote` (only proofs of
containment change), so the promote sends `η_component` back to `η`. -/
private theorem forestQuotientForestSigmaForestCover_promotedComponent_promote_roundtrip
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1))
    (η : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r δ)
    (hLegs :
      η.externalLegs ≤
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
          g r δ).externalLegs) :
    feynmanSubgraphPromote
        (γ_outer := forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
          g r δ)
        (forestQuotientForestSigmaForestCover_promotedComponentAsComponent
          g r δ η hη hLegs) = η :=
  FeynmanSubgraph.ext_iff.mpr ⟨rfl, rfl, rfl⟩

/-- Sprint F2i-3q-hBP-1d-1a: `Classical.choose`-based δ recovery from a
`LiftedForestComponents` element γ (= Plus δ for some δ ∈ ForestComponents). -/
private noncomputable def forestQuotientForestSigmaForestCover_liftedForestSource
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1) :=
  Classical.choose
    (forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists g r hγ)

/-- Sprint F2i-3q-hBP-1d-1a: `_liftedForestSource ∈ ForestComponents`. -/
private theorem forestQuotientForestSigmaForestCover_liftedForestSource_mem
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    forestQuotientForestSigmaForestCover_liftedForestSource g r hγ ∈
      forestQuotientForestSigmaForestCoverForestComponents g r :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists g r hγ)).1

/-- Sprint F2i-3q-hBP-1d-1a: `Plus(_liftedForestSource) = γ`. -/
private theorem forestQuotientForestSigmaForestCover_liftedForestSource_plus_eq
    [IsDivergencePreservedByAdmissibleForestContract]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r) :
    forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus g r
        (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ) = γ :=
  (Classical.choose_spec
    (forestQuotientForestSigmaForestCoverLiftedForestComponents_mem_exists g r hγ)).2

/-- Sprint F2i-3q-model-3a-1: `toFeynmanGraph` transports across `▸` over a
graph equation.  `cases h` collapses the Eq.rec, so `toFG` is preserved
literally.  Helper for the BElementMap CD/NOD transport chain. -/
private theorem feynmanSubgraph_eqRec_toFeynmanGraph_eq
    {G₁ G₂ : FeynmanGraph} (h : G₁ = G₂) (γ : FeynmanSubgraph G₁) :
    (h ▸ γ).toFeynmanGraph = γ.toFeynmanGraph := by
  cases h; rfl

/-- Sprint F2i-3q-hBP-1d-1b: per-η element map from `PromotedComponents
(_liftedForestSource γ)` (subgraphs of `repG g`) to `FeynmanSubgraph (repG
(γ.toHopfGen ...)).toFeynmanGraph`.  Three-step pipeline:
1. `_promotedComponentAsComponent`: repackage `η` as a subgraph of `(Plus δ)`
   (with the G2 `_externalLegs_le_plus` discharging `hLegs`).
2. Transport along `_liftedForestSource_plus_eq` (`Plus δ = γ`) so the
   component now lives in `γ.toFeynmanGraph`.
3. `mapPermSubgraph` via `feynmanSubgraphToHopfGenRepPerm_spec γ hCD` to land
   in `(repG (γ.toHopfGen hCD)).toFeynmanGraph`. -/
private noncomputable def forestQuotientForestSigmaForestCover_BElementMap
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (η : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ)) :
    FeynmanSubgraph
      (repG (γ.toHopfGen
        (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
          g r hForestCD hγ))).toFeynmanGraph :=
  let δ := forestQuotientForestSigmaForestCover_liftedForestSource g r hγ
  let ηComp :
      FeynmanSubgraph
        (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
          g r δ).toFeynmanGraph :=
    forestQuotientForestSigmaForestCover_promotedComponentAsComponent
      g r δ η hη
      (forestQuotientForestSigmaForestCover_promotedComponent_externalLegs_le_plus
        g r δ hη)
  let hPlusToFG :
      (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
        g r δ).toFeynmanGraph = γ.toFeynmanGraph :=
    congrArg FeynmanSubgraph.toFeynmanGraph
      (forestQuotientForestSigmaForestCover_liftedForestSource_plus_eq g r hγ)
  let ηγ : FeynmanSubgraph γ.toFeynmanGraph := hPlusToFG ▸ ηComp
  let hCD :=
    forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
      g r hForestCD hγ
  mapPermSubgraph (feynmanSubgraphToHopfGenRepPerm_spec γ hCD) ηγ

/-- Sprint F2i-3q-model-3a-2: `_BElementMap`'s `toFeynmanGraph` factors
through a single perm action: `(_BElementMap η hη).toFG =
η.toFG.mapPerm π`, where π is `feynmanSubgraphToHopfGenRepPerm γ hCD`.
The three-step pipeline collapses to this single perm because the
`_promotedComponentAsComponent` repackage and the `Plus`-eq `▸`
transport are both data-preserving (vertices/edges/legs unchanged). -/
private theorem forestQuotientForestSigmaForestCover_BElementMap_toFeynmanGraph_eq
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (η : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ)) :
    (forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η hη).toFeynmanGraph =
      η.toFeynmanGraph.mapPerm
        (feynmanSubgraphToHopfGenRepPerm γ
          (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
            g r hForestCD hγ)) := by
  unfold forestQuotientForestSigmaForestCover_BElementMap
  rw [mapPermSubgraph_toFeynmanGraph, feynmanSubgraph_eqRec_toFeynmanGraph_eq]
  rfl

/-- Sprint F2i-3q-model-3a-3: per-η CD on `_BElementMap`.  Chain:
1. η.IsConnectedDivergent (from `r.1.1.1.isConnectedDivergent_of_mem`
   via `PromotedComponents ⊆ r.1.1.1.elements`).
2. `mapPermSubgraph rfl η` on `(repG g).mapPerm π` has CD (via
   `mapPermSubgraph_isConnectedDivergent`).
3. Its `toFG = η.toFG.mapPerm π` (via `mapPermSubgraph_toFeynmanGraph`).
4. `_BElementMap.toFG = η.toFG.mapPerm π` (Target 2, `_toFeynmanGraph_eq`).
5. Bridge via `_isConnectedDivergent_of_toFeynmanGraph_eq`. -/
private theorem forestQuotientForestSigmaForestCover_BElementMap_isConnectedDivergent
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (η : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη : η ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ)) :
    (forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η hη).IsConnectedDivergent := by
  have hηForest : η ∈ r.1.1.1.elements :=
    ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
      g r _).mp hη).1
  have hηCD : η.IsConnectedDivergent :=
    r.1.1.1.isConnectedDivergent_of_mem hηForest
  set π := feynmanSubgraphToHopfGenRepPerm γ
    (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
      g r hForestCD hγ) with hπdef
  have hLift : (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
      (repG g).toFeynmanGraph.mapPerm π) η).IsConnectedDivergent :=
    mapPermSubgraph_isConnectedDivergent _ hηCD
  have hLiftToFG :
      (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
          (repG g).toFeynmanGraph.mapPerm π) η).toFeynmanGraph =
        η.toFeynmanGraph.mapPerm π :=
    mapPermSubgraph_toFeynmanGraph _ η
  have hBToFG := forestQuotientForestSigmaForestCover_BElementMap_toFeynmanGraph_eq
    g r hForestCD hγ η hη
  exact feynmanSubgraph_isConnectedDivergent_of_toFeynmanGraph_eq
    (hBToFG.trans hLiftToFG.symm) hLift

/-- Sprint F2i-3q-model-3a-4-helper: NOD transports across `toFeynmanGraph`
equality (NOD only depends on vertices/edges/legs, which are extracted
from `toFG`). -/
private theorem feynmanSubgraph_nestedOrDisjoint_of_toFeynmanGraph_eq
    {G₁ G₂ : FeynmanGraph}
    {α₁ β₁ : FeynmanSubgraph G₁} {α₂ β₂ : FeynmanSubgraph G₂}
    (hα : α₂.toFeynmanGraph = α₁.toFeynmanGraph)
    (hβ : β₂.toFeynmanGraph = β₁.toFeynmanGraph)
    (h : α₁.NestedOrDisjoint β₁) :
    α₂.NestedOrDisjoint β₂ := by
  have hαV : α₂.vertices = α₁.vertices :=
    show α₂.toFeynmanGraph.vertices = α₁.toFeynmanGraph.vertices from
      congrArg FeynmanGraph.vertices hα
  have hβV : β₂.vertices = β₁.vertices :=
    show β₂.toFeynmanGraph.vertices = β₁.toFeynmanGraph.vertices from
      congrArg FeynmanGraph.vertices hβ
  have hαI : α₂.internalEdges = α₁.internalEdges :=
    show α₂.toFeynmanGraph.internalEdges = α₁.toFeynmanGraph.internalEdges from
      congrArg FeynmanGraph.internalEdges hα
  have hβI : β₂.internalEdges = β₁.internalEdges :=
    show β₂.toFeynmanGraph.internalEdges = β₁.toFeynmanGraph.internalEdges from
      congrArg FeynmanGraph.internalEdges hβ
  have hαL : α₂.externalLegs = α₁.externalLegs :=
    show α₂.toFeynmanGraph.externalLegs = α₁.toFeynmanGraph.externalLegs from
      congrArg FeynmanGraph.externalLegs hα
  have hβL : β₂.externalLegs = β₁.externalLegs :=
    show β₂.toFeynmanGraph.externalLegs = β₁.toFeynmanGraph.externalLegs from
      congrArg FeynmanGraph.externalLegs hβ
  simpa [FeynmanSubgraph.NestedOrDisjoint, FeynmanSubgraph.Nested,
    FeynmanSubgraph.Disjoint, FeynmanSubgraph.le_def,
    hαV, hβV, hαI, hβI, hαL, hβL] using h

/-- Sprint F2i-3q-model-3a-4: per-pair NOD on `_BElementMap`.  Chain:
1. Reflexive case `η₁ = η₂`: NOD reflexive via `le_refl'`.
2. Distinct case:
   - η₁, η₂ ∈ `r.1.1.1.elements` (from `mem_promotedComponents_iff`).
   - `η₁.NOD η₂` via `r.1.1.1.forest.nestedOrDisjoint`.
   - Lift to `mapPermSubgraph rfl η_i` via `mapPermSubgraph_nestedOrDisjoint`.
   - Bridge to `_BElementMap` via `_nestedOrDisjoint_of_toFG_eq` and Target 2. -/
private theorem forestQuotientForestSigmaForestCover_BElementMap_nestedOrDisjoint
    [IsAmbientInvariantDivergence]
    [IsDivergencePreservedByAdmissibleForestContract]
    [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
    (g : HopfGen)
    (r : {r : forestQuotientForestSigma g //
      r ∈ forestQuotientForestSigmaIndex g})
    (hForestCD :
      ∀ δ : FeynmanSubgraph (forestOuterActualQuotientGraph g r.1.1),
        δ ∈ forestQuotientForestSigmaForestCoverForestComponents g r →
          (forestQuotientForestSigmaForestCoverSourceSubgraphExactPlus
            g r δ).IsConnectedDivergent)
    {γ : FeynmanSubgraph (repG g).toFeynmanGraph}
    (hγ : γ ∈ forestQuotientForestSigmaForestCoverLiftedForestComponents g r)
    (η₁ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη₁ : η₁ ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ))
    (η₂ : FeynmanSubgraph (repG g).toFeynmanGraph)
    (hη₂ : η₂ ∈ forestQuotientForestSigmaForestCoverPromotedComponents g r
      (forestQuotientForestSigmaForestCover_liftedForestSource g r hγ)) :
    (forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η₁ hη₁).NestedOrDisjoint
      (forestQuotientForestSigmaForestCover_BElementMap
        g r hForestCD hγ η₂ hη₂) := by
  by_cases hEq : η₁ = η₂
  · subst hEq
    exact Or.inl (Or.inl (FeynmanSubgraph.le_refl' _))
  · have hη₁A : η₁ ∈ r.1.1.1.elements :=
      ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r _).mp hη₁).1
    have hη₂A : η₂ ∈ r.1.1.1.elements :=
      ((forestQuotientForestSigmaForestCover_mem_promotedComponents_iff
        g r _).mp hη₂).1
    have hηNOD : η₁.NestedOrDisjoint η₂ :=
      r.1.1.1.forest.nestedOrDisjoint hη₁A hη₂A hEq
    set π := feynmanSubgraphToHopfGenRepPerm γ
      (forestQuotientForestSigmaForestCoverLiftedForestComponents_cd_of_source_cd
        g r hForestCD hγ) with hπdef
    have hLift :
        (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
            (repG g).toFeynmanGraph.mapPerm π) η₁).NestedOrDisjoint
          (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
            (repG g).toFeynmanGraph.mapPerm π) η₂) :=
      mapPermSubgraph_nestedOrDisjoint _ hηNOD
    have hBToFG₁ := forestQuotientForestSigmaForestCover_BElementMap_toFeynmanGraph_eq
      g r hForestCD hγ η₁ hη₁
    have hBToFG₂ := forestQuotientForestSigmaForestCover_BElementMap_toFeynmanGraph_eq
      g r hForestCD hγ η₂ hη₂
    have hLiftToFG₁ : (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
        (repG g).toFeynmanGraph.mapPerm π) η₁).toFeynmanGraph =
        η₁.toFeynmanGraph.mapPerm π :=
      mapPermSubgraph_toFeynmanGraph _ η₁
    have hLiftToFG₂ : (mapPermSubgraph (rfl : (repG g).toFeynmanGraph.mapPerm π =
        (repG g).toFeynmanGraph.mapPerm π) η₂).toFeynmanGraph =
        η₂.toFeynmanGraph.mapPerm π :=
      mapPermSubgraph_toFeynmanGraph _ η₂
    exact feynmanSubgraph_nestedOrDisjoint_of_toFeynmanGraph_eq
      (hBToFG₁.trans hLiftToFG₁.symm)
      (hBToFG₂.trans hLiftToFG₂.symm)
      hLift

/-- Sprint F2i-3q-hBP-1d-1c: facade `Model` typeclass packaging the
`IsConnectedDivergent` + `NestedOrDisjoint` properties of the
`_BElementMap` image, which would otherwise require chasing three
transports (component repackage + `Plus`-eq ▸ + `mapPermSubgraph`).
Discharged elsewhere via ambient-invariant divergence + `mapPermSubgraph`
preservation lemmas; here we expose the cleaned-up endpoints so the
B-candidate construction (`AdmissibleSubgraph.ofElements`) is a pure
wiring step. -/
private class
    ForestQuotientForestSigmaForestCoverBElementMapAdmissibleModel : Prop where
  isConnectedDivergent :
    ∀ [IsAmbientInvariantDivergence]
      [IsDivergencePreservedByAdmissibleForestContract]
      [ForestQuotientForestSigmaForestCoverPromotedExternalLegsLiftableModel]
      (g : HopfGen)
      (r : {r : forestQuotientForestSigma g //
        r ∈ forestQuotientForestSigmaIndex g})
      (hForestCD :
